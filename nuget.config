<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <packageSources>
    <add key="NuGet official package source" value="https://api.nuget.org/v3/index.json" />
    <add key="platform.uno dev" value="https://uno-platform.pkgs.visualstudio.com/Uno%20Platform/_packaging/unoplatformdev/nuget/v3/index.json" />
  </packageSources>
  <!--
    Required by Central Package Management (CPM): with multiple package sources,
    NuGet's restore-graph evaluation enforces explicit source mapping. Without
    this block, MSBuildWorkspace (used by Uno.WinUI.DevServer to load the project
    graph for hot-reload) surfaces NU1507 as `[Failure]` and may leave projects
    out of the workspace, breaking EnC delta computation (HR returns "Found 0
    metadata updates"). `dotnet build` is more lenient and only warns.
  -->
  <packageSourceMapping>
    <packageSource key="NuGet official package source">
      <package pattern="*" />
    </packageSource>
    <packageSource key="platform.uno dev">
      <package pattern="Uno.*" />
      <package pattern="uno.*" />
    </packageSource>
  </packageSourceMapping>
</configuration>
