	<!-- ==========================================================================
	     M3 TextBox — v3
	     Material Design 3 text field with filled and outlined variants.
	     Based on: https://m3.material.io/components/text-fields/overview

	     Variants: Filled (surface-variant background + bottom active indicator)
	               Outlined (transparent background + outline border)

	     Expected TextBox behavior:
	     - Without Header/Placeholder: Simple TextBox
	     - With placeholder but no header: Placeholder shown until text is inputted
	     - With header but no placeholder: Header at text position, floats up on focus/input
	     - With header and placeholder: Header at top, placeholder shown until text is inputted

	     Migrated from the SDS M3TextBox React/CSS component.
	     ========================================================================== -->

	<ResourceDictionary.ThemeDictionaries>
		<ResourceDictionary x:Key="Default">
			<!--#region DownscaledHeader visual state (floating label animation) -->
			<x:Double x:Key="DownscaledHeaderHeaderCompositeTransformTranslateY">-11</x:Double>
