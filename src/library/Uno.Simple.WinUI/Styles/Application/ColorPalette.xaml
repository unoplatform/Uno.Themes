			<StaticResource x:Key="SimpleBackgroundDefaultSecondaryBrush" ResourceKey="SurfaceVariantBrush" />
			<StaticResource x:Key="SimpleBackgroundDefaultSecondaryHoverBrush" ResourceKey="PrimaryContainerBrush" />
			<StaticResource x:Key="SimpleBackgroundDefaultSecondaryPressedBrush" ResourceKey="TertiaryContainerBrush" />
			<StaticResource x:Key="SimpleBackgroundDefaultTertiaryBrush" ResourceKey="OutlineBrush" />
			<StaticResource x:Key="SimpleBackgroundDefaultTertiaryHoverBrush" ResourceKey="SecondaryContainerBrush" />
			<StaticResource x:Key="SimpleBackgroundDefaultTertiaryPressedBrush" ResourceKey="OutlineVariantBrush" />

			<!-- Disabled Background -->
			<StaticResource x:Key="SimpleBackgroundDisabledDefaultBrush" ResourceKey="OnSurfaceDisabledBrush" />

			<!-- Neutral Backgrounds -->
			<StaticResource x:Key="SimpleBackgroundNeutralDefaultBrush" ResourceKey="SurfaceInverseBrush" />
			<StaticResource x:Key="SimpleBackgroundNeutralHoverBrush" ResourceKey="SurfaceInverseHoverBrush" />
			<StaticResource x:Key="SimpleBackgroundNeutralPressedBrush" ResourceKey="SurfaceInversePressedBrush" />
			<StaticResource x:Key="SimpleBackgroundNeutralSecondaryBrush" ResourceKey="OutlineVariantBrush" />
			<StaticResource x:Key="SimpleBackgroundNeutralSecondaryHoverBrush" ResourceKey="OutlineVariantHoverBrush" />
			<StaticResource x:Key="SimpleBackgroundNeutralSecondaryPressedBrush" ResourceKey="OutlineVariantPressedBrush" />
			<StaticResource x:Key="SimpleBackgroundNeutralTertiaryBrush" ResourceKey="SurfaceVariantBrush" />
			<StaticResource x:Key="SimpleBackgroundNeutralTertiaryHoverBrush" ResourceKey="SurfaceVariantHoverBrush" />
			<StaticResource x:Key="SimpleBackgroundNeutralTertiaryPressedBrush" ResourceKey="SurfaceVariantPressedBrush" />

			<!-- Utility Backgrounds (Simple-specific) -->
			<SolidColorBrush x:Key="SimpleBackgroundUtilitiesBlanketBrush" Color="#B2000000" />
			<SolidColorBrush x:Key="SimpleBackgroundUtilitiesMeasurementBrush" Color="{StaticResource SimplePink200Color}" />
			<SolidColorBrush x:Key="SimpleBackgroundUtilitiesOverlayBrush" Color="#80000000" />
			<SolidColorBrush x:Key="SimpleBackgroundUtilitiesScrimBrush" Color="#CCFFFFFF" />

			<!-- ─────────────────────────────────────────────────────────────── -->
			<!-- SDS Alias Brushes — Text                                      -->
			<!-- ─────────────────────────────────────────────────────────────── -->

			<!-- Brand Text -->
			<StaticResource x:Key="SimpleTextBrandDefaultBrush" ResourceKey="PrimaryBrush" />
			<StaticResource x:Key="SimpleTextBrandOnBrandBrush" ResourceKey="OnPrimaryBrush" />
			<StaticResource x:Key="SimpleTextBrandOnBrandSecondaryBrush" ResourceKey="OnPrimaryContainerBrush" />
			<StaticResource x:Key="SimpleTextBrandOnBrandTertiaryBrush" ResourceKey="PrimaryBrush" />
			<StaticResource x:Key="SimpleTextBrandSecondaryBrush" ResourceKey="PrimaryMediumBrush" />
			<StaticResource x:Key="SimpleTextBrandTertiaryBrush" ResourceKey="PrimaryLowBrush" />

			<!-- Danger Text -->
			<StaticResource x:Key="SimpleTextDangerDefaultBrush" ResourceKey="ErrorBrush" />
			<StaticResource x:Key="SimpleTextDangerOnDangerBrush" ResourceKey="OnErrorBrush" />
			<StaticResource x:Key="SimpleTextDangerOnDangerSecondaryBrush" ResourceKey="OnErrorContainerBrush" />
			<StaticResource x:Key="SimpleTextDangerOnDangerTertiaryBrush" ResourceKey="OnErrorContainerBrush" />
			<StaticResource x:Key="SimpleTextDangerSecondaryBrush" ResourceKey="ErrorMediumBrush" />
			<StaticResource x:Key="SimpleTextDangerTertiaryBrush" ResourceKey="ErrorLowBrush" />

			<!-- Default Text -->
			<StaticResource x:Key="SimpleTextDefaultDefaultBrush" ResourceKey="OnSurfaceBrush" />
			<StaticResource x:Key="SimpleTextDefaultSecondaryBrush" ResourceKey="OnSurfaceMediumBrush" />
