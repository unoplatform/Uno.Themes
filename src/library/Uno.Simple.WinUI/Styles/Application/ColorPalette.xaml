			<!-- ─────────────────────────────────────────────────────────────── -->
			<!-- SDS Alias Brushes — Border                                    -->
			<!-- ─────────────────────────────────────────────────────────────── -->

			<!-- Brand Borders -->
			<StaticResource x:Key="SimpleBorderBrandDefaultBrush" ResourceKey="PrimaryBrush" />
			<StaticResource x:Key="SimpleBorderBrandSecondaryBrush" ResourceKey="PrimaryMediumBrush" />
			<StaticResource x:Key="SimpleBorderBrandTertiaryBrush" ResourceKey="PrimaryLowBrush" />

			<!-- Danger Borders -->
			<StaticResource x:Key="SimpleBorderDangerDefaultBrush" ResourceKey="ErrorBrush" />
			<StaticResource x:Key="SimpleBorderDangerSecondaryBrush" ResourceKey="ErrorMediumBrush" />
			<StaticResource x:Key="SimpleBorderDangerTertiaryBrush" ResourceKey="ErrorLowBrush" />

			<!-- Default Borders -->
			<StaticResource x:Key="SimpleBorderDefaultDefaultBrush" ResourceKey="OutlineBrush" />
			<StaticResource x:Key="SimpleBorderDefaultSecondaryBrush" ResourceKey="OutlineVariantBrush" />
			<StaticResource x:Key="SimpleBorderDefaultTertiaryBrush" ResourceKey="OnSurfaceVariantBrush" />

			<!-- Disabled Border -->
			<StaticResource x:Key="SimpleBorderDisabledDefaultBrush" ResourceKey="OutlineDisabledBrush" />

			<!-- Neutral Borders -->
			<StaticResource x:Key="SimpleBorderNeutralDefaultBrush" ResourceKey="OnSurfaceVariantBrush" />
			<StaticResource x:Key="SimpleBorderNeutralSecondaryBrush" ResourceKey="OutlineVariantBrush" />
			<StaticResource x:Key="SimpleBorderNeutralTertiaryBrush" ResourceKey="OutlineLowBrush" />

			<!-- Utility Borders (Simple-specific) -->
			<SolidColorBrush x:Key="SimpleBorderUtilitiesMeasurementBrush" Color="{StaticResource SimplePink400Color}" />
