			<!-- Disabled Text -->
			<StaticResource x:Key="SimpleTextDisabledDefaultBrush" ResourceKey="OnSurfaceDisabledBrush" />
			<StaticResource x:Key="SimpleTextDisabledOnDisabledBrush" ResourceKey="OnSurfaceDisabledBrush" />

			<!-- Neutral Text -->
			<StaticResource x:Key="SimpleTextNeutralDefaultBrush" ResourceKey="OnSurfaceVariantBrush" />
			<StaticResource x:Key="SimpleTextNeutralOnNeutralBrush" ResourceKey="OnSurfaceInverseBrush" />
			<StaticResource x:Key="SimpleTextNeutralOnNeutralSecondaryBrush" ResourceKey="OnSurfaceVariantBrush" />
			<StaticResource x:Key="SimpleTextNeutralOnNeutralTertiaryBrush" ResourceKey="OnSurfaceVariantBrush" />
			<StaticResource x:Key="SimpleTextNeutralSecondaryBrush" ResourceKey="OnSurfaceVariantMediumBrush" />
			<StaticResource x:Key="SimpleTextNeutralTertiaryBrush" ResourceKey="OnSurfaceVariantLowBrush" />

			<!-- Utility Text (Simple-specific) -->
			<SolidColorBrush x:Key="SimpleTextUtilitiesOnMeasurementBrush" Color="{StaticResource SimplePink800Color}" />
			<StaticResource x:Key="SimpleTextUtilitiesOnOverlayBrush" ResourceKey="OnSurfaceInverseBrush" />

			<!-- ─────────────────────────────────────────────────────────────── -->
			<!-- SDS Alias Brushes — Icon                                      -->
			<!-- (Same mapping pattern as Text — SDS keeps Text/Icon identical) -->
			<!-- ─────────────────────────────────────────────────────────────── -->

			<!-- Brand Icons -->
			<StaticResource x:Key="SimpleIconBrandDefaultBrush" ResourceKey="PrimaryBrush" />
			<StaticResource x:Key="SimpleIconBrandOnBrandBrush" ResourceKey="OnPrimaryBrush" />
