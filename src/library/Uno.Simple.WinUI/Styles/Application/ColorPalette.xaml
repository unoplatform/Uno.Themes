			<StaticResource x:Key="SimpleIconDangerOnDangerTertiaryBrush" ResourceKey="OnErrorContainerBrush" />
			<StaticResource x:Key="SimpleIconDangerSecondaryBrush" ResourceKey="ErrorMediumBrush" />
			<StaticResource x:Key="SimpleIconDangerTertiaryBrush" ResourceKey="ErrorLowBrush" />

			<!-- Default Icons -->
			<StaticResource x:Key="SimpleIconDefaultDefaultBrush" ResourceKey="OnSurfaceBrush" />
			<StaticResource x:Key="SimpleIconDefaultSecondaryBrush" ResourceKey="OnSurfaceMediumBrush" />
			<StaticResource x:Key="SimpleIconDefaultTertiaryBrush" ResourceKey="OnSurfaceLowBrush" />

			<!-- Disabled Icons -->
