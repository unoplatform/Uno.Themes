			<!-- Outline -->
			<Color x:Key="OutlineColor">#D9D9D9</Color>
			<Color x:Key="OutlineVariantColor">#767676</Color>

			<!-- Shadow -->
			<Color x:Key="ShadowColor">#33000000</Color>

			<!-- ─────────────────────────────────────────────────────────────── -->
			<!-- Utility-only Primitives (Pink — used by measurement brushes)   -->
			<!-- ─────────────────────────────────────────────────────────────── -->
			<Color x:Key="SimplePink200Color">#FAE1FA</Color>
			<Color x:Key="SimplePink400Color">#F19EDC</Color>
			<Color x:Key="SimplePink600Color">#D732A8</Color>
			<Color x:Key="SimplePink800Color">#8A226F</Color>

			<!-- ─────────────────────────────────────────────────────────────── -->
			<!-- SDS Alias Brushes — Background                                -->
			<!-- Maps SDS brush keys to shared semantic brushes for backward    -->
			<!-- compatibility with existing control styles.                    -->
			<!-- ─────────────────────────────────────────────────────────────── -->

			<!-- Brand Backgrounds -->
			<StaticResource x:Key="SimpleBackgroundBrandDefaultBrush" ResourceKey="PrimaryBrush" />
			<StaticResource x:Key="SimpleBackgroundBrandHoverBrush" ResourceKey="PrimaryVariantDarkBrush" />
			<StaticResource x:Key="SimpleBackgroundBrandPressedBrush" ResourceKey="PrimaryVariantDarkBrush" />
			<StaticResource x:Key="SimpleBackgroundBrandSecondaryBrush" ResourceKey="PrimaryContainerBrush" />
			<StaticResource x:Key="SimpleBackgroundBrandSecondaryHoverBrush" ResourceKey="TertiaryContainerBrush" />
			<StaticResource x:Key="SimpleBackgroundBrandSecondaryPressedBrush" ResourceKey="SecondaryContainerBrush" />
			<StaticResource x:Key="SimpleBackgroundBrandTertiaryBrush" ResourceKey="PrimaryVariantLightBrush" />
			<StaticResource x:Key="SimpleBackgroundBrandTertiaryHoverBrush" ResourceKey="PrimaryContainerBrush" />
			<StaticResource x:Key="SimpleBackgroundBrandTertiaryPressedBrush" ResourceKey="TertiaryContainerBrush" />

			<!-- Danger Backgrounds -->
			<StaticResource x:Key="SimpleBackgroundDangerDefaultBrush" ResourceKey="ErrorBrush" />
			<StaticResource x:Key="SimpleBackgroundDangerHoverBrush" ResourceKey="ErrorHoverBrush" />
			<StaticResource x:Key="SimpleBackgroundDangerPressedBrush" ResourceKey="ErrorPressedBrush" />
			<StaticResource x:Key="SimpleBackgroundDangerSecondaryBrush" ResourceKey="ErrorContainerBrush" />
			<StaticResource x:Key="SimpleBackgroundDangerSecondaryHoverBrush" ResourceKey="ErrorContainerHoverBrush" />
			<StaticResource x:Key="SimpleBackgroundDangerSecondaryPressedBrush" ResourceKey="ErrorContainerPressedBrush" />
			<StaticResource x:Key="SimpleBackgroundDangerTertiaryBrush" ResourceKey="OnErrorBrush" />
			<StaticResource x:Key="SimpleBackgroundDangerTertiaryHoverBrush" ResourceKey="OnErrorHoverBrush" />
			<StaticResource x:Key="SimpleBackgroundDangerTertiaryPressedBrush" ResourceKey="OnErrorPressedBrush" />

