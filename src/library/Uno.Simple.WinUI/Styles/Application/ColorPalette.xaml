<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
					xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

	<!--
		Simple Design System — Color Palette

		This file provides:
		  1. SharedColorPalette overrides — Simple's flat grayscale values for all
		     shared color roles (Primary, Error, Surface, Outline, etc.).
		  2. Utility-only primitives — Pink scale + hardcoded utility colors that
		     have no shared equivalent.

		All control styles reference shared semantic brushes directly
		(from SharedColors.xaml). No SDS alias brushes remain in this file.
	-->

	<ResourceDictionary.ThemeDictionaries>

		<!-- ═══════════════════════════════════════════════════════════════════ -->
		<!-- LIGHT THEME                                                       -->
		<!-- ═══════════════════════════════════════════════════════════════════ -->
		<ResourceDictionary x:Key="Light">

			<!-- ─────────────────────────────────────────────────────────────── -->
			<!-- SharedColorPalette Overrides                                   -->
			<!-- ─────────────────────────────────────────────────────────────── -->

			<!-- Primary (SDS Brand) -->
			<Color x:Key="PrimaryColor">#2C2C2C</Color>
			<Color x:Key="OnPrimaryColor">#F5F5F5</Color>
			<Color x:Key="PrimaryContainerColor">#E6E6E6</Color>
			<Color x:Key="OnPrimaryContainerColor">#1E1E1E</Color>
			<Color x:Key="PrimaryInverseColor">#F5F5F5</Color>
			<Color x:Key="PrimaryVariantDarkColor">#1E1E1E</Color>
			<Color x:Key="PrimaryVariantLightColor">#F5F5F5</Color>

			<!-- Secondary -->
			<Color x:Key="SecondaryColor">#757575</Color>
			<Color x:Key="OnSecondaryColor">#F3F3F3</Color>
			<Color x:Key="SecondaryContainerColor">#CDCDCD</Color>
			<Color x:Key="OnSecondaryContainerColor">#242424</Color>

			<!-- Tertiary -->
			<Color x:Key="TertiaryColor">#767676</Color>
			<Color x:Key="OnTertiaryColor">#FFFFFF</Color>
			<Color x:Key="TertiaryContainerColor">#D9D9D9</Color>
			<Color x:Key="OnTertiaryContainerColor">#1E1E1E</Color>

			<!-- Error (SDS Danger) -->
			<Color x:Key="ErrorColor">#EC221F</Color>
			<Color x:Key="OnErrorColor">#FEE9E7</Color>
			<Color x:Key="ErrorContainerColor">#FDD3D0</Color>
			<Color x:Key="OnErrorContainerColor">#300603</Color>

			<!-- Background -->
			<Color x:Key="BackgroundColor">#F5F5F5</Color>
			<Color x:Key="OnBackgroundColor">#1E1E1E</Color>

			<!-- Surface (SDS Default) -->
			<Color x:Key="SurfaceColor">#FFFFFF</Color>
			<Color x:Key="OnSurfaceColor">#1E1E1E</Color>
			<Color x:Key="SurfaceVariantColor">#F5F5F5</Color>
			<Color x:Key="OnSurfaceVariantColor">#757575</Color>
			<Color x:Key="SurfaceInverseColor">#5A5A5A</Color>
			<Color x:Key="OnSurfaceInverseColor">#F3F3F3</Color>
			<Color x:Key="SurfaceTintColor">#2C2C2C</Color>

			<!-- Outline -->
			<Color x:Key="OutlineColor">#D9D9D9</Color>
			<Color x:Key="OutlineVariantColor">#767676</Color>

			<!-- Shadow -->
			<Color x:Key="ShadowColor">#33000000</Color>

			<!-- ─────────────────────────────────────────────────────────────── -->
			<!-- Utility-only Primitives (Pink — used by measurement brushes)   -->
			<!-- ─────────────────────────────────────────────────────────────── -->
			<Color x:Key="SimplePink200Color">#FAE1FA</Color>
			<Color x:Key="SimplePink400Color">#F19EDC</Color>
			<Color x:Key="SimplePink600Color">#D732A8</Color>
			<Color x:Key="SimplePink800Color">#8A226F</Color>

			<!-- ─────────────────────────────────────────────────────────────── -->
			<!-- Utility Brushes (Simple-specific, no shared equivalent)        -->
			<!-- ─────────────────────────────────────────────────────────────── -->
			<SolidColorBrush x:Key="SimpleBackgroundUtilitiesBlanketBrush" Color="#B2000000" />
			<SolidColorBrush x:Key="SimpleBackgroundUtilitiesMeasurementBrush" Color="{StaticResource SimplePink200Color}" />
			<SolidColorBrush x:Key="SimpleBackgroundUtilitiesOverlayBrush" Color="#80000000" />
			<SolidColorBrush x:Key="SimpleBackgroundUtilitiesScrimBrush" Color="#CCFFFFFF" />
			<SolidColorBrush x:Key="SimpleTextUtilitiesOnMeasurementBrush" Color="{StaticResource SimplePink800Color}" />
			<StaticResource x:Key="SimpleTextUtilitiesOnOverlayBrush" ResourceKey="OnSurfaceInverseBrush" />
			<SolidColorBrush x:Key="SimpleIconUtilitiesBrush" Color="{StaticResource SimplePink600Color}" />
			<SolidColorBrush x:Key="SimpleIconUtilitiesOnMeasurementBrush" Color="{StaticResource SimplePink800Color}" />
			<SolidColorBrush x:Key="SimpleBorderUtilitiesMeasurementBrush" Color="{StaticResource SimplePink400Color}" />
			<SolidColorBrush x:Key="SimpleBorderUtilitiesSwatchBrush" Color="#3D000000" />
		</ResourceDictionary>

		<!-- ═══════════════════════════════════════════════════════════════════ -->
		<!-- DARK THEME (Default)                                              -->
		<!-- ═══════════════════════════════════════════════════════════════════ -->
		<ResourceDictionary x:Key="Default">

			<!-- ─────────────────────────────────────────────────────────────── -->
			<!-- SharedColorPalette Overrides                                   -->
			<!-- ─────────────────────────────────────────────────────────────── -->

			<!-- Primary (SDS Brand) -->
			<Color x:Key="PrimaryColor">#F5F5F5</Color>
			<Color x:Key="OnPrimaryColor">#1E1E1E</Color>
			<Color x:Key="PrimaryContainerColor">#444444</Color>
			<Color x:Key="OnPrimaryContainerColor">#E6E6E6</Color>
			<Color x:Key="PrimaryInverseColor">#1E1E1E</Color>
			<Color x:Key="PrimaryVariantDarkColor">#D9D9D9</Color>
			<Color x:Key="PrimaryVariantLightColor">#1E1E1E</Color>

			<!-- Secondary -->
			<Color x:Key="SecondaryColor">#949494</Color>
			<Color x:Key="OnSecondaryColor">#242424</Color>
			<Color x:Key="SecondaryContainerColor">#434343</Color>
			<Color x:Key="OnSecondaryContainerColor">#F3F3F3</Color>

			<!-- Tertiary -->
			<Color x:Key="TertiaryColor">#949494</Color>
			<Color x:Key="OnTertiaryColor">#242424</Color>
			<Color x:Key="TertiaryContainerColor">#383838</Color>
			<Color x:Key="OnTertiaryContainerColor">#E6E6E6</Color>

			<!-- Error (SDS Danger) -->
			<Color x:Key="ErrorColor">#C00F0C</Color>
			<Color x:Key="OnErrorColor">#FEE9E7</Color>
			<Color x:Key="ErrorContainerColor">#690807</Color>
			<Color x:Key="OnErrorContainerColor">#FEE9E7</Color>

			<!-- Background -->
			<Color x:Key="BackgroundColor">#1E1E1E</Color>
			<Color x:Key="OnBackgroundColor">#FFFFFF</Color>

			<!-- Surface (SDS Default) -->
			<Color x:Key="SurfaceColor">#1E1E1E</Color>
			<Color x:Key="OnSurfaceColor">#FFFFFF</Color>
			<Color x:Key="SurfaceVariantColor">#2C2C2C</Color>
			<Color x:Key="OnSurfaceVariantColor">#B3B3B3</Color>
			<Color x:Key="SurfaceInverseColor">#B2B2B2</Color>
			<Color x:Key="OnSurfaceInverseColor">#242424</Color>
			<Color x:Key="SurfaceTintColor">#F5F5F5</Color>

			<!-- Outline -->
			<Color x:Key="OutlineColor">#444444</Color>
			<Color x:Key="OutlineVariantColor">#757575</Color>

			<!-- Shadow -->
			<Color x:Key="ShadowColor">#33000000</Color>

			<!-- ─────────────────────────────────────────────────────────────── -->
			<!-- Utility-only Primitives (Pink — used by measurement brushes)   -->
			<!-- ─────────────────────────────────────────────────────────────── -->
			<Color x:Key="SimplePink200Color">#FAE1FA</Color>
			<Color x:Key="SimplePink400Color">#F19EDC</Color>
			<Color x:Key="SimplePink600Color">#D732A8</Color>
			<Color x:Key="SimplePink800Color">#8A226F</Color>

			<!-- ─────────────────────────────────────────────────────────────── -->
			<!-- Utility Brushes (Simple-specific, no shared equivalent)        -->
			<!-- ─────────────────────────────────────────────────────────────── -->
			<SolidColorBrush x:Key="SimpleBackgroundUtilitiesBlanketBrush" Color="#B2000000" />
			<SolidColorBrush x:Key="SimpleBackgroundUtilitiesMeasurementBrush" Color="{StaticResource SimplePink800Color}" />
			<SolidColorBrush x:Key="SimpleBackgroundUtilitiesOverlayBrush" Color="#80000000" />
			<SolidColorBrush x:Key="SimpleBackgroundUtilitiesScrimBrush" Color="#CC000000" />
			<SolidColorBrush x:Key="SimpleTextUtilitiesOnMeasurementBrush" Color="{StaticResource SimplePink200Color}" />
			<StaticResource x:Key="SimpleTextUtilitiesOnOverlayBrush" ResourceKey="OnSurfaceBrush" />
			<SolidColorBrush x:Key="SimpleIconUtilitiesBrush" Color="{StaticResource SimplePink400Color}" />
			<SolidColorBrush x:Key="SimpleIconUtilitiesOnMeasurementBrush" Color="{StaticResource SimplePink200Color}" />
			<SolidColorBrush x:Key="SimpleBorderUtilitiesMeasurementBrush" Color="{StaticResource SimplePink600Color}" />
			<SolidColorBrush x:Key="SimpleBorderUtilitiesSwatchBrush" Color="#3DFFFFFF" />
		</ResourceDictionary>

	</ResourceDictionary.ThemeDictionaries>

</ResourceDictionary>
