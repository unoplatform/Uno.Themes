<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
					xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

	<!--
		Size defaults: Small
		Loaded by SimpleTheme when DefaultSize = Small (the default).

		These aliases map generic resource keys to their Small-specific counterparts.
		Base styles reference the generic keys, so this file controls the default sizing.
	-->

	<!-- Button -->
	<StaticResource x:Key="SimpleButtonMinHeight" ResourceKey="SimpleButtonSmallMinHeight" />
	<StaticResource x:Key="SimpleButtonPadding" ResourceKey="SimpleButtonSmallPadding" />
	<StaticResource x:Key="SimpleButtonFontSize" ResourceKey="SimpleButtonSmallFontSize" />

	<!-- IconButton -->
	<StaticResource x:Key="SimpleIconButtonMinSize" ResourceKey="SimpleIconButtonSmallMinSize" />
	<StaticResource x:Key="SimpleIconButtonPadding" ResourceKey="SimpleIconButtonSmallPadding" />

	<!-- ToggleButton -->
	<StaticResource x:Key="SimpleToggleButtonMinHeight" ResourceKey="SimpleToggleButtonSmallMinHeight" />
	<StaticResource x:Key="SimpleToggleButtonPadding" ResourceKey="SimpleToggleButtonSmallPadding" />
	<StaticResource x:Key="SimpleToggleButtonFontSize" ResourceKey="SimpleToggleButtonSmallFontSize" />

</ResourceDictionary>
