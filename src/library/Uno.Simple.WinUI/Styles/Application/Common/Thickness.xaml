<!-- ─────────────────────────────────────────────────────────────── -->
<!-- SDS Icon Sizing → Shared tokens                                -->
<!-- ─────────────────────────────────────────────────────────────── -->
<StaticResource x:Key="SimpleIconSmall" ResourceKey="IconSizeSmall" />
<StaticResource x:Key="SimpleIconMedium" ResourceKey="IconSizeMedium" />
<StaticResource x:Key="SimpleIconLarge" ResourceKey="IconSizeLarge" />

<!-- ─────────────────────────────────────────────────────────────── -->
<!-- SDS Stroke (Simple-specific, no shared equivalent yet)         -->
<!-- ─────────────────────────────────────────────────────────────── -->
<x:Double x:Key="SimpleStrokeBorder">1</x:Double>
<x:Double x:Key="SimpleStrokeFocusRing">2</x:Double>
<Thickness x:Key="SimpleStrokeBorderThickness">1</Thickness>
