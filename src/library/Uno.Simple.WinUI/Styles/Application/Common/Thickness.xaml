			<!-- ─────────────────────────────────────────────────────────────── -->
			<!-- SDS Primitive Tokens: Spacing (sds-size-space-*)               -->
			<!-- 1 rem = 16 px                                                  -->
			<!-- ─────────────────────────────────────────────────────────────── -->
			<x:Double x:Key="SimpleSpace0">0</x:Double>           <!-- sds-size-space-0:    0 rem    =   0 px -->
			<x:Double x:Key="SimpleSpace050">2</x:Double>         <!-- sds-size-space-050:  0.125 rem =  2 px -->
			<x:Double x:Key="SimpleSpace100">4</x:Double>         <!-- sds-size-space-100:  0.25 rem  =  4 px -->
			<x:Double x:Key="SimpleSpace150">6</x:Double>         <!-- sds-size-space-150:  0.375 rem =  6 px -->
			<x:Double x:Key="SimpleSpace200">8</x:Double>         <!-- sds-size-space-200:  0.5 rem   =  8 px -->
			<x:Double x:Key="SimpleSpace300">12</x:Double>        <!-- sds-size-space-300:  0.75 rem  = 12 px -->
			<x:Double x:Key="SimpleSpace400">16</x:Double>        <!-- sds-size-space-400:  1 rem     = 16 px -->
			<x:Double x:Key="SimpleSpace600">24</x:Double>        <!-- sds-size-space-600:  1.5 rem   = 24 px -->
			<x:Double x:Key="SimpleSpace800">32</x:Double>        <!-- sds-size-space-800:  2 rem     = 32 px -->
			<x:Double x:Key="SimpleSpace1200">48</x:Double>       <!-- sds-size-space-1200: 3 rem     = 48 px -->
			<x:Double x:Key="SimpleSpace1600">64</x:Double>       <!-- sds-size-space-1600: 4 rem     = 64 px -->
			<x:Double x:Key="SimpleSpace2400">96</x:Double>       <!-- sds-size-space-2400: 6 rem     = 96 px -->
			<x:Double x:Key="SimpleSpace4000">160</x:Double>      <!-- sds-size-space-4000: 10 rem    =160 px -->

			<!-- ─────────────────────────────────────────────────────────────── -->
			<!-- SDS Primitive Tokens: Corner Radius (sds-size-radius-*)        -->
			<!-- ─────────────────────────────────────────────────────────────── -->
			<x:Double x:Key="SimpleRadius100">4</x:Double>        <!-- sds-size-radius-100:  0.25 rem =  4 px -->
			<x:Double x:Key="SimpleRadius200">8</x:Double>        <!-- sds-size-radius-200:  0.5 rem  =  8 px -->
			<x:Double x:Key="SimpleRadius400">16</x:Double>       <!-- sds-size-radius-400:  1 rem    = 16 px -->
			<x:Double x:Key="SimpleRadiusFull">9999</x:Double>    <!-- sds-size-radius-full: pill     = 9999 px -->

			<!-- Typed CornerRadius companions -->
			<CornerRadius x:Key="SimpleRadius100CornerRadius">4</CornerRadius>
			<CornerRadius x:Key="SimpleRadius200CornerRadius">8</CornerRadius>
			<CornerRadius x:Key="SimpleRadius400CornerRadius">16</CornerRadius>
			<CornerRadius x:Key="SimpleRadiusFullCornerRadius">9999</CornerRadius>

			<!-- ─────────────────────────────────────────────────────────────── -->
			<!-- SDS Primitive Tokens: Icon Sizing (sds-size-icon-*)            -->
			<!-- ─────────────────────────────────────────────────────────────── -->
			<x:Double x:Key="SimpleIconSmall">24</x:Double>       <!-- sds-size-icon-small:  1.5 rem = 24 px -->
			<x:Double x:Key="SimpleIconMedium">32</x:Double>      <!-- sds-size-icon-medium: 2 rem   = 32 px -->
			<x:Double x:Key="SimpleIconLarge">40</x:Double>       <!-- sds-size-icon-large:  2.5 rem = 40 px -->

			<!-- ─────────────────────────────────────────────────────────────── -->
			<!-- SDS Primitive Tokens: Stroke (sds-size-stroke-*)               -->
			<!-- ─────────────────────────────────────────────────────────────── -->
			<x:Double x:Key="SimpleStrokeBorder">1</x:Double>     <!-- sds-size-stroke-border:     0.0625 rem = 1 px -->
			<x:Double x:Key="SimpleStrokeFocusRing">2</x:Double>  <!-- sds-size-stroke-focus-ring: 0.125 rem  = 2 px -->

			<!-- Typed Thickness companions -->
			<Thickness x:Key="SimpleStrokeBorderThickness">1</Thickness>
			<Thickness x:Key="SimpleStrokeFocusRingThickness">2</Thickness>

			<!-- ─────────────────────────────────────────────────────────────── -->
			<!-- Typed Thickness companions for uniform spacing                 -->
			<!-- ─────────────────────────────────────────────────────────────── -->
			<Thickness x:Key="SimpleSpace0Thickness">0</Thickness>
			<Thickness x:Key="SimpleSpace050Thickness">2</Thickness>
			<Thickness x:Key="SimpleSpace100Thickness">4</Thickness>
			<Thickness x:Key="SimpleSpace150Thickness">6</Thickness>
			<Thickness x:Key="SimpleSpace200Thickness">8</Thickness>
			<Thickness x:Key="SimpleSpace300Thickness">12</Thickness>
			<Thickness x:Key="SimpleSpace400Thickness">16</Thickness>
			<Thickness x:Key="SimpleSpace600Thickness">24</Thickness>
			<Thickness x:Key="SimpleSpace800Thickness">32</Thickness>

		</ResourceDictionary>

	</ResourceDictionary.ThemeDictionaries>

</ResourceDictionary>
