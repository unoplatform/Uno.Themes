<StaticResource x:Key="SimpleSpace2400" ResourceKey="Space2400" />
<StaticResource x:Key="SimpleSpace4000" ResourceKey="Space4000" />

<!-- ─────────────────────────────────────────────────────────────── -->
<!-- SDS Corner Radius → Shared tokens                              -->
