<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
					xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

	<!-- Corner Radius -->
	<CornerRadius x:Key="SimpleButtonCornerRadius">8</CornerRadius>
	<CornerRadius x:Key="SimpleTextBoxCornerRadius">8</CornerRadius>
	<CornerRadius x:Key="SimpleCheckBoxCornerRadius">4</CornerRadius>

	<!-- Border Thickness -->
	<Thickness x:Key="BorderThickness">1</Thickness>
	<Thickness x:Key="SimpleButtonBorderThickness">1</Thickness>
	<Thickness x:Key="SimpleTextBoxBorderThickness">1</Thickness>

	<!-- Padding - Buttons -->
	<Thickness x:Key="SimpleButtonMediumPadding">12,12,12,12</Thickness>
	<Thickness x:Key="SimpleButtonSmallPadding">8,8,8,8</Thickness>
	<Thickness x:Key="SimpleButtonLargePadding">20,16,20,16</Thickness>

	<!-- Padding - TextBox/Input -->
	<Thickness x:Key="SimpleTextBoxPadding">12,12,12,12</Thickness>

	<!-- Control Heights -->
	<x:Double x:Key="SimpleButtonMediumHeight">40</x:Double>
	<x:Double x:Key="SimpleButtonSmallHeight">32</x:Double>
	<x:Double x:Key="SimpleButtonLargeHeight">48</x:Double>
	<x:Double x:Key="SimpleTextBoxMediumHeight">40</x:Double>
	<x:Double x:Key="SimpleTextBoxSmallHeight">32</x:Double>

</ResourceDictionary>
