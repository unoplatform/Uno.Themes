<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
					xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

	<!--
		Simple Design System — Typography Tokens
		Maps SDS Figma typography primitives to XAML resources.
	-->

	<ResourceDictionary.ThemeDictionaries>

		<!-- ─── Light Theme ─── -->
		<ResourceDictionary x:Key="Light">

			<!-- SDS Font Families -->
			<FontFamily x:Key="SimpleFontFamily">Inter</FontFamily>
			<FontFamily x:Key="SimpleFontFamilySans">Inter</FontFamily>
			<FontFamily x:Key="SimpleFontFamilySerif">Noto Serif</FontFamily>
			<FontFamily x:Key="SimpleFontFamilyMono">Roboto Mono</FontFamily>

			<!-- SDS Typography Scale (font sizes in px) -->
			<x:Double x:Key="SimpleTypographyScale01">12</x:Double>
			<x:Double x:Key="SimpleTypographyScale02">14</x:Double>
			<x:Double x:Key="SimpleTypographyScale03">16</x:Double>
			<x:Double x:Key="SimpleTypographyScale04">20</x:Double>
			<x:Double x:Key="SimpleTypographyScale05">24</x:Double>
			<x:Double x:Key="SimpleTypographyScale06">32</x:Double>
			<x:Double x:Key="SimpleTypographyScale07">40</x:Double>
			<x:Double x:Key="SimpleTypographyScale08">48</x:Double>
			<x:Double x:Key="SimpleTypographyScale09">56</x:Double>
			<x:Double x:Key="SimpleTypographyScale10">72</x:Double>

			<!-- SDS Line Heights (px) -->
			<x:Double x:Key="SimpleLineHeight01">16</x:Double>
			<x:Double x:Key="SimpleLineHeight02">20</x:Double>
			<x:Double x:Key="SimpleLineHeight03">24</x:Double>
			<x:Double x:Key="SimpleLineHeight04">28</x:Double>
			<x:Double x:Key="SimpleLineHeight05">32</x:Double>
			<x:Double x:Key="SimpleLineHeight06">40</x:Double>
			<x:Double x:Key="SimpleLineHeight07">48</x:Double>
			<x:Double x:Key="SimpleLineHeight08">56</x:Double>
			<x:Double x:Key="SimpleLineHeight09">64</x:Double>
			<x:Double x:Key="SimpleLineHeight10">80</x:Double>

			<!-- Semantic Typography Aliases -->
			<x:Double x:Key="SimpleTitleHeroFontSize">72</x:Double>
			<x:Double x:Key="SimpleTitleHeroLineHeight">80</x:Double>
			<x:Double x:Key="SimpleTitlePageFontSize">48</x:Double>
			<x:Double x:Key="SimpleTitlePageLineHeight">56</x:Double>
			<x:Double x:Key="SimpleSubtitleFontSize">32</x:Double>
			<x:Double x:Key="SimpleSubtitleLineHeight">40</x:Double>
			<x:Double x:Key="SimpleHeadingFontSize">24</x:Double>
			<x:Double x:Key="SimpleHeadingLineHeight">32</x:Double>
			<x:Double x:Key="SimpleSubheadingFontSize">20</x:Double>
			<x:Double x:Key="SimpleSubheadingLineHeight">28</x:Double>
			<x:Double x:Key="SimpleBodyFontSize">16</x:Double>
			<x:Double x:Key="SimpleBodyLineHeight">24</x:Double>
			<x:Double x:Key="SimpleBodySmallFontSize">14</x:Double>
			<x:Double x:Key="SimpleBodySmallLineHeight">20</x:Double>
			<x:Double x:Key="SimpleCaptionFontSize">12</x:Double>
			<x:Double x:Key="SimpleCaptionLineHeight">16</x:Double>

			<!-- SDS Font Weights -->
			<FontWeight x:Key="SimpleRegularFontWeight">Normal</FontWeight>
			<FontWeight x:Key="SimpleMediumFontWeight">Medium</FontWeight>
			<FontWeight x:Key="SimpleSemiBoldFontWeight">SemiBold</FontWeight>
			<FontWeight x:Key="SimpleBoldFontWeight">Bold</FontWeight>

			<!-- ──────────────────────────────────────────────────────── -->
			<!-- Shared Typography Token Overrides (M3-compatible)      -->
			<!-- Override SharedTypography defaults with Simple values  -->
			<!-- ──────────────────────────────────────────────────────── -->

			<!-- FontFamily: all scales use Inter -->
			<StaticResource x:Key="DisplayLargeFontFamily" ResourceKey="SimpleFontFamily" />
			<StaticResource x:Key="DisplayMediumFontFamily" ResourceKey="SimpleFontFamily" />
			<StaticResource x:Key="DisplaySmallFontFamily" ResourceKey="SimpleFontFamily" />
			<StaticResource x:Key="HeadlineLargeFontFamily" ResourceKey="SimpleFontFamily" />
			<StaticResource x:Key="HeadlineMediumFontFamily" ResourceKey="SimpleFontFamily" />
			<StaticResource x:Key="HeadlineSmallFontFamily" ResourceKey="SimpleFontFamily" />
			<StaticResource x:Key="TitleLargeFontFamily" ResourceKey="SimpleFontFamily" />
			<StaticResource x:Key="TitleMediumFontFamily" ResourceKey="SimpleFontFamily" />
			<StaticResource x:Key="TitleSmallFontFamily" ResourceKey="SimpleFontFamily" />
			<StaticResource x:Key="BodyLargeFontFamily" ResourceKey="SimpleFontFamily" />
			<StaticResource x:Key="BodyMediumFontFamily" ResourceKey="SimpleFontFamily" />
			<StaticResource x:Key="BodySmallFontFamily" ResourceKey="SimpleFontFamily" />
			<StaticResource x:Key="LabelLargeFontFamily" ResourceKey="SimpleFontFamily" />
			<StaticResource x:Key="LabelMediumFontFamily" ResourceKey="SimpleFontFamily" />
			<StaticResource x:Key="LabelSmallFontFamily" ResourceKey="SimpleFontFamily" />
			<StaticResource x:Key="LabelExtraSmallFontFamily" ResourceKey="SimpleFontFamily" />
			<StaticResource x:Key="CaptionLargeFontFamily" ResourceKey="SimpleFontFamily" />
			<StaticResource x:Key="CaptionMediumFontFamily" ResourceKey="SimpleFontFamily" />
			<StaticResource x:Key="CaptionSmallFontFamily" ResourceKey="SimpleFontFamily" />

			<!-- FontSize: override only where Simple differs from shared defaults -->
			<x:Double x:Key="LabelLargeFontSize">16</x:Double>

		</ResourceDictionary>

		<!-- ─── Dark Theme (Default) ─── -->
		<ResourceDictionary x:Key="Default">

			<!-- SDS Font Families -->
			<FontFamily x:Key="SimpleFontFamily">Inter</FontFamily>
			<FontFamily x:Key="SimpleFontFamilySans">Inter</FontFamily>
			<FontFamily x:Key="SimpleFontFamilySerif">Noto Serif</FontFamily>
			<FontFamily x:Key="SimpleFontFamilyMono">Roboto Mono</FontFamily>

			<!-- SDS Typography Scale (font sizes in px) -->
			<x:Double x:Key="SimpleTypographyScale01">12</x:Double>
			<x:Double x:Key="SimpleTypographyScale02">14</x:Double>
			<x:Double x:Key="SimpleTypographyScale03">16</x:Double>
			<x:Double x:Key="SimpleTypographyScale04">20</x:Double>
			<x:Double x:Key="SimpleTypographyScale05">24</x:Double>
			<x:Double x:Key="SimpleTypographyScale06">32</x:Double>
			<x:Double x:Key="SimpleTypographyScale07">40</x:Double>
			<x:Double x:Key="SimpleTypographyScale08">48</x:Double>
			<x:Double x:Key="SimpleTypographyScale09">56</x:Double>
			<x:Double x:Key="SimpleTypographyScale10">72</x:Double>

			<!-- SDS Line Heights (px) -->
			<x:Double x:Key="SimpleLineHeight01">16</x:Double>
			<x:Double x:Key="SimpleLineHeight02">20</x:Double>
			<x:Double x:Key="SimpleLineHeight03">24</x:Double>
			<x:Double x:Key="SimpleLineHeight04">28</x:Double>
			<x:Double x:Key="SimpleLineHeight05">32</x:Double>
			<x:Double x:Key="SimpleLineHeight06">40</x:Double>
			<x:Double x:Key="SimpleLineHeight07">48</x:Double>
			<x:Double x:Key="SimpleLineHeight08">56</x:Double>
			<x:Double x:Key="SimpleLineHeight09">64</x:Double>
			<x:Double x:Key="SimpleLineHeight10">80</x:Double>

			<!-- Semantic Typography Aliases -->
			<x:Double x:Key="SimpleTitleHeroFontSize">72</x:Double>
			<x:Double x:Key="SimpleTitleHeroLineHeight">80</x:Double>
			<x:Double x:Key="SimpleTitlePageFontSize">48</x:Double>
			<x:Double x:Key="SimpleTitlePageLineHeight">56</x:Double>
			<x:Double x:Key="SimpleSubtitleFontSize">32</x:Double>
			<x:Double x:Key="SimpleSubtitleLineHeight">40</x:Double>
			<x:Double x:Key="SimpleHeadingFontSize">24</x:Double>
			<x:Double x:Key="SimpleHeadingLineHeight">32</x:Double>
			<x:Double x:Key="SimpleSubheadingFontSize">20</x:Double>
			<x:Double x:Key="SimpleSubheadingLineHeight">28</x:Double>
			<x:Double x:Key="SimpleBodyFontSize">16</x:Double>
			<x:Double x:Key="SimpleBodyLineHeight">24</x:Double>
			<x:Double x:Key="SimpleBodySmallFontSize">14</x:Double>
			<x:Double x:Key="SimpleBodySmallLineHeight">20</x:Double>
			<x:Double x:Key="SimpleCaptionFontSize">12</x:Double>
			<x:Double x:Key="SimpleCaptionLineHeight">16</x:Double>

			<!-- SDS Font Weights -->
			<FontWeight x:Key="SimpleRegularFontWeight">Normal</FontWeight>
			<FontWeight x:Key="SimpleMediumFontWeight">Medium</FontWeight>
			<FontWeight x:Key="SimpleSemiBoldFontWeight">SemiBold</FontWeight>
			<FontWeight x:Key="SimpleBoldFontWeight">Bold</FontWeight>

			<!-- ──────────────────────────────────────────────────────────── -->
			<!-- Shared Typography Token Overrides (M3-compatible)      -->
			<!-- Override SharedTypography defaults with Simple values  -->
			<!-- ──────────────────────────────────────────────────────────── -->

			<!-- FontFamily: all scales use Inter -->
			<StaticResource x:Key="DisplayLargeFontFamily" ResourceKey="SimpleFontFamily" />
			<StaticResource x:Key="DisplayMediumFontFamily" ResourceKey="SimpleFontFamily" />
			<StaticResource x:Key="DisplaySmallFontFamily" ResourceKey="SimpleFontFamily" />
			<StaticResource x:Key="HeadlineLargeFontFamily" ResourceKey="SimpleFontFamily" />
			<StaticResource x:Key="HeadlineMediumFontFamily" ResourceKey="SimpleFontFamily" />
			<StaticResource x:Key="HeadlineSmallFontFamily" ResourceKey="SimpleFontFamily" />
			<StaticResource x:Key="TitleLargeFontFamily" ResourceKey="SimpleFontFamily" />
			<StaticResource x:Key="TitleMediumFontFamily" ResourceKey="SimpleFontFamily" />
			<StaticResource x:Key="TitleSmallFontFamily" ResourceKey="SimpleFontFamily" />
			<StaticResource x:Key="BodyLargeFontFamily" ResourceKey="SimpleFontFamily" />
			<StaticResource x:Key="BodyMediumFontFamily" ResourceKey="SimpleFontFamily" />
			<StaticResource x:Key="BodySmallFontFamily" ResourceKey="SimpleFontFamily" />
			<StaticResource x:Key="LabelLargeFontFamily" ResourceKey="SimpleFontFamily" />
			<StaticResource x:Key="LabelMediumFontFamily" ResourceKey="SimpleFontFamily" />
			<StaticResource x:Key="LabelSmallFontFamily" ResourceKey="SimpleFontFamily" />
			<StaticResource x:Key="LabelExtraSmallFontFamily" ResourceKey="SimpleFontFamily" />
			<StaticResource x:Key="CaptionLargeFontFamily" ResourceKey="SimpleFontFamily" />
			<StaticResource x:Key="CaptionMediumFontFamily" ResourceKey="SimpleFontFamily" />
			<StaticResource x:Key="CaptionSmallFontFamily" ResourceKey="SimpleFontFamily" />

			<!-- FontSize: override only where Simple differs from shared defaults -->
			<x:Double x:Key="LabelLargeFontSize">16</x:Double>

		</ResourceDictionary>

	</ResourceDictionary.ThemeDictionaries>

</ResourceDictionary>
