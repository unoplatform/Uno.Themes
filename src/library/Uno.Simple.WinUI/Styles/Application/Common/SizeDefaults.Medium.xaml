<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
					xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

	<!--
		Size defaults: Medium
		Loaded by SimpleTheme when DefaultSize = Medium.

		These aliases map generic resource keys to their Medium-specific counterparts.
		Base styles reference the generic keys, so this file controls the default sizing.
	-->

	<!-- Button -->
	<StaticResource x:Key="SimpleButtonMinHeight" ResourceKey="SimpleButtonMediumMinHeight" />
	<StaticResource x:Key="SimpleButtonPadding" ResourceKey="SimpleButtonMediumPadding" />
	<StaticResource x:Key="SimpleButtonFontSize" ResourceKey="SimpleButtonMediumFontSize" />

	<!-- IconButton -->
	<StaticResource x:Key="SimpleIconButtonMinSize" ResourceKey="SimpleIconButtonMediumMinSize" />
	<StaticResource x:Key="SimpleIconButtonPadding" ResourceKey="SimpleIconButtonMediumPadding" />

	<!-- ToggleButton -->
	<StaticResource x:Key="SimpleToggleButtonMinHeight" ResourceKey="SimpleToggleButtonMediumMinHeight" />
	<StaticResource x:Key="SimpleToggleButtonPadding" ResourceKey="SimpleToggleButtonMediumPadding" />
	<StaticResource x:Key="SimpleToggleButtonFontSize" ResourceKey="SimpleToggleButtonMediumFontSize" />

</ResourceDictionary>
