<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
					xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
					xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
					mc:Ignorable="">

	<!--
		Simple Design System — MenuFlyout Styles
		Maps SDS Menu component tokens to WinUI MenuFlyoutPresenter, MenuFlyoutItem,
		MenuFlyoutSubItem, MenuFlyoutSeparator, ToggleMenuFlyoutItem.

		SDS Menu:
		  Container: bg = background-default-default, border = border-default-default,
		             radius = 8px, padding = 8px, shadow = drop-shadow-400
		  Item normal: transparent bg, text = text-default-default, description = text-default-secondary
		  Item focused/hovered: bg = background-brand-default, text = text-brand-on-brand
		  Item disabled: text = text-disabled-default, icon = icon-disabled-default
		  Separator: bg = border-default-default, height = 1px, margin = 4px 16px
		  Heading: text = text-default-secondary, font = body-strong
	-->

	<!-- ═══════════════════════════════════════════════════════════════════════ -->
	<!-- Lightweight styling ThemeResource aliases                              -->
	<!-- ═══════════════════════════════════════════════════════════════════════ -->
	<ResourceDictionary.ThemeDictionaries>

		<!-- ─── Light Theme ─── -->
		<ResourceDictionary x:Key="Light">
			<!-- Presenter (container) -->
			<StaticResource x:Key="SimpleMenuFlyoutPresenterBackground" ResourceKey="SimpleBackgroundDefaultDefaultBrush" />
			<StaticResource x:Key="SimpleMenuFlyoutPresenterBorderBrush" ResourceKey="SimpleBorderDefaultDefaultBrush" />

			<!-- Item — Normal -->
			<SolidColorBrush x:Key="SimpleMenuFlyoutItemBackground" Color="Transparent" />
			<StaticResource x:Key="SimpleMenuFlyoutItemForeground" ResourceKey="SimpleTextDefaultDefaultBrush" />
			<StaticResource x:Key="SimpleMenuFlyoutItemDescriptionForeground" ResourceKey="SimpleTextDefaultSecondaryBrush" />
			<StaticResource x:Key="SimpleMenuFlyoutItemIconForeground" ResourceKey="SimpleIconDefaultDefaultBrush" />

			<!-- Item — PointerOver / Focused -->
			<StaticResource x:Key="SimpleMenuFlyoutItemBackgroundPointerOver" ResourceKey="SimpleBackgroundBrandDefaultBrush" />
			<StaticResource x:Key="SimpleMenuFlyoutItemForegroundPointerOver" ResourceKey="SimpleTextBrandOnBrandBrush" />
			<StaticResource x:Key="SimpleMenuFlyoutItemIconForegroundPointerOver" ResourceKey="SimpleIconBrandOnBrandBrush" />

			<!-- Item — Pressed -->
			<StaticResource x:Key="SimpleMenuFlyoutItemBackgroundPressed" ResourceKey="SimpleBackgroundBrandPressedBrush" />
			<StaticResource x:Key="SimpleMenuFlyoutItemForegroundPressed" ResourceKey="SimpleTextBrandOnBrandBrush" />
			<StaticResource x:Key="SimpleMenuFlyoutItemIconForegroundPressed" ResourceKey="SimpleIconBrandOnBrandBrush" />

			<!-- Item — Disabled -->
			<StaticResource x:Key="SimpleMenuFlyoutItemForegroundDisabled" ResourceKey="SimpleTextDisabledDefaultBrush" />
			<StaticResource x:Key="SimpleMenuFlyoutItemIconForegroundDisabled" ResourceKey="SimpleIconDisabledDefaultBrush" />

			<!-- Separator -->
			<StaticResource x:Key="SimpleMenuFlyoutSeparatorBackground" ResourceKey="SimpleBorderDefaultDefaultBrush" />
		</ResourceDictionary>

		<!-- ─── Dark Theme (Default) ─── -->
		<ResourceDictionary x:Key="Default">
			<StaticResource x:Key="SimpleMenuFlyoutPresenterBackground" ResourceKey="SimpleBackgroundDefaultDefaultBrush" />
			<StaticResource x:Key="SimpleMenuFlyoutPresenterBorderBrush" ResourceKey="SimpleBorderDefaultDefaultBrush" />

			<SolidColorBrush x:Key="SimpleMenuFlyoutItemBackground" Color="Transparent" />
			<StaticResource x:Key="SimpleMenuFlyoutItemForeground" ResourceKey="SimpleTextDefaultDefaultBrush" />
			<StaticResource x:Key="SimpleMenuFlyoutItemDescriptionForeground" ResourceKey="SimpleTextDefaultSecondaryBrush" />
			<StaticResource x:Key="SimpleMenuFlyoutItemIconForeground" ResourceKey="SimpleIconDefaultDefaultBrush" />

			<StaticResource x:Key="SimpleMenuFlyoutItemBackgroundPointerOver" ResourceKey="SimpleBackgroundBrandDefaultBrush" />
			<StaticResource x:Key="SimpleMenuFlyoutItemForegroundPointerOver" ResourceKey="SimpleTextBrandOnBrandBrush" />
			<StaticResource x:Key="SimpleMenuFlyoutItemIconForegroundPointerOver" ResourceKey="SimpleIconBrandOnBrandBrush" />

			<StaticResource x:Key="SimpleMenuFlyoutItemBackgroundPressed" ResourceKey="SimpleBackgroundBrandPressedBrush" />
			<StaticResource x:Key="SimpleMenuFlyoutItemForegroundPressed" ResourceKey="SimpleTextBrandOnBrandBrush" />
			<StaticResource x:Key="SimpleMenuFlyoutItemIconForegroundPressed" ResourceKey="SimpleIconBrandOnBrandBrush" />

			<StaticResource x:Key="SimpleMenuFlyoutItemForegroundDisabled" ResourceKey="SimpleTextDisabledDefaultBrush" />
			<StaticResource x:Key="SimpleMenuFlyoutItemIconForegroundDisabled" ResourceKey="SimpleIconDisabledDefaultBrush" />

			<StaticResource x:Key="SimpleMenuFlyoutSeparatorBackground" ResourceKey="SimpleBorderDefaultDefaultBrush" />
		</ResourceDictionary>

	</ResourceDictionary.ThemeDictionaries>

	<!-- ═══════════════════════════════════════════════════════════════════════ -->
	<!-- Sizing / layout constants                                              -->
	<!-- ═══════════════════════════════════════════════════════════════════════ -->
	<x:Double x:Key="SimpleMenuFlyoutPresenterMinWidth">112</x:Double> <!-- no exact SDS token (112) -->
	<x:Double x:Key="SimpleMenuFlyoutPresenterMaxWidth">320</x:Double> <!-- no exact SDS token (320) -->
	<StaticResource x:Key="SimpleMenuFlyoutItemHeight" ResourceKey="SimpleSizeIconLarge" /> <!-- sds-size-icon-large -->
	<StaticResource x:Key="SimpleMenuFlyoutSeparatorHeight" ResourceKey="SimpleSizeStrokeBorder" /> <!-- sds-size-stroke-border -->
	<Thickness x:Key="SimpleMenuFlyoutItemPadding">12,8</Thickness> <!-- H: sds-size-space-300, V: sds-size-space-200 -->
	<Thickness x:Key="SimpleMenuFlyoutItemIconMargin">0,0,16,0</Thickness> <!-- 0,0,sds-size-space-400,0 -->
	<Thickness x:Key="SimpleMenuFlyoutItemAcceleratorMargin">16,0,0,0</Thickness> <!-- sds-size-space-400,0,0,0 -->
	<Thickness x:Key="SimpleMenuFlyoutCheckGlyphMargin">0,0,8,0</Thickness> <!-- 0,0,sds-size-space-200,0 -->
	<Thickness x:Key="SimpleMenuFlyoutSeparatorPadding">16,4</Thickness> <!-- sds-size-space-400,sds-size-space-100 -->

	<!-- ═══════════════════════════════════════════════════════════════════════ -->
	<!-- MenuFlyoutPresenter Style                                              -->
	<!-- ═══════════════════════════════════════════════════════════════════════ -->
	<Style x:Key="SimpleMenuFlyoutPresenterStyle"
		   TargetType="MenuFlyoutPresenter">

		<Setter Property="Background" Value="{ThemeResource SimpleMenuFlyoutPresenterBackground}" />
		<Setter Property="BorderBrush" Value="{ThemeResource SimpleMenuFlyoutPresenterBorderBrush}" />
		<Setter Property="BorderThickness" Value="{StaticResource SimpleSizeStrokeBorderThickness}" />
		<Setter Property="Foreground" Value="{ThemeResource SimpleMenuFlyoutItemForeground}" />
		<Setter Property="FontFamily" Value="{ThemeResource SimpleFontFamily}" />
		<Setter Property="FontSize" Value="{ThemeResource SimpleBodyFontSize}" />
		<Setter Property="MinWidth" Value="{StaticResource SimpleMenuFlyoutPresenterMinWidth}" />
		<Setter Property="MaxWidth" Value="{StaticResource SimpleMenuFlyoutPresenterMaxWidth}" />
		<Setter Property="Padding" Value="{StaticResource SimpleSizeSpace200Thickness}" />
		<Setter Property="CornerRadius" Value="{StaticResource SimpleSizeRadius200CornerRadius}" />
		<Setter Property="ScrollViewer.HorizontalScrollMode" Value="Disabled" />
		<Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled" />
	</Style>

	<!-- ═══════════════════════════════════════════════════════════════════════ -->
	<!-- MenuFlyoutItem Style                                                   -->
	<!-- ═══════════════════════════════════════════════════════════════════════ -->
	<Style x:Key="SimpleMenuFlyoutItemStyle"
		   TargetType="MenuFlyoutItem">

		<Setter Property="Background" Value="{ThemeResource SimpleMenuFlyoutItemBackground}" />
		<Setter Property="Foreground" Value="{ThemeResource SimpleMenuFlyoutItemForeground}" />
		<Setter Property="FontFamily" Value="{ThemeResource SimpleFontFamily}" />
		<Setter Property="FontSize" Value="{ThemeResource SimpleBodyFontSize}" />
		<Setter Property="Height" Value="{StaticResource SimpleMenuFlyoutItemHeight}" />
		<Setter Property="Padding" Value="{StaticResource SimpleMenuFlyoutItemPadding}" />
		<Setter Property="CornerRadius" Value="{StaticResource SimpleSizeRadius200CornerRadius}" />

		<Setter Property="Template">
			<Setter.Value>
				<ControlTemplate TargetType="MenuFlyoutItem">
					<Grid x:Name="LayoutRoot"
						  Background="{TemplateBinding Background}"
						  CornerRadius="{TemplateBinding CornerRadius}"
						  Padding="{TemplateBinding Padding}">

						<VisualStateManager.VisualStateGroups>
							<VisualStateGroup x:Name="CommonStates">
								<VisualState x:Name="Normal" />

								<VisualState x:Name="PointerOver">
									<VisualState.Setters>
										<Setter Target="LayoutRoot.Background" Value="{ThemeResource SimpleMenuFlyoutItemBackgroundPointerOver}" />
										<Setter Target="TextBlock.Foreground" Value="{ThemeResource SimpleMenuFlyoutItemForegroundPointerOver}" />
										<Setter Target="IconContent.Foreground" Value="{ThemeResource SimpleMenuFlyoutItemIconForegroundPointerOver}" />
									</VisualState.Setters>
								</VisualState>

								<VisualState x:Name="Pressed">
									<VisualState.Setters>
										<Setter Target="LayoutRoot.Background" Value="{ThemeResource SimpleMenuFlyoutItemBackgroundPressed}" />
										<Setter Target="TextBlock.Foreground" Value="{ThemeResource SimpleMenuFlyoutItemForegroundPressed}" />
										<Setter Target="IconContent.Foreground" Value="{ThemeResource SimpleMenuFlyoutItemIconForegroundPressed}" />
									</VisualState.Setters>
								</VisualState>

								<VisualState x:Name="Disabled">
									<VisualState.Setters>
										<Setter Target="TextBlock.Foreground" Value="{ThemeResource SimpleMenuFlyoutItemForegroundDisabled}" />
										<Setter Target="IconContent.Foreground" Value="{ThemeResource SimpleMenuFlyoutItemIconForegroundDisabled}" />
									</VisualState.Setters>
								</VisualState>
							</VisualStateGroup>

							<VisualStateGroup x:Name="CheckPlaceholderStates">
								<VisualState x:Name="NoPlaceholder" />
								<VisualState x:Name="CheckPlaceholder" />
								<VisualState x:Name="IconPlaceholder">
									<VisualState.Setters>
										<Setter Target="IconRoot.Visibility" Value="Visible" />
									</VisualState.Setters>
								</VisualState>
								<VisualState x:Name="CheckAndIconPlaceholder">
									<VisualState.Setters>
										<Setter Target="IconRoot.Visibility" Value="Visible" />
									</VisualState.Setters>
								</VisualState>
							</VisualStateGroup>

							<VisualStateGroup x:Name="KeyboardAcceleratorTextVisibility">
								<VisualState x:Name="KeyboardAcceleratorTextCollapsed" />
								<VisualState x:Name="KeyboardAcceleratorTextVisible">
									<VisualState.Setters>
										<Setter Target="KeyboardAcceleratorTextBlock.Visibility" Value="Visible" />
									</VisualState.Setters>
								</VisualState>
							</VisualStateGroup>
						</VisualStateManager.VisualStateGroups>

						<Grid.ColumnDefinitions>
							<ColumnDefinition Width="Auto" />
							<ColumnDefinition Width="*" />
							<ColumnDefinition Width="Auto" />
						</Grid.ColumnDefinitions>

						<Viewbox x:Name="IconRoot"
								 Grid.Column="0"
								 Width="{StaticResource SimpleSizeSpace400}"
								 Height="{StaticResource SimpleSizeSpace400}"
								 Margin="{StaticResource SimpleMenuFlyoutItemIconMargin}"
								 HorizontalAlignment="Left"
								 VerticalAlignment="Center"
								 Visibility="Collapsed">
							<ContentPresenter x:Name="IconContent"
											  Content="{TemplateBinding Icon}"
											  Foreground="{ThemeResource SimpleMenuFlyoutItemIconForeground}" />
						</Viewbox>

						<TextBlock x:Name="TextBlock"
								   Grid.Column="1"
								   VerticalAlignment="Center"
								   Foreground="{TemplateBinding Foreground}"
								   Text="{TemplateBinding Text}"
								   TextTrimming="CharacterEllipsis" />

						<TextBlock x:Name="KeyboardAcceleratorTextBlock"
								   Grid.Column="2"
								   Margin="{StaticResource SimpleMenuFlyoutItemAcceleratorMargin}"
								   VerticalAlignment="Center"
								   Foreground="{ThemeResource SimpleMenuFlyoutItemDescriptionForeground}"
								   Text="{TemplateBinding KeyboardAcceleratorTextOverride}"
								   FontSize="{ThemeResource SimpleBodySmallFontSize}"
								   Visibility="Collapsed" />
					</Grid>
				</ControlTemplate>
			</Setter.Value>
		</Setter>
	</Style>

	<!-- ═══════════════════════════════════════════════════════════════════════ -->
	<!-- ToggleMenuFlyoutItem Style                                             -->
	<!-- ═══════════════════════════════════════════════════════════════════════ -->
	<Style x:Key="SimpleToggleMenuFlyoutItemStyle"
		   TargetType="ToggleMenuFlyoutItem">

		<Setter Property="Background" Value="{ThemeResource SimpleMenuFlyoutItemBackground}" />
		<Setter Property="Foreground" Value="{ThemeResource SimpleMenuFlyoutItemForeground}" />
		<Setter Property="FontFamily" Value="{ThemeResource SimpleFontFamily}" />
		<Setter Property="FontSize" Value="{ThemeResource SimpleBodyFontSize}" />
		<Setter Property="Height" Value="{StaticResource SimpleMenuFlyoutItemHeight}" />
		<Setter Property="Padding" Value="{StaticResource SimpleMenuFlyoutItemPadding}" />
		<Setter Property="CornerRadius" Value="{StaticResource SimpleSizeRadius200CornerRadius}" />

		<Setter Property="Template">
			<Setter.Value>
				<ControlTemplate TargetType="ToggleMenuFlyoutItem">
					<Grid x:Name="LayoutRoot"
						  Background="{TemplateBinding Background}"
						  CornerRadius="{TemplateBinding CornerRadius}"
						  Padding="{TemplateBinding Padding}">

						<VisualStateManager.VisualStateGroups>
							<VisualStateGroup x:Name="CommonStates">
								<VisualState x:Name="Normal" />

								<VisualState x:Name="PointerOver">
									<VisualState.Setters>
										<Setter Target="LayoutRoot.Background" Value="{ThemeResource SimpleMenuFlyoutItemBackgroundPointerOver}" />
										<Setter Target="TextBlock.Foreground" Value="{ThemeResource SimpleMenuFlyoutItemForegroundPointerOver}" />
										<Setter Target="CheckGlyph.Foreground" Value="{ThemeResource SimpleMenuFlyoutItemIconForegroundPointerOver}" />
									</VisualState.Setters>
								</VisualState>

								<VisualState x:Name="Pressed">
									<VisualState.Setters>
										<Setter Target="LayoutRoot.Background" Value="{ThemeResource SimpleMenuFlyoutItemBackgroundPressed}" />
										<Setter Target="TextBlock.Foreground" Value="{ThemeResource SimpleMenuFlyoutItemForegroundPressed}" />
										<Setter Target="CheckGlyph.Foreground" Value="{ThemeResource SimpleMenuFlyoutItemIconForegroundPressed}" />
									</VisualState.Setters>
								</VisualState>

								<VisualState x:Name="Disabled">
									<VisualState.Setters>
										<Setter Target="TextBlock.Foreground" Value="{ThemeResource SimpleMenuFlyoutItemForegroundDisabled}" />
										<Setter Target="CheckGlyph.Foreground" Value="{ThemeResource SimpleMenuFlyoutItemIconForegroundDisabled}" />
									</VisualState.Setters>
								</VisualState>
							</VisualStateGroup>

							<VisualStateGroup x:Name="CheckStates">
								<VisualState x:Name="Unchecked" />
								<VisualState x:Name="Checked">
									<VisualState.Setters>
										<Setter Target="CheckGlyph.Opacity" Value="1" />
									</VisualState.Setters>
								</VisualState>
								<VisualState x:Name="UncheckedWithIcon">
									<VisualState.Setters>
										<Setter Target="IconRoot.Visibility" Value="Visible" />
									</VisualState.Setters>
								</VisualState>
								<VisualState x:Name="CheckedWithIcon">
									<VisualState.Setters>
										<Setter Target="IconRoot.Visibility" Value="Visible" />
										<Setter Target="CheckGlyph.Opacity" Value="1" />
									</VisualState.Setters>
								</VisualState>
							</VisualStateGroup>
						</VisualStateManager.VisualStateGroups>

						<Grid.ColumnDefinitions>
							<ColumnDefinition Width="Auto" />
							<ColumnDefinition Width="Auto" />
							<ColumnDefinition Width="*" />
							<ColumnDefinition Width="Auto" />
						</Grid.ColumnDefinitions>

						<!-- Check glyph -->
						<FontIcon x:Name="CheckGlyph"
								  Grid.Column="0"
								  Glyph="&#xE73E;"
								  FontSize="{ThemeResource SimpleCaptionFontSize}"
								  Foreground="{ThemeResource SimpleMenuFlyoutItemIconForeground}"
								  Margin="{StaticResource SimpleMenuFlyoutCheckGlyphMargin}"
								  Opacity="0"
								  VerticalAlignment="Center" />

						<Viewbox x:Name="IconRoot"
								 Grid.Column="1"
								 Width="{StaticResource SimpleSizeSpace400}"
								 Height="{StaticResource SimpleSizeSpace400}"
								 Margin="{StaticResource SimpleMenuFlyoutItemIconMargin}"
								 HorizontalAlignment="Left"
								 VerticalAlignment="Center"
								 Visibility="Collapsed">
							<ContentPresenter x:Name="IconContent"
											  Content="{TemplateBinding Icon}"
											  Foreground="{ThemeResource SimpleMenuFlyoutItemIconForeground}" />
						</Viewbox>

						<TextBlock x:Name="TextBlock"
								   Grid.Column="2"
								   VerticalAlignment="Center"
								   Foreground="{TemplateBinding Foreground}"
								   Text="{TemplateBinding Text}"
								   TextTrimming="CharacterEllipsis" />

						<TextBlock x:Name="KeyboardAcceleratorTextBlock"
								   Grid.Column="3"
								   Margin="{StaticResource SimpleMenuFlyoutItemAcceleratorMargin}"
								   VerticalAlignment="Center"
								   Foreground="{ThemeResource SimpleMenuFlyoutItemDescriptionForeground}"
								   Text="{TemplateBinding KeyboardAcceleratorTextOverride}"
								   FontSize="{ThemeResource SimpleBodySmallFontSize}"
								   Visibility="Collapsed" />
					</Grid>
				</ControlTemplate>
			</Setter.Value>
		</Setter>
	</Style>

	<!-- ═══════════════════════════════════════════════════════════════════════ -->
	<!-- MenuFlyoutSubItem Style                                                -->
	<!-- ═══════════════════════════════════════════════════════════════════════ -->
	<Style x:Key="SimpleMenuFlyoutSubItemStyle"
		   TargetType="MenuFlyoutSubItem">

		<Setter Property="Background" Value="{ThemeResource SimpleMenuFlyoutItemBackground}" />
		<Setter Property="Foreground" Value="{ThemeResource SimpleMenuFlyoutItemForeground}" />
		<Setter Property="FontFamily" Value="{ThemeResource SimpleFontFamily}" />
		<Setter Property="FontSize" Value="{ThemeResource SimpleBodyFontSize}" />
		<Setter Property="Height" Value="{StaticResource SimpleMenuFlyoutItemHeight}" />
		<Setter Property="Padding" Value="{StaticResource SimpleMenuFlyoutItemPadding}" />
		<Setter Property="CornerRadius" Value="{StaticResource SimpleSizeRadius200CornerRadius}" />

		<Setter Property="Template">
			<Setter.Value>
				<ControlTemplate TargetType="MenuFlyoutSubItem">
					<Grid x:Name="LayoutRoot"
						  Background="{TemplateBinding Background}"
						  CornerRadius="{TemplateBinding CornerRadius}"
						  Padding="{TemplateBinding Padding}">

						<VisualStateManager.VisualStateGroups>
							<VisualStateGroup x:Name="CommonStates">
								<VisualState x:Name="Normal" />

								<VisualState x:Name="PointerOver">
									<VisualState.Setters>
										<Setter Target="LayoutRoot.Background" Value="{ThemeResource SimpleMenuFlyoutItemBackgroundPointerOver}" />
										<Setter Target="TextBlock.Foreground" Value="{ThemeResource SimpleMenuFlyoutItemForegroundPointerOver}" />
										<Setter Target="SubItemChevron.Foreground" Value="{ThemeResource SimpleMenuFlyoutItemIconForegroundPointerOver}" />
									</VisualState.Setters>
								</VisualState>

								<VisualState x:Name="Pressed">
									<VisualState.Setters>
										<Setter Target="LayoutRoot.Background" Value="{ThemeResource SimpleMenuFlyoutItemBackgroundPressed}" />
										<Setter Target="TextBlock.Foreground" Value="{ThemeResource SimpleMenuFlyoutItemForegroundPressed}" />
										<Setter Target="SubItemChevron.Foreground" Value="{ThemeResource SimpleMenuFlyoutItemIconForegroundPressed}" />
									</VisualState.Setters>
								</VisualState>

								<VisualState x:Name="SubMenuOpened">
									<VisualState.Setters>
										<Setter Target="LayoutRoot.Background" Value="{ThemeResource SimpleMenuFlyoutItemBackgroundPointerOver}" />
										<Setter Target="TextBlock.Foreground" Value="{ThemeResource SimpleMenuFlyoutItemForegroundPointerOver}" />
										<Setter Target="SubItemChevron.Foreground" Value="{ThemeResource SimpleMenuFlyoutItemIconForegroundPointerOver}" />
									</VisualState.Setters>
								</VisualState>

								<VisualState x:Name="Disabled">
									<VisualState.Setters>
										<Setter Target="TextBlock.Foreground" Value="{ThemeResource SimpleMenuFlyoutItemForegroundDisabled}" />
										<Setter Target="SubItemChevron.Foreground" Value="{ThemeResource SimpleMenuFlyoutItemIconForegroundDisabled}" />
									</VisualState.Setters>
								</VisualState>
							</VisualStateGroup>

							<VisualStateGroup x:Name="CheckPlaceholderStates">
								<VisualState x:Name="NoPlaceholder" />
								<VisualState x:Name="CheckPlaceholder" />
								<VisualState x:Name="IconPlaceholder">
									<VisualState.Setters>
										<Setter Target="IconRoot.Visibility" Value="Visible" />
									</VisualState.Setters>
								</VisualState>
								<VisualState x:Name="CheckAndIconPlaceholder">
									<VisualState.Setters>
										<Setter Target="IconRoot.Visibility" Value="Visible" />
									</VisualState.Setters>
								</VisualState>
							</VisualStateGroup>
						</VisualStateManager.VisualStateGroups>

						<Grid.ColumnDefinitions>
							<ColumnDefinition Width="Auto" />
							<ColumnDefinition Width="*" />
							<ColumnDefinition Width="Auto" />
						</Grid.ColumnDefinitions>

						<Viewbox x:Name="IconRoot"
								 Grid.Column="0"
								 Width="{StaticResource SimpleSizeSpace400}"
								 Height="{StaticResource SimpleSizeSpace400}"
								 Margin="{StaticResource SimpleMenuFlyoutItemIconMargin}"
								 HorizontalAlignment="Left"
								 VerticalAlignment="Center"
								 Visibility="Collapsed">
							<ContentPresenter x:Name="IconContent"
											  Content="{TemplateBinding Icon}"
											  Foreground="{ThemeResource SimpleMenuFlyoutItemIconForeground}" />
						</Viewbox>

						<TextBlock x:Name="TextBlock"
								   Grid.Column="1"
								   VerticalAlignment="Center"
								   Foreground="{TemplateBinding Foreground}"
								   Text="{TemplateBinding Text}"
								   TextTrimming="CharacterEllipsis" />

						<!-- Chevron for submenu -->
						<FontIcon x:Name="SubItemChevron"
								  Grid.Column="2"
								  Glyph="&#xE76C;"
								  FontSize="{ThemeResource SimpleCaptionFontSize}"
								  Foreground="{ThemeResource SimpleMenuFlyoutItemIconForeground}"
								  Margin="{StaticResource SimpleMenuFlyoutItemAcceleratorMargin}"
								  VerticalAlignment="Center" />
					</Grid>
				</ControlTemplate>
			</Setter.Value>
		</Setter>
	</Style>

	<!-- ═══════════════════════════════════════════════════════════════════════ -->
	<!-- MenuFlyoutSeparator Style                                              -->
	<!-- ═══════════════════════════════════════════════════════════════════════ -->
	<Style x:Key="SimpleMenuFlyoutSeparatorStyle"
		   TargetType="MenuFlyoutSeparator">

		<Setter Property="Background" Value="{ThemeResource SimpleMenuFlyoutSeparatorBackground}" />
		<Setter Property="Padding" Value="{StaticResource SimpleMenuFlyoutSeparatorPadding}" />

		<Setter Property="Template">
			<Setter.Value>
				<ControlTemplate TargetType="MenuFlyoutSeparator">
					<Rectangle Fill="{TemplateBinding Background}"
							   Margin="{TemplateBinding Padding}"
							   Height="{StaticResource SimpleMenuFlyoutSeparatorHeight}" />
				</ControlTemplate>
			</Setter.Value>
		</Setter>
	</Style>

	<!-- ═══════════════════════════════════════════════════════════════════════ -->
	<!-- Default aliases                                                        -->
	<!-- ═══════════════════════════════════════════════════════════════════════ -->
	<Style x:Key="SimpleDefaultMenuFlyoutPresenterStyle"
		   TargetType="MenuFlyoutPresenter"
		   BasedOn="{StaticResource SimpleMenuFlyoutPresenterStyle}" />

	<Style x:Key="SimpleDefaultMenuFlyoutItemStyle"
		   TargetType="MenuFlyoutItem"
		   BasedOn="{StaticResource SimpleMenuFlyoutItemStyle}" />

	<Style x:Key="SimpleDefaultToggleMenuFlyoutItemStyle"
		   TargetType="ToggleMenuFlyoutItem"
		   BasedOn="{StaticResource SimpleToggleMenuFlyoutItemStyle}" />

	<Style x:Key="SimpleDefaultMenuFlyoutSubItemStyle"
		   TargetType="MenuFlyoutSubItem"
		   BasedOn="{StaticResource SimpleMenuFlyoutSubItemStyle}" />

	<Style x:Key="SimpleDefaultMenuFlyoutSeparatorStyle"
		   TargetType="MenuFlyoutSeparator"
		   BasedOn="{StaticResource SimpleMenuFlyoutSeparatorStyle}" />

</ResourceDictionary>
