<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
					xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
					xmlns:muxc="using:Microsoft.UI.Xaml.Controls">

	<!--
		Simple Design System — NavigationView & NavigationViewItem Styles
		Left-rail / top-nav navigation consistent with Simple's layout and color tokens.
		Includes selection indicators, expand/collapse behavior, and compact/expanded modes.
		
		Uses the built-in WinUI NavigationView template and overrides its
		ThemeResource keys to apply Simple's design language.
		
		Resource layers:
		NavigationView*       = semantic keys (source of truth)
		SimpleNavigationView* = Simple-prefixed aliases → NavigationView*
	-->

	<ResourceDictionary.ThemeDictionaries>

		<!-- ─── Light Theme ─── -->
		<ResourceDictionary x:Key="Light">

			<!-- NavigationView pane & content -->
			<StaticResource x:Key="NavigationViewContentBackground" ResourceKey="SimpleBackgroundDefaultDefaultBrush" />
			<StaticResource x:Key="NavigationViewDefaultPaneBackground" ResourceKey="SimpleBackgroundDefaultDefaultBrush" />
			<StaticResource x:Key="NavigationViewExpandedPaneBackground" ResourceKey="SimpleBackgroundDefaultDefaultBrush" />

			<!-- NavigationView top pane -->
			<StaticResource x:Key="NavigationViewTopPaneBackground" ResourceKey="SimpleBackgroundDefaultDefaultBrush" />

			<!-- NavigationView buttons (hamburger, back, etc.) -->
			<StaticResource x:Key="NavigationViewButtonForeground" ResourceKey="SimpleIconDefaultDefaultBrush" />
			<StaticResource x:Key="NavigationViewButtonForegroundPointerOver" ResourceKey="SimpleIconDefaultDefaultBrush" />
			<StaticResource x:Key="NavigationViewButtonForegroundPressed" ResourceKey="SimpleIconDefaultDefaultBrush" />
			<StaticResource x:Key="NavigationViewButtonForegroundDisabled" ResourceKey="SimpleIconDisabledDefaultBrush" />
			<SolidColorBrush x:Key="NavigationViewButtonBackgroundPointerOver"
							 Color="Transparent" />
			<SolidColorBrush x:Key="NavigationViewButtonBackgroundPressed"
							 Color="Transparent" />
			<SolidColorBrush x:Key="NavigationViewButtonBackgroundDisabled"
							 Color="Transparent" />

			<!-- Item — Normal -->
			<StaticResource x:Key="NavigationViewItemForeground" ResourceKey="SimpleTextDefaultDefaultBrush" />
			<SolidColorBrush x:Key="NavigationViewItemBackground"
							 Color="Transparent" />

			<!-- Item — PointerOver -->
			<StaticResource x:Key="NavigationViewItemForegroundPointerOver" ResourceKey="SimpleTextDefaultDefaultBrush" />
			<StaticResource x:Key="NavigationViewItemBackgroundPointerOver" ResourceKey="SimpleBackgroundDefaultSecondaryHoverBrush" />

			<!-- Item — Pressed -->
			<StaticResource x:Key="NavigationViewItemForegroundPressed" ResourceKey="SimpleTextDefaultDefaultBrush" />
			<StaticResource x:Key="NavigationViewItemBackgroundPressed" ResourceKey="SimpleBackgroundDefaultSecondaryPressedBrush" />

			<!-- Item — Selected -->
			<StaticResource x:Key="NavigationViewItemForegroundSelected" ResourceKey="SimpleTextBrandDefaultBrush" />
			<StaticResource x:Key="NavigationViewItemBackgroundSelected" ResourceKey="SimpleBackgroundBrandSecondaryBrush" />

			<!-- Item — Selected + PointerOver -->
			<StaticResource x:Key="NavigationViewItemForegroundSelectedPointerOver" ResourceKey="SimpleTextBrandDefaultBrush" />
			<StaticResource x:Key="NavigationViewItemBackgroundSelectedPointerOver" ResourceKey="SimpleBackgroundBrandSecondaryBrush" />

			<!-- Item — Selected + Pressed -->
			<StaticResource x:Key="NavigationViewItemForegroundSelectedPressed" ResourceKey="SimpleTextBrandDefaultBrush" />
			<StaticResource x:Key="NavigationViewItemBackgroundSelectedPressed" ResourceKey="SimpleBackgroundBrandSecondaryBrush" />

			<!-- Item — Disabled -->
			<StaticResource x:Key="NavigationViewItemForegroundDisabled" ResourceKey="SimpleTextDisabledDefaultBrush" />
			<SolidColorBrush x:Key="NavigationViewItemBackgroundDisabled"
							 Color="Transparent" />

			<!-- Selection indicator -->
			<StaticResource x:Key="NavigationViewSelectionIndicatorForeground" ResourceKey="SimpleBackgroundBrandDefaultBrush" />

			<!-- Item separator -->
			<StaticResource x:Key="NavigationViewItemSeparatorForeground" ResourceKey="SimpleBorderDefaultDefaultBrush" />

			<!-- Top navigation item text -->
			<StaticResource x:Key="TopNavigationViewItemForeground" ResourceKey="SimpleTextDefaultDefaultBrush" />
			<StaticResource x:Key="TopNavigationViewItemForegroundPointerOver" ResourceKey="SimpleTextDefaultDefaultBrush" />
			<StaticResource x:Key="TopNavigationViewItemForegroundPressed" ResourceKey="SimpleTextDefaultDefaultBrush" />
			<StaticResource x:Key="TopNavigationViewItemForegroundSelected" ResourceKey="SimpleTextBrandDefaultBrush" />
			<StaticResource x:Key="TopNavigationViewItemForegroundDisabled" ResourceKey="SimpleTextDisabledDefaultBrush" />

			<!-- Backwards-compat aliases -->
		</ResourceDictionary>

		<!-- ─── Dark Theme (Default) ─── -->
		<ResourceDictionary x:Key="Default">

			<StaticResource x:Key="NavigationViewContentBackground" ResourceKey="SimpleBackgroundDefaultDefaultBrush" />
			<StaticResource x:Key="NavigationViewDefaultPaneBackground" ResourceKey="SimpleBackgroundDefaultDefaultBrush" />
			<StaticResource x:Key="NavigationViewExpandedPaneBackground" ResourceKey="SimpleBackgroundDefaultDefaultBrush" />

			<StaticResource x:Key="NavigationViewTopPaneBackground" ResourceKey="SimpleBackgroundDefaultDefaultBrush" />

			<StaticResource x:Key="NavigationViewButtonForeground" ResourceKey="SimpleIconDefaultDefaultBrush" />
			<StaticResource x:Key="NavigationViewButtonForegroundPointerOver" ResourceKey="SimpleIconDefaultDefaultBrush" />
			<StaticResource x:Key="NavigationViewButtonForegroundPressed" ResourceKey="SimpleIconDefaultDefaultBrush" />
			<StaticResource x:Key="NavigationViewButtonForegroundDisabled" ResourceKey="SimpleIconDisabledDefaultBrush" />
			<SolidColorBrush x:Key="NavigationViewButtonBackgroundPointerOver"
							 Color="Transparent" />
			<SolidColorBrush x:Key="NavigationViewButtonBackgroundPressed"
							 Color="Transparent" />
			<SolidColorBrush x:Key="NavigationViewButtonBackgroundDisabled"
							 Color="Transparent" />

			<StaticResource x:Key="NavigationViewItemForeground" ResourceKey="SimpleTextDefaultDefaultBrush" />
			<SolidColorBrush x:Key="NavigationViewItemBackground"
							 Color="Transparent" />

			<StaticResource x:Key="NavigationViewItemForegroundPointerOver" ResourceKey="SimpleTextDefaultDefaultBrush" />
			<StaticResource x:Key="NavigationViewItemBackgroundPointerOver" ResourceKey="SimpleBackgroundDefaultSecondaryHoverBrush" />

			<StaticResource x:Key="NavigationViewItemForegroundPressed" ResourceKey="SimpleTextDefaultDefaultBrush" />
			<StaticResource x:Key="NavigationViewItemBackgroundPressed" ResourceKey="SimpleBackgroundDefaultSecondaryPressedBrush" />

			<StaticResource x:Key="NavigationViewItemForegroundSelected" ResourceKey="SimpleTextBrandDefaultBrush" />
			<StaticResource x:Key="NavigationViewItemBackgroundSelected" ResourceKey="SimpleBackgroundBrandSecondaryBrush" />

			<StaticResource x:Key="NavigationViewItemForegroundSelectedPointerOver" ResourceKey="SimpleTextBrandDefaultBrush" />
			<StaticResource x:Key="NavigationViewItemBackgroundSelectedPointerOver" ResourceKey="SimpleBackgroundBrandSecondaryBrush" />

			<StaticResource x:Key="NavigationViewItemForegroundSelectedPressed" ResourceKey="SimpleTextBrandDefaultBrush" />
			<StaticResource x:Key="NavigationViewItemBackgroundSelectedPressed" ResourceKey="SimpleBackgroundBrandSecondaryBrush" />

			<StaticResource x:Key="NavigationViewItemForegroundDisabled" ResourceKey="SimpleTextDisabledDefaultBrush" />
			<SolidColorBrush x:Key="NavigationViewItemBackgroundDisabled"
							 Color="Transparent" />

			<StaticResource x:Key="NavigationViewSelectionIndicatorForeground" ResourceKey="SimpleBackgroundBrandDefaultBrush" />

			<StaticResource x:Key="NavigationViewItemSeparatorForeground" ResourceKey="SimpleBorderDefaultDefaultBrush" />

			<StaticResource x:Key="TopNavigationViewItemForeground" ResourceKey="SimpleTextDefaultDefaultBrush" />
			<StaticResource x:Key="TopNavigationViewItemForegroundPointerOver" ResourceKey="SimpleTextDefaultDefaultBrush" />
			<StaticResource x:Key="TopNavigationViewItemForegroundPressed" ResourceKey="SimpleTextDefaultDefaultBrush" />
			<StaticResource x:Key="TopNavigationViewItemForegroundSelected" ResourceKey="SimpleTextBrandDefaultBrush" />
			<StaticResource x:Key="TopNavigationViewItemForegroundDisabled" ResourceKey="SimpleTextDisabledDefaultBrush" />

		</ResourceDictionary>

	</ResourceDictionary.ThemeDictionaries>

	<!-- ═══════════════════════════════════════════════════════════════════════ -->
	<!-- NavigationView Style -->
	<!-- ═══════════════════════════════════════════════════════════════════════ -->
	<Style x:Key="SimpleNavigationViewStyle"
		   TargetType="muxc:NavigationView">
		<Setter Property="Background" Value="{ThemeResource NavigationViewContentBackground}" />
	</Style>

	<!-- ═══════════════════════════════════════════════════════════════════════ -->
	<!-- NavigationViewItem Style -->
	<!-- ═══════════════════════════════════════════════════════════════════════ -->
	<Style x:Key="SimpleNavigationViewItemStyle"
		   TargetType="muxc:NavigationViewItem">
		<Setter Property="Foreground" Value="{ThemeResource NavigationViewItemForeground}" />
	</Style>

	<!-- ═══════════════════════════════════════════════════════════════════════ -->
	<!-- Default aliases -->
	<!-- ═══════════════════════════════════════════════════════════════════════ -->
	<Style x:Key="SimpleDefaultNavigationViewStyle"
		   TargetType="muxc:NavigationView"
		   BasedOn="{StaticResource SimpleNavigationViewStyle}" />

	<Style x:Key="SimpleDefaultNavigationViewItemStyle"
		   TargetType="muxc:NavigationViewItem"
		   BasedOn="{StaticResource SimpleNavigationViewItemStyle}" />

</ResourceDictionary>
