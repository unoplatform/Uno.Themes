			<StaticResource x:Key="TextToggleButtonBackgroundDisabled" ResourceKey="SimpleBackgroundDisabledDefaultBrush" />
			<StaticResource x:Key="TextToggleButtonBorderBrush" ResourceKey="SimpleBorderDefaultDefaultBrush" />
			<StaticResource x:Key="TextToggleButtonBorderBrushPointerOver" ResourceKey="SimpleBorderDefaultDefaultBrush" />
			<StaticResource x:Key="TextToggleButtonBorderBrushPressed" ResourceKey="SimpleBorderDefaultDefaultBrush" />
			<StaticResource x:Key="TextToggleButtonBorderBrushDisabled" ResourceKey="SimpleBorderDisabledDefaultBrush" />

			<!-- Checked -->
			<StaticResource x:Key="TextToggleButtonForegroundChecked" ResourceKey="SimpleTextBrandOnBrandBrush" />
			<StaticResource x:Key="TextToggleButtonForegroundCheckedPointerOver" ResourceKey="SimpleTextBrandOnBrandBrush" />
			<StaticResource x:Key="TextToggleButtonForegroundCheckedPressed" ResourceKey="SimpleTextBrandOnBrandBrush" />
			<StaticResource x:Key="TextToggleButtonForegroundCheckedDisabled" ResourceKey="SimpleTextDisabledDefaultBrush" />
			<StaticResource x:Key="TextToggleButtonBackgroundChecked" ResourceKey="SimpleBackgroundBrandDefaultBrush" />
			<StaticResource x:Key="TextToggleButtonBackgroundCheckedPointerOver" ResourceKey="SimpleBackgroundBrandHoverBrush" />
			<StaticResource x:Key="TextToggleButtonBackgroundCheckedPressed" ResourceKey="SimpleBackgroundBrandPressedBrush" />
			<StaticResource x:Key="TextToggleButtonBackgroundCheckedDisabled" ResourceKey="SimpleBackgroundDisabledDefaultBrush" />
			<StaticResource x:Key="TextToggleButtonBorderBrushChecked" ResourceKey="SimpleBorderBrandDefaultBrush" />
			<StaticResource x:Key="TextToggleButtonBorderBrushCheckedPointerOver" ResourceKey="SimpleBorderBrandDefaultBrush" />
			<StaticResource x:Key="TextToggleButtonBorderBrushCheckedPressed" ResourceKey="SimpleBorderBrandDefaultBrush" />
			<StaticResource x:Key="TextToggleButtonBorderBrushCheckedDisabled" ResourceKey="SimpleBorderDisabledDefaultBrush" />

			<!-- Indeterminate (same as Unchecked) -->
			<StaticResource x:Key="TextToggleButtonForegroundIndeterminate" ResourceKey="SimpleTextDefaultDefaultBrush" />
			<StaticResource x:Key="TextToggleButtonForegroundIndeterminatePointerOver" ResourceKey="SimpleTextDefaultDefaultBrush" />
			<StaticResource x:Key="TextToggleButtonForegroundIndeterminatePressed" ResourceKey="SimpleTextDefaultDefaultBrush" />
			<StaticResource x:Key="TextToggleButtonForegroundIndeterminateDisabled" ResourceKey="SimpleTextDisabledDefaultBrush" />
			<StaticResource x:Key="TextToggleButtonBackgroundIndeterminate" ResourceKey="SimpleBackgroundDefaultSecondaryBrush" />
			<StaticResource x:Key="TextToggleButtonBackgroundIndeterminatePointerOver" ResourceKey="SimpleBackgroundDefaultSecondaryHoverBrush" />
			<StaticResource x:Key="TextToggleButtonBackgroundIndeterminatePressed" ResourceKey="SimpleBackgroundDefaultSecondaryPressedBrush" />
			<StaticResource x:Key="TextToggleButtonBackgroundIndeterminateDisabled" ResourceKey="SimpleBackgroundDisabledDefaultBrush" />
			<StaticResource x:Key="TextToggleButtonBorderBrushIndeterminate" ResourceKey="SimpleBorderDefaultDefaultBrush" />
			<StaticResource x:Key="TextToggleButtonBorderBrushIndeterminatePointerOver" ResourceKey="SimpleBorderDefaultDefaultBrush" />
			<StaticResource x:Key="TextToggleButtonBorderBrushIndeterminatePressed" ResourceKey="SimpleBorderDefaultDefaultBrush" />
			<StaticResource x:Key="TextToggleButtonBorderBrushIndeterminateDisabled" ResourceKey="SimpleBorderDisabledDefaultBrush" />

			<!-- Backwards-compat aliases (SimpleToggleButton* → TextToggleButton*) -->
			<!-- Unchecked -->
			<StaticResource x:Key="SimpleToggleButtonForeground" ResourceKey="TextToggleButtonForeground" />
			<StaticResource x:Key="SimpleToggleButtonForegroundPointerOver" ResourceKey="TextToggleButtonForegroundPointerOver" />
			<StaticResource x:Key="SimpleToggleButtonForegroundPressed" ResourceKey="TextToggleButtonForegroundPressed" />
			<StaticResource x:Key="SimpleToggleButtonForegroundDisabled" ResourceKey="TextToggleButtonForegroundDisabled" />
			<StaticResource x:Key="SimpleToggleButtonBackground" ResourceKey="TextToggleButtonBackground" />
			<StaticResource x:Key="SimpleToggleButtonBackgroundPointerOver" ResourceKey="TextToggleButtonBackgroundPointerOver" />
			<StaticResource x:Key="SimpleToggleButtonBackgroundPressed" ResourceKey="TextToggleButtonBackgroundPressed" />
			<StaticResource x:Key="SimpleToggleButtonBackgroundDisabled" ResourceKey="TextToggleButtonBackgroundDisabled" />
			<StaticResource x:Key="SimpleToggleButtonBorderBrush" ResourceKey="TextToggleButtonBorderBrush" />
			<StaticResource x:Key="SimpleToggleButtonBorderBrushPointerOver" ResourceKey="TextToggleButtonBorderBrushPointerOver" />
			<StaticResource x:Key="SimpleToggleButtonBorderBrushPressed" ResourceKey="TextToggleButtonBorderBrushPressed" />
			<StaticResource x:Key="SimpleToggleButtonBorderBrushDisabled" ResourceKey="TextToggleButtonBorderBrushDisabled" />
			<!-- Checked -->
			<StaticResource x:Key="SimpleToggleButtonForegroundChecked" ResourceKey="TextToggleButtonForegroundChecked" />
			<StaticResource x:Key="SimpleToggleButtonForegroundCheckedPointerOver" ResourceKey="TextToggleButtonForegroundCheckedPointerOver" />
			<StaticResource x:Key="SimpleToggleButtonForegroundCheckedPressed" ResourceKey="TextToggleButtonForegroundCheckedPressed" />
			<StaticResource x:Key="SimpleToggleButtonForegroundCheckedDisabled" ResourceKey="TextToggleButtonForegroundCheckedDisabled" />
			<StaticResource x:Key="SimpleToggleButtonBackgroundChecked" ResourceKey="TextToggleButtonBackgroundChecked" />
			<StaticResource x:Key="SimpleToggleButtonBackgroundCheckedPointerOver" ResourceKey="TextToggleButtonBackgroundCheckedPointerOver" />
			<StaticResource x:Key="SimpleToggleButtonBackgroundCheckedPressed" ResourceKey="TextToggleButtonBackgroundCheckedPressed" />
			<StaticResource x:Key="SimpleToggleButtonBackgroundCheckedDisabled" ResourceKey="TextToggleButtonBackgroundCheckedDisabled" />
			<StaticResource x:Key="SimpleToggleButtonBorderBrushChecked" ResourceKey="TextToggleButtonBorderBrushChecked" />
			<StaticResource x:Key="SimpleToggleButtonBorderBrushCheckedPointerOver" ResourceKey="TextToggleButtonBorderBrushCheckedPointerOver" />
			<StaticResource x:Key="SimpleToggleButtonBorderBrushCheckedPressed" ResourceKey="TextToggleButtonBorderBrushCheckedPressed" />
			<StaticResource x:Key="SimpleToggleButtonBorderBrushCheckedDisabled" ResourceKey="TextToggleButtonBorderBrushCheckedDisabled" />
			<!-- Indeterminate -->
			<StaticResource x:Key="SimpleToggleButtonForegroundIndeterminate" ResourceKey="TextToggleButtonForegroundIndeterminate" />
			<StaticResource x:Key="SimpleToggleButtonForegroundIndeterminatePointerOver" ResourceKey="TextToggleButtonForegroundIndeterminatePointerOver" />
			<StaticResource x:Key="SimpleToggleButtonForegroundIndeterminatePressed" ResourceKey="TextToggleButtonForegroundIndeterminatePressed" />
			<StaticResource x:Key="SimpleToggleButtonForegroundIndeterminateDisabled" ResourceKey="TextToggleButtonForegroundIndeterminateDisabled" />
			<StaticResource x:Key="SimpleToggleButtonBackgroundIndeterminate" ResourceKey="TextToggleButtonBackgroundIndeterminate" />
			<StaticResource x:Key="SimpleToggleButtonBackgroundIndeterminatePointerOver" ResourceKey="TextToggleButtonBackgroundIndeterminatePointerOver" />
			<StaticResource x:Key="SimpleToggleButtonBackgroundIndeterminatePressed" ResourceKey="TextToggleButtonBackgroundIndeterminatePressed" />
			<StaticResource x:Key="SimpleToggleButtonBackgroundIndeterminateDisabled" ResourceKey="TextToggleButtonBackgroundIndeterminateDisabled" />
			<StaticResource x:Key="SimpleToggleButtonBorderBrushIndeterminate" ResourceKey="TextToggleButtonBorderBrushIndeterminate" />
			<StaticResource x:Key="SimpleToggleButtonBorderBrushIndeterminatePointerOver" ResourceKey="TextToggleButtonBorderBrushIndeterminatePointerOver" />
			<StaticResource x:Key="SimpleToggleButtonBorderBrushIndeterminatePressed" ResourceKey="TextToggleButtonBorderBrushIndeterminatePressed" />
			<StaticResource x:Key="SimpleToggleButtonBorderBrushIndeterminateDisabled" ResourceKey="TextToggleButtonBorderBrushIndeterminateDisabled" />
		</ResourceDictionary>

	</ResourceDictionary.ThemeDictionaries>

	<!-- ═══════════════════════════════════════════════════════════════════════ -->
	<!-- Layout / sizing resources (theme-agnostic)                            -->
	<!-- Size-specific keys use explicit Small/Medium suffixes.                 -->
	<!-- Generic keys are defined in the SizeDefaults file loaded by            -->
	<!-- SimpleTheme based on DefaultSize.                                      -->
	<!-- ═══════════════════════════════════════════════════════════════════════ -->
	<StaticResource x:Key="SimpleToggleButtonCornerRadius" ResourceKey="SimpleRadius200CornerRadius" />     <!-- sds-size-radius-200 = 8 px -->
	<StaticResource x:Key="SimpleToggleButtonBorderThickness" ResourceKey="SimpleStrokeBorderThickness" />  <!-- sds-size-stroke-border = 1 px -->
	<StaticResource x:Key="SimpleToggleButtonMediumPadding" ResourceKey="SimpleSpace300Thickness" />        <!-- sds-size-space-300 = 12 px -->
	<StaticResource x:Key="SimpleToggleButtonSmallPadding" ResourceKey="SimpleSpace200Thickness" />         <!-- sds-size-space-200 = 8 px -->
	<StaticResource x:Key="SimpleToggleButtonMediumMinHeight" ResourceKey="SimpleIconLarge" />              <!-- sds-size-icon-large = 40 px -->
	<StaticResource x:Key="SimpleToggleButtonSmallMinHeight" ResourceKey="SimpleIconMedium" />              <!-- sds-size-icon-medium = 32 px -->
	<StaticResource x:Key="SimpleToggleButtonMediumFontSize" ResourceKey="SimpleTypographyScale03" />           <!-- sds-typography-scale-03 = 16 px -->
	<StaticResource x:Key="SimpleToggleButtonSmallFontSize" ResourceKey="SimpleTypographyScale02" />            <!-- sds-typography-scale-02 = 14 px -->
	<StaticResource x:Key="SimpleToggleButtonIconSpacing" ResourceKey="SimpleSpace200" />                   <!-- sds-size-space-200 = 8 px -->
	<FontFamily x:Key="SimpleToggleButtonFontFamily">Inter</FontFamily>

	<!-- ═══════════════════════════════════════════════════════════════════════ -->
	<!-- Default ToggleButton (Neutral unchecked → Primary checked)            -->
	<!-- ═══════════════════════════════════════════════════════════════════════ -->
	<Style x:Key="SimpleDefaultToggleButtonStyle" TargetType="ToggleButton">
		<Setter Property="FontFamily" Value="{StaticResource SimpleToggleButtonFontFamily}" />
		<Setter Property="FontSize" Value="{StaticResource SimpleToggleButtonFontSize}" />
		<Setter Property="FontWeight" Value="Normal" />
		<Setter Property="MinHeight" Value="{StaticResource SimpleToggleButtonMinHeight}" />
		<Setter Property="Padding" Value="{StaticResource SimpleToggleButtonPadding}" />
		<Setter Property="CornerRadius" Value="{StaticResource SimpleToggleButtonCornerRadius}" />
		<Setter Property="BorderThickness" Value="{StaticResource SimpleToggleButtonBorderThickness}" />
		<Setter Property="HorizontalAlignment" Value="Left" />
		<Setter Property="VerticalAlignment" Value="Center" />
		<Setter Property="HorizontalContentAlignment" Value="Center" />
		<Setter Property="VerticalContentAlignment" Value="Center" />
		<Setter Property="UseSystemFocusVisuals" Value="{StaticResource UseSystemFocusVisuals}" />
		<Setter Property="FocusVisualMargin" Value="-3" />
		<Setter Property="Foreground" Value="{ThemeResource SimpleToggleButtonForeground}" />
		<Setter Property="Background" Value="{ThemeResource SimpleToggleButtonBackground}" />
		<Setter Property="BorderBrush" Value="{ThemeResource SimpleToggleButtonBorderBrush}" />
		<Setter Property="Template">
			<Setter.Value>
				<ControlTemplate TargetType="ToggleButton">
					<Grid x:Name="Root"
						  Background="{TemplateBinding Background}"
						  BorderBrush="{TemplateBinding BorderBrush}"
						  BorderThickness="{TemplateBinding BorderThickness}"
						  CornerRadius="{TemplateBinding CornerRadius}"
						  Padding="{TemplateBinding Padding}"
						  AutomationProperties.AccessibilityView="Raw">

						<VisualStateManager.VisualStateGroups>
							<VisualStateGroup x:Name="CommonStates">

								<!-- Unchecked states -->
								<VisualState x:Name="Normal" />
								<VisualState x:Name="PointerOver">
									<VisualState.Setters>
										<Setter Target="Root.Background" Value="{ThemeResource SimpleToggleButtonBackgroundPointerOver}" />
										<Setter Target="Root.BorderBrush" Value="{ThemeResource SimpleToggleButtonBorderBrushPointerOver}" />
										<Setter Target="ContentPresenter.Foreground" Value="{ThemeResource SimpleToggleButtonForegroundPointerOver}" />
										<Setter Target="LeadingIconPresenter.Foreground" Value="{ThemeResource SimpleToggleButtonForegroundPointerOver}" />
										<Setter Target="TrailingIconPresenter.Foreground" Value="{ThemeResource SimpleToggleButtonForegroundPointerOver}" />
									</VisualState.Setters>
								</VisualState>
								<VisualState x:Name="Pressed">
									<VisualState.Setters>
										<Setter Target="Root.Background" Value="{ThemeResource SimpleToggleButtonBackgroundPressed}" />
										<Setter Target="Root.BorderBrush" Value="{ThemeResource SimpleToggleButtonBorderBrushPressed}" />
										<Setter Target="ContentPresenter.Foreground" Value="{ThemeResource SimpleToggleButtonForegroundPressed}" />
										<Setter Target="LeadingIconPresenter.Foreground" Value="{ThemeResource SimpleToggleButtonForegroundPressed}" />
										<Setter Target="TrailingIconPresenter.Foreground" Value="{ThemeResource SimpleToggleButtonForegroundPressed}" />
									</VisualState.Setters>
								</VisualState>
								<VisualState x:Name="Disabled">
									<VisualState.Setters>
										<Setter Target="Root.Background" Value="{ThemeResource SimpleToggleButtonBackgroundDisabled}" />
										<Setter Target="Root.BorderBrush" Value="{ThemeResource SimpleToggleButtonBorderBrushDisabled}" />
										<Setter Target="ContentPresenter.Foreground" Value="{ThemeResource SimpleToggleButtonForegroundDisabled}" />
										<Setter Target="LeadingIconPresenter.Foreground" Value="{ThemeResource SimpleToggleButtonForegroundDisabled}" />
										<Setter Target="TrailingIconPresenter.Foreground" Value="{ThemeResource SimpleToggleButtonForegroundDisabled}" />
									</VisualState.Setters>
								</VisualState>

								<!-- Checked states -->
								<VisualState x:Name="Checked">
									<VisualState.Setters>
										<Setter Target="Root.Background" Value="{ThemeResource SimpleToggleButtonBackgroundChecked}" />
										<Setter Target="Root.BorderBrush" Value="{ThemeResource SimpleToggleButtonBorderBrushChecked}" />
										<Setter Target="ContentPresenter.Foreground" Value="{ThemeResource SimpleToggleButtonForegroundChecked}" />
										<Setter Target="LeadingIconPresenter.Foreground" Value="{ThemeResource SimpleToggleButtonForegroundChecked}" />
										<Setter Target="TrailingIconPresenter.Foreground" Value="{ThemeResource SimpleToggleButtonForegroundChecked}" />
									</VisualState.Setters>
								</VisualState>
								<VisualState x:Name="CheckedPointerOver">
									<VisualState.Setters>
										<Setter Target="Root.Background" Value="{ThemeResource SimpleToggleButtonBackgroundCheckedPointerOver}" />
										<Setter Target="Root.BorderBrush" Value="{ThemeResource SimpleToggleButtonBorderBrushCheckedPointerOver}" />
										<Setter Target="ContentPresenter.Foreground" Value="{ThemeResource SimpleToggleButtonForegroundCheckedPointerOver}" />
										<Setter Target="LeadingIconPresenter.Foreground" Value="{ThemeResource SimpleToggleButtonForegroundCheckedPointerOver}" />
										<Setter Target="TrailingIconPresenter.Foreground" Value="{ThemeResource SimpleToggleButtonForegroundCheckedPointerOver}" />
									</VisualState.Setters>
								</VisualState>
								<VisualState x:Name="CheckedPressed">
									<VisualState.Setters>
										<Setter Target="Root.Background" Value="{ThemeResource SimpleToggleButtonBackgroundCheckedPressed}" />
										<Setter Target="Root.BorderBrush" Value="{ThemeResource SimpleToggleButtonBorderBrushCheckedPressed}" />
										<Setter Target="ContentPresenter.Foreground" Value="{ThemeResource SimpleToggleButtonForegroundCheckedPressed}" />
										<Setter Target="LeadingIconPresenter.Foreground" Value="{ThemeResource SimpleToggleButtonForegroundCheckedPressed}" />
										<Setter Target="TrailingIconPresenter.Foreground" Value="{ThemeResource SimpleToggleButtonForegroundCheckedPressed}" />
									</VisualState.Setters>
								</VisualState>
								<VisualState x:Name="CheckedDisabled">
									<VisualState.Setters>
										<Setter Target="Root.Background" Value="{ThemeResource SimpleToggleButtonBackgroundCheckedDisabled}" />
										<Setter Target="Root.BorderBrush" Value="{ThemeResource SimpleToggleButtonBorderBrushCheckedDisabled}" />
										<Setter Target="ContentPresenter.Foreground" Value="{ThemeResource SimpleToggleButtonForegroundCheckedDisabled}" />
										<Setter Target="LeadingIconPresenter.Foreground" Value="{ThemeResource SimpleToggleButtonForegroundCheckedDisabled}" />
										<Setter Target="TrailingIconPresenter.Foreground" Value="{ThemeResource SimpleToggleButtonForegroundCheckedDisabled}" />
									</VisualState.Setters>
								</VisualState>

								<!-- Indeterminate states -->
								<VisualState x:Name="IndeterminateNormal">
									<VisualState.Setters>
										<Setter Target="Root.Background" Value="{ThemeResource SimpleToggleButtonBackgroundIndeterminate}" />
										<Setter Target="Root.BorderBrush" Value="{ThemeResource SimpleToggleButtonBorderBrushIndeterminate}" />
										<Setter Target="ContentPresenter.Foreground" Value="{ThemeResource SimpleToggleButtonForegroundIndeterminate}" />
										<Setter Target="LeadingIconPresenter.Foreground" Value="{ThemeResource SimpleToggleButtonForegroundIndeterminate}" />
										<Setter Target="TrailingIconPresenter.Foreground" Value="{ThemeResource SimpleToggleButtonForegroundIndeterminate}" />
									</VisualState.Setters>
								</VisualState>
								<VisualState x:Name="IndeterminatePointerOver">
									<VisualState.Setters>
										<Setter Target="Root.Background" Value="{ThemeResource SimpleToggleButtonBackgroundIndeterminatePointerOver}" />
										<Setter Target="Root.BorderBrush" Value="{ThemeResource SimpleToggleButtonBorderBrushIndeterminatePointerOver}" />
										<Setter Target="ContentPresenter.Foreground" Value="{ThemeResource SimpleToggleButtonForegroundIndeterminatePointerOver}" />
										<Setter Target="LeadingIconPresenter.Foreground" Value="{ThemeResource SimpleToggleButtonForegroundIndeterminatePointerOver}" />
										<Setter Target="TrailingIconPresenter.Foreground" Value="{ThemeResource SimpleToggleButtonForegroundIndeterminatePointerOver}" />
									</VisualState.Setters>
								</VisualState>
								<VisualState x:Name="IndeterminatePressed">
									<VisualState.Setters>
										<Setter Target="Root.Background" Value="{ThemeResource SimpleToggleButtonBackgroundIndeterminatePressed}" />
										<Setter Target="Root.BorderBrush" Value="{ThemeResource SimpleToggleButtonBorderBrushIndeterminatePressed}" />
										<Setter Target="ContentPresenter.Foreground" Value="{ThemeResource SimpleToggleButtonForegroundIndeterminatePressed}" />
										<Setter Target="LeadingIconPresenter.Foreground" Value="{ThemeResource SimpleToggleButtonForegroundIndeterminatePressed}" />
										<Setter Target="TrailingIconPresenter.Foreground" Value="{ThemeResource SimpleToggleButtonForegroundIndeterminatePressed}" />
									</VisualState.Setters>
								</VisualState>
								<VisualState x:Name="IndeterminateDisabled">
									<VisualState.Setters>
										<Setter Target="Root.Background" Value="{ThemeResource SimpleToggleButtonBackgroundIndeterminateDisabled}" />
										<Setter Target="Root.BorderBrush" Value="{ThemeResource SimpleToggleButtonBorderBrushIndeterminateDisabled}" />
										<Setter Target="ContentPresenter.Foreground" Value="{ThemeResource SimpleToggleButtonForegroundIndeterminateDisabled}" />
										<Setter Target="LeadingIconPresenter.Foreground" Value="{ThemeResource SimpleToggleButtonForegroundIndeterminateDisabled}" />
										<Setter Target="TrailingIconPresenter.Foreground" Value="{ThemeResource SimpleToggleButtonForegroundIndeterminateDisabled}" />
									</VisualState.Setters>
								</VisualState>
							</VisualStateGroup>
						</VisualStateManager.VisualStateGroups>

						<StackPanel Orientation="Horizontal"
									HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
									VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
									Spacing="{StaticResource SimpleToggleButtonIconSpacing}">

							<ContentPresenter x:Name="LeadingIconPresenter"
											  Content="{Binding Path=(ut:ControlExtensions.LeadingIcon), RelativeSource={RelativeSource TemplatedParent}}"
											  Foreground="{TemplateBinding Foreground}"
											  Visibility="{Binding Path=(ut:ControlExtensions.LeadingIcon), RelativeSource={RelativeSource TemplatedParent}, Converter={StaticResource NullToCollapsedConverter}, FallbackValue=Collapsed, TargetNullValue=Collapsed}"
											  VerticalAlignment="Center" />

							<ContentPresenter x:Name="ContentPresenter"
											  Content="{TemplateBinding Content}"
											  ContentTemplate="{TemplateBinding ContentTemplate}"
											  ContentTransitions="{TemplateBinding ContentTransitions}"
											  Foreground="{TemplateBinding Foreground}"
											  HorizontalContentAlignment="{TemplateBinding HorizontalContentAlignment}"
											  VerticalContentAlignment="{TemplateBinding VerticalContentAlignment}" />

							<ContentPresenter x:Name="TrailingIconPresenter"
											  Content="{Binding Path=(ut:ControlExtensions.TrailingIcon), RelativeSource={RelativeSource TemplatedParent}}"
											  Foreground="{TemplateBinding Foreground}"
											  Visibility="{Binding Path=(ut:ControlExtensions.TrailingIcon), RelativeSource={RelativeSource TemplatedParent}, Converter={StaticResource NullToCollapsedConverter}, FallbackValue=Collapsed, TargetNullValue=Collapsed}"
											  VerticalAlignment="Center" />
						</StackPanel>
					</Grid>
				</ControlTemplate>
			</Setter.Value>
		</Setter>
	</Style>

	<!-- ═══════════════════════════════════════════════════════════════════════ -->
	<!-- Small size variant                                                    -->
	<!-- ═══════════════════════════════════════════════════════════════════════ -->
	<Style x:Key="SimpleSmallToggleButtonStyle" TargetType="ToggleButton" BasedOn="{StaticResource SimpleDefaultToggleButtonStyle}">
		<Setter Property="MinHeight" Value="{StaticResource SimpleToggleButtonSmallMinHeight}" />
		<Setter Property="Padding" Value="{StaticResource SimpleToggleButtonSmallPadding}" />
		<Setter Property="FontSize" Value="{StaticResource SimpleToggleButtonSmallFontSize}" />
	</Style>

	<!-- ═══════════════════════════════════════════════════════════════════════ -->
	<!-- Medium size variant                                                   -->
	<!-- ═══════════════════════════════════════════════════════════════════════ -->
	<Style x:Key="SimpleMediumToggleButtonStyle" TargetType="ToggleButton" BasedOn="{StaticResource SimpleDefaultToggleButtonStyle}">
