<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
					xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
					xmlns:ut="using:Uno.Themes">

	<!--
		Simple Design System — ToggleButton Styles
		Lightweight styling pattern: every visual-state brush is exposed via ThemeResource
		so consumers can override any individual key.
		
		Templates reference Simple-prefixed keys (SimpleToggleButton*) which alias
		to the semantic keys (TextToggleButton*).  Consumers can override EITHER key.
		
		Backwards-compat aliases are provided for all old Simple-prefixed names.
		
		Default style: Neutral (unchecked) → Primary (checked)
		VisualStates: Normal, PointerOver, Pressed, Disabled,
		Checked, CheckedPointerOver, CheckedPressed, CheckedDisabled,
		Indeterminate*
	-->

	<!-- ═══════════════════════════════════════════════════════════════════════ -->
	<!-- Lightweight styling ThemeResource aliases -->
	<!-- ═══════════════════════════════════════════════════════════════════════ -->
	<ResourceDictionary.ThemeDictionaries>

		<!-- ─── Light Theme ─── -->
		<ResourceDictionary x:Key="Light">

			<!-- ── TextToggleButton — semantic keys (source of truth) ── -->

			<!-- Unchecked -->
			<StaticResource x:Key="TextToggleButtonForeground" ResourceKey="OnSurfaceBrush" />
			<StaticResource x:Key="TextToggleButtonForegroundPointerOver" ResourceKey="OnSurfaceBrush" />
			<StaticResource x:Key="TextToggleButtonForegroundPressed" ResourceKey="OnSurfaceBrush" />
			<StaticResource x:Key="TextToggleButtonForegroundDisabled" ResourceKey="OnSurfaceDisabledBrush" />
			<StaticResource x:Key="TextToggleButtonBackground" ResourceKey="SurfaceVariantBrush" />
			<StaticResource x:Key="TextToggleButtonBackgroundPointerOver" ResourceKey="PrimaryContainerBrush" />
			<StaticResource x:Key="TextToggleButtonBackgroundPressed" ResourceKey="TertiaryContainerBrush" />
			<StaticResource x:Key="TextToggleButtonBackgroundDisabled" ResourceKey="OnSurfaceDisabledBrush" />
			<StaticResource x:Key="TextToggleButtonBorderBrush" ResourceKey="OutlineBrush" />
			<StaticResource x:Key="TextToggleButtonBorderBrushPointerOver" ResourceKey="OutlineBrush" />
			<StaticResource x:Key="TextToggleButtonBorderBrushPressed" ResourceKey="OutlineBrush" />
			<StaticResource x:Key="TextToggleButtonBorderBrushDisabled" ResourceKey="OutlineDisabledBrush" />

			<!-- Checked -->
			<StaticResource x:Key="TextToggleButtonForegroundChecked" ResourceKey="OnPrimaryBrush" />
			<StaticResource x:Key="TextToggleButtonForegroundCheckedPointerOver" ResourceKey="OnPrimaryBrush" />
			<StaticResource x:Key="TextToggleButtonForegroundCheckedPressed" ResourceKey="OnPrimaryBrush" />
			<StaticResource x:Key="TextToggleButtonForegroundCheckedDisabled" ResourceKey="OnSurfaceDisabledBrush" />
			<StaticResource x:Key="TextToggleButtonBackgroundChecked" ResourceKey="PrimaryBrush" />
			<StaticResource x:Key="TextToggleButtonBackgroundCheckedPointerOver" ResourceKey="PrimaryVariantDarkBrush" />
			<StaticResource x:Key="TextToggleButtonBackgroundCheckedPressed" ResourceKey="PrimaryVariantDarkBrush" />
			<StaticResource x:Key="TextToggleButtonBackgroundCheckedDisabled" ResourceKey="OnSurfaceDisabledBrush" />
			<StaticResource x:Key="TextToggleButtonBorderBrushChecked" ResourceKey="PrimaryBrush" />
			<StaticResource x:Key="TextToggleButtonBorderBrushCheckedPointerOver" ResourceKey="PrimaryBrush" />
			<StaticResource x:Key="TextToggleButtonBorderBrushCheckedPressed" ResourceKey="PrimaryBrush" />
			<StaticResource x:Key="TextToggleButtonBorderBrushCheckedDisabled" ResourceKey="OutlineDisabledBrush" />

			<!-- Indeterminate (same as Unchecked) -->
			<StaticResource x:Key="TextToggleButtonForegroundIndeterminate" ResourceKey="OnSurfaceBrush" />
			<StaticResource x:Key="TextToggleButtonForegroundIndeterminatePointerOver" ResourceKey="OnSurfaceBrush" />
			<StaticResource x:Key="TextToggleButtonForegroundIndeterminatePressed" ResourceKey="OnSurfaceBrush" />
			<StaticResource x:Key="TextToggleButtonForegroundIndeterminateDisabled" ResourceKey="OnSurfaceDisabledBrush" />
			<StaticResource x:Key="TextToggleButtonBackgroundIndeterminate" ResourceKey="SurfaceVariantBrush" />
			<StaticResource x:Key="TextToggleButtonBackgroundIndeterminatePointerOver" ResourceKey="PrimaryContainerBrush" />
			<StaticResource x:Key="TextToggleButtonBackgroundIndeterminatePressed" ResourceKey="TertiaryContainerBrush" />
			<StaticResource x:Key="TextToggleButtonBackgroundIndeterminateDisabled" ResourceKey="OnSurfaceDisabledBrush" />
			<StaticResource x:Key="TextToggleButtonBorderBrushIndeterminate" ResourceKey="OutlineBrush" />
			<StaticResource x:Key="TextToggleButtonBorderBrushIndeterminatePointerOver" ResourceKey="OutlineBrush" />
			<StaticResource x:Key="TextToggleButtonBorderBrushIndeterminatePressed" ResourceKey="OutlineBrush" />
			<StaticResource x:Key="TextToggleButtonBorderBrushIndeterminateDisabled" ResourceKey="OutlineDisabledBrush" />

			<!-- Unchecked -->
			<!-- Checked -->
			<!-- Indeterminate -->
		</ResourceDictionary>

		<!-- ─── Dark Theme (Default) ─── -->
		<ResourceDictionary x:Key="Default">

			<!-- ── TextToggleButton — semantic keys (source of truth) ── -->

			<!-- Unchecked -->
			<StaticResource x:Key="TextToggleButtonForeground" ResourceKey="OnSurfaceBrush" />
			<StaticResource x:Key="TextToggleButtonForegroundPointerOver" ResourceKey="OnSurfaceBrush" />
			<StaticResource x:Key="TextToggleButtonForegroundPressed" ResourceKey="OnSurfaceBrush" />
			<StaticResource x:Key="TextToggleButtonForegroundDisabled" ResourceKey="OnSurfaceDisabledBrush" />
			<StaticResource x:Key="TextToggleButtonBackground" ResourceKey="SurfaceVariantBrush" />
			<StaticResource x:Key="TextToggleButtonBackgroundPointerOver" ResourceKey="PrimaryContainerBrush" />
			<StaticResource x:Key="TextToggleButtonBackgroundPressed" ResourceKey="TertiaryContainerBrush" />
			<StaticResource x:Key="TextToggleButtonBackgroundDisabled" ResourceKey="OnSurfaceDisabledBrush" />
			<StaticResource x:Key="TextToggleButtonBorderBrush" ResourceKey="OutlineBrush" />
			<StaticResource x:Key="TextToggleButtonBorderBrushPointerOver" ResourceKey="OutlineBrush" />
			<StaticResource x:Key="TextToggleButtonBorderBrushPressed" ResourceKey="OutlineBrush" />
			<StaticResource x:Key="TextToggleButtonBorderBrushDisabled" ResourceKey="OutlineDisabledBrush" />

			<!-- Checked -->
			<StaticResource x:Key="TextToggleButtonForegroundChecked" ResourceKey="OnPrimaryBrush" />
			<StaticResource x:Key="TextToggleButtonForegroundCheckedPointerOver" ResourceKey="OnPrimaryBrush" />
			<StaticResource x:Key="TextToggleButtonForegroundCheckedPressed" ResourceKey="OnPrimaryBrush" />
			<StaticResource x:Key="TextToggleButtonForegroundCheckedDisabled" ResourceKey="OnSurfaceDisabledBrush" />
			<StaticResource x:Key="TextToggleButtonBackgroundChecked" ResourceKey="PrimaryBrush" />
			<StaticResource x:Key="TextToggleButtonBackgroundCheckedPointerOver" ResourceKey="PrimaryVariantDarkBrush" />
			<StaticResource x:Key="TextToggleButtonBackgroundCheckedPressed" ResourceKey="PrimaryVariantDarkBrush" />
			<StaticResource x:Key="TextToggleButtonBackgroundCheckedDisabled" ResourceKey="OnSurfaceDisabledBrush" />
			<StaticResource x:Key="TextToggleButtonBorderBrushChecked" ResourceKey="PrimaryBrush" />
			<StaticResource x:Key="TextToggleButtonBorderBrushCheckedPointerOver" ResourceKey="PrimaryBrush" />
			<StaticResource x:Key="TextToggleButtonBorderBrushCheckedPressed" ResourceKey="PrimaryBrush" />
			<StaticResource x:Key="TextToggleButtonBorderBrushCheckedDisabled" ResourceKey="OutlineDisabledBrush" />

			<!-- Indeterminate (same as Unchecked) -->
			<StaticResource x:Key="TextToggleButtonForegroundIndeterminate" ResourceKey="OnSurfaceBrush" />
			<StaticResource x:Key="TextToggleButtonForegroundIndeterminatePointerOver" ResourceKey="OnSurfaceBrush" />
			<StaticResource x:Key="TextToggleButtonForegroundIndeterminatePressed" ResourceKey="OnSurfaceBrush" />
			<StaticResource x:Key="TextToggleButtonForegroundIndeterminateDisabled" ResourceKey="OnSurfaceDisabledBrush" />
			<StaticResource x:Key="TextToggleButtonBackgroundIndeterminate" ResourceKey="SurfaceVariantBrush" />
			<StaticResource x:Key="TextToggleButtonBackgroundIndeterminatePointerOver" ResourceKey="PrimaryContainerBrush" />
			<StaticResource x:Key="TextToggleButtonBackgroundIndeterminatePressed" ResourceKey="TertiaryContainerBrush" />
			<StaticResource x:Key="TextToggleButtonBackgroundIndeterminateDisabled" ResourceKey="OnSurfaceDisabledBrush" />
			<StaticResource x:Key="TextToggleButtonBorderBrushIndeterminate" ResourceKey="OutlineBrush" />
			<StaticResource x:Key="TextToggleButtonBorderBrushIndeterminatePointerOver" ResourceKey="OutlineBrush" />
			<StaticResource x:Key="TextToggleButtonBorderBrushIndeterminatePressed" ResourceKey="OutlineBrush" />
			<StaticResource x:Key="TextToggleButtonBorderBrushIndeterminateDisabled" ResourceKey="OutlineDisabledBrush" />

			<!-- Unchecked -->
			<!-- Checked -->
			<!-- Indeterminate -->
		</ResourceDictionary>

	</ResourceDictionary.ThemeDictionaries>

	<StaticResource x:Key="SimpleToggleButtonCornerRadius" ResourceKey="SimpleRadius200CornerRadius" />     <!-- sds-size-radius-200 = 8 px -->
	<StaticResource x:Key="SimpleToggleButtonBorderThickness" ResourceKey="SimpleStrokeBorderThickness" />  <!-- sds-size-stroke-border = 1 px -->
	<StaticResource x:Key="SimpleToggleButtonMediumPadding" ResourceKey="SimpleSpace300Thickness" />        <!-- sds-size-space-300 = 12 px -->
	<StaticResource x:Key="SimpleToggleButtonSmallPadding" ResourceKey="SimpleSpace200Thickness" />         <!-- sds-size-space-200 = 8 px -->
	<StaticResource x:Key="SimpleToggleButtonMediumMinHeight" ResourceKey="SimpleIconLarge" />              <!-- sds-size-icon-large = 40 px -->
	<StaticResource x:Key="SimpleToggleButtonSmallMinHeight" ResourceKey="SimpleIconMedium" />              <!-- sds-size-icon-medium = 32 px -->
	<StaticResource x:Key="SimpleToggleButtonMediumFontSize" ResourceKey="SimpleTypographyScale03" />           <!-- sds-typography-scale-03 = 16 px -->
	<StaticResource x:Key="SimpleToggleButtonSmallFontSize" ResourceKey="SimpleTypographyScale02" />            <!-- sds-typography-scale-02 = 14 px -->
	<StaticResource x:Key="SimpleToggleButtonIconSpacing" ResourceKey="SimpleSpace200" />                   <!-- sds-size-space-200 = 8 px -->


	<!-- ═══════════════════════════════════════════════════════════════════════ -->
	<!-- Layout / sizing resources (theme-agnostic) -->
	<!-- Size-specific keys use explicit Small/Medium suffixes. -->
	<!-- Generic keys are defined in the SizeDefaults file loaded by -->
	<!-- SimpleTheme based on DefaultSize. -->
	<!-- ═══════════════════════════════════════════════════════════════════════ -->
	<FontFamily x:Key="SimpleToggleButtonFontFamily">Inter</FontFamily>

	<!-- ═══════════════════════════════════════════════════════════════════════ -->
	<!-- Default ToggleButton (Neutral unchecked → Primary checked) -->
	<!-- ═══════════════════════════════════════════════════════════════════════ -->
	<Style x:Key="SimpleDefaultToggleButtonStyle"
		   TargetType="ToggleButton">
		<Setter Property="FontFamily" Value="{StaticResource SimpleToggleButtonFontFamily}" />
		<Setter Property="FontSize" Value="{StaticResource SimpleToggleButtonFontSize}" />
		<Setter Property="FontWeight" Value="Normal" />
		<Setter Property="MinHeight" Value="{StaticResource SimpleToggleButtonMinHeight}" />
		<Setter Property="Padding" Value="{StaticResource SimpleToggleButtonPadding}" />
		<Setter Property="CornerRadius" Value="{StaticResource SimpleToggleButtonCornerRadius}" />
		<Setter Property="BorderThickness" Value="{StaticResource SimpleToggleButtonBorderThickness}" />
		<Setter Property="HorizontalAlignment" Value="Left" />
		<Setter Property="VerticalAlignment" Value="Center" />
		<Setter Property="HorizontalContentAlignment" Value="Center" />
		<Setter Property="VerticalContentAlignment" Value="Center" />
		<Setter Property="UseSystemFocusVisuals" Value="{StaticResource UseSystemFocusVisuals}" />
		<Setter Property="FocusVisualMargin" Value="-3" />
		<Setter Property="Foreground" Value="{ThemeResource TextToggleButtonForeground}" />
		<Setter Property="Background" Value="{ThemeResource TextToggleButtonBackground}" />
		<Setter Property="BorderBrush" Value="{ThemeResource TextToggleButtonBorderBrush}" />
		<Setter Property="Template">
			<Setter.Value>
				<ControlTemplate TargetType="ToggleButton">
					<Grid x:Name="Root"
						  Background="{TemplateBinding Background}"
						  BorderBrush="{TemplateBinding BorderBrush}"
						  BorderThickness="{TemplateBinding BorderThickness}"
						  CornerRadius="{TemplateBinding CornerRadius}"
						  Padding="{TemplateBinding Padding}"
						  AutomationProperties.AccessibilityView="Raw">

						<VisualStateManager.VisualStateGroups>
							<VisualStateGroup x:Name="CommonStates">

								<!-- Unchecked states -->
								<VisualState x:Name="Normal" />
								<VisualState x:Name="PointerOver">
									<VisualState.Setters>
										<Setter Target="Root.Background" Value="{ThemeResource TextToggleButtonBackgroundPointerOver}" />
										<Setter Target="Root.BorderBrush" Value="{ThemeResource TextToggleButtonBorderBrushPointerOver}" />
										<Setter Target="ContentPresenter.Foreground" Value="{ThemeResource TextToggleButtonForegroundPointerOver}" />
										<Setter Target="LeadingIconPresenter.Foreground" Value="{ThemeResource TextToggleButtonForegroundPointerOver}" />
										<Setter Target="TrailingIconPresenter.Foreground" Value="{ThemeResource TextToggleButtonForegroundPointerOver}" />
									</VisualState.Setters>
								</VisualState>
								<VisualState x:Name="Pressed">
									<VisualState.Setters>
										<Setter Target="Root.Background" Value="{ThemeResource TextToggleButtonBackgroundPressed}" />
										<Setter Target="Root.BorderBrush" Value="{ThemeResource TextToggleButtonBorderBrushPressed}" />
										<Setter Target="ContentPresenter.Foreground" Value="{ThemeResource TextToggleButtonForegroundPressed}" />
										<Setter Target="LeadingIconPresenter.Foreground" Value="{ThemeResource TextToggleButtonForegroundPressed}" />
										<Setter Target="TrailingIconPresenter.Foreground" Value="{ThemeResource TextToggleButtonForegroundPressed}" />
									</VisualState.Setters>
								</VisualState>
								<VisualState x:Name="Disabled">
									<VisualState.Setters>
										<Setter Target="Root.Background" Value="{ThemeResource TextToggleButtonBackgroundDisabled}" />
										<Setter Target="Root.BorderBrush" Value="{ThemeResource TextToggleButtonBorderBrushDisabled}" />
										<Setter Target="ContentPresenter.Foreground" Value="{ThemeResource TextToggleButtonForegroundDisabled}" />
										<Setter Target="LeadingIconPresenter.Foreground" Value="{ThemeResource TextToggleButtonForegroundDisabled}" />
										<Setter Target="TrailingIconPresenter.Foreground" Value="{ThemeResource TextToggleButtonForegroundDisabled}" />
									</VisualState.Setters>
								</VisualState>

								<!-- Checked states -->
								<VisualState x:Name="Checked">
									<VisualState.Setters>
										<Setter Target="Root.Background" Value="{ThemeResource TextToggleButtonBackgroundChecked}" />
										<Setter Target="Root.BorderBrush" Value="{ThemeResource TextToggleButtonBorderBrushChecked}" />
										<Setter Target="ContentPresenter.Foreground" Value="{ThemeResource TextToggleButtonForegroundChecked}" />
										<Setter Target="LeadingIconPresenter.Foreground" Value="{ThemeResource TextToggleButtonForegroundChecked}" />
										<Setter Target="TrailingIconPresenter.Foreground" Value="{ThemeResource TextToggleButtonForegroundChecked}" />
									</VisualState.Setters>
								</VisualState>
								<VisualState x:Name="CheckedPointerOver">
									<VisualState.Setters>
										<Setter Target="Root.Background" Value="{ThemeResource TextToggleButtonBackgroundCheckedPointerOver}" />
										<Setter Target="Root.BorderBrush" Value="{ThemeResource TextToggleButtonBorderBrushCheckedPointerOver}" />
										<Setter Target="ContentPresenter.Foreground" Value="{ThemeResource TextToggleButtonForegroundCheckedPointerOver}" />
										<Setter Target="LeadingIconPresenter.Foreground" Value="{ThemeResource TextToggleButtonForegroundCheckedPointerOver}" />
										<Setter Target="TrailingIconPresenter.Foreground" Value="{ThemeResource TextToggleButtonForegroundCheckedPointerOver}" />
									</VisualState.Setters>
								</VisualState>
								<VisualState x:Name="CheckedPressed">
									<VisualState.Setters>
										<Setter Target="Root.Background" Value="{ThemeResource TextToggleButtonBackgroundCheckedPressed}" />
										<Setter Target="Root.BorderBrush" Value="{ThemeResource TextToggleButtonBorderBrushCheckedPressed}" />
										<Setter Target="ContentPresenter.Foreground" Value="{ThemeResource TextToggleButtonForegroundCheckedPressed}" />
										<Setter Target="LeadingIconPresenter.Foreground" Value="{ThemeResource TextToggleButtonForegroundCheckedPressed}" />
										<Setter Target="TrailingIconPresenter.Foreground" Value="{ThemeResource TextToggleButtonForegroundCheckedPressed}" />
									</VisualState.Setters>
								</VisualState>
								<VisualState x:Name="CheckedDisabled">
									<VisualState.Setters>
										<Setter Target="Root.Background" Value="{ThemeResource TextToggleButtonBackgroundCheckedDisabled}" />
										<Setter Target="Root.BorderBrush" Value="{ThemeResource TextToggleButtonBorderBrushCheckedDisabled}" />
										<Setter Target="ContentPresenter.Foreground" Value="{ThemeResource TextToggleButtonForegroundCheckedDisabled}" />
										<Setter Target="LeadingIconPresenter.Foreground" Value="{ThemeResource TextToggleButtonForegroundCheckedDisabled}" />
										<Setter Target="TrailingIconPresenter.Foreground" Value="{ThemeResource TextToggleButtonForegroundCheckedDisabled}" />
									</VisualState.Setters>
								</VisualState>

								<!-- Indeterminate states -->
								<VisualState x:Name="IndeterminateNormal">
									<VisualState.Setters>
										<Setter Target="Root.Background" Value="{ThemeResource TextToggleButtonBackgroundIndeterminate}" />
										<Setter Target="Root.BorderBrush" Value="{ThemeResource TextToggleButtonBorderBrushIndeterminate}" />
										<Setter Target="ContentPresenter.Foreground" Value="{ThemeResource TextToggleButtonForegroundIndeterminate}" />
										<Setter Target="LeadingIconPresenter.Foreground" Value="{ThemeResource TextToggleButtonForegroundIndeterminate}" />
										<Setter Target="TrailingIconPresenter.Foreground" Value="{ThemeResource TextToggleButtonForegroundIndeterminate}" />
									</VisualState.Setters>
								</VisualState>
								<VisualState x:Name="IndeterminatePointerOver">
									<VisualState.Setters>
										<Setter Target="Root.Background" Value="{ThemeResource TextToggleButtonBackgroundIndeterminatePointerOver}" />
										<Setter Target="Root.BorderBrush" Value="{ThemeResource TextToggleButtonBorderBrushIndeterminatePointerOver}" />
										<Setter Target="ContentPresenter.Foreground" Value="{ThemeResource TextToggleButtonForegroundIndeterminatePointerOver}" />
										<Setter Target="LeadingIconPresenter.Foreground" Value="{ThemeResource TextToggleButtonForegroundIndeterminatePointerOver}" />
										<Setter Target="TrailingIconPresenter.Foreground" Value="{ThemeResource TextToggleButtonForegroundIndeterminatePointerOver}" />
									</VisualState.Setters>
								</VisualState>
								<VisualState x:Name="IndeterminatePressed">
									<VisualState.Setters>
										<Setter Target="Root.Background" Value="{ThemeResource TextToggleButtonBackgroundIndeterminatePressed}" />
										<Setter Target="Root.BorderBrush" Value="{ThemeResource TextToggleButtonBorderBrushIndeterminatePressed}" />
										<Setter Target="ContentPresenter.Foreground" Value="{ThemeResource TextToggleButtonForegroundIndeterminatePressed}" />
										<Setter Target="LeadingIconPresenter.Foreground" Value="{ThemeResource TextToggleButtonForegroundIndeterminatePressed}" />
										<Setter Target="TrailingIconPresenter.Foreground" Value="{ThemeResource TextToggleButtonForegroundIndeterminatePressed}" />
									</VisualState.Setters>
								</VisualState>
								<VisualState x:Name="IndeterminateDisabled">
									<VisualState.Setters>
										<Setter Target="Root.Background" Value="{ThemeResource TextToggleButtonBackgroundIndeterminateDisabled}" />
										<Setter Target="Root.BorderBrush" Value="{ThemeResource TextToggleButtonBorderBrushIndeterminateDisabled}" />
										<Setter Target="ContentPresenter.Foreground" Value="{ThemeResource TextToggleButtonForegroundIndeterminateDisabled}" />
										<Setter Target="LeadingIconPresenter.Foreground" Value="{ThemeResource TextToggleButtonForegroundIndeterminateDisabled}" />
										<Setter Target="TrailingIconPresenter.Foreground" Value="{ThemeResource TextToggleButtonForegroundIndeterminateDisabled}" />
									</VisualState.Setters>
								</VisualState>
							</VisualStateGroup>
						</VisualStateManager.VisualStateGroups>

						<StackPanel Orientation="Horizontal"
									HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
									VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
									Spacing="{StaticResource SimpleToggleButtonIconSpacing}">

							<ContentPresenter x:Name="LeadingIconPresenter"
											  Content="{Binding Path=(ut:ControlExtensions.LeadingIcon), RelativeSource={RelativeSource TemplatedParent}}"
											  Foreground="{TemplateBinding Foreground}"
											  Visibility="{Binding Path=(ut:ControlExtensions.LeadingIcon), RelativeSource={RelativeSource TemplatedParent}, Converter={StaticResource NullToCollapsedConverter}, FallbackValue=Collapsed, TargetNullValue=Collapsed}"
											  VerticalAlignment="Center" />

							<ContentPresenter x:Name="ContentPresenter"
											  Content="{TemplateBinding Content}"
											  ContentTemplate="{TemplateBinding ContentTemplate}"
											  ContentTransitions="{TemplateBinding ContentTransitions}"
											  Foreground="{TemplateBinding Foreground}"
											  HorizontalContentAlignment="{TemplateBinding HorizontalContentAlignment}"
											  VerticalContentAlignment="{TemplateBinding VerticalContentAlignment}" />

							<ContentPresenter x:Name="TrailingIconPresenter"
											  Content="{Binding Path=(ut:ControlExtensions.TrailingIcon), RelativeSource={RelativeSource TemplatedParent}}"
											  Foreground="{TemplateBinding Foreground}"
											  Visibility="{Binding Path=(ut:ControlExtensions.TrailingIcon), RelativeSource={RelativeSource TemplatedParent}, Converter={StaticResource NullToCollapsedConverter}, FallbackValue=Collapsed, TargetNullValue=Collapsed}"
											  VerticalAlignment="Center" />
						</StackPanel>
					</Grid>
				</ControlTemplate>
			</Setter.Value>
		</Setter>
	</Style>

	<!-- ═══════════════════════════════════════════════════════════════════════ -->
	<!-- Small size variant -->
	<!-- ═══════════════════════════════════════════════════════════════════════ -->
	<Style x:Key="SimpleSmallToggleButtonStyle"
		   TargetType="ToggleButton"
		   BasedOn="{StaticResource SimpleDefaultToggleButtonStyle}">
		<Setter Property="MinHeight" Value="{StaticResource SimpleToggleButtonSmallMinHeight}" />
		<Setter Property="Padding" Value="{StaticResource SimpleToggleButtonSmallPadding}" />
		<Setter Property="FontSize" Value="{StaticResource SimpleToggleButtonSmallFontSize}" />
	</Style>

	<!-- ═══════════════════════════════════════════════════════════════════════ -->
	<!-- Medium size variant -->
	<!-- ═══════════════════════════════════════════════════════════════════════ -->
	<Style x:Key="SimpleMediumToggleButtonStyle"
		   TargetType="ToggleButton"
		   BasedOn="{StaticResource SimpleDefaultToggleButtonStyle}">
		<Setter Property="MinHeight" Value="{StaticResource SimpleToggleButtonMediumMinHeight}" />
		<Setter Property="Padding" Value="{StaticResource SimpleToggleButtonMediumPadding}" />
		<Setter Property="FontSize" Value="{StaticResource SimpleToggleButtonMediumFontSize}" />
	</Style>

	<!-- ═══════════════════════════════════════════════════════════════════════ -->
	<!-- Icon-only ToggleButton (compact, circular — mirrors IconButton shape) -->
	<!-- ═══════════════════════════════════════════════════════════════════════ -->
	<Style x:Key="SimpleIconToggleButtonStyle"
		   TargetType="ToggleButton">
		<Setter Property="FontFamily" Value="{StaticResource SimpleToggleButtonFontFamily}" />
		<Setter Property="FontSize" Value="16" />
		<Setter Property="MinHeight" Value="{StaticResource SimpleIconButtonMinSize}" />
		<Setter Property="MinWidth" Value="{StaticResource SimpleIconButtonMinSize}" />
		<Setter Property="MaxHeight" Value="{StaticResource SimpleIconButtonMinSize}" />
		<Setter Property="MaxWidth" Value="{StaticResource SimpleIconButtonMinSize}" />
		<Setter Property="Padding" Value="{StaticResource SimpleIconButtonPadding}" />
		<Setter Property="CornerRadius" Value="{StaticResource SimpleIconButtonCornerRadius}" />
		<Setter Property="BorderThickness" Value="{StaticResource SimpleIconButtonBorderThickness}" />
		<Setter Property="HorizontalAlignment" Value="Center" />
		<Setter Property="VerticalAlignment" Value="Center" />
		<Setter Property="HorizontalContentAlignment" Value="Center" />
		<Setter Property="VerticalContentAlignment" Value="Center" />
		<Setter Property="UseSystemFocusVisuals" Value="{StaticResource UseSystemFocusVisuals}" />
		<Setter Property="FocusVisualMargin" Value="-3" />
		<Setter Property="Foreground" Value="{ThemeResource TextToggleButtonForeground}" />
		<Setter Property="Background" Value="{ThemeResource TextToggleButtonBackground}" />
		<Setter Property="BorderBrush" Value="{ThemeResource TextToggleButtonBorderBrush}" />
		<Setter Property="Template">
			<Setter.Value>
				<ControlTemplate TargetType="ToggleButton">
					<ContentPresenter x:Name="ContentPresenter"
									  Background="{TemplateBinding Background}"
									  BorderBrush="{TemplateBinding BorderBrush}"
									  BorderThickness="{TemplateBinding BorderThickness}"
									  CornerRadius="{TemplateBinding CornerRadius}"
									  Content="{TemplateBinding Content}"
									  ContentTemplate="{TemplateBinding ContentTemplate}"
									  ContentTransitions="{TemplateBinding ContentTransitions}"
									  Foreground="{TemplateBinding Foreground}"
									  Padding="{TemplateBinding Padding}"
									  HorizontalContentAlignment="{TemplateBinding HorizontalContentAlignment}"
									  VerticalContentAlignment="{TemplateBinding VerticalContentAlignment}"
									  AutomationProperties.AccessibilityView="Raw">

						<VisualStateManager.VisualStateGroups>
							<VisualStateGroup x:Name="CommonStates">

								<!-- Unchecked states -->
								<VisualState x:Name="Normal" />
								<VisualState x:Name="PointerOver">
									<VisualState.Setters>
										<Setter Target="ContentPresenter.Background" Value="{ThemeResource TextToggleButtonBackgroundPointerOver}" />
										<Setter Target="ContentPresenter.BorderBrush" Value="{ThemeResource TextToggleButtonBorderBrushPointerOver}" />
										<Setter Target="ContentPresenter.Foreground" Value="{ThemeResource TextToggleButtonForegroundPointerOver}" />
									</VisualState.Setters>
								</VisualState>
								<VisualState x:Name="Pressed">
									<VisualState.Setters>
										<Setter Target="ContentPresenter.Background" Value="{ThemeResource TextToggleButtonBackgroundPressed}" />
										<Setter Target="ContentPresenter.BorderBrush" Value="{ThemeResource TextToggleButtonBorderBrushPressed}" />
										<Setter Target="ContentPresenter.Foreground" Value="{ThemeResource TextToggleButtonForegroundPressed}" />
									</VisualState.Setters>
								</VisualState>
								<VisualState x:Name="Disabled">
									<VisualState.Setters>
										<Setter Target="ContentPresenter.Background" Value="{ThemeResource TextToggleButtonBackgroundDisabled}" />
										<Setter Target="ContentPresenter.BorderBrush" Value="{ThemeResource TextToggleButtonBorderBrushDisabled}" />
										<Setter Target="ContentPresenter.Foreground" Value="{ThemeResource TextToggleButtonForegroundDisabled}" />
									</VisualState.Setters>
								</VisualState>

								<!-- Checked states -->
								<VisualState x:Name="Checked">
									<VisualState.Setters>
										<Setter Target="ContentPresenter.Background" Value="{ThemeResource TextToggleButtonBackgroundChecked}" />
										<Setter Target="ContentPresenter.BorderBrush" Value="{ThemeResource TextToggleButtonBorderBrushChecked}" />
										<Setter Target="ContentPresenter.Foreground" Value="{ThemeResource TextToggleButtonForegroundChecked}" />
									</VisualState.Setters>
								</VisualState>
								<VisualState x:Name="CheckedPointerOver">
									<VisualState.Setters>
										<Setter Target="ContentPresenter.Background" Value="{ThemeResource TextToggleButtonBackgroundCheckedPointerOver}" />
										<Setter Target="ContentPresenter.BorderBrush" Value="{ThemeResource TextToggleButtonBorderBrushCheckedPointerOver}" />
										<Setter Target="ContentPresenter.Foreground" Value="{ThemeResource TextToggleButtonForegroundCheckedPointerOver}" />
									</VisualState.Setters>
								</VisualState>
								<VisualState x:Name="CheckedPressed">
									<VisualState.Setters>
										<Setter Target="ContentPresenter.Background" Value="{ThemeResource TextToggleButtonBackgroundCheckedPressed}" />
										<Setter Target="ContentPresenter.BorderBrush" Value="{ThemeResource TextToggleButtonBorderBrushCheckedPressed}" />
										<Setter Target="ContentPresenter.Foreground" Value="{ThemeResource TextToggleButtonForegroundCheckedPressed}" />
									</VisualState.Setters>
								</VisualState>
