			<StaticResource x:Key="SimpleNeutralButtonBackgroundPointerOver" ResourceKey="SimpleBackgroundDefaultSecondaryHoverBrush" />
			<StaticResource x:Key="SimpleNeutralButtonBackgroundPressed" ResourceKey="SimpleBackgroundDefaultSecondaryHoverBrush" />
			<StaticResource x:Key="SimpleNeutralButtonBackgroundDisabled" ResourceKey="SimpleBackgroundDisabledDefaultBrush" />
			<StaticResource x:Key="SimpleNeutralButtonBorderBrush" ResourceKey="SimpleBorderDefaultDefaultBrush" />
			<StaticResource x:Key="SimpleNeutralButtonBorderBrushPointerOver" ResourceKey="SimpleBorderDefaultDefaultBrush" />
			<StaticResource x:Key="SimpleNeutralButtonBorderBrushPressed" ResourceKey="SimpleBorderDefaultDefaultBrush" />
			<StaticResource x:Key="SimpleNeutralButtonBorderBrushDisabled" ResourceKey="SimpleBorderDisabledDefaultBrush" />

			<!-- Subtle -->
			<StaticResource x:Key="SimpleSubtleButtonForeground" ResourceKey="SimpleTextBrandDefaultBrush" />
			<StaticResource x:Key="SimpleSubtleButtonForegroundPointerOver" ResourceKey="SimpleTextBrandDefaultBrush" />
			<StaticResource x:Key="SimpleSubtleButtonForegroundPressed" ResourceKey="SimpleTextBrandDefaultBrush" />
			<StaticResource x:Key="SimpleSubtleButtonForegroundDisabled" ResourceKey="SimpleTextDisabledDefaultBrush" />
			<StaticResource x:Key="SimpleSubtleButtonBackground" ResourceKey="SystemControlTransparentBrush" />
			<StaticResource x:Key="SimpleSubtleButtonBackgroundPointerOver" ResourceKey="SimpleBackgroundDefaultDefaultHoverBrush" />
			<StaticResource x:Key="SimpleSubtleButtonBackgroundPressed" ResourceKey="SimpleBackgroundDefaultDefaultHoverBrush" />
			<StaticResource x:Key="SimpleSubtleButtonBackgroundDisabled" ResourceKey="SimpleBackgroundDisabledDefaultBrush" />
			<StaticResource x:Key="SimpleSubtleButtonBorderBrush" ResourceKey="SystemControlTransparentBrush" />
			<StaticResource x:Key="SimpleSubtleButtonBorderBrushPointerOver" ResourceKey="SystemControlTransparentBrush" />
			<StaticResource x:Key="SimpleSubtleButtonBorderBrushPressed" ResourceKey="SystemControlTransparentBrush" />
			<StaticResource x:Key="SimpleSubtleButtonBorderBrushDisabled" ResourceKey="SimpleBorderDisabledDefaultBrush" />

