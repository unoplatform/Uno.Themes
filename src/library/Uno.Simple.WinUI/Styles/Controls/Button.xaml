	<!-- Generic keys (SimpleButtonMinHeight, etc.) are defined in the          -->
	<!-- SizeDefaults file loaded by SimpleTheme based on DefaultSize.          -->
	<!-- ═══════════════════════════════════════════════════════════════════════ -->
	<StaticResource x:Key="SimpleButtonCornerRadius" ResourceKey="SimpleRadius200CornerRadius" />          <!-- sds-size-radius-200 = 8 px -->
	<StaticResource x:Key="SimpleButtonBorderThickness" ResourceKey="SimpleStrokeBorderThickness" />       <!-- sds-size-stroke-border = 1 px -->
	<StaticResource x:Key="SimpleButtonMediumPadding" ResourceKey="SimpleSpace300Thickness" />             <!-- sds-size-space-300 = 12 px -->
	<StaticResource x:Key="SimpleButtonSmallPadding" ResourceKey="SimpleSpace200Thickness" />              <!-- sds-size-space-200 = 8 px -->
	<StaticResource x:Key="SimpleButtonMediumMinHeight" ResourceKey="SimpleIconLarge" />                   <!-- sds-size-icon-large = 40 px -->
	<StaticResource x:Key="SimpleButtonSmallMinHeight" ResourceKey="SimpleIconMedium" />                   <!-- sds-size-icon-medium = 32 px -->
	<StaticResource x:Key="SimpleButtonMediumFontSize" ResourceKey="SimpleTypographyScale03" />                <!-- sds-typography-scale-03 = 16 px -->
	<StaticResource x:Key="SimpleButtonSmallFontSize" ResourceKey="SimpleTypographyScale02" />                 <!-- sds-typography-scale-02 = 14 px -->
	<StaticResource x:Key="SimpleButtonIconSpacing" ResourceKey="SimpleSpace200" />                        <!-- sds-size-space-200 = 8 px -->
	<FontFamily x:Key="SimpleButtonFontFamily">Inter</FontFamily>
	<x:String x:Key="SimpleButtonFontWeight">Normal</x:String>

	<!-- ═══════════════════════════════════════════════════════════════════════ -->
	<!-- Base style — shared setters (no template)                             -->
	<!-- ═══════════════════════════════════════════════════════════════════════ -->
	<Style x:Key="SimpleBaseButtonStyle" TargetType="Button">
		<Setter Property="FontFamily" Value="{StaticResource SimpleButtonFontFamily}" />
		<Setter Property="FontSize" Value="{StaticResource SimpleButtonFontSize}" />
		<Setter Property="FontWeight" Value="Normal" />
		<Setter Property="MinHeight" Value="{StaticResource SimpleButtonMinHeight}" />
		<Setter Property="Padding" Value="{StaticResource SimpleButtonPadding}" />
		<Setter Property="CornerRadius" Value="{StaticResource SimpleButtonCornerRadius}" />
		<Setter Property="BorderThickness" Value="{StaticResource SimpleButtonBorderThickness}" />
		<Setter Property="HorizontalAlignment" Value="Left" />
		<Setter Property="VerticalAlignment" Value="Center" />
		<Setter Property="HorizontalContentAlignment" Value="Center" />
		<Setter Property="VerticalContentAlignment" Value="Center" />
		<Setter Property="UseSystemFocusVisuals" Value="{StaticResource UseSystemFocusVisuals}" />
		<Setter Property="FocusVisualMargin" Value="-3" />
	</Style>

	<!-- ═══════════════════════════════════════════════════════════════════════ -->
