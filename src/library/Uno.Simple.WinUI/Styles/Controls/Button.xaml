			<StaticResource x:Key="SimpleDangerPrimaryButtonForegroundPointerOver" ResourceKey="SimpleTextDangerOnDangerBrush" />
			<StaticResource x:Key="SimpleDangerPrimaryButtonForegroundPressed" ResourceKey="SimpleTextDangerOnDangerBrush" />
			<StaticResource x:Key="SimpleDangerPrimaryButtonForegroundDisabled" ResourceKey="SimpleTextDisabledDefaultBrush" />
			<StaticResource x:Key="SimpleDangerPrimaryButtonBackground" ResourceKey="SimpleBackgroundDangerDefaultBrush" />
			<StaticResource x:Key="SimpleDangerPrimaryButtonBackgroundPointerOver" ResourceKey="SimpleBackgroundDangerHoverBrush" />
			<StaticResource x:Key="SimpleDangerPrimaryButtonBackgroundPressed" ResourceKey="SimpleBackgroundDangerHoverBrush" />
			<StaticResource x:Key="SimpleDangerPrimaryButtonBackgroundDisabled" ResourceKey="SimpleBackgroundDisabledDefaultBrush" />
			<StaticResource x:Key="SimpleDangerPrimaryButtonBorderBrush" ResourceKey="SimpleBorderDangerSecondaryBrush" />
			<StaticResource x:Key="SimpleDangerPrimaryButtonBorderBrushPointerOver" ResourceKey="SimpleBorderDangerDefaultBrush" />
			<StaticResource x:Key="SimpleDangerPrimaryButtonBorderBrushPressed" ResourceKey="SimpleBorderDangerDefaultBrush" />
			<StaticResource x:Key="SimpleDangerPrimaryButtonBorderBrushDisabled" ResourceKey="SimpleBorderDisabledDefaultBrush" />

