<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
					xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

	<!--
		Simple Design System — Button Styles
		Lightweight styling pattern: every visual-state brush is exposed via ThemeResource
		so consumers can override any individual key.

		Variants: Primary, Neutral, Subtle, DangerPrimary, DangerSubtle
		Sizes:    Medium (default), Small
	-->

	<!-- ═══════════════════════════════════════════════════════════════════════ -->
	<!-- Layout / sizing resources (theme-agnostic)                            -->
	<!-- ═══════════════════════════════════════════════════════════════════════ -->
	<CornerRadius x:Key="SimpleButtonCornerRadius">8</CornerRadius>
	<Thickness x:Key="SimpleButtonBorderThickness">1</Thickness>
	<Thickness x:Key="SimpleButtonPadding">12</Thickness>
	<Thickness x:Key="SimpleButtonSmallPadding">8</Thickness>
	<x:Double x:Key="SimpleButtonMinHeight">40</x:Double>
	<x:Double x:Key="SimpleButtonSmallMinHeight">32</x:Double>
	<x:Double x:Key="SimpleButtonFontSize">16</x:Double>
	<x:Double x:Key="SimpleButtonSmallFontSize">14</x:Double>
	<FontFamily x:Key="SimpleButtonFontFamily">Inter</FontFamily>
	<x:String x:Key="SimpleButtonFontWeight">Normal</x:String>

	<!-- ═══════════════════════════════════════════════════════════════════════ -->
	<!-- Lightweight styling ThemeResource aliases                              -->
	<!-- ═══════════════════════════════════════════════════════════════════════ -->
	<ResourceDictionary.ThemeDictionaries>

		<!-- ─── Light Theme ─── -->
		<ResourceDictionary x:Key="Light">

			<!-- Primary -->
			<StaticResource x:Key="SimplePrimaryButtonForeground" ResourceKey="SimpleTextBrandOnBrandBrush" />
			<StaticResource x:Key="SimplePrimaryButtonForegroundPointerOver" ResourceKey="SimpleTextBrandOnBrandBrush" />
			<StaticResource x:Key="SimplePrimaryButtonForegroundPressed" ResourceKey="SimpleTextBrandOnBrandBrush" />
			<StaticResource x:Key="SimplePrimaryButtonForegroundDisabled" ResourceKey="SimpleTextDisabledDefaultBrush" />
			<StaticResource x:Key="SimplePrimaryButtonBackground" ResourceKey="SimpleBackgroundBrandDefaultBrush" />
			<StaticResource x:Key="SimplePrimaryButtonBackgroundPointerOver" ResourceKey="SimpleBackgroundBrandHoverBrush" />
			<StaticResource x:Key="SimplePrimaryButtonBackgroundPressed" ResourceKey="SimpleBackgroundBrandHoverBrush" />
			<StaticResource x:Key="SimplePrimaryButtonBackgroundDisabled" ResourceKey="SimpleBackgroundDisabledDefaultBrush" />
			<StaticResource x:Key="SimplePrimaryButtonBorderBrush" ResourceKey="SimpleBorderBrandDefaultBrush" />
			<StaticResource x:Key="SimplePrimaryButtonBorderBrushPointerOver" ResourceKey="SimpleBorderBrandDefaultBrush" />
			<StaticResource x:Key="SimplePrimaryButtonBorderBrushPressed" ResourceKey="SimpleBorderBrandDefaultBrush" />
			<StaticResource x:Key="SimplePrimaryButtonBorderBrushDisabled" ResourceKey="SimpleBorderDisabledDefaultBrush" />

			<!-- Neutral -->
