					xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
					xmlns:ut="using:Uno.Themes">

	<!--
		Simple Design System — Button Styles
		Lightweight styling pattern: every visual-state brush is exposed via ThemeResource
		so consumers can override any individual key.

		Semantic resource layer:
		  FilledButton*       = Primary variant   (was SimplePrimaryButton*)
		  FilledTonalButton*  = Neutral variant    (was SimpleNeutralButton*)
		  OutlinedButton*     = alias for FilledTonalButton*
		  TextButton*         = Subtle variant     (was SimpleSubtleButton*)
		  IconButton*         = Primary icon variant (aliases FilledButton*; template uses IconButton* for full override parity)

		Backwards-compat aliases are provided for all old Simple-prefixed names.

		Simple-only variants (no semantic rename):
		  SimpleDangerPrimaryButton* — no Material equivalent
		  SimpleDangerSubtleButton*  — no Material equivalent

		Variants: Primary, Neutral, Subtle, DangerPrimary, DangerSubtle
		Sizes:    Small (default), Medium — configurable via SimpleTheme.DefaultSize
	-->

