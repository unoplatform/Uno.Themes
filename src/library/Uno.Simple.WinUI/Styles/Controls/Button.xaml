<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
					xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
					xmlns:ut="using:Uno.Themes">

	<!--
		Simple Design System — Button Styles
		Lightweight styling pattern: every visual-state brush is exposed via ThemeResource
		so consumers can override any individual semantic key.
		
		Semantic keys (source of truth in ThemeDictionary):
		FilledButton*       = Primary variant
		FilledTonalButton*  = Neutral variant
		OutlinedButton*     = alias for FilledTonalButton*
		TextButton*         = Subtle variant
		IconButton*         = Primary icon variant (aliases FilledButton*)
		
		Simple-only variants (no semantic rename):
		SimpleDangerPrimaryButton* — no Material equivalent
		SimpleDangerSubtleButton*  — no Material equivalent
		
		Variants: Primary, Neutral, Subtle, DangerPrimary, DangerSubtle
		Sizing:   Controlled by Space scale (DefaultSpacing) and ControlHeight tokens
	-->

	<!-- ═══════════════════════════════════════════════════════════════════════ -->
	<!-- Lightweight styling ThemeResource aliases -->
	<!-- Semantic keys are the source of truth for all brush overrides. -->
	<!-- ═══════════════════════════════════════════════════════════════════════ -->
	<ResourceDictionary.ThemeDictionaries>

		<!-- ─── Light Theme ─── -->
		<ResourceDictionary x:Key="Light">

			<!-- ── FilledButton (Primary) — semantic keys (source of truth) ── -->
			<StaticResource x:Key="FilledButtonForeground" ResourceKey="OnPrimaryBrush" />
			<StaticResource x:Key="FilledButtonForegroundPointerOver" ResourceKey="OnPrimaryBrush" />
			<StaticResource x:Key="FilledButtonForegroundPressed" ResourceKey="OnPrimaryBrush" />
			<StaticResource x:Key="FilledButtonForegroundDisabled" ResourceKey="OnSurfaceDisabledBrush" />
			<StaticResource x:Key="FilledButtonBackground" ResourceKey="PrimaryBrush" />
			<StaticResource x:Key="FilledButtonBackgroundPointerOver" ResourceKey="PrimaryVariantDarkBrush" />
			<StaticResource x:Key="FilledButtonBackgroundPressed" ResourceKey="PrimaryVariantDarkBrush" />
			<StaticResource x:Key="FilledButtonBackgroundDisabled" ResourceKey="OnSurfaceDisabledBrush" />
			<StaticResource x:Key="FilledButtonBorderBrush" ResourceKey="PrimaryBrush" />
			<StaticResource x:Key="FilledButtonBorderBrushPointerOver" ResourceKey="PrimaryBrush" />
			<StaticResource x:Key="FilledButtonBorderBrushPressed" ResourceKey="PrimaryBrush" />
			<StaticResource x:Key="FilledButtonBorderBrushDisabled" ResourceKey="OutlineDisabledBrush" />
			<!-- ── FilledTonalButton (Neutral) — semantic keys (source of truth) ── -->
			<StaticResource x:Key="FilledTonalButtonForeground" ResourceKey="OnSurfaceBrush" />
			<StaticResource x:Key="FilledTonalButtonForegroundPointerOver" ResourceKey="OnSurfaceBrush" />
			<StaticResource x:Key="FilledTonalButtonForegroundPressed" ResourceKey="OnSurfaceBrush" />
			<StaticResource x:Key="FilledTonalButtonForegroundDisabled" ResourceKey="OnSurfaceDisabledBrush" />
			<StaticResource x:Key="FilledTonalButtonBackground" ResourceKey="SurfaceVariantBrush" />
			<StaticResource x:Key="FilledTonalButtonBackgroundPointerOver" ResourceKey="PrimaryContainerBrush" />
			<StaticResource x:Key="FilledTonalButtonBackgroundPressed" ResourceKey="TertiaryContainerBrush" />
			<StaticResource x:Key="FilledTonalButtonBackgroundDisabled" ResourceKey="OnSurfaceDisabledBrush" />
			<StaticResource x:Key="FilledTonalButtonBorderBrush" ResourceKey="OutlineBrush" />
			<StaticResource x:Key="FilledTonalButtonBorderBrushPointerOver" ResourceKey="OutlineBrush" />
			<StaticResource x:Key="FilledTonalButtonBorderBrushPressed" ResourceKey="OutlineBrush" />
			<StaticResource x:Key="FilledTonalButtonBorderBrushDisabled" ResourceKey="OutlineDisabledBrush" />
			<!-- OutlinedButton aliases (read parity — point to FilledTonalButton*) -->
			<StaticResource x:Key="OutlinedButtonForeground" ResourceKey="FilledTonalButtonForeground" />
			<StaticResource x:Key="OutlinedButtonForegroundPointerOver" ResourceKey="FilledTonalButtonForegroundPointerOver" />
			<StaticResource x:Key="OutlinedButtonForegroundPressed" ResourceKey="FilledTonalButtonForegroundPressed" />
			<StaticResource x:Key="OutlinedButtonForegroundDisabled" ResourceKey="FilledTonalButtonForegroundDisabled" />
			<StaticResource x:Key="OutlinedButtonBackground" ResourceKey="FilledTonalButtonBackground" />
			<StaticResource x:Key="OutlinedButtonBackgroundPointerOver" ResourceKey="FilledTonalButtonBackgroundPointerOver" />
			<StaticResource x:Key="OutlinedButtonBackgroundPressed" ResourceKey="FilledTonalButtonBackgroundPressed" />
			<StaticResource x:Key="OutlinedButtonBackgroundDisabled" ResourceKey="FilledTonalButtonBackgroundDisabled" />
			<StaticResource x:Key="OutlinedButtonBorderBrush" ResourceKey="FilledTonalButtonBorderBrush" />
			<StaticResource x:Key="OutlinedButtonBorderBrushPointerOver" ResourceKey="FilledTonalButtonBorderBrushPointerOver" />
			<StaticResource x:Key="OutlinedButtonBorderBrushPressed" ResourceKey="FilledTonalButtonBorderBrushPressed" />
			<StaticResource x:Key="OutlinedButtonBorderBrushDisabled" ResourceKey="FilledTonalButtonBorderBrushDisabled" />
			<!-- ── TextButton (Subtle) — semantic keys (source of truth) ── -->
			<StaticResource x:Key="TextButtonForeground" ResourceKey="PrimaryBrush" />
			<StaticResource x:Key="TextButtonForegroundPointerOver" ResourceKey="PrimaryBrush" />
			<StaticResource x:Key="TextButtonForegroundPressed" ResourceKey="PrimaryBrush" />
			<StaticResource x:Key="TextButtonForegroundDisabled" ResourceKey="OnSurfaceDisabledBrush" />
			<StaticResource x:Key="TextButtonBackground" ResourceKey="SystemControlTransparentBrush" />
			<StaticResource x:Key="TextButtonBackgroundPointerOver" ResourceKey="SurfaceVariantBrush" />
			<StaticResource x:Key="TextButtonBackgroundPressed" ResourceKey="PrimaryContainerBrush" />
			<StaticResource x:Key="TextButtonBackgroundDisabled" ResourceKey="OnSurfaceDisabledBrush" />
			<StaticResource x:Key="TextButtonBorderBrush" ResourceKey="SystemControlTransparentBrush" />
			<StaticResource x:Key="TextButtonBorderBrushPointerOver" ResourceKey="SystemControlTransparentBrush" />
			<StaticResource x:Key="TextButtonBorderBrushPressed" ResourceKey="SystemControlTransparentBrush" />
			<StaticResource x:Key="TextButtonBorderBrushDisabled" ResourceKey="OutlineDisabledBrush" />
			<!-- ── IconButton — semantic keys ── -->
			<StaticResource x:Key="IconButtonForeground" ResourceKey="FilledButtonForeground" />
			<StaticResource x:Key="IconButtonForegroundPointerOver" ResourceKey="FilledButtonForegroundPointerOver" />
			<StaticResource x:Key="IconButtonForegroundPressed" ResourceKey="FilledButtonForegroundPressed" />
			<StaticResource x:Key="IconButtonForegroundDisabled" ResourceKey="FilledButtonForegroundDisabled" />
			<StaticResource x:Key="IconButtonBackground" ResourceKey="FilledButtonBackground" />
			<StaticResource x:Key="IconButtonBackgroundPointerOver" ResourceKey="FilledButtonBackgroundPointerOver" />
			<StaticResource x:Key="IconButtonBackgroundPressed" ResourceKey="FilledButtonBackgroundPressed" />
			<StaticResource x:Key="IconButtonBackgroundDisabled" ResourceKey="FilledButtonBackgroundDisabled" />
			<StaticResource x:Key="IconButtonBorderBrush" ResourceKey="FilledButtonBorderBrush" />
			<StaticResource x:Key="IconButtonBorderBrushPointerOver" ResourceKey="FilledButtonBorderBrushPointerOver" />
			<StaticResource x:Key="IconButtonBorderBrushPressed" ResourceKey="FilledButtonBorderBrushPressed" />
			<StaticResource x:Key="IconButtonBorderBrushDisabled" ResourceKey="FilledButtonBorderBrushDisabled" />
			<!-- ── DangerPrimary (Simple-only — no semantic rename) ── -->
			<!-- ── DangerSubtle (Simple-only — no semantic rename) ── -->
		</ResourceDictionary>

		<!-- ─── Dark Theme (Default) ─── -->
		<ResourceDictionary x:Key="Default">

			<!-- ── FilledButton (Primary) — semantic keys (source of truth) ── -->
			<StaticResource x:Key="FilledButtonForeground" ResourceKey="OnPrimaryBrush" />
			<StaticResource x:Key="FilledButtonForegroundPointerOver" ResourceKey="OnPrimaryBrush" />
			<StaticResource x:Key="FilledButtonForegroundPressed" ResourceKey="OnPrimaryBrush" />
			<StaticResource x:Key="FilledButtonForegroundDisabled" ResourceKey="OnSurfaceDisabledBrush" />
			<StaticResource x:Key="FilledButtonBackground" ResourceKey="PrimaryBrush" />
			<StaticResource x:Key="FilledButtonBackgroundPointerOver" ResourceKey="PrimaryVariantDarkBrush" />
			<StaticResource x:Key="FilledButtonBackgroundPressed" ResourceKey="PrimaryVariantDarkBrush" />
			<StaticResource x:Key="FilledButtonBackgroundDisabled" ResourceKey="OnSurfaceDisabledBrush" />
			<StaticResource x:Key="FilledButtonBorderBrush" ResourceKey="PrimaryBrush" />
			<StaticResource x:Key="FilledButtonBorderBrushPointerOver" ResourceKey="PrimaryBrush" />
			<StaticResource x:Key="FilledButtonBorderBrushPressed" ResourceKey="PrimaryBrush" />
			<StaticResource x:Key="FilledButtonBorderBrushDisabled" ResourceKey="OutlineDisabledBrush" />
			<!-- ── FilledTonalButton (Neutral) — semantic keys (source of truth) ── -->
			<StaticResource x:Key="FilledTonalButtonForeground" ResourceKey="OnSurfaceBrush" />
			<StaticResource x:Key="FilledTonalButtonForegroundPointerOver" ResourceKey="OnSurfaceBrush" />
			<StaticResource x:Key="FilledTonalButtonForegroundPressed" ResourceKey="OnSurfaceBrush" />
			<StaticResource x:Key="FilledTonalButtonForegroundDisabled" ResourceKey="OnSurfaceDisabledBrush" />
			<StaticResource x:Key="FilledTonalButtonBackground" ResourceKey="SurfaceVariantBrush" />
			<StaticResource x:Key="FilledTonalButtonBackgroundPointerOver" ResourceKey="PrimaryContainerBrush" />
			<StaticResource x:Key="FilledTonalButtonBackgroundPressed" ResourceKey="TertiaryContainerBrush" />
			<StaticResource x:Key="FilledTonalButtonBackgroundDisabled" ResourceKey="OnSurfaceDisabledBrush" />
			<StaticResource x:Key="FilledTonalButtonBorderBrush" ResourceKey="OutlineBrush" />
			<StaticResource x:Key="FilledTonalButtonBorderBrushPointerOver" ResourceKey="OutlineBrush" />
			<StaticResource x:Key="FilledTonalButtonBorderBrushPressed" ResourceKey="OutlineBrush" />
			<StaticResource x:Key="FilledTonalButtonBorderBrushDisabled" ResourceKey="OutlineDisabledBrush" />
			<!-- OutlinedButton aliases (read parity — point to FilledTonalButton*) -->
			<StaticResource x:Key="OutlinedButtonForeground" ResourceKey="FilledTonalButtonForeground" />
			<StaticResource x:Key="OutlinedButtonForegroundPointerOver" ResourceKey="FilledTonalButtonForegroundPointerOver" />
			<StaticResource x:Key="OutlinedButtonForegroundPressed" ResourceKey="FilledTonalButtonForegroundPressed" />
			<StaticResource x:Key="OutlinedButtonForegroundDisabled" ResourceKey="FilledTonalButtonForegroundDisabled" />
			<StaticResource x:Key="OutlinedButtonBackground" ResourceKey="FilledTonalButtonBackground" />
			<StaticResource x:Key="OutlinedButtonBackgroundPointerOver" ResourceKey="FilledTonalButtonBackgroundPointerOver" />
			<StaticResource x:Key="OutlinedButtonBackgroundPressed" ResourceKey="FilledTonalButtonBackgroundPressed" />
			<StaticResource x:Key="OutlinedButtonBackgroundDisabled" ResourceKey="FilledTonalButtonBackgroundDisabled" />
			<StaticResource x:Key="OutlinedButtonBorderBrush" ResourceKey="FilledTonalButtonBorderBrush" />
			<StaticResource x:Key="OutlinedButtonBorderBrushPointerOver" ResourceKey="FilledTonalButtonBorderBrushPointerOver" />
			<StaticResource x:Key="OutlinedButtonBorderBrushPressed" ResourceKey="FilledTonalButtonBorderBrushPressed" />
			<StaticResource x:Key="OutlinedButtonBorderBrushDisabled" ResourceKey="FilledTonalButtonBorderBrushDisabled" />
			<!-- ── TextButton (Subtle) — semantic keys (source of truth) ── -->
			<StaticResource x:Key="TextButtonForeground" ResourceKey="PrimaryBrush" />
			<StaticResource x:Key="TextButtonForegroundPointerOver" ResourceKey="PrimaryBrush" />
			<StaticResource x:Key="TextButtonForegroundPressed" ResourceKey="PrimaryBrush" />
			<StaticResource x:Key="TextButtonForegroundDisabled" ResourceKey="OnSurfaceDisabledBrush" />
			<StaticResource x:Key="TextButtonBackground" ResourceKey="SystemControlTransparentBrush" />
			<StaticResource x:Key="TextButtonBackgroundPointerOver" ResourceKey="SurfaceVariantBrush" />
			<StaticResource x:Key="TextButtonBackgroundPressed" ResourceKey="PrimaryContainerBrush" />
			<StaticResource x:Key="TextButtonBackgroundDisabled" ResourceKey="OnSurfaceDisabledBrush" />
			<StaticResource x:Key="TextButtonBorderBrush" ResourceKey="SystemControlTransparentBrush" />
			<StaticResource x:Key="TextButtonBorderBrushPointerOver" ResourceKey="SystemControlTransparentBrush" />
			<StaticResource x:Key="TextButtonBorderBrushPressed" ResourceKey="SystemControlTransparentBrush" />
			<StaticResource x:Key="TextButtonBorderBrushDisabled" ResourceKey="OutlineDisabledBrush" />
			<!-- ── IconButton — semantic keys ── -->
			<StaticResource x:Key="IconButtonForeground" ResourceKey="FilledButtonForeground" />
			<StaticResource x:Key="IconButtonForegroundPointerOver" ResourceKey="FilledButtonForegroundPointerOver" />
			<StaticResource x:Key="IconButtonForegroundPressed" ResourceKey="FilledButtonForegroundPressed" />
			<StaticResource x:Key="IconButtonForegroundDisabled" ResourceKey="FilledButtonForegroundDisabled" />
			<StaticResource x:Key="IconButtonBackground" ResourceKey="FilledButtonBackground" />
			<StaticResource x:Key="IconButtonBackgroundPointerOver" ResourceKey="FilledButtonBackgroundPointerOver" />
			<StaticResource x:Key="IconButtonBackgroundPressed" ResourceKey="FilledButtonBackgroundPressed" />
			<StaticResource x:Key="IconButtonBackgroundDisabled" ResourceKey="FilledButtonBackgroundDisabled" />
			<StaticResource x:Key="IconButtonBorderBrush" ResourceKey="FilledButtonBorderBrush" />
			<StaticResource x:Key="IconButtonBorderBrushPointerOver" ResourceKey="FilledButtonBorderBrushPointerOver" />
			<StaticResource x:Key="IconButtonBorderBrushPressed" ResourceKey="FilledButtonBorderBrushPressed" />
			<StaticResource x:Key="IconButtonBorderBrushDisabled" ResourceKey="FilledButtonBorderBrushDisabled" />
			<!-- ── DangerPrimary (Simple-only — no semantic rename) ── -->
			<!-- ── DangerSubtle (Simple-only — no semantic rename) ── -->
		</ResourceDictionary>

	</ResourceDictionary.ThemeDictionaries>

	<StaticResource x:Key="SimpleButtonCornerRadius" ResourceKey="SimpleRadius200CornerRadius" />
	<StaticResource x:Key="SimpleButtonBorderThickness" ResourceKey="SimpleStrokeBorderThickness" />
	<StaticResource x:Key="SimpleButtonIconSpacing" ResourceKey="SimpleSpace200" />
	<StaticResource x:Key="SimpleIconButtonCornerRadius" ResourceKey="SimpleRadiusFullCornerRadius" />
	<StaticResource x:Key="SimpleIconButtonBorderThickness" ResourceKey="SimpleStrokeBorderThickness" />


	<!-- ═══════════════════════════════════════════════════════════════════════ -->
	<!-- Layout / sizing resources (theme-agnostic) -->
	<!-- ═══════════════════════════════════════════════════════════════════════ -->
	<StaticResource x:Key="SimpleButtonFontFamily" ResourceKey="TypefaceBrand" />
	<x:String x:Key="SimpleButtonFontWeight">Normal</x:String>

	<!-- ═══════════════════════════════════════════════════════════════════════ -->
	<!-- Base style — shared setters (no template) -->
	<!-- ═══════════════════════════════════════════════════════════════════════ -->
	<Style x:Key="SimpleBaseButtonStyle"
		   TargetType="Button">
		<Setter Property="FontFamily" Value="{StaticResource SimpleButtonFontFamily}" />
		<Setter Property="FontSize" Value="{StaticResource LabelLargeFontSize}" />
		<Setter Property="FontWeight" Value="Normal" />
		<Setter Property="MinHeight" Value="{StaticResource ControlHeightMedium}" />
		<Setter Property="Padding" Value="{StaticResource SimpleSpace300Thickness}" />
		<Setter Property="CornerRadius" Value="{StaticResource SimpleButtonCornerRadius}" />
		<Setter Property="BorderThickness" Value="{StaticResource SimpleButtonBorderThickness}" />
		<Setter Property="HorizontalAlignment" Value="Left" />
		<Setter Property="VerticalAlignment" Value="Center" />
		<Setter Property="HorizontalContentAlignment" Value="Center" />
		<Setter Property="VerticalContentAlignment" Value="Center" />
		<Setter Property="UseSystemFocusVisuals" Value="{StaticResource UseSystemFocusVisuals}" />
		<Setter Property="FocusVisualMargin" Value="-3" />
	</Style>

	<!-- ═══════════════════════════════════════════════════════════════════════ -->
	<!-- Primary Button -->
	<!-- ═══════════════════════════════════════════════════════════════════════ -->
	<Style x:Key="SimpleFilledButtonStyle"
		   TargetType="Button"
		   BasedOn="{StaticResource SimpleBaseButtonStyle}">
		<Setter Property="Foreground" Value="{ThemeResource FilledButtonForeground}" />
		<Setter Property="Background" Value="{ThemeResource FilledButtonBackground}" />
		<Setter Property="BorderBrush" Value="{ThemeResource FilledButtonBorderBrush}" />
		<Setter Property="Template">
			<Setter.Value>
				<ControlTemplate TargetType="Button">
					<Grid x:Name="Root"
						  Background="{TemplateBinding Background}"
						  BorderBrush="{TemplateBinding BorderBrush}"
						  BorderThickness="{TemplateBinding BorderThickness}"
						  CornerRadius="{TemplateBinding CornerRadius}"
						  Padding="{TemplateBinding Padding}"
						  AutomationProperties.AccessibilityView="Raw">

						<VisualStateManager.VisualStateGroups>
							<VisualStateGroup x:Name="CommonStates">
								<VisualState x:Name="Normal" />
								<VisualState x:Name="PointerOver">
									<VisualState.Setters>
										<Setter Target="Root.Background" Value="{ThemeResource FilledButtonBackgroundPointerOver}" />
										<Setter Target="Root.BorderBrush" Value="{ThemeResource FilledButtonBorderBrushPointerOver}" />
										<Setter Target="ContentPresenter.Foreground" Value="{ThemeResource FilledButtonForegroundPointerOver}" />
										<Setter Target="LeadingIconPresenter.Foreground" Value="{ThemeResource FilledButtonForegroundPointerOver}" />
										<Setter Target="TrailingIconPresenter.Foreground" Value="{ThemeResource FilledButtonForegroundPointerOver}" />
									</VisualState.Setters>
								</VisualState>
								<VisualState x:Name="Pressed">
									<VisualState.Setters>
										<Setter Target="Root.Background" Value="{ThemeResource FilledButtonBackgroundPressed}" />
										<Setter Target="Root.BorderBrush" Value="{ThemeResource FilledButtonBorderBrushPressed}" />
										<Setter Target="ContentPresenter.Foreground" Value="{ThemeResource FilledButtonForegroundPressed}" />
										<Setter Target="LeadingIconPresenter.Foreground" Value="{ThemeResource FilledButtonForegroundPressed}" />
										<Setter Target="TrailingIconPresenter.Foreground" Value="{ThemeResource FilledButtonForegroundPressed}" />
									</VisualState.Setters>
								</VisualState>
								<VisualState x:Name="Disabled">
									<VisualState.Setters>
										<Setter Target="Root.Background" Value="{ThemeResource FilledButtonBackgroundDisabled}" />
										<Setter Target="Root.BorderBrush" Value="{ThemeResource FilledButtonBorderBrushDisabled}" />
										<Setter Target="ContentPresenter.Foreground" Value="{ThemeResource FilledButtonForegroundDisabled}" />
										<Setter Target="LeadingIconPresenter.Foreground" Value="{ThemeResource FilledButtonForegroundDisabled}" />
										<Setter Target="TrailingIconPresenter.Foreground" Value="{ThemeResource FilledButtonForegroundDisabled}" />
									</VisualState.Setters>
								</VisualState>
							</VisualStateGroup>
						</VisualStateManager.VisualStateGroups>

						<StackPanel Orientation="Horizontal"
									HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
									VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
									Spacing="{StaticResource SimpleButtonIconSpacing}">

							<ContentPresenter x:Name="LeadingIconPresenter"
											  Content="{Binding Path=(ut:ControlExtensions.LeadingIcon), RelativeSource={RelativeSource TemplatedParent}}"
											  Foreground="{TemplateBinding Foreground}"
											  Visibility="{Binding Path=(ut:ControlExtensions.LeadingIcon), RelativeSource={RelativeSource TemplatedParent}, Converter={StaticResource NullToCollapsedConverter}, FallbackValue=Collapsed, TargetNullValue=Collapsed}"
											  VerticalAlignment="Center" />

							<ContentPresenter x:Name="ContentPresenter"
											  Content="{TemplateBinding Content}"
											  ContentTemplate="{TemplateBinding ContentTemplate}"
											  ContentTransitions="{TemplateBinding ContentTransitions}"
											  Foreground="{TemplateBinding Foreground}"
											  HorizontalContentAlignment="{TemplateBinding HorizontalContentAlignment}"
											  VerticalContentAlignment="{TemplateBinding VerticalContentAlignment}" />

							<ContentPresenter x:Name="TrailingIconPresenter"
											  Content="{Binding Path=(ut:ControlExtensions.TrailingIcon), RelativeSource={RelativeSource TemplatedParent}}"
											  Foreground="{TemplateBinding Foreground}"
											  Visibility="{Binding Path=(ut:ControlExtensions.TrailingIcon), RelativeSource={RelativeSource TemplatedParent}, Converter={StaticResource NullToCollapsedConverter}, FallbackValue=Collapsed, TargetNullValue=Collapsed}"
											  VerticalAlignment="Center" />
						</StackPanel>
					</Grid>
				</ControlTemplate>
			</Setter.Value>
		</Setter>
	</Style>

	<!-- ═══════════════════════════════════════════════════════════════════════ -->
	<!-- Neutral Button -->
