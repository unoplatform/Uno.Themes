	<!-- IconButton Styles                                                     -->
	<!-- ═══════════════════════════════════════════════════════════════════════ -->
	<!--
		Simple Design System — IconButton Styles (targeting Button)
		Maps SDS IconButton component to WinUI Button with circular shape.

		SDS IconButton: inherits all Button variant tokens,
		overrides border-radius to radius-full (9999px) and uses square aspect ratio.

		Variants: Primary, Neutral, Subtle, DangerPrimary, DangerSubtle
		Sizes:    Small (default), Medium — configurable via SimpleTheme.DefaultSize
	-->

	<!-- ═══════════════════════════════════════════════════════════════════════ -->
	<!-- IconButton layout / sizing resources                                  -->
	<!-- Size-specific keys use explicit Small/Medium suffixes.                 -->
	<!-- Generic keys are defined in the SizeDefaults file.                     -->
	<!-- ═══════════════════════════════════════════════════════════════════════ -->
	<StaticResource x:Key="SimpleIconButtonCornerRadius" ResourceKey="SimpleRadiusFullCornerRadius" />      <!-- sds-size-radius-full = pill -->
	<StaticResource x:Key="SimpleIconButtonBorderThickness" ResourceKey="SimpleStrokeBorderThickness" />   <!-- sds-size-stroke-border = 1 px -->
	<StaticResource x:Key="SimpleIconButtonMediumPadding" ResourceKey="SimpleSpace200Thickness" />         <!-- sds-size-space-200 = 8 px -->
	<StaticResource x:Key="SimpleIconButtonSmallPadding" ResourceKey="SimpleSpace100Thickness" />          <!-- sds-size-space-100 = 4 px -->
	<StaticResource x:Key="SimpleIconButtonMediumMinSize" ResourceKey="SimpleIconLarge" />                 <!-- sds-size-icon-large = 40 px -->
	<StaticResource x:Key="SimpleIconButtonSmallMinSize" ResourceKey="SimpleIconMedium" />                 <!-- sds-size-icon-medium = 32 px -->

