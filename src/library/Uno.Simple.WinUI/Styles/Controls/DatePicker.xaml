			<!-- sds-size-icon-large -->
			<StaticResource x:Key="DatePickerFlyoutPresenterHighlightHeight" ResourceKey="SimpleIconLarge" />
			<!-- sds: no exact token (52) -->
			<x:Double x:Key="DatePickerFlyoutPresenterAcceptDismissHostGridHeight">52</x:Double>
			<!-- sds-size-stroke-border -->
			<StaticResource x:Key="DatePickerSpacerThemeWidth" ResourceKey="SimpleStrokeBorder" />
			<!-- sds-size-stroke-border -->
			<StaticResource x:Key="DatePickerFlyoutBorderThickness" ResourceKey="SimpleStrokeBorder" />
