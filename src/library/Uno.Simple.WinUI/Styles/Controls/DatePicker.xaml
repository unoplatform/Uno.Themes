<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
					xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

	<ResourceDictionary.ThemeDictionaries>
		<!-- Light Theme -->
		<ResourceDictionary x:Key="Light">
			<StaticResource x:Key="DatePickerFlyoutButtonBackground" ResourceKey="TransparentBrush" />

			<!-- Button chrome = Outlined input field -->
			<StaticResource x:Key="DatePickerButtonBackground" ResourceKey="SurfaceBrush" />
			<StaticResource x:Key="DatePickerButtonBackgroundPointerOver" ResourceKey="SurfaceBrush" />
			<StaticResource x:Key="DatePickerButtonBackgroundPressed" ResourceKey="SurfaceBrush" />
			<StaticResource x:Key="DatePickerButtonBackgroundDisabled" ResourceKey="DisabledBrush" />
			<StaticResource x:Key="DatePickerButtonForeground" ResourceKey="OnSurfaceBrush" />
			<StaticResource x:Key="DatePickerButtonForegroundPointerOver" ResourceKey="OnSurfaceBrush" />
			<StaticResource x:Key="DatePickerButtonForegroundPressed" ResourceKey="OnSurfaceBrush" />
			<StaticResource x:Key="DatePickerButtonForegroundDisabled" ResourceKey="OnSurfaceLowBrush" />
			<StaticResource x:Key="DatePickerButtonBorderBrush" ResourceKey="OutlineBrush" />
			<StaticResource x:Key="DatePickerButtonBorderBrushPointerOver" ResourceKey="OnSurfaceBrush" />
			<StaticResource x:Key="DatePickerButtonBorderBrushPressed" ResourceKey="PrimaryBrush" />
			<StaticResource x:Key="DatePickerButtonBorderBrushDisabled" ResourceKey="OnSurfaceLowBrush" />

			<!-- Date text within the button -->
			<StaticResource x:Key="DatePickerButtonDateTextForeground" ResourceKey="OnSurfaceBrush" />
			<StaticResource x:Key="DatePickerButtonDateTextForegroundPointerOver" ResourceKey="OnSurfaceBrush" />
			<StaticResource x:Key="DatePickerButtonDateTextForegroundPressed" ResourceKey="OnSurfaceBrush" />
			<StaticResource x:Key="DatePickerButtonDateTextForegroundDisabled" ResourceKey="OnSurfaceLowBrush" />

			<!-- Placeholder / Header -->
			<StaticResource x:Key="DatePickerPlaceholderTextForeground" ResourceKey="OnSurfaceMediumBrush" />
			<StaticResource x:Key="DatePickerHeaderForeground" ResourceKey="OnSurfaceBrush" />
			<StaticResource x:Key="DatePickerHeaderForegroundDisabled" ResourceKey="OnSurfaceLowBrush" />

			<!-- Column separator line -->
			<StaticResource x:Key="DatePickerSpacerFill" ResourceKey="OutlineBrush" />

			<!-- Flyout popup -->
			<StaticResource x:Key="DatePickerFlyoutPresenterBackground" ResourceKey="SurfaceBrush" />
			<StaticResource x:Key="DatePickerFlyoutPresenterBorderBrush" ResourceKey="OutlineBrush" />
			<StaticResource x:Key="DatePickerFlyoutPresenterSpacerFill" ResourceKey="OutlineBrush" />

			<!-- Highlight band -->
			<StaticResource x:Key="DatePickerFlyoutPresenterHighlightFill" ResourceKey="BackgroundTertiaryBrush" />

			<!-- Sizing -->
			<x:Double x:Key="DatePickerSpacerThemeWidth">1</x:Double>
			<x:Double x:Key="DatePickerFlyoutPresenterHighlightHeight">40</x:Double>
			<x:Double x:Key="DatePickerFlyoutPresenterAcceptDismissHostGridHeight">41</x:Double>
			<CornerRadius x:Key="DatePickerCornerRadius">8</CornerRadius>
			<Thickness x:Key="DatePickerHostPadding">0</Thickness>
		</ResourceDictionary>

		<!-- Dark Theme -->
		<ResourceDictionary x:Key="Default">
			<StaticResource x:Key="DatePickerFlyoutButtonBackground" ResourceKey="TransparentBrush" />

			<StaticResource x:Key="DatePickerButtonBackground" ResourceKey="SurfaceBrush" />
			<StaticResource x:Key="DatePickerButtonBackgroundPointerOver" ResourceKey="SurfaceBrush" />
			<StaticResource x:Key="DatePickerButtonBackgroundPressed" ResourceKey="SurfaceBrush" />
			<StaticResource x:Key="DatePickerButtonBackgroundDisabled" ResourceKey="DisabledBrush" />
			<StaticResource x:Key="DatePickerButtonForeground" ResourceKey="OnSurfaceBrush" />
			<StaticResource x:Key="DatePickerButtonForegroundPointerOver" ResourceKey="OnSurfaceBrush" />
			<StaticResource x:Key="DatePickerButtonForegroundPressed" ResourceKey="OnSurfaceBrush" />
			<StaticResource x:Key="DatePickerButtonForegroundDisabled" ResourceKey="OnSurfaceLowBrush" />
			<StaticResource x:Key="DatePickerButtonBorderBrush" ResourceKey="OutlineBrush" />
			<StaticResource x:Key="DatePickerButtonBorderBrushPointerOver" ResourceKey="OnSurfaceBrush" />
			<StaticResource x:Key="DatePickerButtonBorderBrushPressed" ResourceKey="PrimaryBrush" />
			<StaticResource x:Key="DatePickerButtonBorderBrushDisabled" ResourceKey="OnSurfaceLowBrush" />

			<StaticResource x:Key="DatePickerButtonDateTextForeground" ResourceKey="OnSurfaceBrush" />
			<StaticResource x:Key="DatePickerButtonDateTextForegroundPointerOver" ResourceKey="OnSurfaceBrush" />
			<StaticResource x:Key="DatePickerButtonDateTextForegroundPressed" ResourceKey="OnSurfaceBrush" />
			<StaticResource x:Key="DatePickerButtonDateTextForegroundDisabled" ResourceKey="OnSurfaceLowBrush" />

			<StaticResource x:Key="DatePickerPlaceholderTextForeground" ResourceKey="OnSurfaceMediumBrush" />
			<StaticResource x:Key="DatePickerHeaderForeground" ResourceKey="OnSurfaceBrush" />
			<StaticResource x:Key="DatePickerHeaderForegroundDisabled" ResourceKey="OnSurfaceLowBrush" />

			<StaticResource x:Key="DatePickerSpacerFill" ResourceKey="OutlineBrush" />

			<StaticResource x:Key="DatePickerFlyoutPresenterBackground" ResourceKey="SurfaceBrush" />
			<StaticResource x:Key="DatePickerFlyoutPresenterBorderBrush" ResourceKey="OutlineBrush" />
			<StaticResource x:Key="DatePickerFlyoutPresenterSpacerFill" ResourceKey="OutlineBrush" />
			<StaticResource x:Key="DatePickerFlyoutPresenterHighlightFill" ResourceKey="BackgroundTertiaryBrush" />

			<x:Double x:Key="DatePickerSpacerThemeWidth">1</x:Double>
			<x:Double x:Key="DatePickerFlyoutPresenterHighlightHeight">40</x:Double>
			<x:Double x:Key="DatePickerFlyoutPresenterAcceptDismissHostGridHeight">41</x:Double>
			<CornerRadius x:Key="DatePickerCornerRadius">8</CornerRadius>
			<Thickness x:Key="DatePickerHostPadding">0</Thickness>
		</ResourceDictionary>
	</ResourceDictionary.ThemeDictionaries>

	<Style x:Key="SimpleDatePickerStyle"
		   TargetType="DatePicker">
		<Setter Property="Foreground" Value="{ThemeResource OnSurfaceBrush}" />
		<Setter Property="Background" Value="{ThemeResource SurfaceBrush}" />
		<Setter Property="BorderBrush" Value="{ThemeResource OutlineBrush}" />
		<Setter Property="BorderThickness" Value="1" />
		<Setter Property="CornerRadius" Value="{ThemeResource DatePickerCornerRadius}" />
		<Setter Property="MinHeight" Value="40" />
		<Setter Property="HorizontalAlignment" Value="Stretch" />
	</Style>

	<Style x:Key="SimpleDefaultDatePickerStyle"
		   TargetType="DatePicker"
		   BasedOn="{StaticResource SimpleDatePickerStyle}" />

	<Style x:Key="SimpleDatePickerFlyoutPresenterStyle"
		   TargetType="DatePickerFlyoutPresenter">
		<Setter Property="Background" Value="{ThemeResource SurfaceBrush}" />
		<Setter Property="BorderBrush" Value="{ThemeResource OutlineBrush}" />
		<Setter Property="BorderThickness" Value="1" />
		<Setter Property="CornerRadius" Value="8" />
	</Style>

	<Style x:Key="SimpleDefaultDatePickerFlyoutPresenterStyle"
		   TargetType="DatePickerFlyoutPresenter"
		   BasedOn="{StaticResource SimpleDatePickerFlyoutPresenterStyle}" />
</ResourceDictionary>
