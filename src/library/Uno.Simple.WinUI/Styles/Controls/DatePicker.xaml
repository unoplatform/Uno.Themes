		<!-- ─── Light Theme ─── -->
		<ResourceDictionary x:Key="Light">

			<!-- ── FlyoutButton (transparent wrapper) — semantic keys (source of truth) ── -->
			<StaticResource x:Key="DatePickerFlyoutButtonBackground" ResourceKey="SystemControlTransparentBrush" />
			<!-- Backwards-compat alias -->
			<StaticResource x:Key="SimpleDatePickerFlyoutButtonBackground" ResourceKey="DatePickerFlyoutButtonBackground" />

			<!-- ── FlyoutPresenter — semantic keys (source of truth) ── -->
			<StaticResource x:Key="DatePickerFlyoutPresenterBackground"  ResourceKey="SimpleBackgroundDefaultDefaultBrush" />
			<StaticResource x:Key="DatePickerFlyoutPresenterBorderBrush" ResourceKey="SimpleBorderDefaultDefaultBrush" />
			<StaticResource x:Key="DatePickerFlyoutPresenterSpacerFill"  ResourceKey="SimpleBorderDefaultDefaultBrush" />
			<StaticResource x:Key="DatePickerFlyoutPresenterHighlightFill" ResourceKey="SimpleBackgroundBrandTertiaryBrush" />
			<!-- sds-size-radius-400 -->
			<StaticResource x:Key="DatePickerFlyoutPresenterCornerRadius" ResourceKey="SimpleRadius400CornerRadius" />
			<!-- sds: no exact token (296) -->
			<x:Double x:Key="DatePickerFlyoutPresenterWidth">296</x:Double>
			<!-- sds: no exact token (296) -->
			<x:Double x:Key="DatePickerFlyoutPresenterMinWidth">296</x:Double>
			<!-- sds: no exact token (398) -->
