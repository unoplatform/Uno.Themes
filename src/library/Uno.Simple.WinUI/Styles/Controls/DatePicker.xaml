<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
					xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
					xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
					xmlns:not_win="http://uno.ui/not_win"
					xmlns:ut="using:Uno.Themes"
					mc:Ignorable="not_win">

	<!--
		Simple Design System — DatePicker Style
		Inspired by CalendarDatePicker field appearance with SDS design tokens.

		SDS DatePicker CSS mapping:
		  Field:       background-default-default bg, border-default-default border, radius-200 (8px), text-default-default
		  Hover:       same as normal (SDS field doesn't change on hover)
		  Disabled:    background-disabled-default, border-disabled-default, text-disabled-default
		  Placeholder: text-default-tertiary
		  Header:      text-default-default
		  Date text:   text-default-default, disabled → text-disabled-default
		  Flyout:      background-default-default, border-default-default, radius-400 (16px), shadow

		Lightweight styling pattern: every visual-state brush is exposed via
		ThemeResource so consumers can override any individual key.
	-->

	<!-- ═══════════════════════════════════════════════════════════════════════ -->
	<!-- Lightweight styling ThemeResource aliases                              -->
	<!-- ═══════════════════════════════════════════════════════════════════════ -->
	<ResourceDictionary.ThemeDictionaries>

		<!-- ─── Light Theme ─── -->
		<ResourceDictionary x:Key="Light">

			<!-- FlyoutButton (transparent wrapper) -->
			<StaticResource x:Key="SimpleDatePickerFlyoutButtonBackground" ResourceKey="SystemControlTransparentBrush" />

			<!-- FlyoutPresenter -->
			<StaticResource x:Key="SimpleDatePickerFlyoutPresenterBackground"  ResourceKey="SimpleBackgroundDefaultDefaultBrush" />
			<StaticResource x:Key="SimpleDatePickerFlyoutPresenterBorderBrush" ResourceKey="SimpleBorderDefaultDefaultBrush" />
			<StaticResource x:Key="SimpleDatePickerFlyoutPresenterSpacerFill"  ResourceKey="SimpleBorderDefaultDefaultBrush" />
			<StaticResource x:Key="SimpleDatePickerFlyoutPresenterHighlightFill" ResourceKey="SimpleBackgroundBrandTertiaryBrush" />
			<!-- sds-size-radius-400 -->
			<StaticResource x:Key="SimpleDatePickerFlyoutPresenterCornerRadius" ResourceKey="SimpleRadius400CornerRadius" />
			<!-- sds: no exact token (296) -->
			<x:Double x:Key="SimpleDatePickerFlyoutPresenterWidth">296</x:Double>
			<!-- sds: no exact token (296) -->
			<x:Double x:Key="SimpleDatePickerFlyoutPresenterMinWidth">296</x:Double>
			<!-- sds: no exact token (398) -->
			<x:Double x:Key="SimpleDatePickerFlyoutPresenterMaxHeight">398</x:Double>
			<!-- sds-size-icon-large -->
			<StaticResource x:Key="SimpleDatePickerFlyoutPresenterHighlightHeight" ResourceKey="SimpleIconLarge" />
			<!-- sds: no exact token (52) -->
			<x:Double x:Key="SimpleDatePickerFlyoutPresenterAcceptDismissHostGridHeight">52</x:Double>
			<!-- sds-size-stroke-border -->
			<StaticResource x:Key="SimpleDatePickerSpacerThemeWidth" ResourceKey="SimpleStrokeBorder" />
			<!-- sds-size-stroke-border -->
			<StaticResource x:Key="SimpleDatePickerFlyoutBorderThickness" ResourceKey="SimpleStrokeBorder" />

			<!-- Typography -->
			<StaticResource x:Key="SimpleDatePickerFlyoutPresenterFontFamily" ResourceKey="SimpleFontFamily" />

			<!-- DatePicker Button (field appearance) -->
			<StaticResource x:Key="SimpleDatePickerButtonBackground"              ResourceKey="SimpleBackgroundDefaultDefaultBrush" />
			<StaticResource x:Key="SimpleDatePickerButtonBackgroundPointerOver"   ResourceKey="SimpleBackgroundDefaultDefaultBrush" />
			<StaticResource x:Key="SimpleDatePickerButtonBackgroundPressed"       ResourceKey="SimpleBackgroundDefaultDefaultBrush" />
			<StaticResource x:Key="SimpleDatePickerButtonBackgroundDisabled"      ResourceKey="SimpleBackgroundDisabledDefaultBrush" />

			<StaticResource x:Key="SimpleDatePickerButtonForeground"              ResourceKey="SimpleTextDefaultDefaultBrush" />
			<StaticResource x:Key="SimpleDatePickerButtonForegroundPointerOver"   ResourceKey="SimpleTextDefaultDefaultBrush" />
			<StaticResource x:Key="SimpleDatePickerButtonForegroundPressed"       ResourceKey="SimpleTextDefaultDefaultBrush" />
			<StaticResource x:Key="SimpleDatePickerButtonForegroundDisabled"      ResourceKey="SimpleTextDisabledDefaultBrush" />

			<StaticResource x:Key="SimpleDatePickerButtonBorderBrush"             ResourceKey="SimpleBorderDefaultDefaultBrush" />
			<StaticResource x:Key="SimpleDatePickerButtonBorderBrushPointerOver"  ResourceKey="SimpleBorderDefaultDefaultBrush" />
			<StaticResource x:Key="SimpleDatePickerButtonBorderBrushPressed"      ResourceKey="SimpleBorderDefaultDefaultBrush" />
			<StaticResource x:Key="SimpleDatePickerButtonBorderBrushDisabled"     ResourceKey="SimpleBorderDisabledDefaultBrush" />

			<!-- Date text -->
			<StaticResource x:Key="SimpleDatePickerButtonDateTextForeground"             ResourceKey="SimpleTextDefaultDefaultBrush" />
			<StaticResource x:Key="SimpleDatePickerButtonDateTextForegroundPointerOver"  ResourceKey="SimpleTextDefaultDefaultBrush" />
			<StaticResource x:Key="SimpleDatePickerButtonDateTextForegroundPressed"      ResourceKey="SimpleTextDefaultDefaultBrush" />
			<StaticResource x:Key="SimpleDatePickerButtonDateTextForegroundDisabled"     ResourceKey="SimpleTextDisabledDefaultBrush" />

			<!-- Placeholder text -->
			<StaticResource x:Key="SimpleDatePickerPlaceholderTextForeground" ResourceKey="SimpleTextDefaultTertiaryBrush" />

			<!-- Header -->
			<StaticResource x:Key="SimpleDatePickerHeaderForeground"          ResourceKey="SimpleTextDefaultDefaultBrush" />
			<StaticResource x:Key="SimpleDatePickerHeaderForegroundDisabled"  ResourceKey="SimpleTextDisabledDefaultBrush" />

			<!-- Dimensions -->
			<!-- sds-size-radius-200 -->
			<StaticResource x:Key="SimpleDatePickerCornerRadius" ResourceKey="SimpleRadius200CornerRadius" />
			<!-- sds-size-stroke-border -->
			<StaticResource x:Key="SimpleDatePickerBorderThemeThickness" ResourceKey="SimpleStrokeBorderThickness" />
			<!-- sds-size-space-400,10,sds-size-space-400,10 -->
			<Thickness x:Key="SimpleDatePickerContentMargin">16,10,16,10</Thickness>
			<!-- sds-size-space-0 -->
			<StaticResource x:Key="SimpleDatePickerFlyoutButtonPadding" ResourceKey="SimpleSpace0Thickness" />
			<!-- sds: no exact token (44) -->
			<x:Double x:Key="SimpleDatePickerMinHeight">44</x:Double>
			<x:Double x:Key="SimpleDatePickerFlyoutButtonOpacityPressed">0.8</x:Double>
			<x:Double x:Key="SimpleDatePickerFlyoutButtonOpacityDisabled">0.5</x:Double>
			<!-- sds: 0,0,0,sds-size-space-100 -->
			<Thickness x:Key="SimpleDatePickerHeaderMargin">0,0,0,4</Thickness>

		</ResourceDictionary>

		<!-- ─── Dark Theme (Default) ─── -->
		<ResourceDictionary x:Key="Default">

			<!-- FlyoutButton (transparent wrapper) -->
			<StaticResource x:Key="SimpleDatePickerFlyoutButtonBackground" ResourceKey="SystemControlTransparentBrush" />

			<!-- FlyoutPresenter -->
			<StaticResource x:Key="SimpleDatePickerFlyoutPresenterBackground"  ResourceKey="SimpleBackgroundDefaultDefaultBrush" />
			<StaticResource x:Key="SimpleDatePickerFlyoutPresenterBorderBrush" ResourceKey="SimpleBorderDefaultDefaultBrush" />
			<StaticResource x:Key="SimpleDatePickerFlyoutPresenterSpacerFill"  ResourceKey="SimpleBorderDefaultDefaultBrush" />
			<StaticResource x:Key="SimpleDatePickerFlyoutPresenterHighlightFill" ResourceKey="SimpleBackgroundBrandTertiaryBrush" />
			<!-- sds-size-radius-400 -->
			<StaticResource x:Key="SimpleDatePickerFlyoutPresenterCornerRadius" ResourceKey="SimpleRadius400CornerRadius" />
			<!-- sds: no exact token (296) -->
			<x:Double x:Key="SimpleDatePickerFlyoutPresenterWidth">296</x:Double>
			<!-- sds: no exact token (296) -->
			<x:Double x:Key="SimpleDatePickerFlyoutPresenterMinWidth">296</x:Double>
			<!-- sds: no exact token (398) -->
			<x:Double x:Key="SimpleDatePickerFlyoutPresenterMaxHeight">398</x:Double>
			<!-- sds-size-icon-large -->
			<StaticResource x:Key="SimpleDatePickerFlyoutPresenterHighlightHeight" ResourceKey="SimpleIconLarge" />
			<!-- sds: no exact token (52) -->
			<x:Double x:Key="SimpleDatePickerFlyoutPresenterAcceptDismissHostGridHeight">52</x:Double>
			<!-- sds-size-stroke-border -->
			<StaticResource x:Key="SimpleDatePickerSpacerThemeWidth" ResourceKey="SimpleStrokeBorder" />
			<!-- sds-size-stroke-border -->
			<StaticResource x:Key="SimpleDatePickerFlyoutBorderThickness" ResourceKey="SimpleStrokeBorder" />

			<!-- Typography -->
			<StaticResource x:Key="SimpleDatePickerFlyoutPresenterFontFamily" ResourceKey="SimpleFontFamily" />

			<!-- DatePicker Button (field appearance) -->
			<StaticResource x:Key="SimpleDatePickerButtonBackground"              ResourceKey="SimpleBackgroundDefaultDefaultBrush" />
			<StaticResource x:Key="SimpleDatePickerButtonBackgroundPointerOver"   ResourceKey="SimpleBackgroundDefaultDefaultBrush" />
			<StaticResource x:Key="SimpleDatePickerButtonBackgroundPressed"       ResourceKey="SimpleBackgroundDefaultDefaultBrush" />
			<StaticResource x:Key="SimpleDatePickerButtonBackgroundDisabled"      ResourceKey="SimpleBackgroundDisabledDefaultBrush" />

			<StaticResource x:Key="SimpleDatePickerButtonForeground"              ResourceKey="SimpleTextDefaultDefaultBrush" />
			<StaticResource x:Key="SimpleDatePickerButtonForegroundPointerOver"   ResourceKey="SimpleTextDefaultDefaultBrush" />
			<StaticResource x:Key="SimpleDatePickerButtonForegroundPressed"       ResourceKey="SimpleTextDefaultDefaultBrush" />
			<StaticResource x:Key="SimpleDatePickerButtonForegroundDisabled"      ResourceKey="SimpleTextDisabledDefaultBrush" />

			<StaticResource x:Key="SimpleDatePickerButtonBorderBrush"             ResourceKey="SimpleBorderDefaultDefaultBrush" />
			<StaticResource x:Key="SimpleDatePickerButtonBorderBrushPointerOver"  ResourceKey="SimpleBorderDefaultDefaultBrush" />
			<StaticResource x:Key="SimpleDatePickerButtonBorderBrushPressed"      ResourceKey="SimpleBorderDefaultDefaultBrush" />
			<StaticResource x:Key="SimpleDatePickerButtonBorderBrushDisabled"     ResourceKey="SimpleBorderDisabledDefaultBrush" />

			<!-- Date text -->
			<StaticResource x:Key="SimpleDatePickerButtonDateTextForeground"             ResourceKey="SimpleTextDefaultDefaultBrush" />
			<StaticResource x:Key="SimpleDatePickerButtonDateTextForegroundPointerOver"  ResourceKey="SimpleTextDefaultDefaultBrush" />
			<StaticResource x:Key="SimpleDatePickerButtonDateTextForegroundPressed"      ResourceKey="SimpleTextDefaultDefaultBrush" />
			<StaticResource x:Key="SimpleDatePickerButtonDateTextForegroundDisabled"     ResourceKey="SimpleTextDisabledDefaultBrush" />

			<!-- Placeholder text -->
			<StaticResource x:Key="SimpleDatePickerPlaceholderTextForeground" ResourceKey="SimpleTextDefaultTertiaryBrush" />

			<!-- Header -->
			<StaticResource x:Key="SimpleDatePickerHeaderForeground"          ResourceKey="SimpleTextDefaultDefaultBrush" />
			<StaticResource x:Key="SimpleDatePickerHeaderForegroundDisabled"  ResourceKey="SimpleTextDisabledDefaultBrush" />

			<!-- Dimensions -->
			<!-- sds-size-radius-200 -->
			<StaticResource x:Key="SimpleDatePickerCornerRadius" ResourceKey="SimpleRadius200CornerRadius" />
			<!-- sds-size-stroke-border -->
			<StaticResource x:Key="SimpleDatePickerBorderThemeThickness" ResourceKey="SimpleStrokeBorderThickness" />
			<!-- sds-size-space-400,10,sds-size-space-400,10 -->
			<Thickness x:Key="SimpleDatePickerContentMargin">16,10,16,10</Thickness>
			<!-- sds-size-space-0 -->
			<StaticResource x:Key="SimpleDatePickerFlyoutButtonPadding" ResourceKey="SimpleSpace0Thickness" />
			<!-- sds: no exact token (44) -->
			<x:Double x:Key="SimpleDatePickerMinHeight">44</x:Double>
			<x:Double x:Key="SimpleDatePickerFlyoutButtonOpacityPressed">0.8</x:Double>
			<x:Double x:Key="SimpleDatePickerFlyoutButtonOpacityDisabled">0.5</x:Double>
			<!-- sds: 0,0,0,sds-size-space-100 -->
			<Thickness x:Key="SimpleDatePickerHeaderMargin">0,0,0,4</Thickness>

		</ResourceDictionary>

	</ResourceDictionary.ThemeDictionaries>

	<!-- Local converter for formatting the SelectedDate -->
	<ut:StringFormatConverter x:Key="SimpleDatePickerStringFormatConverter" />

	<!-- ═══════════════════════════════════════════════════════════════════════ -->
	<!-- SimpleDatePickerFlyoutButtonStyle                                      -->
	<!-- Transparent wrapper — visual field is rendered by DatePicker template  -->
	<!-- ═══════════════════════════════════════════════════════════════════════ -->
	<Style x:Key="SimpleDatePickerFlyoutButtonStyle"
		   TargetType="Button">

		<Setter Property="Background" Value="{ThemeResource SimpleDatePickerFlyoutButtonBackground}" />
		<Setter Property="Padding" Value="{ThemeResource SimpleDatePickerFlyoutButtonPadding}" />

		<Setter Property="Template">
			<Setter.Value>
				<ControlTemplate TargetType="Button">
					<Grid x:Name="RootGrid"
						  Background="{TemplateBinding Background}">

						<ContentPresenter x:Name="ContentPresenter"
										  Margin="{TemplateBinding Padding}"
										  HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
										  VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
										  AutomationProperties.AccessibilityView="Raw"
										  Content="{TemplateBinding Content}"
										  ContentTemplate="{TemplateBinding ContentTemplate}"
										  ContentTransitions="{TemplateBinding ContentTransitions}" />

						<VisualStateManager.VisualStateGroups>
							<VisualStateGroup x:Name="CommonStates">
								<VisualState x:Name="Normal" />
								<VisualState x:Name="PointerOver" />
								<VisualState x:Name="Pressed">
									<VisualState.Setters>
										<Setter Target="RootGrid.Opacity" Value="{ThemeResource SimpleDatePickerFlyoutButtonOpacityPressed}" />
									</VisualState.Setters>
								</VisualState>
								<VisualState x:Name="Disabled">
									<VisualState.Setters>
										<Setter Target="RootGrid.Opacity" Value="{ThemeResource SimpleDatePickerFlyoutButtonOpacityDisabled}" />
									</VisualState.Setters>
								</VisualState>
							</VisualStateGroup>
						</VisualStateManager.VisualStateGroups>
					</Grid>
				</ControlTemplate>
			</Setter.Value>
		</Setter>
	</Style>

	<!-- ═══════════════════════════════════════════════════════════════════════ -->
	<!-- SimpleDatePickerFlyoutPresenterStyle                                   -->
	<!-- Flyout panel with day/month/year columns + accept/dismiss buttons      -->
	<!-- ═══════════════════════════════════════════════════════════════════════ -->
	<Style x:Key="SimpleDatePickerFlyoutPresenterStyle"
		   TargetType="DatePickerFlyoutPresenter">

		<Setter Property="Width" Value="{ThemeResource SimpleDatePickerFlyoutPresenterWidth}" />
		<Setter Property="MinWidth" Value="{ThemeResource SimpleDatePickerFlyoutPresenterMinWidth}" />
		<Setter Property="MaxHeight" Value="{ThemeResource SimpleDatePickerFlyoutPresenterMaxHeight}" />
		<Setter Property="IsTabStop" Value="False" />
		<Setter Property="FontFamily" Value="{ThemeResource SimpleDatePickerFlyoutPresenterFontFamily}" />
		<Setter Property="FontWeight" Value="Normal" />
		<Setter Property="FontSize" Value="{ThemeResource SimpleTypographyScale03}" />
		<Setter Property="Background" Value="{ThemeResource SimpleDatePickerFlyoutPresenterBackground}" />
		<Setter Property="AutomationProperties.AutomationId" Value="DatePickerFlyoutPresenter" />
		<Setter Property="BorderThickness" Value="{ThemeResource SimpleDatePickerFlyoutBorderThickness}" />
		<Setter Property="BorderBrush" Value="{ThemeResource SimpleDatePickerFlyoutPresenterBorderBrush}" />
		<Setter Property="CornerRadius" Value="{ThemeResource SimpleDatePickerFlyoutPresenterCornerRadius}" />

		<Setter Property="Template">
			<Setter.Value>
				<ControlTemplate TargetType="DatePickerFlyoutPresenter">
					<Border x:Name="Background"
							MaxHeight="{TemplateBinding MaxHeight}"
							Background="{TemplateBinding Background}"
							BorderBrush="{TemplateBinding BorderBrush}"
							BorderThickness="{TemplateBinding BorderThickness}"
							CornerRadius="{TemplateBinding CornerRadius}">

						<Grid x:Name="ContentPanel">
							<Grid.RowDefinitions>
								<RowDefinition Height="*" />
								<RowDefinition Height="Auto" />
							</Grid.RowDefinitions>

							<!-- Picker columns -->
							<Grid x:Name="PickerHostGrid">
								<Grid.ColumnDefinitions>
									<ColumnDefinition x:Name="DayColumn"
													  Width="78*" />
									<ColumnDefinition x:Name="FirstSpacerColumn"
													  Width="Auto" />
									<ColumnDefinition x:Name="MonthColumn"
													  Width="132*" />
									<ColumnDefinition x:Name="SecondSpacerColumn"
													  Width="Auto" />
									<ColumnDefinition x:Name="YearColumn"
													  Width="78*" />
								</Grid.ColumnDefinitions>

								<!-- Selection highlight -->
								<!-- sds: RadiusX/RadiusY=8 maps to sds-size-radius-200 (double, not CornerRadius type) -->
								<Rectangle x:Name="HighlightRect"
										   Grid.Column="0"
										   Grid.ColumnSpan="5"
										   Height="{ThemeResource SimpleDatePickerFlyoutPresenterHighlightHeight}"
										   VerticalAlignment="Center"
										   Fill="{ThemeResource SimpleDatePickerFlyoutPresenterHighlightFill}"
										   RadiusX="8"
										   RadiusY="8" />

								<!-- Column spacers -->
								<Rectangle x:Name="FirstPickerSpacing"
										   Grid.Column="1"
										   Width="{ThemeResource SimpleDatePickerSpacerThemeWidth}"
										   HorizontalAlignment="Center"
										   Fill="{ThemeResource SimpleDatePickerFlyoutPresenterSpacerFill}" />

								<Rectangle x:Name="SecondPickerSpacing"
										   Grid.Column="3"
										   Width="{ThemeResource SimpleDatePickerSpacerThemeWidth}"
										   HorizontalAlignment="Center"
										   Fill="{ThemeResource SimpleDatePickerFlyoutPresenterSpacerFill}" />
							</Grid>

							<!-- Accept / Dismiss buttons -->
							<Grid x:Name="AcceptDismissHostGrid"
								  Grid.Row="1"
								  Height="{ThemeResource SimpleDatePickerFlyoutPresenterAcceptDismissHostGridHeight}"
								  VerticalAlignment="Bottom"
								  Background="{TemplateBinding Background}">

								<Grid.ColumnDefinitions>
									<ColumnDefinition Width="*" />
									<ColumnDefinition Width="Auto" />
									<ColumnDefinition Width="Auto" />
								</Grid.ColumnDefinitions>

								<!-- Top separator line -->
								<Rectangle Grid.ColumnSpan="3"
										   Height="{ThemeResource SimpleDatePickerSpacerThemeWidth}"
										   VerticalAlignment="Top"
										   Fill="{ThemeResource SimpleDatePickerFlyoutPresenterSpacerFill}" />

								<Button x:Name="DismissButton"
										x:Uid="DatePickerFlyoutDismissButton"
										Grid.Column="1"
										HorizontalAlignment="Right"
										VerticalAlignment="Center"
										Content="Cancel"
										Style="{StaticResource SimpleSubtleButtonStyle}" />

								<Button x:Name="AcceptButton"
										x:Uid="DatePickerFlyoutAcceptButton"
										Grid.Column="2"
										HorizontalAlignment="Right"
										VerticalAlignment="Center"
										Content="OK"
										Style="{StaticResource SimpleSubtleButtonStyle}" />
							</Grid>
						</Grid>
					</Border>
				</ControlTemplate>
			</Setter.Value>
		</Setter>
	</Style>

	<!-- ═══════════════════════════════════════════════════════════════════════ -->
	<!-- SimpleDatePickerStyle                                                  -->
	<!-- Field-like appearance inspired by CalendarDatePicker                   -->
	<!-- ═══════════════════════════════════════════════════════════════════════ -->
	<Style x:Key="SimpleDatePickerStyle"
		   TargetType="DatePicker">

		<Setter Property="Background" Value="{ThemeResource SimpleDatePickerButtonBackground}" />
		<Setter Property="Foreground" Value="{ThemeResource SimpleDatePickerButtonForeground}" />
		<Setter Property="BorderBrush" Value="{ThemeResource SimpleDatePickerButtonBorderBrush}" />
		<Setter Property="BorderThickness" Value="{ThemeResource SimpleDatePickerBorderThemeThickness}" />
		<Setter Property="HorizontalAlignment" Value="Stretch" />
		<Setter Property="MinHeight" Value="{ThemeResource SimpleDatePickerMinHeight}" />
		<Setter Property="CornerRadius" Value="{ThemeResource SimpleDatePickerCornerRadius}" />
		<Setter Property="FontFamily" Value="{ThemeResource SimpleFontFamily}" />
		<Setter Property="FontSize" Value="{ThemeResource SimpleTypographyScale03}" />
		<Setter Property="UseSystemFocusVisuals" Value="{StaticResource UseSystemFocusVisuals}" />
		<not_win:Setter Property="FlyoutPresenterStyle"
					    Value="{StaticResource SimpleDatePickerFlyoutPresenterStyle}" />

		<Setter Property="Template">
			<Setter.Value>
				<ControlTemplate TargetType="DatePicker">
					<!-- Root Grid -->
					<Grid x:Name="LayoutRoot">

						<Grid.RowDefinitions>
							<RowDefinition Height="Auto" />
							<RowDefinition Height="Auto" />
						</Grid.RowDefinitions>

						<!-- Header (above the field) -->
						<ContentPresenter x:Name="HeaderContentPresenter"
										  Grid.Row="0"
										  Content="{TemplateBinding Header}"
										  ContentTemplate="{TemplateBinding HeaderTemplate}"
										  Foreground="{ThemeResource SimpleDatePickerHeaderForeground}"
										  FontSize="{ThemeResource SimpleTypographyScale02}"
										  FontFamily="{ThemeResource SimpleFontFamily}"
										  FontWeight="SemiBold"
										  TextWrapping="Wrap"
										  Margin="{ThemeResource SimpleDatePickerHeaderMargin}"
										  Visibility="Collapsed"
										  AutomationProperties.AccessibilityView="Raw" />

						<!-- Flyout Button -->
						<Button x:Name="FlyoutButton"
								Grid.Row="1"
								HorizontalAlignment="Stretch"
								HorizontalContentAlignment="Stretch"
								IsEnabled="{TemplateBinding IsEnabled}"
								Style="{StaticResource SimpleDatePickerFlyoutButtonStyle}"
								UseSystemFocusVisuals="{TemplateBinding UseSystemFocusVisuals}">

							<Grid x:Name="ContentButton">

								<!-- Field border -->
								<Border x:Name="Background"
										Background="{TemplateBinding Background}"
										BorderBrush="{TemplateBinding BorderBrush}"
										BorderThickness="{TemplateBinding BorderThickness}"
										CornerRadius="{TemplateBinding CornerRadius}"
										MinHeight="{TemplateBinding MinHeight}" />

								<!-- Content -->
								<Grid Margin="{ThemeResource SimpleDatePickerContentMargin}"
									  VerticalAlignment="Center">

									<!-- Date text row -->
									<Grid x:Name="FlyoutButtonContentGrid"
										  VerticalAlignment="Center">

										<!-- Formatted date text -->
										<TextBlock x:Name="DateText"
												   Foreground="{ThemeResource SimpleDatePickerButtonDateTextForeground}"
												   FontSize="{TemplateBinding FontSize}"
												   FontFamily="{TemplateBinding FontFamily}"
												   VerticalAlignment="Center"
												   Text="{Binding SelectedDate, RelativeSource={RelativeSource TemplatedParent}, Converter={StaticResource SimpleDatePickerStringFormatConverter}, ConverterParameter=' {0:d}'}" />

										<!-- Placeholder text (shown when no date) -->
										<TextBlock x:Name="PlaceholderText"
												   Foreground="{ThemeResource SimpleDatePickerPlaceholderTextForeground}"
												   FontSize="{TemplateBinding FontSize}"
												   FontFamily="{TemplateBinding FontFamily}"
												   VerticalAlignment="Center"
												   Text="{TemplateBinding Header}"
												   Visibility="Collapsed" />

										<!-- Hidden required named part -->
										<TextBlock x:Name="DayTextBlock"
												   Opacity="0" />
									</Grid>
								</Grid>
							</Grid>
						</Button>

						<VisualStateManager.VisualStateGroups>
							<VisualStateGroup x:Name="CommonStates">
								<VisualState x:Name="Normal" />

								<VisualState x:Name="PointerOver">
									<VisualState.Setters>
										<Setter Target="Background.Background" Value="{ThemeResource SimpleDatePickerButtonBackgroundPointerOver}" />
										<Setter Target="Background.BorderBrush" Value="{ThemeResource SimpleDatePickerButtonBorderBrushPointerOver}" />
										<Setter Target="DateText.Foreground" Value="{ThemeResource SimpleDatePickerButtonDateTextForegroundPointerOver}" />
										<Setter Target="HeaderContentPresenter.Foreground" Value="{ThemeResource SimpleDatePickerButtonForegroundPointerOver}" />
									</VisualState.Setters>
								</VisualState>

								<VisualState x:Name="Pressed">
									<VisualState.Setters>
										<Setter Target="Background.Background" Value="{ThemeResource SimpleDatePickerButtonBackgroundPressed}" />
										<Setter Target="Background.BorderBrush" Value="{ThemeResource SimpleDatePickerButtonBorderBrushPressed}" />
										<Setter Target="DateText.Foreground" Value="{ThemeResource SimpleDatePickerButtonDateTextForegroundPressed}" />
										<Setter Target="HeaderContentPresenter.Foreground" Value="{ThemeResource SimpleDatePickerButtonForegroundPressed}" />
									</VisualState.Setters>
								</VisualState>

								<VisualState x:Name="Disabled">
									<VisualState.Setters>
										<Setter Target="Background.Background" Value="{ThemeResource SimpleDatePickerButtonBackgroundDisabled}" />
										<Setter Target="Background.BorderBrush" Value="{ThemeResource SimpleDatePickerButtonBorderBrushDisabled}" />
										<Setter Target="DateText.Foreground" Value="{ThemeResource SimpleDatePickerButtonDateTextForegroundDisabled}" />
										<Setter Target="HeaderContentPresenter.Foreground" Value="{ThemeResource SimpleDatePickerHeaderForegroundDisabled}" />
									</VisualState.Setters>
								</VisualState>
							</VisualStateGroup>

							<VisualStateGroup x:Name="HasDateStates">
								<VisualState x:Name="HasDate" />
								<VisualState x:Name="HasNoDate">
									<VisualState.Setters>
										<Setter Target="DateText.Visibility" Value="Collapsed" />
										<Setter Target="PlaceholderText.Visibility" Value="Visible" />
									</VisualState.Setters>
								</VisualState>
							</VisualStateGroup>
						</VisualStateManager.VisualStateGroups>
					</Grid>
				</ControlTemplate>
			</Setter.Value>
		</Setter>
	</Style>

	<!-- ═══════════════════════════════════════════════════════════════════════ -->
	<!-- Default aliases (for implicit styles)                                  -->
	<!-- ═══════════════════════════════════════════════════════════════════════ -->
	<Style x:Key="SimpleDefaultDatePickerStyle"
		   TargetType="DatePicker"
		   BasedOn="{StaticResource SimpleDatePickerStyle}" />

	<Style x:Key="SimpleDefaultDatePickerFlyoutPresenterStyle"
		   TargetType="DatePickerFlyoutPresenter"
		   BasedOn="{StaticResource SimpleDatePickerFlyoutPresenterStyle}" />

</ResourceDictionary>
