<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
					xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

	<!--
		Simple Design System — RatingControl Style
		Star (or similar) rating icons using Simple's icon and accent color tokens.
		Supports filled, empty, and placeholder states, plus read-only and interactive modes.

		Resource layers:
		  RatingControl*       = semantic keys (source of truth)
		  SimpleRatingControl* = Simple-prefixed aliases → RatingControl*
	-->

	<ResourceDictionary.ThemeDictionaries>

		<!-- ─── Light Theme ─── -->
		<ResourceDictionary x:Key="Light">
			<StaticResource x:Key="RatingControlForeground" ResourceKey="SimpleBackgroundBrandDefaultBrush" />
			<StaticResource x:Key="RatingControlSelectedForeground" ResourceKey="SimpleBackgroundBrandDefaultBrush" />
			<StaticResource x:Key="RatingControlUnselectedForeground" ResourceKey="SimpleIconDefaultSecondaryBrush" />
			<StaticResource x:Key="RatingControlPlaceholderForeground" ResourceKey="SimpleIconDefaultSecondaryBrush" />
			<StaticResource x:Key="RatingControlPointerOverPlaceholderForeground" ResourceKey="SimpleBackgroundBrandDefaultBrush" />
			<StaticResource x:Key="RatingControlPointerOverSelectedForeground" ResourceKey="SimpleBackgroundBrandHoverBrush" />
			<StaticResource x:Key="RatingControlPointerOverUnselectedForeground" ResourceKey="SimpleIconDefaultTertiaryBrush" />
			<StaticResource x:Key="RatingControlDisabledSelectedForeground" ResourceKey="SimpleBackgroundDisabledDefaultBrush" />
			<StaticResource x:Key="RatingControlCaptionForeground" ResourceKey="SimpleTextDefaultSecondaryBrush" />

			<!-- Backwards-compat aliases -->
			<StaticResource x:Key="SimpleRatingControlForeground" ResourceKey="RatingControlForeground" />
			<StaticResource x:Key="SimpleRatingControlSelectedForeground" ResourceKey="RatingControlSelectedForeground" />
			<StaticResource x:Key="SimpleRatingControlUnselectedForeground" ResourceKey="RatingControlUnselectedForeground" />
			<StaticResource x:Key="SimpleRatingControlPlaceholderForeground" ResourceKey="RatingControlPlaceholderForeground" />
			<StaticResource x:Key="SimpleRatingControlCaptionForeground" ResourceKey="RatingControlCaptionForeground" />
		</ResourceDictionary>

		<!-- ─── Dark Theme (Default) ─── -->
		<ResourceDictionary x:Key="Default">
			<StaticResource x:Key="RatingControlForeground" ResourceKey="SimpleBackgroundBrandDefaultBrush" />
			<StaticResource x:Key="RatingControlSelectedForeground" ResourceKey="SimpleBackgroundBrandDefaultBrush" />
			<StaticResource x:Key="RatingControlUnselectedForeground" ResourceKey="SimpleIconDefaultSecondaryBrush" />
			<StaticResource x:Key="RatingControlPlaceholderForeground" ResourceKey="SimpleIconDefaultSecondaryBrush" />
			<StaticResource x:Key="RatingControlPointerOverPlaceholderForeground" ResourceKey="SimpleBackgroundBrandDefaultBrush" />
			<StaticResource x:Key="RatingControlPointerOverSelectedForeground" ResourceKey="SimpleBackgroundBrandHoverBrush" />
			<StaticResource x:Key="RatingControlPointerOverUnselectedForeground" ResourceKey="SimpleIconDefaultTertiaryBrush" />
			<StaticResource x:Key="RatingControlDisabledSelectedForeground" ResourceKey="SimpleBackgroundDisabledDefaultBrush" />
			<StaticResource x:Key="RatingControlCaptionForeground" ResourceKey="SimpleTextDefaultSecondaryBrush" />

			<StaticResource x:Key="SimpleRatingControlForeground" ResourceKey="RatingControlForeground" />
			<StaticResource x:Key="SimpleRatingControlSelectedForeground" ResourceKey="RatingControlSelectedForeground" />
			<StaticResource x:Key="SimpleRatingControlUnselectedForeground" ResourceKey="RatingControlUnselectedForeground" />
			<StaticResource x:Key="SimpleRatingControlPlaceholderForeground" ResourceKey="RatingControlPlaceholderForeground" />
			<StaticResource x:Key="SimpleRatingControlCaptionForeground" ResourceKey="RatingControlCaptionForeground" />
		</ResourceDictionary>

	</ResourceDictionary.ThemeDictionaries>

	<!-- ═══════════════════════════════════════════════════════════════════════ -->
	<!-- Sizing constants                                                       -->
	<!-- ═══════════════════════════════════════════════════════════════════════ -->
	<x:Double x:Key="SimpleRatingControlHeight">32</x:Double>

	<!-- ═══════════════════════════════════════════════════════════════════════ -->
	<!-- RatingControl Style                                                    -->
	<!-- ═══════════════════════════════════════════════════════════════════════ -->
	<Style x:Key="SimpleRatingControlStyle"
		   TargetType="RatingControl">
		<Setter Property="Height" Value="{StaticResource SimpleRatingControlHeight}" />
		<Setter Property="Foreground" Value="{ThemeResource SimpleRatingControlForeground}" />
		<Setter Property="FontFamily" Value="{ThemeResource SymbolThemeFontFamily}" />
		<Setter Property="UseSystemFocusVisuals" Value="{StaticResource UseSystemFocusVisuals}" />
	</Style>

	<!-- ═══════════════════════════════════════════════════════════════════════ -->
	<!-- Default alias                                                          -->
	<!-- ═══════════════════════════════════════════════════════════════════════ -->
	<Style x:Key="SimpleDefaultRatingControlStyle"
		   TargetType="RatingControl"
		   BasedOn="{StaticResource SimpleRatingControlStyle}" />

</ResourceDictionary>
