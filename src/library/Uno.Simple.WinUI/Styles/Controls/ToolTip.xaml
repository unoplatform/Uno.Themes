<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
					xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

	<!--
		Simple Design System — ToolTip Style
		Maps SDS Tooltip tokens to WinUI ToolTip.
		
		SDS Tooltip:
		Background  sds-color-background-default-default
		Border      sds-color-border-default-default  (stroke-border=1)
		Foreground  sds-color-text-default-default
		Padding     12,8  (space-300 horizontal, space-200 vertical)
		Radius      8     (radius-200)
		Shadow      drop-shadow-200
	-->

	<!-- ═══════════════════════════════════════════════════════════════════════ -->
	<!-- Lightweight styling ThemeResource aliases -->
	<!-- ═══════════════════════════════════════════════════════════════════════ -->
	<ResourceDictionary.ThemeDictionaries>

		<!-- ─── Light Theme ─── -->
		<ResourceDictionary x:Key="Light">
			<!-- Background -->
			<!-- Border -->
			<!-- Foreground -->
		</ResourceDictionary>

		<!-- ─── Dark Theme (Default) ─── -->
		<ResourceDictionary x:Key="Default">
			<!-- Background -->
			<!-- Border -->
			<!-- Foreground -->
		</ResourceDictionary>

	</ResourceDictionary.ThemeDictionaries>

	<StaticResource x:Key="SimpleToolTipCornerRadius" ResourceKey="SimpleRadius200CornerRadius" />
	<StaticResource x:Key="SimpleToolTipBorderThickness" ResourceKey="SimpleStrokeBorderThickness" />


	<!-- ═══════════════════════════════════════════════════════════════════════ -->
	<!-- Sizing / Geometry constants -->
	<!-- ═══════════════════════════════════════════════════════════════════════ -->
	<Thickness x:Key="SimpleToolTipPadding">12,8,12,8</Thickness>

	<!-- ═══════════════════════════════════════════════════════════════════════ -->
	<!-- ToolTip Style -->
	<!-- ═══════════════════════════════════════════════════════════════════════ -->
	<Style x:Key="SimpleToolTipStyle"
		   TargetType="ToolTip">

		<Setter Property="Background" Value="{ThemeResource SurfaceBrush}" />
		<Setter Property="BorderBrush" Value="{ThemeResource OutlineBrush}" />
		<Setter Property="Foreground" Value="{ThemeResource OnSurfaceBrush}" />
		<Setter Property="BorderThickness" Value="{StaticResource SimpleToolTipBorderThickness}" />
		<Setter Property="Padding" Value="{StaticResource SimpleToolTipPadding}" />
		<Setter Property="CornerRadius" Value="{StaticResource SimpleToolTipCornerRadius}" />
		<Setter Property="FontFamily" Value="{ThemeResource BodyMediumFontFamily}" />
		<Setter Property="FontSize" Value="{ThemeResource BodyMediumFontSize}" />
		<Setter Property="MaxWidth" Value="320" />

		<Setter Property="Template">
			<Setter.Value>
				<ControlTemplate TargetType="ToolTip">
					<Border Background="{TemplateBinding Background}"
							BorderBrush="{TemplateBinding BorderBrush}"
							BorderThickness="{TemplateBinding BorderThickness}"
							CornerRadius="{TemplateBinding CornerRadius}"
							Padding="{TemplateBinding Padding}">
						<ContentPresenter Content="{TemplateBinding Content}"
										  ContentTemplate="{TemplateBinding ContentTemplate}"
										  TextWrapping="Wrap"
										  MaxWidth="{TemplateBinding MaxWidth}" />
					</Border>
				</ControlTemplate>
			</Setter.Value>
		</Setter>
	</Style>

</ResourceDictionary>
