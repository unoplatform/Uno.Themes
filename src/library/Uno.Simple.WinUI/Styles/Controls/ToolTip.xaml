<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
					xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

	<!--
		Simple Design System — ToolTip Style
		Maps SDS Tooltip tokens to WinUI ToolTip.

		SDS Tooltip:
		  Background  sds-color-background-default-default
		  Border      sds-color-border-default-default  (stroke-border=1)
		  Foreground  sds-color-text-default-default
		  Padding     12,8  (space-300 horizontal, space-200 vertical)
		  Radius      8     (radius-200)
		  Shadow      drop-shadow-200
	-->

	<!-- ═══════════════════════════════════════════════════════════════════════ -->
	<!-- Lightweight styling ThemeResource aliases                              -->
	<!-- ═══════════════════════════════════════════════════════════════════════ -->
	<ResourceDictionary.ThemeDictionaries>

		<!-- ─── Light Theme ─── -->
		<ResourceDictionary x:Key="Light">
			<!-- Background -->
			<StaticResource x:Key="SimpleToolTipBackground" ResourceKey="SurfaceBrush" />
			<!-- Border -->
			<StaticResource x:Key="SimpleToolTipBorderBrush" ResourceKey="OutlineBrush" />
			<!-- Foreground -->
			<StaticResource x:Key="SimpleToolTipForeground" ResourceKey="OnSurfaceBrush" />
		</ResourceDictionary>

		<!-- ─── Dark Theme (Default) ─── -->
		<ResourceDictionary x:Key="Default">
			<!-- Background -->
			<StaticResource x:Key="SimpleToolTipBackground" ResourceKey="SurfaceBrush" />
			<!-- Border -->
			<StaticResource x:Key="SimpleToolTipBorderBrush" ResourceKey="OutlineBrush" />
			<!-- Foreground -->
			<StaticResource x:Key="SimpleToolTipForeground" ResourceKey="OnSurfaceBrush" />
		</ResourceDictionary>

	</ResourceDictionary.ThemeDictionaries>

	<!-- ═══════════════════════════════════════════════════════════════════════ -->
	<!-- Sizing / Geometry constants                                            -->
	<!-- ═══════════════════════════════════════════════════════════════════════ -->
	<Thickness x:Key="SimpleToolTipPadding">12,8,12,8</Thickness> <!-- H: sds-size-space-300, V: sds-size-space-200 -->
	<StaticResource x:Key="SimpleToolTipCornerRadius" ResourceKey="SimpleRadius200CornerRadius" /> <!-- sds-size-radius-200 -->
	<StaticResource x:Key="SimpleToolTipBorderThickness" ResourceKey="SimpleStrokeBorderThickness" /> <!-- sds-size-stroke-border -->

	<!-- ═══════════════════════════════════════════════════════════════════════ -->
	<!-- ToolTip Style                                                          -->
	<!-- ═══════════════════════════════════════════════════════════════════════ -->
	<Style x:Key="SimpleToolTipStyle"
		   TargetType="ToolTip">

		<Setter Property="Background" Value="{ThemeResource SimpleToolTipBackground}" />
		<Setter Property="BorderBrush" Value="{ThemeResource SimpleToolTipBorderBrush}" />
		<Setter Property="Foreground" Value="{ThemeResource SimpleToolTipForeground}" />
		<Setter Property="BorderThickness" Value="{StaticResource SimpleToolTipBorderThickness}" />
		<Setter Property="Padding" Value="{StaticResource SimpleToolTipPadding}" />
		<Setter Property="CornerRadius" Value="{StaticResource SimpleToolTipCornerRadius}" />
		<Setter Property="FontFamily" Value="{ThemeResource SimpleFontFamily}" />
		<Setter Property="FontSize" Value="{ThemeResource SimpleBodySmallFontSize}" />
		<Setter Property="MaxWidth" Value="320" />

		<Setter Property="Template">
			<Setter.Value>
				<ControlTemplate TargetType="ToolTip">
					<Border Background="{TemplateBinding Background}"
							BorderBrush="{TemplateBinding BorderBrush}"
							BorderThickness="{TemplateBinding BorderThickness}"
							CornerRadius="{TemplateBinding CornerRadius}"
							Padding="{TemplateBinding Padding}">
						<ContentPresenter Content="{TemplateBinding Content}"
										  ContentTemplate="{TemplateBinding ContentTemplate}"
										  TextWrapping="Wrap"
										  MaxWidth="{TemplateBinding MaxWidth}" />
					</Border>
				</ControlTemplate>
			</Setter.Value>
		</Setter>
	</Style>

</ResourceDictionary>
