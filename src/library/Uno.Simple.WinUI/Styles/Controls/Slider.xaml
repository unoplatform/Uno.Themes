<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
					xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

	<!--
		Simple Design System — Slider Style
		Maps SDS Slider component tokens to WinUI Slider.
		
		Templates reference Simple-prefixed keys (SimpleSlider*) which alias
		to the semantic keys (Slider*).  Consumers can override EITHER key.
		
		SDS Slider:
		Thumb: 16px circle, bg = background-brand-default
		Track filled: bg = background-brand-default (decrease region), 8px tall
		Track empty: bg = background-brand-secondary (increase region), 4px tall
		Disabled: thumb + track = background-disabled-default, thumb border = border-disabled-default
	-->

	<!-- ═══════════════════════════════════════════════════════════════════════ -->
	<!-- Lightweight styling ThemeResource aliases -->
	<!-- ═══════════════════════════════════════════════════════════════════════ -->
	<ResourceDictionary.ThemeDictionaries>

		<!-- ─── Light Theme ─── -->
		<ResourceDictionary x:Key="Light">
			<!-- ── Slider — semantic keys (source of truth) ── -->
			<!-- Normal state -->
			<StaticResource x:Key="SliderThumbBackground" ResourceKey="PrimaryBrush" />
			<StaticResource x:Key="SliderTrackValueFill" ResourceKey="PrimaryBrush" />
			<StaticResource x:Key="SliderTrackFill" ResourceKey="OutlineBrush" />

			<!-- Pressed state (Simple-only, no Material equivalent) -->
			<StaticResource x:Key="SliderThumbBackgroundPressed" ResourceKey="PrimaryVariantDarkBrush" />
			<StaticResource x:Key="SliderTrackValueFillPressed" ResourceKey="PrimaryVariantDarkBrush" />

			<!-- Disabled state -->
			<StaticResource x:Key="SliderThumbBackgroundDisabled" ResourceKey="OnSurfaceDisabledBrush" />
			<StaticResource x:Key="SliderTrackValueFillDisabled" ResourceKey="OnSurfaceDisabledBrush" />
			<StaticResource x:Key="SliderTrackFillDisabled" ResourceKey="OnSurfaceDisabledBrush" />

		</ResourceDictionary>

		<!-- ─── Dark Theme (Default) ─── -->
		<ResourceDictionary x:Key="Default">
			<!-- ── Slider — semantic keys (source of truth) ── -->
			<!-- Normal state -->
			<StaticResource x:Key="SliderThumbBackground" ResourceKey="PrimaryBrush" />
			<StaticResource x:Key="SliderTrackValueFill" ResourceKey="PrimaryBrush" />
			<StaticResource x:Key="SliderTrackFill" ResourceKey="OutlineBrush" />

			<!-- Pressed state (Simple-only, no Material equivalent) -->
			<StaticResource x:Key="SliderThumbBackgroundPressed" ResourceKey="PrimaryVariantDarkBrush" />
			<StaticResource x:Key="SliderTrackValueFillPressed" ResourceKey="PrimaryVariantDarkBrush" />

			<!-- Disabled state -->
			<StaticResource x:Key="SliderThumbBackgroundDisabled" ResourceKey="OnSurfaceDisabledBrush" />
			<StaticResource x:Key="SliderTrackValueFillDisabled" ResourceKey="OnSurfaceDisabledBrush" />
			<StaticResource x:Key="SliderTrackFillDisabled" ResourceKey="OnSurfaceDisabledBrush" />

		</ResourceDictionary>

	</ResourceDictionary.ThemeDictionaries>

	<StaticResource x:Key="SimpleSliderThumbCornerRadius" ResourceKey="SliderThumbCornerRadius" />
	<StaticResource x:Key="SimpleSliderTrackThickness" ResourceKey="SliderTrackThickness" />
	<StaticResource x:Key="SimpleSliderFillThickness" ResourceKey="SliderFillThickness" />


	<!-- ═══════════════════════════════════════════════════════════════════════ -->
	<!-- Sizing / layout constants -->
	<!-- Semantic keys (source of truth) + backwards-compat aliases -->
	<!-- ═══════════════════════════════════════════════════════════════════════ -->
	<StaticResource x:Key="SliderThumbWidth" ResourceKey="SimpleSpace400" /> 
	<!-- sds-size-space-400 -->
	<StaticResource x:Key="SliderThumbHeight" ResourceKey="SimpleSpace400" /> 
	<!-- sds-size-space-400 -->
	<StaticResource x:Key="SliderThumbCornerRadius" ResourceKey="SimpleRadius200CornerRadius" /> 
	<!-- sds-size-radius-200 -->
	<StaticResource x:Key="SliderTrackThickness" ResourceKey="SimpleSpace100" /> 
	<!-- sds-size-space-100 -->
	<StaticResource x:Key="SliderFillThickness" ResourceKey="SimpleSpace200" /> 
	<!-- sds-size-space-200 -->
	<x:Double x:Key="SliderPreContentMargin">14</x:Double> 
	<!-- no exact SDS token (14) -->
	<x:Double x:Key="SliderPostContentMargin">14</x:Double> 
	<!-- no exact SDS token (14) -->
	<StaticResource x:Key="SliderHorizontalHeight" ResourceKey="SimpleIconMedium" /> 
	<!-- sds-size-icon-medium -->
	<StaticResource x:Key="SliderVerticalWidth" ResourceKey="SimpleIconMedium" /> 
	<!-- sds-size-icon-medium -->
	<CornerRadius x:Key="SliderHorizontalFillCornerRadius">4,0,0,4</CornerRadius> 
	<!-- sds-size-radius-100,0,0,sds-size-radius-100 -->
	<CornerRadius x:Key="SliderVerticalFillCornerRadius">0,0,4,4</CornerRadius> 
	<!-- 0,0,sds-size-radius-100,sds-size-radius-100 -->
	<StaticResource x:Key="SliderCornerRadius" ResourceKey="Radius050CornerRadius" /> 
	<!-- Radius050 (2px) -->
	<Thickness x:Key="SliderFocusVisualMargin">-7,0</Thickness> 
	<!-- no exact SDS token (negative margins) -->
	<Thickness x:Key="SliderHorizontalFocusVisualMargin">-14,-6,-14,-6</Thickness> 
	<!-- no exact SDS token (negative margins) -->
	<Thickness x:Key="SliderVerticalFocusVisualMargin">-6,-14,-6,-14</Thickness> 
	<!-- no exact SDS token (negative margins) -->
	<Thickness x:Key="SliderHeaderMargin">0,0,0,4</Thickness> 
	<!-- 0,0,0,sds-size-space-100 -->

	<x:Double x:Key="SimpleSliderPreContentMargin">14</x:Double>
	<x:Double x:Key="SimpleSliderPostContentMargin">14</x:Double>
	<CornerRadius x:Key="SimpleSliderHorizontalFillCornerRadius">4,0,0,4</CornerRadius>
	<CornerRadius x:Key="SimpleSliderVerticalFillCornerRadius">0,0,4,4</CornerRadius>
	<StaticResource x:Key="SimpleSliderCornerRadius" ResourceKey="SimpleRadius050CornerRadius" />
	<Thickness x:Key="SimpleSliderFocusVisualMargin">-7,0</Thickness>
	<Thickness x:Key="SimpleSliderHorizontalFocusVisualMargin">-14,-6,-14,-6</Thickness>
	<Thickness x:Key="SimpleSliderVerticalFocusVisualMargin">-6,-14,-6,-14</Thickness>
	<Thickness x:Key="SimpleSliderHeaderMargin">0,0,0,4</Thickness>

	<!-- ═══════════════════════════════════════════════════════════════════════ -->
	<!-- Slider Thumb Style -->
	<!-- ═══════════════════════════════════════════════════════════════════════ -->
	<Style x:Key="SimpleSliderThumbStyle"
		   TargetType="Thumb">
		<Setter Property="Background" Value="{ThemeResource SliderThumbBackground}" />
		<Setter Property="BorderThickness" Value="0" />
		<Setter Property="Template">
			<Setter.Value>
				<ControlTemplate TargetType="Thumb">
					<Border Background="{TemplateBinding Background}"
							BorderBrush="{TemplateBinding BorderBrush}"
							BorderThickness="{TemplateBinding BorderThickness}"
							CornerRadius="{StaticResource SliderThumbCornerRadius}" />
				</ControlTemplate>
			</Setter.Value>
		</Setter>
	</Style>

	<!-- ═══════════════════════════════════════════════════════════════════════ -->
	<!-- Slider Style -->
	<!-- ═══════════════════════════════════════════════════════════════════════ -->
	<Style x:Key="SimpleSliderStyle"
		   TargetType="Slider">
		<Setter Property="Background" Value="{ThemeResource SliderTrackFill}" />
		<Setter Property="Foreground" Value="{ThemeResource SliderTrackValueFill}" />
		<Setter Property="BorderThickness" Value="0" />
		<Setter Property="FontFamily" Value="{ThemeResource BodyLargeFontFamily}" />
		<Setter Property="ManipulationMode" Value="None" />
		<Setter Property="UseSystemFocusVisuals" Value="{StaticResource UseSystemFocusVisuals}" />
		<Setter Property="FocusVisualMargin" Value="{StaticResource SliderFocusVisualMargin}" />
		<Setter Property="IsFocusEngagementEnabled" Value="True" />
		<Setter Property="CornerRadius" Value="{StaticResource SliderCornerRadius}" />

		<Setter Property="Template">
			<Setter.Value>
				<ControlTemplate TargetType="Slider">
					<Grid Margin="{TemplateBinding Padding}">

						<VisualStateManager.VisualStateGroups>
							<VisualStateGroup x:Name="CommonStates">
								<VisualState x:Name="Normal" />

								<VisualState x:Name="Pressed">
									<VisualState.Setters>
										<Setter Target="HorizontalThumb.Background" Value="{ThemeResource SliderThumbBackgroundPressed}" />
										<Setter Target="VerticalThumb.Background" Value="{ThemeResource SliderThumbBackgroundPressed}" />
										<Setter Target="HorizontalDecreaseRect.Fill" Value="{ThemeResource SliderTrackValueFillPressed}" />
										<Setter Target="VerticalDecreaseRect.Fill" Value="{ThemeResource SliderTrackValueFillPressed}" />
									</VisualState.Setters>
								</VisualState>

								<VisualState x:Name="Disabled">
									<VisualState.Setters>
										<Setter Target="HorizontalDecreaseRect.Fill" Value="{ThemeResource SliderTrackValueFillDisabled}" />
										<Setter Target="VerticalDecreaseRect.Fill" Value="{ThemeResource SliderTrackValueFillDisabled}" />
										<Setter Target="HorizontalTrackRect.Fill" Value="{ThemeResource SliderTrackFillDisabled}" />
										<Setter Target="VerticalTrackRect.Fill" Value="{ThemeResource SliderTrackFillDisabled}" />
										<Setter Target="HorizontalThumb.Background" Value="{ThemeResource SliderThumbBackgroundDisabled}" />
										<Setter Target="VerticalThumb.Background" Value="{ThemeResource SliderThumbBackgroundDisabled}" />
									</VisualState.Setters>
								</VisualState>

								<VisualState x:Name="PointerOver" />
							</VisualStateGroup>

							<VisualStateGroup x:Name="FocusEngagementStates">
								<VisualState x:Name="FocusDisengaged" />

								<VisualState x:Name="FocusEngagedHorizontal">
									<Storyboard>
										<ObjectAnimationUsingKeyFrames Storyboard.TargetName="SliderContainer"
																	   Storyboard.TargetProperty="(Control.IsTemplateFocusTarget)">
											<DiscreteObjectKeyFrame KeyTime="0"
																	Value="False" />
										</ObjectAnimationUsingKeyFrames>
										<ObjectAnimationUsingKeyFrames Storyboard.TargetName="HorizontalThumb"
																	   Storyboard.TargetProperty="(Control.IsTemplateFocusTarget)">
											<DiscreteObjectKeyFrame KeyTime="0"
																	Value="True" />
										</ObjectAnimationUsingKeyFrames>
									</Storyboard>
								</VisualState>

								<VisualState x:Name="FocusEngagedVertical">
									<Storyboard>
										<ObjectAnimationUsingKeyFrames Storyboard.TargetName="SliderContainer"
																	   Storyboard.TargetProperty="(Control.IsTemplateFocusTarget)">
											<DiscreteObjectKeyFrame KeyTime="0"
																	Value="False" />
										</ObjectAnimationUsingKeyFrames>
										<ObjectAnimationUsingKeyFrames Storyboard.TargetName="VerticalThumb"
																	   Storyboard.TargetProperty="(Control.IsTemplateFocusTarget)">
											<DiscreteObjectKeyFrame KeyTime="0"
																	Value="True" />
										</ObjectAnimationUsingKeyFrames>
									</Storyboard>
								</VisualState>
							</VisualStateGroup>
						</VisualStateManager.VisualStateGroups>

						<Grid.RowDefinitions>
							<RowDefinition Height="Auto" />
							<RowDefinition Height="*" />
						</Grid.RowDefinitions>

						<!-- Header -->
						<ContentPresenter x:Name="HeaderContentPresenter"
										  Grid.Row="0"
										  Content="{TemplateBinding Header}"
										  ContentTemplate="{TemplateBinding HeaderTemplate}"
										  FontFamily="{ThemeResource BodyLargeFontFamily}"
										  Foreground="{ThemeResource OnSurfaceBrush}"
										  Margin="{StaticResource SliderHeaderMargin}"
										  TextWrapping="Wrap"
										  Visibility="Collapsed"
										  x:DeferLoadStrategy="Lazy" />

						<!-- SliderContainer -->
						<Grid x:Name="SliderContainer"
							  Grid.Row="1"
							  Background="Transparent"
							  Control.IsTemplateFocusTarget="True">

							<!-- ─── HorizontalTemplate ─── -->
							<Grid x:Name="HorizontalTemplate"
								  MinHeight="{StaticResource SliderHorizontalHeight}">

								<Grid.ColumnDefinitions>
									<ColumnDefinition Width="Auto" />
									<ColumnDefinition Width="Auto" />
									<ColumnDefinition Width="*" />
								</Grid.ColumnDefinitions>

								<Grid.RowDefinitions>
									<RowDefinition Height="{StaticResource SliderPreContentMargin}" />
									<RowDefinition Height="Auto" />
									<RowDefinition Height="{StaticResource SliderPostContentMargin}" />
								</Grid.RowDefinitions>

								<!-- Background track -->
								<Rectangle x:Name="HorizontalTrackRect"
										   Grid.Row="1"
										   Grid.ColumnSpan="3"
										   Height="{StaticResource SliderTrackThickness}"
										   Fill="{TemplateBinding Background}"
										   RadiusX="{Binding CornerRadius, RelativeSource={RelativeSource TemplatedParent}, Converter={StaticResource TopLeftCornerRadiusDoubleValueConverter}}"
										   RadiusY="{Binding CornerRadius, RelativeSource={RelativeSource TemplatedParent}, Converter={StaticResource BottomRightCornerRadiusDoubleValueConverter}}" />

								<!-- Filled (decrease) track -->
								<Border Grid.Row="1"
										Height="{StaticResource SliderFillThickness}"
										CornerRadius="{StaticResource SliderHorizontalFillCornerRadius}">
									<Rectangle x:Name="HorizontalDecreaseRect"
											   Fill="{TemplateBinding Foreground}" />
								</Border>

								<!-- Thumb -->
								<Thumb x:Name="HorizontalThumb"
									   Grid.Row="0"
									   Grid.RowSpan="3"
									   Grid.Column="1"
									   Width="{StaticResource SliderThumbWidth}"
									   Height="{StaticResource SliderThumbHeight}"
									   AutomationProperties.AccessibilityView="Raw"
									   DataContext="{TemplateBinding Value}"
									   FocusVisualMargin="{StaticResource SliderHorizontalFocusVisualMargin}"
									   Style="{StaticResource SimpleSliderThumbStyle}" />
							</Grid>

							<!-- ─── VerticalTemplate ─── -->
							<Grid x:Name="VerticalTemplate"
								  MinWidth="{StaticResource SliderVerticalWidth}"
								  Visibility="Collapsed">

								<Grid.RowDefinitions>
									<RowDefinition Height="*" />
									<RowDefinition Height="Auto" />
									<RowDefinition Height="Auto" />
								</Grid.RowDefinitions>

								<Grid.ColumnDefinitions>
									<ColumnDefinition Width="{StaticResource SliderPreContentMargin}" />
									<ColumnDefinition Width="Auto" />
									<ColumnDefinition Width="{StaticResource SliderPostContentMargin}" />
								</Grid.ColumnDefinitions>

								<!-- Background track -->
								<Rectangle x:Name="VerticalTrackRect"
										   Width="{StaticResource SliderTrackThickness}"
										   Grid.RowSpan="3"
										   Grid.Column="1"
										   Fill="{TemplateBinding Background}"
										   RadiusX="{Binding CornerRadius, RelativeSource={RelativeSource TemplatedParent}, Converter={StaticResource TopLeftCornerRadiusDoubleValueConverter}}"
										   RadiusY="{Binding CornerRadius, RelativeSource={RelativeSource TemplatedParent}, Converter={StaticResource BottomRightCornerRadiusDoubleValueConverter}}" />

								<!-- Filled (decrease) track -->
								<Border Grid.Row="2"
										Grid.Column="1"
										CornerRadius="{StaticResource SliderVerticalFillCornerRadius}">
									<Rectangle x:Name="VerticalDecreaseRect"
											   Width="{StaticResource SliderFillThickness}"
											   Fill="{TemplateBinding Foreground}" />
								</Border>

								<!-- Thumb -->
								<Thumb x:Name="VerticalThumb"
									   Grid.Row="1"
									   Grid.Column="0"
									   Grid.ColumnSpan="3"
									   Width="{StaticResource SliderThumbWidth}"
									   Height="{StaticResource SliderThumbHeight}"
									   AutomationProperties.AccessibilityView="Raw"
									   DataContext="{TemplateBinding Value}"
									   FocusVisualMargin="{StaticResource SliderVerticalFocusVisualMargin}"
									   Style="{StaticResource SimpleSliderThumbStyle}" />
							</Grid>
						</Grid>
					</Grid>
				</ControlTemplate>
			</Setter.Value>
		</Setter>
	</Style>

</ResourceDictionary>
