<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
					xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

	<!--
		Simple Design System — Slider Style
		Maps SDS Slider component tokens to WinUI Slider.

		SDS Slider:
		  Thumb: 16px circle, bg = background-brand-default
		  Track filled: bg = background-brand-default (decrease region), 8px tall
		  Track empty: bg = background-brand-secondary (increase region), 4px tall
		  Disabled: thumb + track = background-disabled-default, thumb border = border-disabled-default
	-->

	<!-- ═══════════════════════════════════════════════════════════════════════ -->
	<!-- Lightweight styling ThemeResource aliases                              -->
	<!-- ═══════════════════════════════════════════════════════════════════════ -->
	<ResourceDictionary.ThemeDictionaries>

		<!-- ─── Light Theme ─── -->
		<ResourceDictionary x:Key="Light">
			<!-- Normal state -->
			<StaticResource x:Key="SimpleSliderThumbBackground" ResourceKey="SimpleBackgroundBrandDefaultBrush" />
			<StaticResource x:Key="SimpleSliderTrackValueFill" ResourceKey="SimpleBackgroundBrandDefaultBrush" />
			<StaticResource x:Key="SimpleSliderTrackFill" ResourceKey="SimpleBackgroundBrandSecondaryBrush" />

			<!-- Disabled state -->
			<StaticResource x:Key="SimpleSliderThumbBackgroundDisabled" ResourceKey="SimpleBackgroundDisabledDefaultBrush" />
			<StaticResource x:Key="SimpleSliderTrackValueFillDisabled" ResourceKey="SimpleBackgroundDisabledDefaultBrush" />
			<StaticResource x:Key="SimpleSliderTrackFillDisabled" ResourceKey="SimpleBackgroundDisabledDefaultBrush" />
		</ResourceDictionary>

		<!-- ─── Dark Theme (Default) ─── -->
		<ResourceDictionary x:Key="Default">
			<StaticResource x:Key="SimpleSliderThumbBackground" ResourceKey="SimpleBackgroundBrandDefaultBrush" />
			<StaticResource x:Key="SimpleSliderTrackValueFill" ResourceKey="SimpleBackgroundBrandDefaultBrush" />
			<StaticResource x:Key="SimpleSliderTrackFill" ResourceKey="SimpleBackgroundBrandSecondaryBrush" />

			<StaticResource x:Key="SimpleSliderThumbBackgroundDisabled" ResourceKey="SimpleBackgroundDisabledDefaultBrush" />
			<StaticResource x:Key="SimpleSliderTrackValueFillDisabled" ResourceKey="SimpleBackgroundDisabledDefaultBrush" />
			<StaticResource x:Key="SimpleSliderTrackFillDisabled" ResourceKey="SimpleBackgroundDisabledDefaultBrush" />
		</ResourceDictionary>

	</ResourceDictionary.ThemeDictionaries>

	<!-- ═══════════════════════════════════════════════════════════════════════ -->
	<!-- Sizing / layout constants                                              -->
	<!-- ═══════════════════════════════════════════════════════════════════════ -->
	<x:Double x:Key="SimpleSliderThumbWidth">16</x:Double>
	<x:Double x:Key="SimpleSliderThumbHeight">16</x:Double>
	<x:Double x:Key="SimpleSliderThumbCornerRadius">8</x:Double>
	<x:Double x:Key="SimpleSliderTrackThickness">4</x:Double>
	<x:Double x:Key="SimpleSliderFillThickness">8</x:Double>
	<x:Double x:Key="SimpleSliderPreContentMargin">14</x:Double>
	<x:Double x:Key="SimpleSliderPostContentMargin">14</x:Double>
	<x:Double x:Key="SimpleSliderHorizontalHeight">32</x:Double>
	<x:Double x:Key="SimpleSliderVerticalWidth">32</x:Double>
	<CornerRadius x:Key="SimpleSliderHorizontalFillCornerRadius">4,0,0,4</CornerRadius>
	<CornerRadius x:Key="SimpleSliderVerticalFillCornerRadius">0,0,4,4</CornerRadius>
	<CornerRadius x:Key="SimpleSliderCornerRadius">2</CornerRadius>
	<Thickness x:Key="SimpleSliderFocusVisualMargin">-7,0</Thickness>
	<Thickness x:Key="SimpleSliderHorizontalFocusVisualMargin">-14,-6,-14,-6</Thickness>
	<Thickness x:Key="SimpleSliderVerticalFocusVisualMargin">-6,-14,-6,-14</Thickness>

	<!-- ═══════════════════════════════════════════════════════════════════════ -->
	<!-- Slider Thumb Style                                                     -->
	<!-- ═══════════════════════════════════════════════════════════════════════ -->
	<Style x:Key="SimpleSliderThumbStyle"
		   TargetType="Thumb">
		<Setter Property="Background" Value="{ThemeResource SimpleSliderThumbBackground}" />
		<Setter Property="BorderThickness" Value="0" />
		<Setter Property="Template">
			<Setter.Value>
				<ControlTemplate TargetType="Thumb">
					<Border Background="{TemplateBinding Background}"
							BorderBrush="{TemplateBinding BorderBrush}"
							BorderThickness="{TemplateBinding BorderThickness}"
							CornerRadius="{StaticResource SimpleSliderThumbCornerRadius}" />
				</ControlTemplate>
			</Setter.Value>
		</Setter>
	</Style>

	<!-- ═══════════════════════════════════════════════════════════════════════ -->
	<!-- Slider Style                                                           -->
	<!-- ═══════════════════════════════════════════════════════════════════════ -->
	<Style x:Key="SimpleSliderStyle"
		   TargetType="Slider">
		<Setter Property="Background" Value="{ThemeResource SimpleSliderTrackFill}" />
		<Setter Property="Foreground" Value="{ThemeResource SimpleSliderTrackValueFill}" />
		<Setter Property="BorderThickness" Value="0" />
		<Setter Property="FontFamily" Value="{ThemeResource SimpleFontFamily}" />
		<Setter Property="ManipulationMode" Value="None" />
		<Setter Property="UseSystemFocusVisuals" Value="{StaticResource UseSystemFocusVisuals}" />
		<Setter Property="FocusVisualMargin" Value="{StaticResource SimpleSliderFocusVisualMargin}" />
		<Setter Property="IsFocusEngagementEnabled" Value="True" />
		<Setter Property="CornerRadius" Value="{StaticResource SimpleSliderCornerRadius}" />

		<Setter Property="Template">
			<Setter.Value>
				<ControlTemplate TargetType="Slider">
					<Grid Margin="{TemplateBinding Padding}">

						<VisualStateManager.VisualStateGroups>
							<VisualStateGroup x:Name="CommonStates">
								<VisualState x:Name="Normal" />
								<VisualState x:Name="Pressed" />

								<VisualState x:Name="Disabled">
									<VisualState.Setters>
										<Setter Target="HorizontalDecreaseRect.Fill" Value="{ThemeResource SimpleSliderTrackValueFillDisabled}" />
										<Setter Target="VerticalDecreaseRect.Fill" Value="{ThemeResource SimpleSliderTrackValueFillDisabled}" />
										<Setter Target="HorizontalTrackRect.Fill" Value="{ThemeResource SimpleSliderTrackFillDisabled}" />
										<Setter Target="VerticalTrackRect.Fill" Value="{ThemeResource SimpleSliderTrackFillDisabled}" />
										<Setter Target="HorizontalThumb.Background" Value="{ThemeResource SimpleSliderThumbBackgroundDisabled}" />
										<Setter Target="VerticalThumb.Background" Value="{ThemeResource SimpleSliderThumbBackgroundDisabled}" />
									</VisualState.Setters>
								</VisualState>

								<VisualState x:Name="PointerOver" />
							</VisualStateGroup>

							<VisualStateGroup x:Name="FocusEngagementStates">
								<VisualState x:Name="FocusDisengaged" />

								<VisualState x:Name="FocusEngagedHorizontal">
									<Storyboard>
										<ObjectAnimationUsingKeyFrames Storyboard.TargetName="SliderContainer"
																	   Storyboard.TargetProperty="(Control.IsTemplateFocusTarget)">
											<DiscreteObjectKeyFrame KeyTime="0"
																	Value="False" />
										</ObjectAnimationUsingKeyFrames>
										<ObjectAnimationUsingKeyFrames Storyboard.TargetName="HorizontalThumb"
																	   Storyboard.TargetProperty="(Control.IsTemplateFocusTarget)">
											<DiscreteObjectKeyFrame KeyTime="0"
																	Value="True" />
										</ObjectAnimationUsingKeyFrames>
									</Storyboard>
								</VisualState>

								<VisualState x:Name="FocusEngagedVertical">
									<Storyboard>
										<ObjectAnimationUsingKeyFrames Storyboard.TargetName="SliderContainer"
																	   Storyboard.TargetProperty="(Control.IsTemplateFocusTarget)">
											<DiscreteObjectKeyFrame KeyTime="0"
																	Value="False" />
										</ObjectAnimationUsingKeyFrames>
										<ObjectAnimationUsingKeyFrames Storyboard.TargetName="VerticalThumb"
																	   Storyboard.TargetProperty="(Control.IsTemplateFocusTarget)">
											<DiscreteObjectKeyFrame KeyTime="0"
																	Value="True" />
										</ObjectAnimationUsingKeyFrames>
									</Storyboard>
								</VisualState>
							</VisualStateGroup>
						</VisualStateManager.VisualStateGroups>

						<Grid.RowDefinitions>
							<RowDefinition Height="Auto" />
							<RowDefinition Height="*" />
						</Grid.RowDefinitions>

						<!-- Header -->
						<ContentPresenter x:Name="HeaderContentPresenter"
										  Grid.Row="0"
										  Content="{TemplateBinding Header}"
										  ContentTemplate="{TemplateBinding HeaderTemplate}"
										  FontFamily="{ThemeResource SimpleFontFamily}"
										  Foreground="{ThemeResource SimpleTextDefaultDefaultBrush}"
										  Margin="0,0,0,4"
										  TextWrapping="Wrap"
										  Visibility="Collapsed"
										  x:DeferLoadStrategy="Lazy" />

						<!-- SliderContainer -->
						<Grid x:Name="SliderContainer"
							  Grid.Row="1"
							  Background="Transparent"
							  Control.IsTemplateFocusTarget="True">

							<!-- ─── HorizontalTemplate ─── -->
							<Grid x:Name="HorizontalTemplate"
								  MinHeight="{StaticResource SimpleSliderHorizontalHeight}">

								<Grid.ColumnDefinitions>
									<ColumnDefinition Width="Auto" />
									<ColumnDefinition Width="Auto" />
									<ColumnDefinition Width="*" />
								</Grid.ColumnDefinitions>

								<Grid.RowDefinitions>
									<RowDefinition Height="{StaticResource SimpleSliderPreContentMargin}" />
									<RowDefinition Height="Auto" />
									<RowDefinition Height="{StaticResource SimpleSliderPostContentMargin}" />
								</Grid.RowDefinitions>

								<!-- Background track -->
								<Rectangle x:Name="HorizontalTrackRect"
										   Grid.Row="1"
										   Grid.ColumnSpan="3"
										   Height="{StaticResource SimpleSliderTrackThickness}"
										   Fill="{TemplateBinding Background}"
										   RadiusX="{Binding CornerRadius, RelativeSource={RelativeSource TemplatedParent}, Converter={StaticResource TopLeftCornerRadiusDoubleValueConverter}}"
										   RadiusY="{Binding CornerRadius, RelativeSource={RelativeSource TemplatedParent}, Converter={StaticResource BottomRightCornerRadiusDoubleValueConverter}}" />

								<!-- Filled (decrease) track -->
								<Border Grid.Row="1"
										Height="{StaticResource SimpleSliderFillThickness}"
										CornerRadius="{StaticResource SimpleSliderHorizontalFillCornerRadius}">
									<Rectangle x:Name="HorizontalDecreaseRect"
											   Fill="{TemplateBinding Foreground}" />
								</Border>

								<!-- Thumb -->
								<Thumb x:Name="HorizontalThumb"
									   Grid.Row="0"
									   Grid.RowSpan="3"
									   Grid.Column="1"
									   Width="{StaticResource SimpleSliderThumbWidth}"
									   Height="{StaticResource SimpleSliderThumbHeight}"
									   AutomationProperties.AccessibilityView="Raw"
									   DataContext="{TemplateBinding Value}"
									   FocusVisualMargin="{StaticResource SimpleSliderHorizontalFocusVisualMargin}"
									   Style="{StaticResource SimpleSliderThumbStyle}" />
							</Grid>

							<!-- ─── VerticalTemplate ─── -->
							<Grid x:Name="VerticalTemplate"
								  MinWidth="{StaticResource SimpleSliderVerticalWidth}"
								  Visibility="Collapsed">

								<Grid.RowDefinitions>
									<RowDefinition Height="*" />
									<RowDefinition Height="Auto" />
									<RowDefinition Height="Auto" />
								</Grid.RowDefinitions>

								<Grid.ColumnDefinitions>
									<ColumnDefinition Width="{StaticResource SimpleSliderPreContentMargin}" />
									<ColumnDefinition Width="Auto" />
									<ColumnDefinition Width="{StaticResource SimpleSliderPostContentMargin}" />
								</Grid.ColumnDefinitions>

								<!-- Background track -->
								<Rectangle x:Name="VerticalTrackRect"
										   Width="{StaticResource SimpleSliderTrackThickness}"
										   Grid.RowSpan="3"
										   Grid.Column="1"
										   Fill="{TemplateBinding Background}"
										   RadiusX="{Binding CornerRadius, RelativeSource={RelativeSource TemplatedParent}, Converter={StaticResource TopLeftCornerRadiusDoubleValueConverter}}"
										   RadiusY="{Binding CornerRadius, RelativeSource={RelativeSource TemplatedParent}, Converter={StaticResource BottomRightCornerRadiusDoubleValueConverter}}" />

								<!-- Filled (decrease) track -->
								<Border Grid.Row="2"
										Grid.Column="1"
										CornerRadius="{StaticResource SimpleSliderVerticalFillCornerRadius}">
									<Rectangle x:Name="VerticalDecreaseRect"
											   Width="{StaticResource SimpleSliderFillThickness}"
											   Fill="{TemplateBinding Foreground}" />
								</Border>

								<!-- Thumb -->
								<Thumb x:Name="VerticalThumb"
									   Grid.Row="1"
									   Grid.Column="0"
									   Grid.ColumnSpan="3"
									   Width="{StaticResource SimpleSliderThumbWidth}"
									   Height="{StaticResource SimpleSliderThumbHeight}"
									   AutomationProperties.AccessibilityView="Raw"
									   DataContext="{TemplateBinding Value}"
									   FocusVisualMargin="{StaticResource SimpleSliderVerticalFocusVisualMargin}"
									   Style="{StaticResource SimpleSliderThumbStyle}" />
							</Grid>
						</Grid>
					</Grid>
				</ControlTemplate>
			</Setter.Value>
		</Setter>
	</Style>

</ResourceDictionary>
