<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
					xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

	<!--
		Simple Design System — Slider Style
		Maps SDS Slider component tokens to WinUI Slider.

		SDS Slider:
		  Thumb: 16px circle, bg = background-brand-default
		  Track filled: bg = background-brand-default (decrease region)
		  Track empty: bg = background-brand-secondary (increase region)
		  Disabled: thumb + track = background-disabled-default, thumb border = border-disabled-default
	-->

	<!-- ═══════════════════════════════════════════════════════════════════════ -->
	<!-- Lightweight styling ThemeResource aliases                              -->
	<!-- ═══════════════════════════════════════════════════════════════════════ -->
	<ResourceDictionary.ThemeDictionaries>

		<!-- ─── Light Theme ─── -->
		<ResourceDictionary x:Key="Light">
			<!-- Sizing -->
			<x:Double x:Key="SimpleSliderThumbSize">16</x:Double>
			<x:Double x:Key="SimpleSliderTrackHeight">8</x:Double>
			<CornerRadius x:Key="SimpleSliderTrackCornerRadius">9999</CornerRadius>

			<!-- Normal state -->
			<StaticResource x:Key="SimpleSliderThumbBackground" ResourceKey="SimpleBackgroundBrandDefaultBrush" />
			<StaticResource x:Key="SimpleSliderThumbBorderBrush" ResourceKey="SimpleBackgroundBrandDefaultBrush" />
			<StaticResource x:Key="SimpleSliderTrackDecreaseBackground" ResourceKey="SimpleBackgroundBrandDefaultBrush" />
			<StaticResource x:Key="SimpleSliderTrackIncreaseBackground" ResourceKey="SimpleBackgroundBrandSecondaryBrush" />

			<!-- PointerOver state -->
			<StaticResource x:Key="SimpleSliderThumbBackgroundPointerOver" ResourceKey="SimpleBackgroundBrandHoverBrush" />
			<StaticResource x:Key="SimpleSliderThumbBorderBrushPointerOver" ResourceKey="SimpleBackgroundBrandHoverBrush" />
			<StaticResource x:Key="SimpleSliderTrackDecreaseBackgroundPointerOver" ResourceKey="SimpleBackgroundBrandHoverBrush" />
			<StaticResource x:Key="SimpleSliderTrackIncreaseBackgroundPointerOver" ResourceKey="SimpleBackgroundBrandSecondaryBrush" />

			<!-- Pressed state -->
			<StaticResource x:Key="SimpleSliderThumbBackgroundPressed" ResourceKey="SimpleBackgroundBrandHoverBrush" />
			<StaticResource x:Key="SimpleSliderThumbBorderBrushPressed" ResourceKey="SimpleBackgroundBrandHoverBrush" />
			<StaticResource x:Key="SimpleSliderTrackDecreaseBackgroundPressed" ResourceKey="SimpleBackgroundBrandHoverBrush" />
			<StaticResource x:Key="SimpleSliderTrackIncreaseBackgroundPressed" ResourceKey="SimpleBackgroundBrandSecondaryBrush" />

			<!-- Disabled state -->
			<StaticResource x:Key="SimpleSliderThumbBackgroundDisabled" ResourceKey="SimpleBackgroundDisabledDefaultBrush" />
			<StaticResource x:Key="SimpleSliderThumbBorderBrushDisabled" ResourceKey="SimpleBorderDisabledDefaultBrush" />
			<StaticResource x:Key="SimpleSliderTrackDecreaseBackgroundDisabled" ResourceKey="SimpleBackgroundDisabledDefaultBrush" />
			<StaticResource x:Key="SimpleSliderTrackIncreaseBackgroundDisabled" ResourceKey="SimpleBackgroundDisabledDefaultBrush" />
		</ResourceDictionary>

		<!-- ─── Dark Theme (Default) ─── -->
		<ResourceDictionary x:Key="Default">
			<x:Double x:Key="SimpleSliderThumbSize">16</x:Double>
			<x:Double x:Key="SimpleSliderTrackHeight">8</x:Double>
			<CornerRadius x:Key="SimpleSliderTrackCornerRadius">9999</CornerRadius>

			<StaticResource x:Key="SimpleSliderThumbBackground" ResourceKey="SimpleBackgroundBrandDefaultBrush" />
			<StaticResource x:Key="SimpleSliderThumbBorderBrush" ResourceKey="SimpleBackgroundBrandDefaultBrush" />
			<StaticResource x:Key="SimpleSliderTrackDecreaseBackground" ResourceKey="SimpleBackgroundBrandDefaultBrush" />
			<StaticResource x:Key="SimpleSliderTrackIncreaseBackground" ResourceKey="SimpleBackgroundBrandSecondaryBrush" />

			<StaticResource x:Key="SimpleSliderThumbBackgroundPointerOver" ResourceKey="SimpleBackgroundBrandHoverBrush" />
			<StaticResource x:Key="SimpleSliderThumbBorderBrushPointerOver" ResourceKey="SimpleBackgroundBrandHoverBrush" />
			<StaticResource x:Key="SimpleSliderTrackDecreaseBackgroundPointerOver" ResourceKey="SimpleBackgroundBrandHoverBrush" />
			<StaticResource x:Key="SimpleSliderTrackIncreaseBackgroundPointerOver" ResourceKey="SimpleBackgroundBrandSecondaryBrush" />

			<StaticResource x:Key="SimpleSliderThumbBackgroundPressed" ResourceKey="SimpleBackgroundBrandHoverBrush" />
			<StaticResource x:Key="SimpleSliderThumbBorderBrushPressed" ResourceKey="SimpleBackgroundBrandHoverBrush" />
			<StaticResource x:Key="SimpleSliderTrackDecreaseBackgroundPressed" ResourceKey="SimpleBackgroundBrandHoverBrush" />
			<StaticResource x:Key="SimpleSliderTrackIncreaseBackgroundPressed" ResourceKey="SimpleBackgroundBrandSecondaryBrush" />

			<StaticResource x:Key="SimpleSliderThumbBackgroundDisabled" ResourceKey="SimpleBackgroundDisabledDefaultBrush" />
			<StaticResource x:Key="SimpleSliderThumbBorderBrushDisabled" ResourceKey="SimpleBorderDisabledDefaultBrush" />
			<StaticResource x:Key="SimpleSliderTrackDecreaseBackgroundDisabled" ResourceKey="SimpleBackgroundDisabledDefaultBrush" />
			<StaticResource x:Key="SimpleSliderTrackIncreaseBackgroundDisabled" ResourceKey="SimpleBackgroundDisabledDefaultBrush" />
		</ResourceDictionary>

	</ResourceDictionary.ThemeDictionaries>

	<!-- ═══════════════════════════════════════════════════════════════════════ -->
	<!-- Default Slider Style                                                  -->
	<!-- ═══════════════════════════════════════════════════════════════════════ -->
	<Style x:Key="SimpleSliderStyle"
		   TargetType="Slider">
		<Setter Property="Background" Value="{ThemeResource SimpleSliderTrackIncreaseBackground}" />
		<Setter Property="Foreground" Value="{ThemeResource SimpleSliderTrackDecreaseBackground}" />
		<Setter Property="MinHeight" Value="32" />
		<Setter Property="HorizontalAlignment" Value="Stretch" />
		<Setter Property="VerticalAlignment" Value="Center" />
		<Setter Property="UseSystemFocusVisuals" Value="{StaticResource UseSystemFocusVisuals}" />
		<Setter Property="FocusVisualMargin" Value="-3" />
		<Setter Property="Template">
			<Setter.Value>
				<ControlTemplate TargetType="Slider">
					<Grid Margin="{TemplateBinding Padding}">
						<Grid.RowDefinitions>
							<RowDefinition Height="Auto" />
							<RowDefinition Height="*" />
						</Grid.RowDefinitions>

						<VisualStateManager.VisualStateGroups>
							<VisualStateGroup x:Name="CommonStates">
								<VisualState x:Name="Normal" />

								<VisualState x:Name="PointerOver">
									<VisualState.Setters>
										<Setter Target="SliderThumb.Background" Value="{ThemeResource SimpleSliderThumbBackgroundPointerOver}" />
										<Setter Target="SliderThumb.BorderBrush" Value="{ThemeResource SimpleSliderThumbBorderBrushPointerOver}" />
										<Setter Target="DecreaseRect.Fill" Value="{ThemeResource SimpleSliderTrackDecreaseBackgroundPointerOver}" />
										<Setter Target="IncreaseRect.Fill" Value="{ThemeResource SimpleSliderTrackIncreaseBackgroundPointerOver}" />
									</VisualState.Setters>
								</VisualState>

								<VisualState x:Name="Pressed">
									<VisualState.Setters>
										<Setter Target="SliderThumb.Background" Value="{ThemeResource SimpleSliderThumbBackgroundPressed}" />
										<Setter Target="SliderThumb.BorderBrush" Value="{ThemeResource SimpleSliderThumbBorderBrushPressed}" />
										<Setter Target="DecreaseRect.Fill" Value="{ThemeResource SimpleSliderTrackDecreaseBackgroundPressed}" />
										<Setter Target="IncreaseRect.Fill" Value="{ThemeResource SimpleSliderTrackIncreaseBackgroundPressed}" />
									</VisualState.Setters>
								</VisualState>

								<VisualState x:Name="Disabled">
									<VisualState.Setters>
										<Setter Target="SliderThumb.Background" Value="{ThemeResource SimpleSliderThumbBackgroundDisabled}" />
										<Setter Target="SliderThumb.BorderBrush" Value="{ThemeResource SimpleSliderThumbBorderBrushDisabled}" />
										<Setter Target="DecreaseRect.Fill" Value="{ThemeResource SimpleSliderTrackDecreaseBackgroundDisabled}" />
										<Setter Target="IncreaseRect.Fill" Value="{ThemeResource SimpleSliderTrackIncreaseBackgroundDisabled}" />
									</VisualState.Setters>
								</VisualState>
							</VisualStateGroup>
						</VisualStateManager.VisualStateGroups>

						<!-- Header -->
						<ContentPresenter x:Name="HeaderContentPresenter"
										  Grid.Row="0"
										  Content="{TemplateBinding Header}"
										  ContentTemplate="{TemplateBinding HeaderTemplate}"
										  FontFamily="{ThemeResource SimpleFontFamily}"
										  Foreground="{ThemeResource SimpleTextDefaultDefaultBrush}"
										  Margin="0,0,0,4"
										  TextWrapping="Wrap"
										  Visibility="Collapsed"
										  x:DeferLoadStrategy="Lazy" />

						<!-- Horizontal template (main) -->
						<Grid x:Name="SliderContainer"
							  Grid.Row="1"
							  VerticalAlignment="Center"
							  MinHeight="{TemplateBinding MinHeight}">

							<Grid x:Name="HorizontalTemplate"
								  VerticalAlignment="Center">
								<Grid.ColumnDefinitions>
									<ColumnDefinition Width="Auto" />
									<ColumnDefinition Width="Auto" />
									<ColumnDefinition Width="*" />
								</Grid.ColumnDefinitions>

								<!-- Decrease (filled) track -->
								<Rectangle x:Name="DecreaseRect"
										   Grid.Column="0"
										   Height="{ThemeResource SimpleSliderTrackHeight}"
										   Fill="{ThemeResource SimpleSliderTrackDecreaseBackground}"
										   RadiusX="4"
										   RadiusY="4" />

								<!-- Thumb -->
								<Ellipse x:Name="SliderThumb"
										 Grid.Column="1"
										 Width="{ThemeResource SimpleSliderThumbSize}"
										 Height="{ThemeResource SimpleSliderThumbSize}"
										 Fill="{ThemeResource SimpleSliderThumbBackground}"
										 Stroke="{ThemeResource SimpleSliderThumbBorderBrush}"
										 StrokeThickness="0" />

								<!-- Increase (empty) track -->
								<Rectangle x:Name="IncreaseRect"
										   Grid.Column="2"
										   Height="{ThemeResource SimpleSliderTrackHeight}"
										   Fill="{ThemeResource SimpleSliderTrackIncreaseBackground}"
										   RadiusX="4"
										   RadiusY="4" />
							</Grid>
						</Grid>
					</Grid>
				</ControlTemplate>
			</Setter.Value>
		</Setter>
	</Style>

</ResourceDictionary>
