<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
					xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
					xmlns:muxc="using:Microsoft.UI.Xaml.Controls">

	<!--
		Simple Design System — PipsPager Style
		Pagination dots with Simple's standard sizing, spacing, and color tokens.
		Includes selected/unselected states and optional navigation arrows.
		
		Resource layers:
		PipsPager*       = semantic keys (source of truth)
		SimplePipsPager* = Simple-prefixed aliases → PipsPager*
	-->

	<ResourceDictionary.ThemeDictionaries>

		<!-- ─── Light Theme ─── -->
		<ResourceDictionary x:Key="Light">
			<!-- Selection indicator -->
			<StaticResource x:Key="PipsPagerSelectionIndicatorForeground" ResourceKey="SurfaceVariantBrush" />
			<StaticResource x:Key="PipsPagerSelectionIndicatorForegroundSelected" ResourceKey="PrimaryBrush" />

			<!-- Navigation buttons -->
			<StaticResource x:Key="PipsPagerNavigationButtonForeground" ResourceKey="OnSurfaceBrush" />
			<StaticResource x:Key="PipsPagerNavigationButtonForegroundDisabled" ResourceKey="OnSurfaceDisabledBrush" />
			<StaticResource x:Key="PipsPagerNavigationButtonForegroundPointerOver" ResourceKey="OnSurfaceBrush" />
			<StaticResource x:Key="PipsPagerNavigationButtonForegroundPressed" ResourceKey="OnSurfaceBrush" />
			<SolidColorBrush x:Key="PipsPagerNavigationButtonBackground"
							 Color="Transparent" />
			<StaticResource x:Key="PipsPagerNavigationButtonBackgroundPointerOver" ResourceKey="SurfaceVariantBrush" />
			<StaticResource x:Key="PipsPagerNavigationButtonBackgroundPressed" ResourceKey="PrimaryContainerBrush" />

			<!-- Backwards-compat aliases -->
		</ResourceDictionary>

		<!-- ─── Dark Theme (Default) ─── -->
		<ResourceDictionary x:Key="Default">
			<StaticResource x:Key="PipsPagerSelectionIndicatorForeground" ResourceKey="OutlineBrush" />
			<StaticResource x:Key="PipsPagerSelectionIndicatorForegroundSelected" ResourceKey="PrimaryBrush" />

			<StaticResource x:Key="PipsPagerNavigationButtonForeground" ResourceKey="OnSurfaceBrush" />
			<StaticResource x:Key="PipsPagerNavigationButtonForegroundDisabled" ResourceKey="OnSurfaceDisabledBrush" />
			<StaticResource x:Key="PipsPagerNavigationButtonForegroundPointerOver" ResourceKey="OnSurfaceBrush" />
			<StaticResource x:Key="PipsPagerNavigationButtonForegroundPressed" ResourceKey="OnSurfaceBrush" />
			<SolidColorBrush x:Key="PipsPagerNavigationButtonBackground"
							 Color="Transparent" />
			<StaticResource x:Key="PipsPagerNavigationButtonBackgroundPointerOver" ResourceKey="SurfaceVariantBrush" />
			<StaticResource x:Key="PipsPagerNavigationButtonBackgroundPressed" ResourceKey="PrimaryContainerBrush" />

		</ResourceDictionary>

	</ResourceDictionary.ThemeDictionaries>

	<!-- ═══════════════════════════════════════════════════════════════════════ -->
	<!-- Sizing constants -->
	<!-- ═══════════════════════════════════════════════════════════════════════ -->
	<x:Double x:Key="SimplePipsPagerPipWidth">8</x:Double>
	<x:Double x:Key="SimplePipsPagerPipHeight">8</x:Double>
	<x:Double x:Key="SimplePipsPagerNavigationButtonWidth">32</x:Double>
	<x:Double x:Key="SimplePipsPagerNavigationButtonHeight">32</x:Double>

	<!-- ═══════════════════════════════════════════════════════════════════════ -->
	<!-- PipsPager Style -->
	<!-- ═══════════════════════════════════════════════════════════════════════ -->
	<Style x:Key="SimplePipsPagerStyle"
		   TargetType="muxc:PipsPager">
		<Setter Property="Foreground" Value="{ThemeResource PipsPagerSelectionIndicatorForeground}" />
	</Style>

	<!-- ═══════════════════════════════════════════════════════════════════════ -->
	<!-- Default alias -->
	<!-- ═══════════════════════════════════════════════════════════════════════ -->
	<Style x:Key="SimpleDefaultPipsPagerStyle"
		   TargetType="muxc:PipsPager"
		   BasedOn="{StaticResource SimplePipsPagerStyle}" />

</ResourceDictionary>
