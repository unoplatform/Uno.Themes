<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
					xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
					xmlns:muxc="using:Microsoft.UI.Xaml.Controls">

	<!--
		Simple Design System — PipsPager Style
		Pagination dots with Simple's standard sizing, spacing, and color tokens.
		Includes selected/unselected states and optional navigation arrows.

		Resource layers:
		  PipsPager*       = semantic keys (source of truth)
		  SimplePipsPager* = Simple-prefixed aliases → PipsPager*
	-->

	<ResourceDictionary.ThemeDictionaries>

		<!-- ─── Light Theme ─── -->
		<ResourceDictionary x:Key="Light">
			<!-- Selection indicator -->
			<StaticResource x:Key="PipsPagerSelectionIndicatorForeground" ResourceKey="SimpleBackgroundDefaultSecondaryBrush" />
			<StaticResource x:Key="PipsPagerSelectionIndicatorForegroundSelected" ResourceKey="SimpleBackgroundBrandDefaultBrush" />

			<!-- Navigation buttons -->
			<StaticResource x:Key="PipsPagerNavigationButtonForeground" ResourceKey="SimpleIconDefaultDefaultBrush" />
			<StaticResource x:Key="PipsPagerNavigationButtonForegroundDisabled" ResourceKey="SimpleIconDisabledDefaultBrush" />
			<StaticResource x:Key="PipsPagerNavigationButtonForegroundPointerOver" ResourceKey="SimpleIconDefaultDefaultBrush" />
			<StaticResource x:Key="PipsPagerNavigationButtonForegroundPressed" ResourceKey="SimpleIconDefaultDefaultBrush" />
			<SolidColorBrush x:Key="PipsPagerNavigationButtonBackground" Color="Transparent" />
			<StaticResource x:Key="PipsPagerNavigationButtonBackgroundPointerOver" ResourceKey="SimpleBackgroundDefaultSecondaryHoverBrush" />
			<StaticResource x:Key="PipsPagerNavigationButtonBackgroundPressed" ResourceKey="SimpleBackgroundDefaultSecondaryPressedBrush" />

			<!-- Backwards-compat aliases -->
			<StaticResource x:Key="SimplePipsPagerSelectionIndicatorForeground" ResourceKey="PipsPagerSelectionIndicatorForeground" />
			<StaticResource x:Key="SimplePipsPagerSelectionIndicatorForegroundSelected" ResourceKey="PipsPagerSelectionIndicatorForegroundSelected" />
			<StaticResource x:Key="SimplePipsPagerNavigationButtonForeground" ResourceKey="PipsPagerNavigationButtonForeground" />
			<StaticResource x:Key="SimplePipsPagerNavigationButtonForegroundDisabled" ResourceKey="PipsPagerNavigationButtonForegroundDisabled" />
		</ResourceDictionary>

		<!-- ─── Dark Theme (Default) ─── -->
		<ResourceDictionary x:Key="Default">
			<StaticResource x:Key="PipsPagerSelectionIndicatorForeground" ResourceKey="SimpleBackgroundDefaultTertiaryBrush" />
			<StaticResource x:Key="PipsPagerSelectionIndicatorForegroundSelected" ResourceKey="SimpleBackgroundBrandDefaultBrush" />

			<StaticResource x:Key="PipsPagerNavigationButtonForeground" ResourceKey="SimpleIconDefaultDefaultBrush" />
			<StaticResource x:Key="PipsPagerNavigationButtonForegroundDisabled" ResourceKey="SimpleIconDisabledDefaultBrush" />
			<StaticResource x:Key="PipsPagerNavigationButtonForegroundPointerOver" ResourceKey="SimpleIconDefaultDefaultBrush" />
			<StaticResource x:Key="PipsPagerNavigationButtonForegroundPressed" ResourceKey="SimpleIconDefaultDefaultBrush" />
			<SolidColorBrush x:Key="PipsPagerNavigationButtonBackground" Color="Transparent" />
			<StaticResource x:Key="PipsPagerNavigationButtonBackgroundPointerOver" ResourceKey="SimpleBackgroundDefaultSecondaryHoverBrush" />
			<StaticResource x:Key="PipsPagerNavigationButtonBackgroundPressed" ResourceKey="SimpleBackgroundDefaultSecondaryPressedBrush" />

			<StaticResource x:Key="SimplePipsPagerSelectionIndicatorForeground" ResourceKey="PipsPagerSelectionIndicatorForeground" />
			<StaticResource x:Key="SimplePipsPagerSelectionIndicatorForegroundSelected" ResourceKey="PipsPagerSelectionIndicatorForegroundSelected" />
			<StaticResource x:Key="SimplePipsPagerNavigationButtonForeground" ResourceKey="PipsPagerNavigationButtonForeground" />
			<StaticResource x:Key="SimplePipsPagerNavigationButtonForegroundDisabled" ResourceKey="PipsPagerNavigationButtonForegroundDisabled" />
		</ResourceDictionary>

	</ResourceDictionary.ThemeDictionaries>

	<!-- ═══════════════════════════════════════════════════════════════════════ -->
	<!-- Sizing constants                                                       -->
	<!-- ═══════════════════════════════════════════════════════════════════════ -->
	<x:Double x:Key="SimplePipsPagerPipWidth">8</x:Double>
	<x:Double x:Key="SimplePipsPagerPipHeight">8</x:Double>
	<x:Double x:Key="SimplePipsPagerNavigationButtonWidth">32</x:Double>
	<x:Double x:Key="SimplePipsPagerNavigationButtonHeight">32</x:Double>

	<!-- ═══════════════════════════════════════════════════════════════════════ -->
	<!-- PipsPager Style                                                        -->
	<!-- ═══════════════════════════════════════════════════════════════════════ -->
	<Style x:Key="SimplePipsPagerStyle"
		   TargetType="muxc:PipsPager">
		<Setter Property="Foreground" Value="{ThemeResource SimplePipsPagerSelectionIndicatorForeground}" />
	</Style>

	<!-- ═══════════════════════════════════════════════════════════════════════ -->
	<!-- Default alias                                                          -->
	<!-- ═══════════════════════════════════════════════════════════════════════ -->
	<Style x:Key="SimpleDefaultPipsPagerStyle"
		   TargetType="muxc:PipsPager"
		   BasedOn="{StaticResource SimplePipsPagerStyle}" />

</ResourceDictionary>
