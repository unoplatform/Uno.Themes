<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
					xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
					xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
					xmlns:ut="using:Uno.Themes"
					xmlns:win="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
					xmlns:android="http://uno.ui/android"
					xmlns:ios="http://uno.ui/ios"
					mc:Ignorable="android ios">

	<!--
		Simple Design System — AppBarButton Styles
		Mapped from SDS NavigationButton component.

		SDS NavigationButton has:
		  - Transparent background by default
		  - Icon + label stacked vertically (column direction)
		  - Normal:   text=default-secondary, icon=default-secondary
		  - Hover:    background=default-default-hover
		  - Selected: text=brand-default, icon=brand-default
		  - Disabled: text=disabled-default, icon=disabled-default
		  - Sizes:    medium (16px Normal), small (14px SemiBold)
		  - Spacing:  padding=8px, gap=8px

		Lightweight styling pattern: every visual-state brush is exposed via
		ThemeResource so consumers can override any individual key.

		Semantic resource layer:
		  AppBarButton*       = semantic keys (source of truth)
		  SimpleAppBarButton* = backwards-compat aliases

		Simple-only keys (no Material equivalent, no rename):
		  SimpleAppBarButtonIconForeground*  — separate icon foreground
		  SimpleAppBarButtonIconSize         — icon sizing
		  SimpleAppBarButtonContentSpacing   — gap between icon and label
		  SimpleAppBarButtonPadding          — control padding
	-->

	<!-- ═══════════════════════════════════════════════════════════════════════ -->
	<!-- Lightweight styling ThemeResource aliases                              -->
	<!-- ═══════════════════════════════════════════════════════════════════════ -->
	<ResourceDictionary.ThemeDictionaries>

		<!-- ─── Light Theme ─── -->
		<ResourceDictionary x:Key="Light">

			<!-- ── AppBarButton — semantic keys (source of truth) ── -->
			<StaticResource x:Key="AppBarButtonHeight" ResourceKey="SimpleSpace1600" /> <!-- sds-size-space-1600 -->
			<StaticResource x:Key="AppBarButtonWidth" ResourceKey="SimpleSpace1600" /> <!-- sds-size-space-1600 -->

			<!-- Foreground (label text) -->
			<StaticResource x:Key="AppBarButtonForeground"                ResourceKey="SimpleTextDefaultSecondaryBrush" />
			<StaticResource x:Key="AppBarButtonForegroundPointerOver"     ResourceKey="SimpleTextDefaultSecondaryBrush" />
			<StaticResource x:Key="AppBarButtonForegroundPressed"         ResourceKey="SimpleTextDefaultSecondaryBrush" />
			<StaticResource x:Key="AppBarButtonForegroundDisabled"        ResourceKey="SimpleTextDisabledDefaultBrush" />

			<!-- Background -->
			<StaticResource x:Key="AppBarButtonBackground"                ResourceKey="SystemControlTransparentBrush" />
			<StaticResource x:Key="AppBarButtonBackgroundPointerOver"     ResourceKey="SimpleBackgroundDefaultDefaultHoverBrush" />
			<StaticResource x:Key="AppBarButtonBackgroundPressed"         ResourceKey="SimpleBackgroundDefaultDefaultPressedBrush" />
			<StaticResource x:Key="AppBarButtonBackgroundDisabled"        ResourceKey="SystemControlTransparentBrush" />

			<!-- BorderBrush (none by default, but exposed for overriding) -->
			<StaticResource x:Key="AppBarButtonBorderBrush"               ResourceKey="SystemControlTransparentBrush" />
			<StaticResource x:Key="AppBarButtonBorderBrushPointerOver"    ResourceKey="SystemControlTransparentBrush" />
			<StaticResource x:Key="AppBarButtonBorderBrushPressed"        ResourceKey="SystemControlTransparentBrush" />
			<StaticResource x:Key="AppBarButtonBorderBrushDisabled"       ResourceKey="SystemControlTransparentBrush" />

			<!-- Backwards-compat aliases (SimpleAppBarButton* → AppBarButton*) -->
			<StaticResource x:Key="SimpleAppBarButtonHeight" ResourceKey="AppBarButtonHeight" />
			<StaticResource x:Key="SimpleAppBarButtonWidth" ResourceKey="AppBarButtonWidth" />
			<StaticResource x:Key="SimpleAppBarButtonForeground"                ResourceKey="AppBarButtonForeground" />
			<StaticResource x:Key="SimpleAppBarButtonForegroundPointerOver"     ResourceKey="AppBarButtonForegroundPointerOver" />
			<StaticResource x:Key="SimpleAppBarButtonForegroundPressed"         ResourceKey="AppBarButtonForegroundPressed" />
			<StaticResource x:Key="SimpleAppBarButtonForegroundDisabled"        ResourceKey="AppBarButtonForegroundDisabled" />
			<StaticResource x:Key="SimpleAppBarButtonBackground"                ResourceKey="AppBarButtonBackground" />
			<StaticResource x:Key="SimpleAppBarButtonBackgroundPointerOver"     ResourceKey="AppBarButtonBackgroundPointerOver" />
			<StaticResource x:Key="SimpleAppBarButtonBackgroundPressed"         ResourceKey="AppBarButtonBackgroundPressed" />
			<StaticResource x:Key="SimpleAppBarButtonBackgroundDisabled"        ResourceKey="AppBarButtonBackgroundDisabled" />
			<StaticResource x:Key="SimpleAppBarButtonBorderBrush"               ResourceKey="AppBarButtonBorderBrush" />
			<StaticResource x:Key="SimpleAppBarButtonBorderBrushPointerOver"    ResourceKey="AppBarButtonBorderBrushPointerOver" />
			<StaticResource x:Key="SimpleAppBarButtonBorderBrushPressed"        ResourceKey="AppBarButtonBorderBrushPressed" />
			<StaticResource x:Key="SimpleAppBarButtonBorderBrushDisabled"       ResourceKey="AppBarButtonBorderBrushDisabled" />

			<!-- Simple-only keys (no Material equivalent) -->
			<StaticResource x:Key="SimpleAppBarButtonIconForeground"            ResourceKey="SimpleIconDefaultSecondaryBrush" />
			<StaticResource x:Key="SimpleAppBarButtonIconForegroundPointerOver" ResourceKey="SimpleIconDefaultSecondaryBrush" />
			<StaticResource x:Key="SimpleAppBarButtonIconForegroundPressed"     ResourceKey="SimpleIconDefaultSecondaryBrush" />
			<StaticResource x:Key="SimpleAppBarButtonIconForegroundDisabled"    ResourceKey="SimpleIconDisabledDefaultBrush" />
		</ResourceDictionary>

		<!-- ─── Dark Theme (Default) ─── -->
		<ResourceDictionary x:Key="Default">

			<!-- ── AppBarButton — semantic keys (source of truth) ── -->
			<StaticResource x:Key="AppBarButtonHeight" ResourceKey="SimpleSpace1600" /> <!-- sds-size-space-1600 -->
			<StaticResource x:Key="AppBarButtonWidth" ResourceKey="SimpleSpace1600" /> <!-- sds-size-space-1600 -->

			<!-- Foreground (label text) -->
			<StaticResource x:Key="AppBarButtonForeground"                ResourceKey="SimpleTextDefaultSecondaryBrush" />
			<StaticResource x:Key="AppBarButtonForegroundPointerOver"     ResourceKey="SimpleTextDefaultSecondaryBrush" />
			<StaticResource x:Key="AppBarButtonForegroundPressed"         ResourceKey="SimpleTextDefaultSecondaryBrush" />
			<StaticResource x:Key="AppBarButtonForegroundDisabled"        ResourceKey="SimpleTextDisabledDefaultBrush" />

			<!-- Background -->
			<StaticResource x:Key="AppBarButtonBackground"                ResourceKey="SystemControlTransparentBrush" />
			<StaticResource x:Key="AppBarButtonBackgroundPointerOver"     ResourceKey="SimpleBackgroundDefaultDefaultHoverBrush" />
			<StaticResource x:Key="AppBarButtonBackgroundPressed"         ResourceKey="SimpleBackgroundDefaultDefaultPressedBrush" />
			<StaticResource x:Key="AppBarButtonBackgroundDisabled"        ResourceKey="SystemControlTransparentBrush" />

			<!-- BorderBrush (none by default, but exposed for overriding) -->
			<StaticResource x:Key="AppBarButtonBorderBrush"               ResourceKey="SystemControlTransparentBrush" />
			<StaticResource x:Key="AppBarButtonBorderBrushPointerOver"    ResourceKey="SystemControlTransparentBrush" />
			<StaticResource x:Key="AppBarButtonBorderBrushPressed"        ResourceKey="SystemControlTransparentBrush" />
			<StaticResource x:Key="AppBarButtonBorderBrushDisabled"       ResourceKey="SystemControlTransparentBrush" />

			<!-- Backwards-compat aliases (SimpleAppBarButton* → AppBarButton*) -->
			<StaticResource x:Key="SimpleAppBarButtonHeight" ResourceKey="AppBarButtonHeight" />
			<StaticResource x:Key="SimpleAppBarButtonWidth" ResourceKey="AppBarButtonWidth" />
			<StaticResource x:Key="SimpleAppBarButtonForeground"                ResourceKey="AppBarButtonForeground" />
			<StaticResource x:Key="SimpleAppBarButtonForegroundPointerOver"     ResourceKey="AppBarButtonForegroundPointerOver" />
			<StaticResource x:Key="SimpleAppBarButtonForegroundPressed"         ResourceKey="AppBarButtonForegroundPressed" />
			<StaticResource x:Key="SimpleAppBarButtonForegroundDisabled"        ResourceKey="AppBarButtonForegroundDisabled" />
			<StaticResource x:Key="SimpleAppBarButtonBackground"                ResourceKey="AppBarButtonBackground" />
			<StaticResource x:Key="SimpleAppBarButtonBackgroundPointerOver"     ResourceKey="AppBarButtonBackgroundPointerOver" />
			<StaticResource x:Key="SimpleAppBarButtonBackgroundPressed"         ResourceKey="AppBarButtonBackgroundPressed" />
			<StaticResource x:Key="SimpleAppBarButtonBackgroundDisabled"        ResourceKey="AppBarButtonBackgroundDisabled" />
			<StaticResource x:Key="SimpleAppBarButtonBorderBrush"               ResourceKey="AppBarButtonBorderBrush" />
			<StaticResource x:Key="SimpleAppBarButtonBorderBrushPointerOver"    ResourceKey="AppBarButtonBorderBrushPointerOver" />
			<StaticResource x:Key="SimpleAppBarButtonBorderBrushPressed"        ResourceKey="AppBarButtonBorderBrushPressed" />
			<StaticResource x:Key="SimpleAppBarButtonBorderBrushDisabled"       ResourceKey="AppBarButtonBorderBrushDisabled" />

			<!-- Simple-only keys (no Material equivalent) -->
			<StaticResource x:Key="SimpleAppBarButtonIconForeground"            ResourceKey="SimpleIconDefaultSecondaryBrush" />
			<StaticResource x:Key="SimpleAppBarButtonIconForegroundPointerOver" ResourceKey="SimpleIconDefaultSecondaryBrush" />
			<StaticResource x:Key="SimpleAppBarButtonIconForegroundPressed"     ResourceKey="SimpleIconDefaultSecondaryBrush" />
			<StaticResource x:Key="SimpleAppBarButtonIconForegroundDisabled"    ResourceKey="SimpleIconDisabledDefaultBrush" />
		</ResourceDictionary>
	</ResourceDictionary.ThemeDictionaries>

	<!-- ═══════════════════════════════════════════════════════════════════════ -->
	<!-- Theme-agnostic layout constants                                        -->
	<!-- ═══════════════════════════════════════════════════════════════════════ -->
	<StaticResource x:Key="SimpleAppBarButtonIconSize" ResourceKey="SimpleIconSmall" /> <!-- sds-size-icon-small -->
	<StaticResource x:Key="SimpleAppBarButtonContentSpacing" ResourceKey="SimpleSpace200" /> <!-- sds-size-space-200 -->
	<StaticResource x:Key="SimpleAppBarButtonPadding" ResourceKey="SimpleSpace200Thickness" /> <!-- sds-size-space-200 -->

	<!-- ═══════════════════════════════════════════════════════════════════════ -->
	<!-- SimpleAppBarButtonStyle                                                -->
	<!-- Maps from SDS NavigationButton (column direction, medium size)         -->
	<!-- ═══════════════════════════════════════════════════════════════════════ -->
	<Style x:Key="SimpleAppBarButtonStyle"
		   TargetType="AppBarButton">
		<Setter Property="Background" Value="{ThemeResource AppBarButtonBackground}" />
		<Setter Property="Foreground" Value="{ThemeResource AppBarButtonForeground}" />
		<Setter Property="BorderBrush" Value="{ThemeResource AppBarButtonBorderBrush}" />
		<Setter Property="BorderThickness" Value="0" />
		<Setter Property="Padding" Value="{StaticResource SimpleAppBarButtonPadding}" />
		<Setter Property="HorizontalAlignment" Value="Left" />
		<Setter Property="VerticalAlignment" Value="Top" />
		<Setter Property="Height" Value="{ThemeResource AppBarButtonHeight}" />
		<Setter Property="Width" Value="{ThemeResource AppBarButtonWidth}" />
		<Setter Property="FontFamily" Value="{ThemeResource SimpleFontFamily}" />
		<Setter Property="FontSize" Value="{ThemeResource SimpleTypographyScale03}" />
		<Setter Property="FontWeight" Value="Normal" />
		<Setter Property="UseSystemFocusVisuals" Value="{StaticResource UseSystemFocusVisuals}" />
		<Setter Property="FocusVisualMargin" Value="-3" />
		<Setter Property="AllowFocusOnInteraction" Value="False" />
		<Setter Property="Template">
			<Setter.Value>
				<ControlTemplate TargetType="AppBarButton">
					<Grid x:Name="Root"
						  Background="{TemplateBinding Background}"
						  BorderBrush="{TemplateBinding BorderBrush}"
						  BorderThickness="{TemplateBinding BorderThickness}"
						  Padding="{TemplateBinding Padding}"
						  MinWidth="{TemplateBinding MinWidth}"
						  MaxWidth="{TemplateBinding MaxWidth}">

						<VisualStateManager.VisualStateGroups>
							<VisualStateGroup x:Name="CommonStates">
								<VisualState x:Name="Normal" />

								<VisualState x:Name="PointerOver">
									<VisualState.Setters>
										<Setter Target="Root.Background" Value="{ThemeResource AppBarButtonBackgroundPointerOver}" />
										<Setter Target="Root.BorderBrush" Value="{ThemeResource AppBarButtonBorderBrushPointerOver}" />
										<Setter Target="Content.Foreground" Value="{ThemeResource SimpleAppBarButtonIconForegroundPointerOver}" />
										<Setter Target="ContentPresenter.Foreground" Value="{ThemeResource AppBarButtonForegroundPointerOver}" />
									</VisualState.Setters>
								</VisualState>

								<VisualState x:Name="Pressed">
									<VisualState.Setters>
										<Setter Target="Root.Background" Value="{ThemeResource AppBarButtonBackgroundPressed}" />
										<Setter Target="Root.BorderBrush" Value="{ThemeResource AppBarButtonBorderBrushPressed}" />
										<Setter Target="Content.Foreground" Value="{ThemeResource SimpleAppBarButtonIconForegroundPressed}" />
										<Setter Target="ContentPresenter.Foreground" Value="{ThemeResource AppBarButtonForegroundPressed}" />
									</VisualState.Setters>
								</VisualState>

								<VisualState x:Name="Disabled">
									<VisualState.Setters>
										<Setter Target="Root.Background" Value="{ThemeResource AppBarButtonBackgroundDisabled}" />
										<Setter Target="Root.BorderBrush" Value="{ThemeResource AppBarButtonBorderBrushDisabled}" />
										<Setter Target="Content.Foreground" Value="{ThemeResource SimpleAppBarButtonIconForegroundDisabled}" />
										<Setter Target="ContentPresenter.Foreground" Value="{ThemeResource AppBarButtonForegroundDisabled}" />
									</VisualState.Setters>
								</VisualState>
							</VisualStateGroup>
						</VisualStateManager.VisualStateGroups>

						<StackPanel x:Name="ContentRoot"
									Orientation="Vertical"
									VerticalAlignment="Center"
									HorizontalAlignment="Center"
									Spacing="{StaticResource SimpleAppBarButtonContentSpacing}">

							<!-- Icon content wrapped in Viewbox (shown when Icon is set) -->
							<Viewbox x:Name="ContentViewbox"
									 MaxHeight="{StaticResource SimpleAppBarButtonIconSize}"
									 MaxWidth="{StaticResource SimpleAppBarButtonIconSize}"
									 VerticalAlignment="Center"
									 HorizontalAlignment="Center"
									 AutomationProperties.AccessibilityView="Raw"
									 Visibility="{Binding Icon, RelativeSource={RelativeSource TemplatedParent}, Converter={StaticResource NullToCollapsedConverter}, FallbackValue=Collapsed, TargetNullValue=Collapsed}">
								<ContentPresenter x:Name="Content"
												  Content="{TemplateBinding Icon}"
												  Foreground="{ThemeResource SimpleAppBarButtonIconForeground}" />
							</Viewbox>

							<!-- Label text (shown when Content is not null/empty) -->
							<ContentPresenter x:Name="ContentPresenter"
											  Content="{TemplateBinding Content}"
											  Foreground="{TemplateBinding Foreground}"
											  FontSize="{TemplateBinding FontSize}"
											  FontWeight="{TemplateBinding FontWeight}"
											  FontFamily="{TemplateBinding FontFamily}"
											  VerticalAlignment="Center"
											  HorizontalAlignment="Center"
											  Visibility="{Binding Content, RelativeSource={RelativeSource TemplatedParent}, Converter={StaticResource NullToCollapsedConverter}, FallbackValue=Collapsed, TargetNullValue=Collapsed}" />
						</StackPanel>
					</Grid>
				</ControlTemplate>
			</Setter.Value>
		</Setter>
	</Style>

	<!-- ═══════════════════════════════════════════════════════════════════════ -->
	<!-- Default alias (for implicit style)                                     -->
	<!-- ═══════════════════════════════════════════════════════════════════════ -->
	<Style x:Key="SimpleDefaultAppBarButtonStyle"
		   TargetType="AppBarButton"
		   BasedOn="{StaticResource SimpleAppBarButtonStyle}" />

</ResourceDictionary>
