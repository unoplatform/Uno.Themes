<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
					xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
					xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
					xmlns:ut="using:Uno.Themes"
					xmlns:win="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
					xmlns:android="http://uno.ui/android"
					xmlns:ios="http://uno.ui/ios"
					mc:Ignorable="android ios">

	<!--
		Simple Design System — AppBarButton Styles
		Mapped from SDS NavigationButton component.

		SDS NavigationButton has:
		  - Transparent background by default
		  - Icon + label stacked vertically (column direction)
		  - Normal:   text=default-secondary, icon=default-secondary
		  - Hover:    background=default-default-hover
		  - Selected: text=brand-default, icon=brand-default
		  - Disabled: text=disabled-default, icon=disabled-default
		  - Sizes:    medium (16px Normal), small (14px SemiBold)
		  - Spacing:  padding=8px, gap=8px

		Lightweight styling pattern: every visual-state brush is exposed via
		ThemeResource so consumers can override any individual key.
	-->

	<!-- ═══════════════════════════════════════════════════════════════════════ -->
	<!-- Lightweight styling ThemeResource aliases                              -->
	<!-- ═══════════════════════════════════════════════════════════════════════ -->
	<ResourceDictionary.ThemeDictionaries>

		<!-- ─── Light Theme ─── -->
		<ResourceDictionary x:Key="Light">
			<x:Double x:Key="SimpleAppBarButtonHeight">64</x:Double>
			<x:Double x:Key="SimpleAppBarButtonWidth">64</x:Double>

			<!-- Foreground (label text) -->
			<StaticResource x:Key="SimpleAppBarButtonForeground"                ResourceKey="SimpleTextDefaultSecondaryBrush" />
			<StaticResource x:Key="SimpleAppBarButtonForegroundPointerOver"     ResourceKey="SimpleTextDefaultSecondaryBrush" />
			<StaticResource x:Key="SimpleAppBarButtonForegroundPressed"         ResourceKey="SimpleTextDefaultSecondaryBrush" />
			<StaticResource x:Key="SimpleAppBarButtonForegroundDisabled"        ResourceKey="SimpleTextDisabledDefaultBrush" />

			<!-- Icon foreground -->
			<StaticResource x:Key="SimpleAppBarButtonIconForeground"            ResourceKey="SimpleIconDefaultSecondaryBrush" />
			<StaticResource x:Key="SimpleAppBarButtonIconForegroundPointerOver" ResourceKey="SimpleIconDefaultSecondaryBrush" />
			<StaticResource x:Key="SimpleAppBarButtonIconForegroundPressed"     ResourceKey="SimpleIconDefaultSecondaryBrush" />
			<StaticResource x:Key="SimpleAppBarButtonIconForegroundDisabled"    ResourceKey="SimpleIconDisabledDefaultBrush" />

			<!-- Background -->
			<StaticResource x:Key="SimpleAppBarButtonBackground"                ResourceKey="SystemControlTransparentBrush" />
			<StaticResource x:Key="SimpleAppBarButtonBackgroundPointerOver"     ResourceKey="SimpleBackgroundDefaultDefaultHoverBrush" />
			<StaticResource x:Key="SimpleAppBarButtonBackgroundPressed"         ResourceKey="SimpleBackgroundDefaultDefaultPressedBrush" />
			<StaticResource x:Key="SimpleAppBarButtonBackgroundDisabled"        ResourceKey="SystemControlTransparentBrush" />

			<!-- BorderBrush (none by default, but exposed for overriding) -->
			<StaticResource x:Key="SimpleAppBarButtonBorderBrush"               ResourceKey="SystemControlTransparentBrush" />
			<StaticResource x:Key="SimpleAppBarButtonBorderBrushPointerOver"    ResourceKey="SystemControlTransparentBrush" />
			<StaticResource x:Key="SimpleAppBarButtonBorderBrushPressed"        ResourceKey="SystemControlTransparentBrush" />
			<StaticResource x:Key="SimpleAppBarButtonBorderBrushDisabled"       ResourceKey="SystemControlTransparentBrush" />
		</ResourceDictionary>

		<!-- ─── Dark Theme (Default) ─── -->
		<ResourceDictionary x:Key="Default">
			<x:Double x:Key="SimpleAppBarButtonHeight">64</x:Double>
			<x:Double x:Key="SimpleAppBarButtonWidth">64</x:Double>

			<!-- Foreground (label text) -->
			<StaticResource x:Key="SimpleAppBarButtonForeground"                ResourceKey="SimpleTextDefaultSecondaryBrush" />
			<StaticResource x:Key="SimpleAppBarButtonForegroundPointerOver"     ResourceKey="SimpleTextDefaultSecondaryBrush" />
			<StaticResource x:Key="SimpleAppBarButtonForegroundPressed"         ResourceKey="SimpleTextDefaultSecondaryBrush" />
			<StaticResource x:Key="SimpleAppBarButtonForegroundDisabled"        ResourceKey="SimpleTextDisabledDefaultBrush" />

			<!-- Icon foreground -->
			<StaticResource x:Key="SimpleAppBarButtonIconForeground"            ResourceKey="SimpleIconDefaultSecondaryBrush" />
			<StaticResource x:Key="SimpleAppBarButtonIconForegroundPointerOver" ResourceKey="SimpleIconDefaultSecondaryBrush" />
			<StaticResource x:Key="SimpleAppBarButtonIconForegroundPressed"     ResourceKey="SimpleIconDefaultSecondaryBrush" />
			<StaticResource x:Key="SimpleAppBarButtonIconForegroundDisabled"    ResourceKey="SimpleIconDisabledDefaultBrush" />

			<!-- Background -->
			<StaticResource x:Key="SimpleAppBarButtonBackground"                ResourceKey="SystemControlTransparentBrush" />
			<StaticResource x:Key="SimpleAppBarButtonBackgroundPointerOver"     ResourceKey="SimpleBackgroundDefaultDefaultHoverBrush" />
			<StaticResource x:Key="SimpleAppBarButtonBackgroundPressed"         ResourceKey="SimpleBackgroundDefaultDefaultPressedBrush" />
			<StaticResource x:Key="SimpleAppBarButtonBackgroundDisabled"        ResourceKey="SystemControlTransparentBrush" />

			<!-- BorderBrush (none by default, but exposed for overriding) -->
			<StaticResource x:Key="SimpleAppBarButtonBorderBrush"               ResourceKey="SystemControlTransparentBrush" />
			<StaticResource x:Key="SimpleAppBarButtonBorderBrushPointerOver"    ResourceKey="SystemControlTransparentBrush" />
			<StaticResource x:Key="SimpleAppBarButtonBorderBrushPressed"        ResourceKey="SystemControlTransparentBrush" />
			<StaticResource x:Key="SimpleAppBarButtonBorderBrushDisabled"       ResourceKey="SystemControlTransparentBrush" />
		</ResourceDictionary>
	</ResourceDictionary.ThemeDictionaries>

	<!-- ═══════════════════════════════════════════════════════════════════════ -->
	<!-- Theme-agnostic layout constants                                        -->
	<!-- ═══════════════════════════════════════════════════════════════════════ -->
	<x:Double x:Key="SimpleAppBarButtonIconSize">24</x:Double>
	<x:Double x:Key="SimpleAppBarButtonContentSpacing">8</x:Double>
	<Thickness x:Key="SimpleAppBarButtonPadding">8</Thickness>

	<!-- ═══════════════════════════════════════════════════════════════════════ -->
	<!-- SimpleAppBarButtonStyle                                                -->
	<!-- Maps from SDS NavigationButton (column direction, medium size)         -->
	<!-- ═══════════════════════════════════════════════════════════════════════ -->
	<Style x:Key="SimpleAppBarButtonStyle"
		   TargetType="AppBarButton">
		<Setter Property="Background" Value="{ThemeResource SimpleAppBarButtonBackground}" />
		<Setter Property="Foreground" Value="{ThemeResource SimpleAppBarButtonForeground}" />
		<Setter Property="BorderBrush" Value="{ThemeResource SimpleAppBarButtonBorderBrush}" />
		<Setter Property="BorderThickness" Value="0" />
		<Setter Property="Padding" Value="{StaticResource SimpleAppBarButtonPadding}" />
		<Setter Property="HorizontalAlignment" Value="Left" />
		<Setter Property="VerticalAlignment" Value="Top" />
		<Setter Property="Height" Value="{ThemeResource SimpleAppBarButtonHeight}" />
		<Setter Property="Width" Value="{ThemeResource SimpleAppBarButtonWidth}" />
		<Setter Property="FontFamily" Value="{ThemeResource SimpleFontFamily}" />
		<Setter Property="FontSize" Value="{ThemeResource SimpleTypographyScale03}" />
		<Setter Property="FontWeight" Value="Normal" />
		<Setter Property="UseSystemFocusVisuals" Value="{StaticResource UseSystemFocusVisuals}" />
		<Setter Property="FocusVisualMargin" Value="-3" />
		<Setter Property="AllowFocusOnInteraction" Value="False" />
		<Setter Property="Template">
			<Setter.Value>
				<ControlTemplate TargetType="AppBarButton">
					<Grid x:Name="Root"
						  Background="{TemplateBinding Background}"
						  BorderBrush="{TemplateBinding BorderBrush}"
						  BorderThickness="{TemplateBinding BorderThickness}"
						  Padding="{TemplateBinding Padding}"
						  MinWidth="{TemplateBinding MinWidth}"
						  MaxWidth="{TemplateBinding MaxWidth}">

						<VisualStateManager.VisualStateGroups>
							<VisualStateGroup x:Name="CommonStates">
								<VisualState x:Name="Normal" />

								<VisualState x:Name="PointerOver">
									<VisualState.Setters>
										<Setter Target="Root.Background" Value="{ThemeResource SimpleAppBarButtonBackgroundPointerOver}" />
										<Setter Target="Root.BorderBrush" Value="{ThemeResource SimpleAppBarButtonBorderBrushPointerOver}" />
										<Setter Target="Content.Foreground" Value="{ThemeResource SimpleAppBarButtonIconForegroundPointerOver}" />
										<Setter Target="ContentPresenter.Foreground" Value="{ThemeResource SimpleAppBarButtonForegroundPointerOver}" />
									</VisualState.Setters>
								</VisualState>

								<VisualState x:Name="Pressed">
									<VisualState.Setters>
										<Setter Target="Root.Background" Value="{ThemeResource SimpleAppBarButtonBackgroundPressed}" />
										<Setter Target="Root.BorderBrush" Value="{ThemeResource SimpleAppBarButtonBorderBrushPressed}" />
										<Setter Target="Content.Foreground" Value="{ThemeResource SimpleAppBarButtonIconForegroundPressed}" />
										<Setter Target="ContentPresenter.Foreground" Value="{ThemeResource SimpleAppBarButtonForegroundPressed}" />
									</VisualState.Setters>
								</VisualState>

								<VisualState x:Name="Disabled">
									<VisualState.Setters>
										<Setter Target="Root.Background" Value="{ThemeResource SimpleAppBarButtonBackgroundDisabled}" />
										<Setter Target="Root.BorderBrush" Value="{ThemeResource SimpleAppBarButtonBorderBrushDisabled}" />
										<Setter Target="Content.Foreground" Value="{ThemeResource SimpleAppBarButtonIconForegroundDisabled}" />
										<Setter Target="ContentPresenter.Foreground" Value="{ThemeResource SimpleAppBarButtonForegroundDisabled}" />
									</VisualState.Setters>
								</VisualState>
							</VisualStateGroup>
						</VisualStateManager.VisualStateGroups>

						<StackPanel x:Name="ContentRoot"
									Orientation="Vertical"
									VerticalAlignment="Center"
									HorizontalAlignment="Center"
									Spacing="{StaticResource SimpleAppBarButtonContentSpacing}">

							<!-- Icon content wrapped in Viewbox (shown when Icon is set) -->
							<Viewbox x:Name="ContentViewbox"
									 MaxHeight="{StaticResource SimpleAppBarButtonIconSize}"
									 MaxWidth="{StaticResource SimpleAppBarButtonIconSize}"
									 VerticalAlignment="Center"
									 HorizontalAlignment="Center"
									 AutomationProperties.AccessibilityView="Raw"
									 Visibility="{Binding Icon, RelativeSource={RelativeSource TemplatedParent}, Converter={StaticResource NullToCollapsedConverter}, FallbackValue=Collapsed, TargetNullValue=Collapsed}">
								<ContentPresenter x:Name="Content"
												  Content="{TemplateBinding Icon}"
												  Foreground="{ThemeResource SimpleAppBarButtonIconForeground}" />
							</Viewbox>

							<!-- Label text (shown when Content is not null/empty) -->
							<ContentPresenter x:Name="ContentPresenter"
											  Content="{TemplateBinding Content}"
											  Foreground="{TemplateBinding Foreground}"
											  FontSize="{TemplateBinding FontSize}"
											  FontWeight="{TemplateBinding FontWeight}"
											  FontFamily="{TemplateBinding FontFamily}"
											  VerticalAlignment="Center"
											  HorizontalAlignment="Center"
											  Visibility="{Binding Content, RelativeSource={RelativeSource TemplatedParent}, Converter={StaticResource NullToCollapsedConverter}, FallbackValue=Collapsed, TargetNullValue=Collapsed}" />
						</StackPanel>
					</Grid>
				</ControlTemplate>
			</Setter.Value>
		</Setter>
	</Style>

	<!-- ═══════════════════════════════════════════════════════════════════════ -->
	<!-- Default alias (for implicit style)                                     -->
	<!-- ═══════════════════════════════════════════════════════════════════════ -->
	<Style x:Key="SimpleDefaultAppBarButtonStyle"
		   TargetType="AppBarButton"
		   BasedOn="{StaticResource SimpleAppBarButtonStyle}" />

</ResourceDictionary>
