<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
					xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

	<!--
		Simple Design System — ComboBox (Select) Styles
		Lightweight styling: every visual-state brush is exposed via ThemeResource.
		
		Resource layers:
		ComboBox*           = semantic keys (source of truth) — matches Material naming
		SimpleComboBox*     = Simple-prefixed aliases → ComboBox*
		
		Templates reference Simple-prefixed keys (which alias to semantic keys).
		This allows overriding EITHER the Simple-prefixed key OR the semantic key.
		
		Simple-only resources (error styles) stay as-is with Simple prefix.
		
		Styles: SimpleComboBoxStyle (ComboBox), SimpleComboBoxItemStyle (ComboBoxItem),
		SimpleComboBoxErrorStyle (error variant)
		SDS source: Select/select.css
	-->

	<!-- ═══════════════════════════════════════════════════════════════════════ -->
	<!-- Lightweight styling ThemeResource aliases -->
	<!-- ═══════════════════════════════════════════════════════════════════════ -->
	<ResourceDictionary.ThemeDictionaries>

		<!-- ─── Light Theme ─── -->
		<ResourceDictionary x:Key="Light">

			<!-- ── ComboBox — semantic keys (source of truth) ── -->
			<StaticResource x:Key="ComboBoxBackground" ResourceKey="SurfaceBrush" />
			<StaticResource x:Key="ComboBoxBackgroundPointerOver" ResourceKey="SurfaceBrush" />
			<StaticResource x:Key="ComboBoxBackgroundPressed" ResourceKey="SurfaceBrush" />
			<StaticResource x:Key="ComboBoxBackgroundDisabled" ResourceKey="OnSurfaceDisabledBrush" />
			<StaticResource x:Key="ComboBoxBorderBrush" ResourceKey="OutlineBrush" />
			<StaticResource x:Key="ComboBoxBorderBrushPointerOver" ResourceKey="OutlineBrush" />
			<StaticResource x:Key="ComboBoxBorderBrushPressed" ResourceKey="PrimaryMediumBrush" />
			<StaticResource x:Key="ComboBoxBorderBrushDisabled" ResourceKey="OutlineDisabledBrush" />
			<StaticResource x:Key="ComboBoxForeground" ResourceKey="OnSurfaceBrush" />
			<StaticResource x:Key="ComboBoxForegroundPointerOver" ResourceKey="OnSurfaceBrush" />
			<StaticResource x:Key="ComboBoxForegroundPressed" ResourceKey="OnSurfaceBrush" />
			<StaticResource x:Key="ComboBoxForegroundDisabled" ResourceKey="OnSurfaceDisabledBrush" />
			<StaticResource x:Key="ComboBoxPlaceHolderForeground" ResourceKey="OnSurfaceLowBrush" />
			<StaticResource x:Key="ComboBoxDropDownGlyphForeground" ResourceKey="OnSurfaceBrush" />
			<StaticResource x:Key="ComboBoxDropDownGlyphForegroundDisabled" ResourceKey="OnSurfaceDisabledBrush" />
			<StaticResource x:Key="ComboBoxDropDownBackground" ResourceKey="SurfaceBrush" />
			<StaticResource x:Key="ComboBoxDropDownBorderBrush" ResourceKey="OutlineBrush" />
			<!-- Simple-only (no Material equivalent) -->
			<!-- ── ComboBoxItem — semantic keys (source of truth) ── -->
			<StaticResource x:Key="ComboBoxItemBackground" ResourceKey="SystemControlTransparentBrush" />
			<StaticResource x:Key="ComboBoxItemBackgroundPointerOver" ResourceKey="SurfaceVariantBrush" />
			<StaticResource x:Key="ComboBoxItemBackgroundPressed" ResourceKey="TertiaryContainerBrush" />
			<StaticResource x:Key="ComboBoxItemBackgroundSelected" ResourceKey="PrimaryBrush" />
			<StaticResource x:Key="ComboBoxItemBackgroundSelectedPointerOver" ResourceKey="PrimaryVariantDarkBrush" />
			<StaticResource x:Key="ComboBoxItemBackgroundSelectedPressed" ResourceKey="PrimaryVariantDarkBrush" />
			<StaticResource x:Key="ComboBoxItemBackgroundDisabled" ResourceKey="SystemControlTransparentBrush" />
			<StaticResource x:Key="ComboBoxItemForeground" ResourceKey="OnSurfaceBrush" />
			<StaticResource x:Key="ComboBoxItemForegroundPointerOver" ResourceKey="OnSurfaceBrush" />
			<StaticResource x:Key="ComboBoxItemForegroundPressed" ResourceKey="OnSurfaceBrush" />
			<StaticResource x:Key="ComboBoxItemForegroundSelected" ResourceKey="OnPrimaryBrush" />
			<StaticResource x:Key="ComboBoxItemForegroundSelectedPointerOver" ResourceKey="OnPrimaryBrush" />
			<StaticResource x:Key="ComboBoxItemForegroundSelectedPressed" ResourceKey="OnPrimaryBrush" />
			<StaticResource x:Key="ComboBoxItemForegroundDisabled" ResourceKey="OnSurfaceDisabledBrush" />
		</ResourceDictionary>

		<!-- ─── Dark Theme (Default) ─── -->
		<ResourceDictionary x:Key="Default">

			<!-- ── ComboBox — semantic keys (source of truth) ── -->
			<StaticResource x:Key="ComboBoxBackground" ResourceKey="SurfaceBrush" />
			<StaticResource x:Key="ComboBoxBackgroundPointerOver" ResourceKey="SurfaceBrush" />
			<StaticResource x:Key="ComboBoxBackgroundPressed" ResourceKey="SurfaceBrush" />
			<StaticResource x:Key="ComboBoxBackgroundDisabled" ResourceKey="OnSurfaceDisabledBrush" />
			<StaticResource x:Key="ComboBoxBorderBrush" ResourceKey="OutlineBrush" />
			<StaticResource x:Key="ComboBoxBorderBrushPointerOver" ResourceKey="OutlineBrush" />
			<StaticResource x:Key="ComboBoxBorderBrushPressed" ResourceKey="PrimaryMediumBrush" />
			<StaticResource x:Key="ComboBoxBorderBrushDisabled" ResourceKey="OutlineDisabledBrush" />
			<StaticResource x:Key="ComboBoxForeground" ResourceKey="OnSurfaceBrush" />
			<StaticResource x:Key="ComboBoxForegroundPointerOver" ResourceKey="OnSurfaceBrush" />
			<StaticResource x:Key="ComboBoxForegroundPressed" ResourceKey="OnSurfaceBrush" />
			<StaticResource x:Key="ComboBoxForegroundDisabled" ResourceKey="OnSurfaceDisabledBrush" />
			<StaticResource x:Key="ComboBoxPlaceHolderForeground" ResourceKey="OnSurfaceLowBrush" />
			<StaticResource x:Key="ComboBoxDropDownGlyphForeground" ResourceKey="OnSurfaceBrush" />
			<StaticResource x:Key="ComboBoxDropDownGlyphForegroundDisabled" ResourceKey="OnSurfaceDisabledBrush" />
			<StaticResource x:Key="ComboBoxDropDownBackground" ResourceKey="SurfaceBrush" />
			<StaticResource x:Key="ComboBoxDropDownBorderBrush" ResourceKey="OutlineBrush" />
			<!-- Simple-only (no Material equivalent) -->
			<!-- ── ComboBoxItem — semantic keys (source of truth) ── -->
			<StaticResource x:Key="ComboBoxItemBackground" ResourceKey="SystemControlTransparentBrush" />
			<StaticResource x:Key="ComboBoxItemBackgroundPointerOver" ResourceKey="SurfaceVariantBrush" />
			<StaticResource x:Key="ComboBoxItemBackgroundPressed" ResourceKey="TertiaryContainerBrush" />
			<StaticResource x:Key="ComboBoxItemBackgroundSelected" ResourceKey="PrimaryBrush" />
			<StaticResource x:Key="ComboBoxItemBackgroundSelectedPointerOver" ResourceKey="PrimaryVariantDarkBrush" />
			<StaticResource x:Key="ComboBoxItemBackgroundSelectedPressed" ResourceKey="PrimaryVariantDarkBrush" />
			<StaticResource x:Key="ComboBoxItemBackgroundDisabled" ResourceKey="SystemControlTransparentBrush" />
			<StaticResource x:Key="ComboBoxItemForeground" ResourceKey="OnSurfaceBrush" />
			<StaticResource x:Key="ComboBoxItemForegroundPointerOver" ResourceKey="OnSurfaceBrush" />
			<StaticResource x:Key="ComboBoxItemForegroundPressed" ResourceKey="OnSurfaceBrush" />
			<StaticResource x:Key="ComboBoxItemForegroundSelected" ResourceKey="OnPrimaryBrush" />
			<StaticResource x:Key="ComboBoxItemForegroundSelectedPointerOver" ResourceKey="OnPrimaryBrush" />
			<StaticResource x:Key="ComboBoxItemForegroundSelectedPressed" ResourceKey="OnPrimaryBrush" />
			<StaticResource x:Key="ComboBoxItemForegroundDisabled" ResourceKey="OnSurfaceDisabledBrush" />
		</ResourceDictionary>

	</ResourceDictionary.ThemeDictionaries>

	<StaticResource x:Key="SimpleComboBoxCornerRadius" ResourceKey="ComboBoxCornerRadius" />
	<StaticResource x:Key="SimpleComboBoxMinHeight" ResourceKey="ComboBoxMinHeight" />
	<StaticResource x:Key="SimpleComboBoxBorderThickness" ResourceKey="ComboBoxBorderThickness" />
	<StaticResource x:Key="SimpleComboBoxFocusedBorderThickness" ResourceKey="SimpleStrokeFocusRingThickness" />


	<!-- ═══════════════════════════════════════════════════════════════════════ -->
	<!-- Layout / sizing resources (theme-agnostic) -->
	<!-- ═══════════════════════════════════════════════════════════════════════ -->
	<!-- Semantic keys (source of truth) -->
	<StaticResource x:Key="ComboBoxCornerRadius" ResourceKey="SimpleRadius200CornerRadius" />
	<StaticResource x:Key="ComboBoxMinHeight" ResourceKey="SimpleIconLarge" />
	<StaticResource x:Key="ComboBoxBorderThickness" ResourceKey="SimpleStrokeBorderThickness" />
	<Thickness x:Key="ComboBoxPadding">16,10,12,10</Thickness>
	<!-- Backwards-compat aliases -->
	<Thickness x:Key="SimpleComboBoxPadding">16,10,12,10</Thickness>

	<!-- Simple-only layout resources (no Material equivalent) -->
	<Thickness x:Key="SimpleComboBoxDropDownGlyphMargin">8,0,12,0</Thickness>
	<StaticResource x:Key="SimpleComboBoxPopupPadding" ResourceKey="Space100VerticalThickness" />
	<x:Double x:Key="SimpleComboBoxPopupMaxHeight">400</x:Double>
	<x:String x:Key="SimpleComboBoxDropDownGlyphIcon">&#xE96E;</x:String>

	<!-- SimpleComboBoxStyle - ComboBox (Figma: Select Field) -->
	<Style x:Key="SimpleComboBoxStyle"
		   TargetType="ComboBox">
		<Setter Property="FontFamily" Value="{ThemeResource BodyLargeFontFamily}" />
		<Setter Property="FontSize" Value="14" />
		<Setter Property="Foreground" Value="{ThemeResource ComboBoxForeground}" />
		<Setter Property="Background" Value="{ThemeResource ComboBoxBackground}" />
		<Setter Property="BorderBrush" Value="{ThemeResource ComboBoxBorderBrush}" />
		<Setter Property="BorderThickness" Value="{ThemeResource ComboBoxBorderThickness}" />
		<Setter Property="Padding" Value="{ThemeResource SimpleComboBoxPadding}" />
		<Setter Property="MinHeight" Value="{ThemeResource ComboBoxMinHeight}" />
		<Setter Property="HorizontalAlignment" Value="Stretch" />
		<Setter Property="VerticalAlignment" Value="Top" />
		<Setter Property="HorizontalContentAlignment" Value="Left" />
		<Setter Property="VerticalContentAlignment" Value="Center" />
		<Setter Property="CornerRadius" Value="{StaticResource SimpleComboBoxCornerRadius}" />
		<Setter Property="UseSystemFocusVisuals" Value="{StaticResource UseSystemFocusVisuals}" />
		<Setter Property="FocusVisualMargin" Value="-3" />
		<Setter Property="ItemContainerStyle" Value="{StaticResource SimpleComboBoxItemStyle}" />
		<Setter Property="Template">
			<Setter.Value>
				<ControlTemplate TargetType="ComboBox">
					<Grid>
						<VisualStateManager.VisualStateGroups>
							<VisualStateGroup x:Name="CommonStates">
								<VisualState x:Name="Normal" />

								<VisualState x:Name="PointerOver">
									<VisualState.Setters>
										<Setter Target="BorderElement.Background" Value="{ThemeResource ComboBoxBackgroundPointerOver}" />
										<Setter Target="BorderElement.BorderBrush" Value="{ThemeResource ComboBoxBorderBrushPointerOver}" />
										<Setter Target="ContentPresenter.Foreground" Value="{ThemeResource ComboBoxForegroundPointerOver}" />
									</VisualState.Setters>
								</VisualState>

								<VisualState x:Name="Pressed">
									<VisualState.Setters>
										<Setter Target="BorderElement.Background" Value="{ThemeResource ComboBoxBackgroundPressed}" />
										<Setter Target="BorderElement.BorderBrush" Value="{ThemeResource ComboBoxBorderBrushPressed}" />
										<Setter Target="BorderElement.BorderThickness" Value="{StaticResource SimpleComboBoxFocusedBorderThickness}" />
										<Setter Target="ContentPresenter.Foreground" Value="{ThemeResource ComboBoxForegroundPressed}" />
									</VisualState.Setters>
								</VisualState>

								<VisualState x:Name="Disabled">
									<Storyboard>
										<ObjectAnimationUsingKeyFrames Storyboard.TargetName="BorderElement"
																	   Storyboard.TargetProperty="Background">
											<DiscreteObjectKeyFrame KeyTime="0"
																	Value="{ThemeResource ComboBoxBackgroundDisabled}" />
										</ObjectAnimationUsingKeyFrames>
										<ObjectAnimationUsingKeyFrames Storyboard.TargetName="BorderElement"
																	   Storyboard.TargetProperty="BorderBrush">
											<DiscreteObjectKeyFrame KeyTime="0"
																	Value="{ThemeResource ComboBoxBorderBrushDisabled}" />
										</ObjectAnimationUsingKeyFrames>
										<ObjectAnimationUsingKeyFrames Storyboard.TargetName="ContentPresenter"
																	   Storyboard.TargetProperty="Foreground">
											<DiscreteObjectKeyFrame KeyTime="0"
																	Value="{ThemeResource ComboBoxForegroundDisabled}" />
										</ObjectAnimationUsingKeyFrames>
										<ObjectAnimationUsingKeyFrames Storyboard.TargetName="DropDownGlyph"
																	   Storyboard.TargetProperty="Foreground">
											<DiscreteObjectKeyFrame KeyTime="0"
																	Value="{ThemeResource ComboBoxDropDownGlyphForegroundDisabled}" />
										</ObjectAnimationUsingKeyFrames>
									</Storyboard>
								</VisualState>
							</VisualStateGroup>

							<VisualStateGroup x:Name="FocusStates">
								<VisualState x:Name="Unfocused" />
								<VisualState x:Name="Focused">
									<VisualState.Setters>
										<Setter Target="BorderElement.BorderBrush" Value="{ThemeResource PrimaryMediumBrush}" />
										<Setter Target="BorderElement.BorderThickness" Value="{StaticResource SimpleComboBoxFocusedBorderThickness}" />
									</VisualState.Setters>
								</VisualState>
								<VisualState x:Name="FocusedPressed">
									<VisualState.Setters>
										<Setter Target="BorderElement.BorderBrush" Value="{ThemeResource PrimaryMediumBrush}" />
										<Setter Target="BorderElement.BorderThickness" Value="{StaticResource SimpleComboBoxFocusedBorderThickness}" />
									</VisualState.Setters>
								</VisualState>
							</VisualStateGroup>

							<VisualStateGroup x:Name="DropDownStates">
								<VisualState x:Name="Closed" />
								<VisualState x:Name="Opened">
									<VisualState.Setters>
										<Setter Target="BorderElement.BorderBrush" Value="{ThemeResource PrimaryMediumBrush}" />
										<Setter Target="BorderElement.BorderThickness" Value="{StaticResource SimpleComboBoxFocusedBorderThickness}" />
									</VisualState.Setters>
								</VisualState>
							</VisualStateGroup>
						</VisualStateManager.VisualStateGroups>

						<Border x:Name="BorderElement"
								Background="{TemplateBinding Background}"
								BorderBrush="{TemplateBinding BorderBrush}"
								BorderThickness="{TemplateBinding BorderThickness}"
								CornerRadius="{TemplateBinding CornerRadius}"
								MinHeight="{TemplateBinding MinHeight}">
							<Grid>
								<Grid.ColumnDefinitions>
									<ColumnDefinition Width="*" />
									<ColumnDefinition Width="Auto" />
								</Grid.ColumnDefinitions>

								<!-- Content -->
								<ContentPresenter x:Name="ContentPresenter"
												  Grid.Column="0"
												  Content="{TemplateBinding SelectionBoxItem}"
												  ContentTemplate="{TemplateBinding ItemTemplate}"
												  ContentTemplateSelector="{TemplateBinding ItemTemplateSelector}"
												  Foreground="{TemplateBinding Foreground}"
												  HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
												  VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
												  Margin="{TemplateBinding Padding}" />

								<!-- Dropdown Arrow -->
								<FontIcon x:Name="DropDownGlyph"
										  Grid.Column="1"
										  Glyph="{StaticResource SimpleComboBoxDropDownGlyphIcon}"
										  FontFamily="{ThemeResource SymbolThemeFontFamily}"
										  FontSize="{ThemeResource BodySmallFontSize}"
										  Foreground="{ThemeResource ComboBoxDropDownGlyphForeground}"
										  VerticalAlignment="Center"
										  Margin="{StaticResource SimpleComboBoxDropDownGlyphMargin}"
										  IsHitTestVisible="False"
										  AutomationProperties.AccessibilityView="Raw" />
							</Grid>
						</Border>

						<!-- Popup -->
						<Popup x:Name="Popup"
							   IsLightDismissEnabled="True"
							   AllowFocusOnInteraction="True">
							<Border x:Name="PopupBorder"
									Background="{ThemeResource ComboBoxDropDownBackground}"
									BorderBrush="{ThemeResource ComboBoxDropDownBorderBrush}"
									BorderThickness="{ThemeResource SimpleStrokeBorderThickness}"
									CornerRadius="{StaticResource SimpleComboBoxCornerRadius}"
									Padding="{StaticResource SimpleComboBoxPopupPadding}"
									MaxHeight="{StaticResource SimpleComboBoxPopupMaxHeight}">
								<Border.Shadow>
									<ThemeShadow />
								</Border.Shadow>
								<ScrollViewer x:Name="ScrollViewer"
											  HorizontalScrollMode="Disabled"
											  HorizontalScrollBarVisibility="Disabled"
											  VerticalScrollMode="Auto"
											  VerticalScrollBarVisibility="Auto"
											  ZoomMode="Disabled">
									<ItemsPresenter />
								</ScrollViewer>
							</Border>
						</Popup>
					</Grid>
				</ControlTemplate>
			</Setter.Value>
		</Setter>
	</Style>

	<!-- SimpleComboBoxItemStyle - ComboBox dropdown item -->
	<Style x:Key="SimpleComboBoxItemStyle"
		   TargetType="ComboBoxItem">
		<Setter Property="FontFamily" Value="{ThemeResource BodyLargeFontFamily}" />
		<Setter Property="FontSize" Value="14" />
		<Setter Property="Foreground" Value="{ThemeResource ComboBoxItemForeground}" />
		<Setter Property="Background" Value="Transparent" />
		<Setter Property="Padding" Value="16,12" />
		<Setter Property="MinHeight" Value="40" />
		<Setter Property="HorizontalContentAlignment" Value="Left" />
		<Setter Property="VerticalContentAlignment" Value="Center" />
		<Setter Property="UseSystemFocusVisuals" Value="{StaticResource UseSystemFocusVisuals}" />
		<Setter Property="Template">
			<Setter.Value>
				<ControlTemplate TargetType="ComboBoxItem">
					<Grid x:Name="LayoutRoot"
						  Background="{TemplateBinding Background}"
						  Padding="{TemplateBinding Padding}"
						  MinHeight="{TemplateBinding MinHeight}"
						  CornerRadius="{ThemeResource SimpleRadius100CornerRadius}">
						<VisualStateManager.VisualStateGroups>
							<VisualStateGroup x:Name="CommonStates">
								<VisualState x:Name="Normal" />

								<VisualState x:Name="PointerOver">
									<VisualState.Setters>
										<Setter Target="LayoutRoot.Background" Value="{ThemeResource ComboBoxItemBackgroundPointerOver}" />
										<Setter Target="ContentPresenter.Foreground" Value="{ThemeResource ComboBoxItemForegroundPointerOver}" />
									</VisualState.Setters>
								</VisualState>

								<VisualState x:Name="Pressed">
									<VisualState.Setters>
										<Setter Target="LayoutRoot.Background" Value="{ThemeResource ComboBoxItemBackgroundPressed}" />
										<Setter Target="ContentPresenter.Foreground" Value="{ThemeResource ComboBoxItemForegroundPressed}" />
									</VisualState.Setters>
								</VisualState>

								<VisualState x:Name="Selected">
									<VisualState.Setters>
										<Setter Target="LayoutRoot.Background" Value="{ThemeResource ComboBoxItemBackgroundSelected}" />
										<Setter Target="ContentPresenter.Foreground" Value="{ThemeResource ComboBoxItemForegroundSelected}" />
									</VisualState.Setters>
								</VisualState>

								<VisualState x:Name="SelectedPointerOver">
									<VisualState.Setters>
										<Setter Target="LayoutRoot.Background" Value="{ThemeResource ComboBoxItemBackgroundSelectedPointerOver}" />
										<Setter Target="ContentPresenter.Foreground" Value="{ThemeResource ComboBoxItemForegroundSelectedPointerOver}" />
									</VisualState.Setters>
								</VisualState>

								<VisualState x:Name="SelectedPressed">
									<VisualState.Setters>
										<Setter Target="LayoutRoot.Background" Value="{ThemeResource ComboBoxItemBackgroundSelectedPressed}" />
										<Setter Target="ContentPresenter.Foreground" Value="{ThemeResource ComboBoxItemForegroundSelectedPressed}" />
									</VisualState.Setters>
								</VisualState>

								<VisualState x:Name="Disabled">
									<VisualState.Setters>
										<Setter Target="LayoutRoot.Background" Value="{ThemeResource ComboBoxItemBackgroundDisabled}" />
										<Setter Target="ContentPresenter.Foreground" Value="{ThemeResource ComboBoxItemForegroundDisabled}" />
									</VisualState.Setters>
								</VisualState>
							</VisualStateGroup>
						</VisualStateManager.VisualStateGroups>

						<ContentPresenter x:Name="ContentPresenter"
										  Content="{TemplateBinding Content}"
										  ContentTemplate="{TemplateBinding ContentTemplate}"
										  ContentTransitions="{TemplateBinding ContentTransitions}"
										  Foreground="{TemplateBinding Foreground}"
										  HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
										  VerticalAlignment="{TemplateBinding VerticalContentAlignment}" />
					</Grid>
				</ControlTemplate>
			</Setter.Value>
		</Setter>
	</Style>

	<!-- SimpleComboBoxErrorStyle - Error state -->
	<Style x:Key="SimpleComboBoxErrorStyle"
		   TargetType="ComboBox"
		   BasedOn="{StaticResource SimpleComboBoxStyle}">
		<Setter Property="BorderBrush" Value="{ThemeResource ErrorBrush}" />
	</Style>

</ResourceDictionary>
