<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
					xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

	<!--
		Simple Design System — ComboBox (Select) Styles
		Lightweight styling: every visual-state brush is exposed via ThemeResource.

		Styles: SimpleSelectFieldStyle (ComboBox), SimpleSelectFieldItemStyle (ComboBoxItem),
		        SimpleSelectFieldErrorStyle (error variant)
		SDS source: Select/select.css
	-->

	<!-- ═══════════════════════════════════════════════════════════════════════ -->
	<!-- Lightweight styling ThemeResource aliases                              -->
	<!-- ═══════════════════════════════════════════════════════════════════════ -->
	<ResourceDictionary.ThemeDictionaries>

		<!-- ─── Light Theme ─── -->
		<ResourceDictionary x:Key="Light">

			<!-- ComboBox -->
			<StaticResource x:Key="SimpleComboBoxBackground"                   ResourceKey="SimpleBackgroundDefaultDefaultBrush" />
			<StaticResource x:Key="SimpleComboBoxBackgroundPointerOver"        ResourceKey="SimpleBackgroundDefaultDefaultBrush" />
			<StaticResource x:Key="SimpleComboBoxBackgroundPressed"            ResourceKey="SimpleBackgroundDefaultDefaultBrush" />
			<StaticResource x:Key="SimpleComboBoxBackgroundDisabled"           ResourceKey="SimpleBackgroundDisabledDefaultBrush" />
			<StaticResource x:Key="SimpleComboBoxBorderBrush"                  ResourceKey="SimpleBorderDefaultDefaultBrush" />
			<StaticResource x:Key="SimpleComboBoxBorderBrushPointerOver"       ResourceKey="SimpleBorderDefaultDefaultBrush" />
			<StaticResource x:Key="SimpleComboBoxBorderBrushPressed"           ResourceKey="SimpleBorderBrandSecondaryBrush" />
			<StaticResource x:Key="SimpleComboBoxBorderBrushDisabled"          ResourceKey="SimpleBorderDisabledDefaultBrush" />
			<StaticResource x:Key="SimpleComboBoxBorderBrushFocused"           ResourceKey="SimpleBorderBrandSecondaryBrush" />
			<StaticResource x:Key="SimpleComboBoxBorderBrushError"             ResourceKey="SimpleBorderDangerDefaultBrush" />
			<StaticResource x:Key="SimpleComboBoxForeground"                   ResourceKey="SimpleTextDefaultDefaultBrush" />
			<StaticResource x:Key="SimpleComboBoxForegroundPointerOver"        ResourceKey="SimpleTextDefaultDefaultBrush" />
			<StaticResource x:Key="SimpleComboBoxForegroundPressed"            ResourceKey="SimpleTextDefaultDefaultBrush" />
			<StaticResource x:Key="SimpleComboBoxForegroundDisabled"           ResourceKey="SimpleTextDisabledDefaultBrush" />
			<StaticResource x:Key="SimpleComboBoxPlaceholderForeground"        ResourceKey="SimpleTextDefaultTertiaryBrush" />
			<StaticResource x:Key="SimpleComboBoxDropDownGlyphForeground"      ResourceKey="SimpleIconDefaultDefaultBrush" />
			<StaticResource x:Key="SimpleComboBoxDropDownGlyphForegroundDisabled" ResourceKey="SimpleIconDisabledOnDisabledBrush" />
			<StaticResource x:Key="SimpleComboBoxPopupBackground"              ResourceKey="SimpleBackgroundDefaultDefaultBrush" />
			<StaticResource x:Key="SimpleComboBoxPopupBorderBrush"             ResourceKey="SimpleBorderDefaultDefaultBrush" />

			<!-- ComboBoxItem -->
			<StaticResource x:Key="SimpleComboBoxItemBackground"               ResourceKey="SystemControlTransparentBrush" />
			<StaticResource x:Key="SimpleComboBoxItemBackgroundPointerOver"    ResourceKey="SimpleBackgroundDefaultSecondaryBrush" />
			<StaticResource x:Key="SimpleComboBoxItemBackgroundPressed"        ResourceKey="SimpleBackgroundDefaultSecondaryBrush" />
			<StaticResource x:Key="SimpleComboBoxItemBackgroundSelected"       ResourceKey="SimpleBackgroundBrandDefaultBrush" />
			<StaticResource x:Key="SimpleComboBoxItemBackgroundSelectedPointerOver" ResourceKey="SimpleBackgroundBrandHoverBrush" />
			<StaticResource x:Key="SimpleComboBoxItemBackgroundSelectedPressed" ResourceKey="SimpleBackgroundBrandHoverBrush" />
			<StaticResource x:Key="SimpleComboBoxItemBackgroundDisabled"       ResourceKey="SystemControlTransparentBrush" />
			<StaticResource x:Key="SimpleComboBoxItemForeground"               ResourceKey="SimpleTextDefaultDefaultBrush" />
			<StaticResource x:Key="SimpleComboBoxItemForegroundPointerOver"    ResourceKey="SimpleTextDefaultDefaultBrush" />
			<StaticResource x:Key="SimpleComboBoxItemForegroundPressed"        ResourceKey="SimpleTextDefaultDefaultBrush" />
			<StaticResource x:Key="SimpleComboBoxItemForegroundSelected"       ResourceKey="SimpleTextBrandOnBrandBrush" />
			<StaticResource x:Key="SimpleComboBoxItemForegroundSelectedPointerOver" ResourceKey="SimpleTextBrandOnBrandBrush" />
			<StaticResource x:Key="SimpleComboBoxItemForegroundSelectedPressed" ResourceKey="SimpleTextBrandOnBrandBrush" />
			<StaticResource x:Key="SimpleComboBoxItemForegroundDisabled"       ResourceKey="SimpleTextDisabledDefaultBrush" />
		</ResourceDictionary>

		<!-- ─── Dark Theme (Default) ─── -->
		<ResourceDictionary x:Key="Default">

			<!-- ComboBox -->
			<StaticResource x:Key="SimpleComboBoxBackground"                   ResourceKey="SimpleBackgroundDefaultDefaultBrush" />
			<StaticResource x:Key="SimpleComboBoxBackgroundPointerOver"        ResourceKey="SimpleBackgroundDefaultDefaultBrush" />
			<StaticResource x:Key="SimpleComboBoxBackgroundPressed"            ResourceKey="SimpleBackgroundDefaultDefaultBrush" />
			<StaticResource x:Key="SimpleComboBoxBackgroundDisabled"           ResourceKey="SimpleBackgroundDisabledDefaultBrush" />
			<StaticResource x:Key="SimpleComboBoxBorderBrush"                  ResourceKey="SimpleBorderDefaultDefaultBrush" />
			<StaticResource x:Key="SimpleComboBoxBorderBrushPointerOver"       ResourceKey="SimpleBorderDefaultDefaultBrush" />
			<StaticResource x:Key="SimpleComboBoxBorderBrushPressed"           ResourceKey="SimpleBorderBrandSecondaryBrush" />
			<StaticResource x:Key="SimpleComboBoxBorderBrushDisabled"          ResourceKey="SimpleBorderDisabledDefaultBrush" />
			<StaticResource x:Key="SimpleComboBoxBorderBrushFocused"           ResourceKey="SimpleBorderBrandSecondaryBrush" />
			<StaticResource x:Key="SimpleComboBoxBorderBrushError"             ResourceKey="SimpleBorderDangerDefaultBrush" />
			<StaticResource x:Key="SimpleComboBoxForeground"                   ResourceKey="SimpleTextDefaultDefaultBrush" />
			<StaticResource x:Key="SimpleComboBoxForegroundPointerOver"        ResourceKey="SimpleTextDefaultDefaultBrush" />
			<StaticResource x:Key="SimpleComboBoxForegroundPressed"            ResourceKey="SimpleTextDefaultDefaultBrush" />
			<StaticResource x:Key="SimpleComboBoxForegroundDisabled"           ResourceKey="SimpleTextDisabledDefaultBrush" />
			<StaticResource x:Key="SimpleComboBoxPlaceholderForeground"        ResourceKey="SimpleTextDefaultTertiaryBrush" />
			<StaticResource x:Key="SimpleComboBoxDropDownGlyphForeground"      ResourceKey="SimpleIconDefaultDefaultBrush" />
			<StaticResource x:Key="SimpleComboBoxDropDownGlyphForegroundDisabled" ResourceKey="SimpleIconDisabledOnDisabledBrush" />
			<StaticResource x:Key="SimpleComboBoxPopupBackground"              ResourceKey="SimpleBackgroundDefaultDefaultBrush" />
			<StaticResource x:Key="SimpleComboBoxPopupBorderBrush"             ResourceKey="SimpleBorderDefaultDefaultBrush" />

			<!-- ComboBoxItem -->
			<StaticResource x:Key="SimpleComboBoxItemBackground"               ResourceKey="SystemControlTransparentBrush" />
			<StaticResource x:Key="SimpleComboBoxItemBackgroundPointerOver"    ResourceKey="SimpleBackgroundDefaultSecondaryBrush" />
			<StaticResource x:Key="SimpleComboBoxItemBackgroundPressed"        ResourceKey="SimpleBackgroundDefaultSecondaryBrush" />
			<StaticResource x:Key="SimpleComboBoxItemBackgroundSelected"       ResourceKey="SimpleBackgroundBrandDefaultBrush" />
			<StaticResource x:Key="SimpleComboBoxItemBackgroundSelectedPointerOver" ResourceKey="SimpleBackgroundBrandHoverBrush" />
			<StaticResource x:Key="SimpleComboBoxItemBackgroundSelectedPressed" ResourceKey="SimpleBackgroundBrandHoverBrush" />
			<StaticResource x:Key="SimpleComboBoxItemBackgroundDisabled"       ResourceKey="SystemControlTransparentBrush" />
			<StaticResource x:Key="SimpleComboBoxItemForeground"               ResourceKey="SimpleTextDefaultDefaultBrush" />
			<StaticResource x:Key="SimpleComboBoxItemForegroundPointerOver"    ResourceKey="SimpleTextDefaultDefaultBrush" />
			<StaticResource x:Key="SimpleComboBoxItemForegroundPressed"        ResourceKey="SimpleTextDefaultDefaultBrush" />
			<StaticResource x:Key="SimpleComboBoxItemForegroundSelected"       ResourceKey="SimpleTextBrandOnBrandBrush" />
			<StaticResource x:Key="SimpleComboBoxItemForegroundSelectedPointerOver" ResourceKey="SimpleTextBrandOnBrandBrush" />
			<StaticResource x:Key="SimpleComboBoxItemForegroundSelectedPressed" ResourceKey="SimpleTextBrandOnBrandBrush" />
			<StaticResource x:Key="SimpleComboBoxItemForegroundDisabled"       ResourceKey="SimpleTextDisabledDefaultBrush" />
		</ResourceDictionary>

	</ResourceDictionary.ThemeDictionaries>

	<!-- ═══════════════════════════════════════════════════════════════════════ -->
	<!-- Layout / sizing resources (theme-agnostic)                            -->
	<!-- ═══════════════════════════════════════════════════════════════════════ -->
	<CornerRadius x:Key="SimpleComboBoxCornerRadius">8</CornerRadius>
	<x:Double x:Key="SimpleComboBoxMinHeight">40</x:Double>
	<Thickness x:Key="SimpleComboBoxBorderThickness">1</Thickness>
	<Thickness x:Key="SimpleComboBoxFocusedBorderThickness">2</Thickness>
	<Thickness x:Key="SimpleComboBoxPadding">16,10,12,10</Thickness>
	<x:String x:Key="SimpleComboBoxDropDownGlyphIcon">&#xE96E;</x:String>

	<!-- SimpleSelectFieldStyle - Select Field (Figma: Select Field) -->
	<Style x:Key="SimpleSelectFieldStyle"
		   TargetType="ComboBox">
		<Setter Property="FontFamily" Value="{ThemeResource SimpleFontFamily}" />
		<Setter Property="FontSize" Value="14" />
		<Setter Property="Foreground" Value="{ThemeResource OnSurfaceBrush}" />
		<Setter Property="Background" Value="{ThemeResource SurfaceBrush}" />
		<Setter Property="BorderBrush" Value="{ThemeResource OutlineBrush}" />
		<Setter Property="BorderThickness" Value="{ThemeResource SimpleComboBoxBorderThickness}" />
		<Setter Property="Padding" Value="{ThemeResource SimpleComboBoxPadding}" />
		<Setter Property="MinHeight" Value="{ThemeResource SimpleComboBoxMinHeight}" />
		<Setter Property="HorizontalAlignment" Value="Stretch" />
		<Setter Property="VerticalAlignment" Value="Top" />
		<Setter Property="HorizontalContentAlignment" Value="Left" />
		<Setter Property="VerticalContentAlignment" Value="Center" />
		<Setter Property="CornerRadius" Value="{StaticResource SimpleComboBoxCornerRadius}" />
		<Setter Property="UseSystemFocusVisuals" Value="{StaticResource UseSystemFocusVisuals}" />
		<Setter Property="FocusVisualMargin" Value="-3" />
		<Setter Property="ItemContainerStyle" Value="{StaticResource SimpleSelectFieldItemStyle}" />
		<Setter Property="Template">
			<Setter.Value>
				<ControlTemplate TargetType="ComboBox">
					<Grid>
						<VisualStateManager.VisualStateGroups>
							<VisualStateGroup x:Name="CommonStates">
								<VisualState x:Name="Normal" />

								<VisualState x:Name="PointerOver">
									<VisualState.Setters>
										<Setter Target="BorderElement.Background" Value="{ThemeResource SimpleComboBoxBackgroundPointerOver}" />
										<Setter Target="BorderElement.BorderBrush" Value="{ThemeResource SimpleComboBoxBorderBrushPointerOver}" />
										<Setter Target="ContentPresenter.Foreground" Value="{ThemeResource SimpleComboBoxForegroundPointerOver}" />
									</VisualState.Setters>
								</VisualState>

								<VisualState x:Name="Pressed">
									<VisualState.Setters>
										<Setter Target="BorderElement.Background" Value="{ThemeResource SimpleComboBoxBackgroundPressed}" />
										<Setter Target="BorderElement.BorderBrush" Value="{ThemeResource SimpleComboBoxBorderBrushPressed}" />
										<Setter Target="BorderElement.BorderThickness" Value="{StaticResource SimpleComboBoxFocusedBorderThickness}" />
										<Setter Target="ContentPresenter.Foreground" Value="{ThemeResource SimpleComboBoxForegroundPressed}" />
									</VisualState.Setters>
								</VisualState>

								<VisualState x:Name="Disabled">
									<Storyboard>
										<ObjectAnimationUsingKeyFrames Storyboard.TargetName="BorderElement"
																	   Storyboard.TargetProperty="Background">
											<DiscreteObjectKeyFrame KeyTime="0"
																	Value="{ThemeResource DisabledBrush}" />
										</ObjectAnimationUsingKeyFrames>
										<ObjectAnimationUsingKeyFrames Storyboard.TargetName="BorderElement"
																	   Storyboard.TargetProperty="BorderBrush">
											<DiscreteObjectKeyFrame KeyTime="0">
												<DiscreteObjectKeyFrame.Value>
													<SolidColorBrush Color="#B2B2B2" />
												</DiscreteObjectKeyFrame.Value>
											</DiscreteObjectKeyFrame>
										</ObjectAnimationUsingKeyFrames>
										<ObjectAnimationUsingKeyFrames Storyboard.TargetName="ContentPresenter"
																	   Storyboard.TargetProperty="Foreground">
											<DiscreteObjectKeyFrame KeyTime="0"
																	Value="{ThemeResource OnDisabledBrush}" />
										</ObjectAnimationUsingKeyFrames>
										<ObjectAnimationUsingKeyFrames Storyboard.TargetName="DropDownGlyph"
																	   Storyboard.TargetProperty="Foreground">
											<DiscreteObjectKeyFrame KeyTime="0"
																	Value="{ThemeResource OnDisabledBrush}" />
										</ObjectAnimationUsingKeyFrames>
									</Storyboard>
								</VisualState>
							</VisualStateGroup>

							<VisualStateGroup x:Name="FocusStates">
								<VisualState x:Name="Unfocused" />
								<VisualState x:Name="Focused">
									<VisualState.Setters>
										<Setter Target="BorderElement.BorderBrush" Value="{ThemeResource SimpleComboBoxBorderBrushFocused}" />
										<Setter Target="BorderElement.BorderThickness" Value="{StaticResource SimpleComboBoxFocusedBorderThickness}" />
									</VisualState.Setters>
								</VisualState>
								<VisualState x:Name="FocusedPressed">
									<VisualState.Setters>
										<Setter Target="BorderElement.BorderBrush" Value="{ThemeResource SimpleComboBoxBorderBrushFocused}" />
										<Setter Target="BorderElement.BorderThickness" Value="{StaticResource SimpleComboBoxFocusedBorderThickness}" />
									</VisualState.Setters>
								</VisualState>
							</VisualStateGroup>

							<VisualStateGroup x:Name="DropDownStates">
								<VisualState x:Name="Closed" />
								<VisualState x:Name="Opened">
									<VisualState.Setters>
										<Setter Target="BorderElement.BorderBrush" Value="{ThemeResource SimpleComboBoxBorderBrushFocused}" />
										<Setter Target="BorderElement.BorderThickness" Value="{StaticResource SimpleComboBoxFocusedBorderThickness}" />
									</VisualState.Setters>
								</VisualState>
							</VisualStateGroup>
						</VisualStateManager.VisualStateGroups>

						<Border x:Name="BorderElement"
								Background="{TemplateBinding Background}"
								BorderBrush="{TemplateBinding BorderBrush}"
								BorderThickness="{TemplateBinding BorderThickness}"
								CornerRadius="{TemplateBinding CornerRadius}"
								MinHeight="{TemplateBinding MinHeight}">
							<Grid>
								<Grid.ColumnDefinitions>
									<ColumnDefinition Width="*" />
									<ColumnDefinition Width="Auto" />
								</Grid.ColumnDefinitions>

								<!-- Content -->
								<ContentPresenter x:Name="ContentPresenter"
												  Grid.Column="0"
												  Content="{TemplateBinding SelectionBoxItem}"
												  ContentTemplate="{TemplateBinding ItemTemplate}"
												  ContentTemplateSelector="{TemplateBinding ItemTemplateSelector}"
												  Foreground="{TemplateBinding Foreground}"
												  HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
												  VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
												  Margin="{TemplateBinding Padding}" />

								<!-- Dropdown Arrow -->
								<FontIcon x:Name="DropDownGlyph"
										  Grid.Column="1"
										  Glyph="{StaticResource SimpleComboBoxDropDownGlyphIcon}"
										  FontFamily="{ThemeResource SymbolThemeFontFamily}"
										  FontSize="12"
										  Foreground="{ThemeResource OnSurfaceMediumBrush}"
										  VerticalAlignment="Center"
										  Margin="8,0,12,0"
										  IsHitTestVisible="False"
										  AutomationProperties.AccessibilityView="Raw" />
							</Grid>
						</Border>

						<!-- Popup -->
						<Popup x:Name="Popup"
							   IsLightDismissEnabled="True"
							   AllowFocusOnInteraction="True">
							<Border x:Name="PopupBorder"
									Background="{ThemeResource SimpleComboBoxPopupBackground}"
									BorderBrush="{ThemeResource SimpleComboBoxPopupBorderBrush}"
									BorderThickness="1"
									CornerRadius="{StaticResource SimpleComboBoxCornerRadius}"
									Padding="0,4"
									MaxHeight="400">
								<Border.Shadow>
									<ThemeShadow />
								</Border.Shadow>
								<ScrollViewer x:Name="ScrollViewer"
											  HorizontalScrollMode="Disabled"
											  HorizontalScrollBarVisibility="Disabled"
											  VerticalScrollMode="Auto"
											  VerticalScrollBarVisibility="Auto"
											  ZoomMode="Disabled">
									<ItemsPresenter />
								</ScrollViewer>
							</Border>
						</Popup>
					</Grid>
				</ControlTemplate>
			</Setter.Value>
		</Setter>
	</Style>

	<!-- SimpleSelectFieldItemStyle - Select Field dropdown item -->
	<Style x:Key="SimpleSelectFieldItemStyle"
		   TargetType="ComboBoxItem">
		<Setter Property="FontFamily" Value="{ThemeResource SimpleFontFamily}" />
		<Setter Property="FontSize" Value="14" />
		<Setter Property="Foreground" Value="{ThemeResource OnSurfaceBrush}" />
		<Setter Property="Background" Value="Transparent" />
		<Setter Property="Padding" Value="16,12" />
		<Setter Property="MinHeight" Value="40" />
		<Setter Property="HorizontalContentAlignment" Value="Left" />
		<Setter Property="VerticalContentAlignment" Value="Center" />
		<Setter Property="UseSystemFocusVisuals" Value="{StaticResource UseSystemFocusVisuals}" />
		<Setter Property="Template">
			<Setter.Value>
				<ControlTemplate TargetType="ComboBoxItem">
					<Grid x:Name="LayoutRoot"
						  Background="{TemplateBinding Background}"
						  Padding="{TemplateBinding Padding}"
						  MinHeight="{TemplateBinding MinHeight}"
						  CornerRadius="4">
						<VisualStateManager.VisualStateGroups>
							<VisualStateGroup x:Name="CommonStates">
								<VisualState x:Name="Normal" />

								<VisualState x:Name="PointerOver">
									<VisualState.Setters>
										<Setter Target="LayoutRoot.Background" Value="{ThemeResource SimpleComboBoxItemBackgroundPointerOver}" />
										<Setter Target="ContentPresenter.Foreground" Value="{ThemeResource SimpleComboBoxItemForegroundPointerOver}" />
									</VisualState.Setters>
								</VisualState>

								<VisualState x:Name="Pressed">
									<VisualState.Setters>
										<Setter Target="LayoutRoot.Background" Value="{ThemeResource SimpleComboBoxItemBackgroundPressed}" />
										<Setter Target="ContentPresenter.Foreground" Value="{ThemeResource SimpleComboBoxItemForegroundPressed}" />
									</VisualState.Setters>
								</VisualState>

								<VisualState x:Name="Selected">
									<VisualState.Setters>
										<Setter Target="LayoutRoot.Background" Value="{ThemeResource SimpleComboBoxItemBackgroundSelected}" />
										<Setter Target="ContentPresenter.Foreground" Value="{ThemeResource SimpleComboBoxItemForegroundSelected}" />
									</VisualState.Setters>
								</VisualState>

								<VisualState x:Name="SelectedPointerOver">
									<VisualState.Setters>
										<Setter Target="LayoutRoot.Background" Value="{ThemeResource SimpleComboBoxItemBackgroundSelectedPointerOver}" />
										<Setter Target="ContentPresenter.Foreground" Value="{ThemeResource SimpleComboBoxItemForegroundSelectedPointerOver}" />
									</VisualState.Setters>
								</VisualState>

								<VisualState x:Name="SelectedPressed">
									<VisualState.Setters>
										<Setter Target="LayoutRoot.Background" Value="{ThemeResource SimpleComboBoxItemBackgroundSelectedPressed}" />
										<Setter Target="ContentPresenter.Foreground" Value="{ThemeResource SimpleComboBoxItemForegroundSelectedPressed}" />
									</VisualState.Setters>
								</VisualState>

								<VisualState x:Name="Disabled">
									<VisualState.Setters>
										<Setter Target="LayoutRoot.Background" Value="{ThemeResource SimpleComboBoxItemBackgroundDisabled}" />
										<Setter Target="ContentPresenter.Foreground" Value="{ThemeResource SimpleComboBoxItemForegroundDisabled}" />
									</VisualState.Setters>
								</VisualState>
							</VisualStateGroup>
						</VisualStateManager.VisualStateGroups>

						<ContentPresenter x:Name="ContentPresenter"
										  Content="{TemplateBinding Content}"
										  ContentTemplate="{TemplateBinding ContentTemplate}"
										  ContentTransitions="{TemplateBinding ContentTransitions}"
										  Foreground="{TemplateBinding Foreground}"
										  HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
										  VerticalAlignment="{TemplateBinding VerticalContentAlignment}" />
					</Grid>
				</ControlTemplate>
			</Setter.Value>
		</Setter>
	</Style>

	<!-- SimpleSelectFieldErrorStyle - Error state -->
	<Style x:Key="SimpleSelectFieldErrorStyle"
		   TargetType="ComboBox"
		   BasedOn="{StaticResource SimpleSelectFieldStyle}">
		<Setter Property="BorderBrush" Value="{ThemeResource SimpleComboBoxBorderBrushError}" />
	</Style>

</ResourceDictionary>
