<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
					xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

	<!--
		Simple Design System — ComboBox (Select) Styles
		Lightweight styling: every visual-state brush is exposed via ThemeResource.

		Semantic resource layer:
		  ComboBox*           = semantic keys (source of truth) — matches Material naming
		  SimpleComboBox*     = backwards-compat aliases → ComboBox*

		Simple-only resources (error styles) stay as-is with Simple prefix.

		Styles: SimpleSelectFieldStyle (ComboBox), SimpleSelectFieldItemStyle (ComboBoxItem),
		        SimpleSelectFieldErrorStyle (error variant)
		SDS source: Select/select.css
	-->

	<!-- ═══════════════════════════════════════════════════════════════════════ -->
	<!-- Lightweight styling ThemeResource aliases                              -->
	<!-- ═══════════════════════════════════════════════════════════════════════ -->
	<ResourceDictionary.ThemeDictionaries>

		<!-- ─── Light Theme ─── -->
		<ResourceDictionary x:Key="Light">

			<!-- ── ComboBox — semantic keys (source of truth) ── -->
			<StaticResource x:Key="ComboBoxBackground"                   ResourceKey="SimpleBackgroundDefaultDefaultBrush" />
			<StaticResource x:Key="ComboBoxBackgroundPointerOver"        ResourceKey="SimpleBackgroundDefaultDefaultBrush" />
			<StaticResource x:Key="ComboBoxBackgroundPressed"            ResourceKey="SimpleBackgroundDefaultDefaultBrush" />
			<StaticResource x:Key="ComboBoxBackgroundDisabled"           ResourceKey="SimpleBackgroundDisabledDefaultBrush" />
			<StaticResource x:Key="ComboBoxBorderBrush"                  ResourceKey="SimpleBorderDefaultDefaultBrush" />
			<StaticResource x:Key="ComboBoxBorderBrushPointerOver"       ResourceKey="SimpleBorderDefaultDefaultBrush" />
			<StaticResource x:Key="ComboBoxBorderBrushPressed"           ResourceKey="SimpleBorderBrandSecondaryBrush" />
			<StaticResource x:Key="ComboBoxBorderBrushDisabled"          ResourceKey="SimpleBorderDisabledDefaultBrush" />
			<StaticResource x:Key="ComboBoxForeground"                   ResourceKey="SimpleTextDefaultDefaultBrush" />
			<StaticResource x:Key="ComboBoxForegroundPointerOver"        ResourceKey="SimpleTextDefaultDefaultBrush" />
			<StaticResource x:Key="ComboBoxForegroundPressed"            ResourceKey="SimpleTextDefaultDefaultBrush" />
			<StaticResource x:Key="ComboBoxForegroundDisabled"           ResourceKey="SimpleTextDisabledDefaultBrush" />
			<StaticResource x:Key="ComboBoxPlaceHolderForeground"        ResourceKey="SimpleTextDefaultTertiaryBrush" />
			<StaticResource x:Key="ComboBoxDropDownGlyphForeground"      ResourceKey="SimpleIconDefaultDefaultBrush" />
			<StaticResource x:Key="ComboBoxDropDownGlyphForegroundDisabled" ResourceKey="SimpleIconDisabledOnDisabledBrush" />
			<StaticResource x:Key="ComboBoxDropDownBackground"           ResourceKey="SimpleBackgroundDefaultDefaultBrush" />
			<StaticResource x:Key="ComboBoxDropDownBorderBrush"          ResourceKey="SimpleBorderDefaultDefaultBrush" />
			<!-- Backwards-compat aliases (SimpleComboBox* → ComboBox*) -->
			<StaticResource x:Key="SimpleComboBoxBackground"             ResourceKey="ComboBoxBackground" />
			<StaticResource x:Key="SimpleComboBoxBackgroundPointerOver"  ResourceKey="ComboBoxBackgroundPointerOver" />
			<StaticResource x:Key="SimpleComboBoxBackgroundPressed"      ResourceKey="ComboBoxBackgroundPressed" />
			<StaticResource x:Key="SimpleComboBoxBackgroundDisabled"     ResourceKey="ComboBoxBackgroundDisabled" />
			<StaticResource x:Key="SimpleComboBoxBorderBrush"            ResourceKey="ComboBoxBorderBrush" />
			<StaticResource x:Key="SimpleComboBoxBorderBrushPointerOver" ResourceKey="ComboBoxBorderBrushPointerOver" />
			<StaticResource x:Key="SimpleComboBoxBorderBrushPressed"     ResourceKey="ComboBoxBorderBrushPressed" />
			<StaticResource x:Key="SimpleComboBoxBorderBrushDisabled"    ResourceKey="ComboBoxBorderBrushDisabled" />
			<StaticResource x:Key="SimpleComboBoxForeground"             ResourceKey="ComboBoxForeground" />
			<StaticResource x:Key="SimpleComboBoxForegroundPointerOver"  ResourceKey="ComboBoxForegroundPointerOver" />
			<StaticResource x:Key="SimpleComboBoxForegroundPressed"      ResourceKey="ComboBoxForegroundPressed" />
			<StaticResource x:Key="SimpleComboBoxForegroundDisabled"     ResourceKey="ComboBoxForegroundDisabled" />
			<StaticResource x:Key="SimpleComboBoxPlaceholderForeground"  ResourceKey="ComboBoxPlaceHolderForeground" />
			<StaticResource x:Key="SimpleComboBoxDropDownGlyphForeground" ResourceKey="ComboBoxDropDownGlyphForeground" />
			<StaticResource x:Key="SimpleComboBoxDropDownGlyphForegroundDisabled" ResourceKey="ComboBoxDropDownGlyphForegroundDisabled" />
			<StaticResource x:Key="SimpleComboBoxPopupBackground"        ResourceKey="ComboBoxDropDownBackground" />
			<StaticResource x:Key="SimpleComboBoxPopupBorderBrush"       ResourceKey="ComboBoxDropDownBorderBrush" />

			<!-- Simple-only (no Material equivalent) -->
			<StaticResource x:Key="SimpleComboBoxBorderBrushFocused"     ResourceKey="SimpleBorderBrandSecondaryBrush" />
			<StaticResource x:Key="SimpleComboBoxBorderBrushError"       ResourceKey="SimpleBorderDangerDefaultBrush" />

			<!-- ── ComboBoxItem — semantic keys (source of truth) ── -->
			<StaticResource x:Key="ComboBoxItemBackground"               ResourceKey="SystemControlTransparentBrush" />
			<StaticResource x:Key="ComboBoxItemBackgroundPointerOver"    ResourceKey="SimpleBackgroundDefaultSecondaryBrush" />
			<StaticResource x:Key="ComboBoxItemBackgroundPressed"        ResourceKey="SimpleBackgroundDefaultSecondaryPressedBrush" />
			<StaticResource x:Key="ComboBoxItemBackgroundSelected"       ResourceKey="SimpleBackgroundBrandDefaultBrush" />
			<StaticResource x:Key="ComboBoxItemBackgroundSelectedPointerOver" ResourceKey="SimpleBackgroundBrandHoverBrush" />
			<StaticResource x:Key="ComboBoxItemBackgroundSelectedPressed" ResourceKey="SimpleBackgroundBrandPressedBrush" />
			<StaticResource x:Key="ComboBoxItemBackgroundDisabled"       ResourceKey="SystemControlTransparentBrush" />
			<StaticResource x:Key="ComboBoxItemForeground"               ResourceKey="SimpleTextDefaultDefaultBrush" />
			<StaticResource x:Key="ComboBoxItemForegroundPointerOver"    ResourceKey="SimpleTextDefaultDefaultBrush" />
			<StaticResource x:Key="ComboBoxItemForegroundPressed"        ResourceKey="SimpleTextDefaultDefaultBrush" />
			<StaticResource x:Key="ComboBoxItemForegroundSelected"       ResourceKey="SimpleTextBrandOnBrandBrush" />
			<StaticResource x:Key="ComboBoxItemForegroundSelectedPointerOver" ResourceKey="SimpleTextBrandOnBrandBrush" />
			<StaticResource x:Key="ComboBoxItemForegroundSelectedPressed" ResourceKey="SimpleTextBrandOnBrandBrush" />
			<StaticResource x:Key="ComboBoxItemForegroundDisabled"       ResourceKey="SimpleTextDisabledDefaultBrush" />
			<!-- Backwards-compat aliases (SimpleComboBoxItem* → ComboBoxItem*) -->
			<StaticResource x:Key="SimpleComboBoxItemBackground"         ResourceKey="ComboBoxItemBackground" />
			<StaticResource x:Key="SimpleComboBoxItemBackgroundPointerOver" ResourceKey="ComboBoxItemBackgroundPointerOver" />
			<StaticResource x:Key="SimpleComboBoxItemBackgroundPressed"  ResourceKey="ComboBoxItemBackgroundPressed" />
			<StaticResource x:Key="SimpleComboBoxItemBackgroundSelected" ResourceKey="ComboBoxItemBackgroundSelected" />
			<StaticResource x:Key="SimpleComboBoxItemBackgroundSelectedPointerOver" ResourceKey="ComboBoxItemBackgroundSelectedPointerOver" />
			<StaticResource x:Key="SimpleComboBoxItemBackgroundSelectedPressed" ResourceKey="ComboBoxItemBackgroundSelectedPressed" />
			<StaticResource x:Key="SimpleComboBoxItemBackgroundDisabled" ResourceKey="ComboBoxItemBackgroundDisabled" />
			<StaticResource x:Key="SimpleComboBoxItemForeground"         ResourceKey="ComboBoxItemForeground" />
			<StaticResource x:Key="SimpleComboBoxItemForegroundPointerOver" ResourceKey="ComboBoxItemForegroundPointerOver" />
			<StaticResource x:Key="SimpleComboBoxItemForegroundPressed"  ResourceKey="ComboBoxItemForegroundPressed" />
			<StaticResource x:Key="SimpleComboBoxItemForegroundSelected" ResourceKey="ComboBoxItemForegroundSelected" />
			<StaticResource x:Key="SimpleComboBoxItemForegroundSelectedPointerOver" ResourceKey="ComboBoxItemForegroundSelectedPointerOver" />
			<StaticResource x:Key="SimpleComboBoxItemForegroundSelectedPressed" ResourceKey="ComboBoxItemForegroundSelectedPressed" />
			<StaticResource x:Key="SimpleComboBoxItemForegroundDisabled" ResourceKey="ComboBoxItemForegroundDisabled" />
		</ResourceDictionary>

		<!-- ─── Dark Theme (Default) ─── -->
		<ResourceDictionary x:Key="Default">

			<!-- ── ComboBox — semantic keys (source of truth) ── -->
			<StaticResource x:Key="ComboBoxBackground"                   ResourceKey="SimpleBackgroundDefaultDefaultBrush" />
			<StaticResource x:Key="ComboBoxBackgroundPointerOver"        ResourceKey="SimpleBackgroundDefaultDefaultBrush" />
			<StaticResource x:Key="ComboBoxBackgroundPressed"            ResourceKey="SimpleBackgroundDefaultDefaultBrush" />
			<StaticResource x:Key="ComboBoxBackgroundDisabled"           ResourceKey="SimpleBackgroundDisabledDefaultBrush" />
			<StaticResource x:Key="ComboBoxBorderBrush"                  ResourceKey="SimpleBorderDefaultDefaultBrush" />
			<StaticResource x:Key="ComboBoxBorderBrushPointerOver"       ResourceKey="SimpleBorderDefaultDefaultBrush" />
			<StaticResource x:Key="ComboBoxBorderBrushPressed"           ResourceKey="SimpleBorderBrandSecondaryBrush" />
			<StaticResource x:Key="ComboBoxBorderBrushDisabled"          ResourceKey="SimpleBorderDisabledDefaultBrush" />
			<StaticResource x:Key="ComboBoxForeground"                   ResourceKey="SimpleTextDefaultDefaultBrush" />
			<StaticResource x:Key="ComboBoxForegroundPointerOver"        ResourceKey="SimpleTextDefaultDefaultBrush" />
			<StaticResource x:Key="ComboBoxForegroundPressed"            ResourceKey="SimpleTextDefaultDefaultBrush" />
			<StaticResource x:Key="ComboBoxForegroundDisabled"           ResourceKey="SimpleTextDisabledDefaultBrush" />
			<StaticResource x:Key="ComboBoxPlaceHolderForeground"        ResourceKey="SimpleTextDefaultTertiaryBrush" />
			<StaticResource x:Key="ComboBoxDropDownGlyphForeground"      ResourceKey="SimpleIconDefaultDefaultBrush" />
			<StaticResource x:Key="ComboBoxDropDownGlyphForegroundDisabled" ResourceKey="SimpleIconDisabledOnDisabledBrush" />
			<StaticResource x:Key="ComboBoxDropDownBackground"           ResourceKey="SimpleBackgroundDefaultDefaultBrush" />
			<StaticResource x:Key="ComboBoxDropDownBorderBrush"          ResourceKey="SimpleBorderDefaultDefaultBrush" />
			<!-- Backwards-compat aliases (SimpleComboBox* → ComboBox*) -->
			<StaticResource x:Key="SimpleComboBoxBackground"             ResourceKey="ComboBoxBackground" />
			<StaticResource x:Key="SimpleComboBoxBackgroundPointerOver"  ResourceKey="ComboBoxBackgroundPointerOver" />
			<StaticResource x:Key="SimpleComboBoxBackgroundPressed"      ResourceKey="ComboBoxBackgroundPressed" />
			<StaticResource x:Key="SimpleComboBoxBackgroundDisabled"     ResourceKey="ComboBoxBackgroundDisabled" />
			<StaticResource x:Key="SimpleComboBoxBorderBrush"            ResourceKey="ComboBoxBorderBrush" />
			<StaticResource x:Key="SimpleComboBoxBorderBrushPointerOver" ResourceKey="ComboBoxBorderBrushPointerOver" />
			<StaticResource x:Key="SimpleComboBoxBorderBrushPressed"     ResourceKey="ComboBoxBorderBrushPressed" />
			<StaticResource x:Key="SimpleComboBoxBorderBrushDisabled"    ResourceKey="ComboBoxBorderBrushDisabled" />
			<StaticResource x:Key="SimpleComboBoxForeground"             ResourceKey="ComboBoxForeground" />
			<StaticResource x:Key="SimpleComboBoxForegroundPointerOver"  ResourceKey="ComboBoxForegroundPointerOver" />
			<StaticResource x:Key="SimpleComboBoxForegroundPressed"      ResourceKey="ComboBoxForegroundPressed" />
			<StaticResource x:Key="SimpleComboBoxForegroundDisabled"     ResourceKey="ComboBoxForegroundDisabled" />
			<StaticResource x:Key="SimpleComboBoxPlaceholderForeground"  ResourceKey="ComboBoxPlaceHolderForeground" />
			<StaticResource x:Key="SimpleComboBoxDropDownGlyphForeground" ResourceKey="ComboBoxDropDownGlyphForeground" />
			<StaticResource x:Key="SimpleComboBoxDropDownGlyphForegroundDisabled" ResourceKey="ComboBoxDropDownGlyphForegroundDisabled" />
			<StaticResource x:Key="SimpleComboBoxPopupBackground"        ResourceKey="ComboBoxDropDownBackground" />
			<StaticResource x:Key="SimpleComboBoxPopupBorderBrush"       ResourceKey="ComboBoxDropDownBorderBrush" />

			<!-- Simple-only (no Material equivalent) -->
			<StaticResource x:Key="SimpleComboBoxBorderBrushFocused"     ResourceKey="SimpleBorderBrandSecondaryBrush" />
			<StaticResource x:Key="SimpleComboBoxBorderBrushError"       ResourceKey="SimpleBorderDangerDefaultBrush" />

			<!-- ── ComboBoxItem — semantic keys (source of truth) ── -->
			<StaticResource x:Key="ComboBoxItemBackground"               ResourceKey="SystemControlTransparentBrush" />
			<StaticResource x:Key="ComboBoxItemBackgroundPointerOver"    ResourceKey="SimpleBackgroundDefaultSecondaryBrush" />
			<StaticResource x:Key="ComboBoxItemBackgroundPressed"        ResourceKey="SimpleBackgroundDefaultSecondaryPressedBrush" />
			<StaticResource x:Key="ComboBoxItemBackgroundSelected"       ResourceKey="SimpleBackgroundBrandDefaultBrush" />
			<StaticResource x:Key="ComboBoxItemBackgroundSelectedPointerOver" ResourceKey="SimpleBackgroundBrandHoverBrush" />
			<StaticResource x:Key="ComboBoxItemBackgroundSelectedPressed" ResourceKey="SimpleBackgroundBrandPressedBrush" />
			<StaticResource x:Key="ComboBoxItemBackgroundDisabled"       ResourceKey="SystemControlTransparentBrush" />
			<StaticResource x:Key="ComboBoxItemForeground"               ResourceKey="SimpleTextDefaultDefaultBrush" />
			<StaticResource x:Key="ComboBoxItemForegroundPointerOver"    ResourceKey="SimpleTextDefaultDefaultBrush" />
			<StaticResource x:Key="ComboBoxItemForegroundPressed"        ResourceKey="SimpleTextDefaultDefaultBrush" />
			<StaticResource x:Key="ComboBoxItemForegroundSelected"       ResourceKey="SimpleTextBrandOnBrandBrush" />
			<StaticResource x:Key="ComboBoxItemForegroundSelectedPointerOver" ResourceKey="SimpleTextBrandOnBrandBrush" />
			<StaticResource x:Key="ComboBoxItemForegroundSelectedPressed" ResourceKey="SimpleTextBrandOnBrandBrush" />
			<StaticResource x:Key="ComboBoxItemForegroundDisabled"       ResourceKey="SimpleTextDisabledDefaultBrush" />
			<!-- Backwards-compat aliases (SimpleComboBoxItem* → ComboBoxItem*) -->
			<StaticResource x:Key="SimpleComboBoxItemBackground"         ResourceKey="ComboBoxItemBackground" />
			<StaticResource x:Key="SimpleComboBoxItemBackgroundPointerOver" ResourceKey="ComboBoxItemBackgroundPointerOver" />
			<StaticResource x:Key="SimpleComboBoxItemBackgroundPressed"  ResourceKey="ComboBoxItemBackgroundPressed" />
			<StaticResource x:Key="SimpleComboBoxItemBackgroundSelected" ResourceKey="ComboBoxItemBackgroundSelected" />
			<StaticResource x:Key="SimpleComboBoxItemBackgroundSelectedPointerOver" ResourceKey="ComboBoxItemBackgroundSelectedPointerOver" />
			<StaticResource x:Key="SimpleComboBoxItemBackgroundSelectedPressed" ResourceKey="ComboBoxItemBackgroundSelectedPressed" />
			<StaticResource x:Key="SimpleComboBoxItemBackgroundDisabled" ResourceKey="ComboBoxItemBackgroundDisabled" />
			<StaticResource x:Key="SimpleComboBoxItemForeground"         ResourceKey="ComboBoxItemForeground" />
			<StaticResource x:Key="SimpleComboBoxItemForegroundPointerOver" ResourceKey="ComboBoxItemForegroundPointerOver" />
			<StaticResource x:Key="SimpleComboBoxItemForegroundPressed"  ResourceKey="ComboBoxItemForegroundPressed" />
			<StaticResource x:Key="SimpleComboBoxItemForegroundSelected" ResourceKey="ComboBoxItemForegroundSelected" />
			<StaticResource x:Key="SimpleComboBoxItemForegroundSelectedPointerOver" ResourceKey="ComboBoxItemForegroundSelectedPointerOver" />
			<StaticResource x:Key="SimpleComboBoxItemForegroundSelectedPressed" ResourceKey="ComboBoxItemForegroundSelectedPressed" />
			<StaticResource x:Key="SimpleComboBoxItemForegroundDisabled" ResourceKey="ComboBoxItemForegroundDisabled" />
		</ResourceDictionary>

	</ResourceDictionary.ThemeDictionaries>

	<!-- ═══════════════════════════════════════════════════════════════════════ -->
	<!-- Layout / sizing resources (theme-agnostic)                            -->
	<!-- ═══════════════════════════════════════════════════════════════════════ -->
	<!-- Semantic keys (source of truth) -->
	<!-- sds-radius: 8 = SimpleRadius200CornerRadius -->
	<StaticResource x:Key="ComboBoxCornerRadius"                 ResourceKey="SimpleRadius200CornerRadius" />
	<!-- sds-size: 40 = SimpleIconLarge -->
	<StaticResource x:Key="ComboBoxMinHeight"                    ResourceKey="SimpleIconLarge" />
	<!-- sds-stroke: 1 = SimpleStrokeBorderThickness -->
	<StaticResource x:Key="ComboBoxBorderThickness"              ResourceKey="SimpleStrokeBorderThickness" />
	<!-- sds-spacing: non-uniform (16,10,12,10) — no single SDS token -->
	<Thickness x:Key="ComboBoxPadding">16,10,12,10</Thickness>
	<!-- Backwards-compat aliases -->
	<StaticResource x:Key="SimpleComboBoxCornerRadius"           ResourceKey="ComboBoxCornerRadius" />
	<StaticResource x:Key="SimpleComboBoxMinHeight"              ResourceKey="ComboBoxMinHeight" />
	<StaticResource x:Key="SimpleComboBoxBorderThickness"        ResourceKey="ComboBoxBorderThickness" />
	<Thickness x:Key="SimpleComboBoxPadding">16,10,12,10</Thickness>

	<!-- Simple-only layout resources (no Material equivalent) -->
	<!-- sds-stroke: 2 = SimpleStrokeFocusRingThickness -->
	<StaticResource x:Key="SimpleComboBoxFocusedBorderThickness" ResourceKey="SimpleStrokeFocusRingThickness" />
	<!-- sds-spacing: non-uniform (8,0,12,0) — no single SDS token -->
	<Thickness x:Key="SimpleComboBoxDropDownGlyphMargin">8,0,12,0</Thickness>
	<!-- sds-spacing: non-uniform (0,4) — no single SDS token -->
	<Thickness x:Key="SimpleComboBoxPopupPadding">0,4</Thickness>
	<!-- sds-size: no direct SDS token for 400 -->
	<x:Double x:Key="SimpleComboBoxPopupMaxHeight">400</x:Double>
	<x:String x:Key="SimpleComboBoxDropDownGlyphIcon">&#xE96E;</x:String>

	<!-- SimpleSelectFieldStyle - Select Field (Figma: Select Field) -->
	<Style x:Key="SimpleSelectFieldStyle"
		   TargetType="ComboBox">
		<Setter Property="FontFamily" Value="{ThemeResource SimpleFontFamily}" />
		<Setter Property="FontSize" Value="14" />
		<Setter Property="Foreground" Value="{ThemeResource ComboBoxForeground}" />
		<Setter Property="Background" Value="{ThemeResource ComboBoxBackground}" />
		<Setter Property="BorderBrush" Value="{ThemeResource ComboBoxBorderBrush}" />
		<Setter Property="BorderThickness" Value="{ThemeResource ComboBoxBorderThickness}" />
		<Setter Property="Padding" Value="{ThemeResource ComboBoxPadding}" />
		<Setter Property="MinHeight" Value="{ThemeResource ComboBoxMinHeight}" />
		<Setter Property="HorizontalAlignment" Value="Stretch" />
		<Setter Property="VerticalAlignment" Value="Top" />
		<Setter Property="HorizontalContentAlignment" Value="Left" />
		<Setter Property="VerticalContentAlignment" Value="Center" />
		<Setter Property="CornerRadius" Value="{StaticResource ComboBoxCornerRadius}" />
		<Setter Property="UseSystemFocusVisuals" Value="{StaticResource UseSystemFocusVisuals}" />
		<Setter Property="FocusVisualMargin" Value="-3" />
		<Setter Property="ItemContainerStyle" Value="{StaticResource SimpleSelectFieldItemStyle}" />
		<Setter Property="Template">
			<Setter.Value>
				<ControlTemplate TargetType="ComboBox">
					<Grid>
						<VisualStateManager.VisualStateGroups>
							<VisualStateGroup x:Name="CommonStates">
								<VisualState x:Name="Normal" />

								<VisualState x:Name="PointerOver">
									<VisualState.Setters>
										<Setter Target="BorderElement.Background" Value="{ThemeResource ComboBoxBackgroundPointerOver}" />
										<Setter Target="BorderElement.BorderBrush" Value="{ThemeResource ComboBoxBorderBrushPointerOver}" />
										<Setter Target="ContentPresenter.Foreground" Value="{ThemeResource ComboBoxForegroundPointerOver}" />
									</VisualState.Setters>
								</VisualState>

								<VisualState x:Name="Pressed">
									<VisualState.Setters>
										<Setter Target="BorderElement.Background" Value="{ThemeResource ComboBoxBackgroundPressed}" />
										<Setter Target="BorderElement.BorderBrush" Value="{ThemeResource ComboBoxBorderBrushPressed}" />
										<Setter Target="BorderElement.BorderThickness" Value="{StaticResource SimpleComboBoxFocusedBorderThickness}" />
										<Setter Target="ContentPresenter.Foreground" Value="{ThemeResource ComboBoxForegroundPressed}" />
									</VisualState.Setters>
								</VisualState>

								<VisualState x:Name="Disabled">
									<Storyboard>
										<ObjectAnimationUsingKeyFrames Storyboard.TargetName="BorderElement"
																	   Storyboard.TargetProperty="Background">
											<DiscreteObjectKeyFrame KeyTime="0"
																	Value="{ThemeResource ComboBoxBackgroundDisabled}" />
										</ObjectAnimationUsingKeyFrames>
										<ObjectAnimationUsingKeyFrames Storyboard.TargetName="BorderElement"
																	   Storyboard.TargetProperty="BorderBrush">
											<DiscreteObjectKeyFrame KeyTime="0"
																	Value="{ThemeResource ComboBoxBorderBrushDisabled}" />
										</ObjectAnimationUsingKeyFrames>
										<ObjectAnimationUsingKeyFrames Storyboard.TargetName="ContentPresenter"
																	   Storyboard.TargetProperty="Foreground">
											<DiscreteObjectKeyFrame KeyTime="0"
																	Value="{ThemeResource ComboBoxForegroundDisabled}" />
										</ObjectAnimationUsingKeyFrames>
										<ObjectAnimationUsingKeyFrames Storyboard.TargetName="DropDownGlyph"
																	   Storyboard.TargetProperty="Foreground">
											<DiscreteObjectKeyFrame KeyTime="0"
																	Value="{ThemeResource ComboBoxDropDownGlyphForegroundDisabled}" />
										</ObjectAnimationUsingKeyFrames>
									</Storyboard>
								</VisualState>
							</VisualStateGroup>

							<VisualStateGroup x:Name="FocusStates">
								<VisualState x:Name="Unfocused" />
								<VisualState x:Name="Focused">
									<VisualState.Setters>
										<Setter Target="BorderElement.BorderBrush" Value="{ThemeResource SimpleComboBoxBorderBrushFocused}" />
										<Setter Target="BorderElement.BorderThickness" Value="{StaticResource SimpleComboBoxFocusedBorderThickness}" />
									</VisualState.Setters>
								</VisualState>
								<VisualState x:Name="FocusedPressed">
									<VisualState.Setters>
										<Setter Target="BorderElement.BorderBrush" Value="{ThemeResource SimpleComboBoxBorderBrushFocused}" />
										<Setter Target="BorderElement.BorderThickness" Value="{StaticResource SimpleComboBoxFocusedBorderThickness}" />
									</VisualState.Setters>
								</VisualState>
							</VisualStateGroup>

							<VisualStateGroup x:Name="DropDownStates">
								<VisualState x:Name="Closed" />
								<VisualState x:Name="Opened">
									<VisualState.Setters>
										<Setter Target="BorderElement.BorderBrush" Value="{ThemeResource SimpleComboBoxBorderBrushFocused}" />
										<Setter Target="BorderElement.BorderThickness" Value="{StaticResource SimpleComboBoxFocusedBorderThickness}" />
									</VisualState.Setters>
								</VisualState>
							</VisualStateGroup>
						</VisualStateManager.VisualStateGroups>

						<Border x:Name="BorderElement"
								Background="{TemplateBinding Background}"
								BorderBrush="{TemplateBinding BorderBrush}"
								BorderThickness="{TemplateBinding BorderThickness}"
								CornerRadius="{TemplateBinding CornerRadius}"
								MinHeight="{TemplateBinding MinHeight}">
							<Grid>
								<Grid.ColumnDefinitions>
									<ColumnDefinition Width="*" />
									<ColumnDefinition Width="Auto" />
								</Grid.ColumnDefinitions>

								<!-- Content -->
								<ContentPresenter x:Name="ContentPresenter"
												  Grid.Column="0"
												  Content="{TemplateBinding SelectionBoxItem}"
												  ContentTemplate="{TemplateBinding ItemTemplate}"
												  ContentTemplateSelector="{TemplateBinding ItemTemplateSelector}"
												  Foreground="{TemplateBinding Foreground}"
												  HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
												  VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
												  Margin="{TemplateBinding Padding}" />

								<!-- Dropdown Arrow -->
								<FontIcon x:Name="DropDownGlyph"
										  Grid.Column="1"
										  Glyph="{StaticResource SimpleComboBoxDropDownGlyphIcon}"
										  FontFamily="{ThemeResource SymbolThemeFontFamily}"
										  FontSize="{ThemeResource SimpleCaptionFontSize}"
										  Foreground="{ThemeResource ComboBoxDropDownGlyphForeground}"
										  VerticalAlignment="Center"
										  Margin="{StaticResource SimpleComboBoxDropDownGlyphMargin}"
										  IsHitTestVisible="False"
										  AutomationProperties.AccessibilityView="Raw" />
							</Grid>
						</Border>

						<!-- Popup -->
						<Popup x:Name="Popup"
							   IsLightDismissEnabled="True"
							   AllowFocusOnInteraction="True">
							<Border x:Name="PopupBorder"
									Background="{ThemeResource ComboBoxDropDownBackground}"
									BorderBrush="{ThemeResource ComboBoxDropDownBorderBrush}"
									BorderThickness="{ThemeResource SimpleStrokeBorderThickness}"
									CornerRadius="{StaticResource ComboBoxCornerRadius}"
									Padding="{StaticResource SimpleComboBoxPopupPadding}"
									MaxHeight="{StaticResource SimpleComboBoxPopupMaxHeight}">
								<Border.Shadow>
									<ThemeShadow />
								</Border.Shadow>
								<ScrollViewer x:Name="ScrollViewer"
											  HorizontalScrollMode="Disabled"
											  HorizontalScrollBarVisibility="Disabled"
											  VerticalScrollMode="Auto"
											  VerticalScrollBarVisibility="Auto"
											  ZoomMode="Disabled">
									<ItemsPresenter />
								</ScrollViewer>
							</Border>
						</Popup>
					</Grid>
				</ControlTemplate>
			</Setter.Value>
		</Setter>
	</Style>

	<!-- SimpleSelectFieldItemStyle - Select Field dropdown item -->
	<Style x:Key="SimpleSelectFieldItemStyle"
		   TargetType="ComboBoxItem">
		<Setter Property="FontFamily" Value="{ThemeResource SimpleFontFamily}" />
		<Setter Property="FontSize" Value="14" />
		<Setter Property="Foreground" Value="{ThemeResource ComboBoxItemForeground}" />
		<Setter Property="Background" Value="Transparent" />
		<Setter Property="Padding" Value="16,12" />
		<Setter Property="MinHeight" Value="40" />
		<Setter Property="HorizontalContentAlignment" Value="Left" />
		<Setter Property="VerticalContentAlignment" Value="Center" />
		<Setter Property="UseSystemFocusVisuals" Value="{StaticResource UseSystemFocusVisuals}" />
		<Setter Property="Template">
			<Setter.Value>
				<ControlTemplate TargetType="ComboBoxItem">
					<Grid x:Name="LayoutRoot"
						  Background="{TemplateBinding Background}"
						  Padding="{TemplateBinding Padding}"
						  MinHeight="{TemplateBinding MinHeight}"
						  CornerRadius="{ThemeResource SimpleRadius100CornerRadius}">
						<VisualStateManager.VisualStateGroups>
							<VisualStateGroup x:Name="CommonStates">
								<VisualState x:Name="Normal" />

								<VisualState x:Name="PointerOver">
									<VisualState.Setters>
										<Setter Target="LayoutRoot.Background" Value="{ThemeResource ComboBoxItemBackgroundPointerOver}" />
										<Setter Target="ContentPresenter.Foreground" Value="{ThemeResource ComboBoxItemForegroundPointerOver}" />
									</VisualState.Setters>
								</VisualState>

								<VisualState x:Name="Pressed">
									<VisualState.Setters>
										<Setter Target="LayoutRoot.Background" Value="{ThemeResource ComboBoxItemBackgroundPressed}" />
										<Setter Target="ContentPresenter.Foreground" Value="{ThemeResource ComboBoxItemForegroundPressed}" />
									</VisualState.Setters>
								</VisualState>

								<VisualState x:Name="Selected">
									<VisualState.Setters>
										<Setter Target="LayoutRoot.Background" Value="{ThemeResource ComboBoxItemBackgroundSelected}" />
										<Setter Target="ContentPresenter.Foreground" Value="{ThemeResource ComboBoxItemForegroundSelected}" />
									</VisualState.Setters>
								</VisualState>

								<VisualState x:Name="SelectedPointerOver">
									<VisualState.Setters>
										<Setter Target="LayoutRoot.Background" Value="{ThemeResource ComboBoxItemBackgroundSelectedPointerOver}" />
										<Setter Target="ContentPresenter.Foreground" Value="{ThemeResource ComboBoxItemForegroundSelectedPointerOver}" />
									</VisualState.Setters>
								</VisualState>

								<VisualState x:Name="SelectedPressed">
									<VisualState.Setters>
										<Setter Target="LayoutRoot.Background" Value="{ThemeResource ComboBoxItemBackgroundSelectedPressed}" />
										<Setter Target="ContentPresenter.Foreground" Value="{ThemeResource ComboBoxItemForegroundSelectedPressed}" />
									</VisualState.Setters>
								</VisualState>

								<VisualState x:Name="Disabled">
									<VisualState.Setters>
										<Setter Target="LayoutRoot.Background" Value="{ThemeResource ComboBoxItemBackgroundDisabled}" />
										<Setter Target="ContentPresenter.Foreground" Value="{ThemeResource ComboBoxItemForegroundDisabled}" />
									</VisualState.Setters>
								</VisualState>
							</VisualStateGroup>
						</VisualStateManager.VisualStateGroups>

						<ContentPresenter x:Name="ContentPresenter"
										  Content="{TemplateBinding Content}"
										  ContentTemplate="{TemplateBinding ContentTemplate}"
										  ContentTransitions="{TemplateBinding ContentTransitions}"
										  Foreground="{TemplateBinding Foreground}"
										  HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
										  VerticalAlignment="{TemplateBinding VerticalContentAlignment}" />
					</Grid>
				</ControlTemplate>
			</Setter.Value>
		</Setter>
	</Style>

	<!-- SimpleSelectFieldErrorStyle - Error state -->
	<Style x:Key="SimpleSelectFieldErrorStyle"
		   TargetType="ComboBox"
		   BasedOn="{StaticResource SimpleSelectFieldStyle}">
		<Setter Property="BorderBrush" Value="{ThemeResource SimpleComboBoxBorderBrushError}" />
	</Style>

</ResourceDictionary>
