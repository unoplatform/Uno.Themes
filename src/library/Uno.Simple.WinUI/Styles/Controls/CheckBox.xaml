<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
					xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

	<!--
		Simple Design System — CheckBox Style
		Lightweight styling: every visual-state brush is exposed via ThemeResource.

		Semantic resource layer:
		  CheckBox{Property}{State}  = semantic keys (Material naming, source of truth)
		  SimpleCheckBox{State}{Property} = Simple-prefixed keys that alias → semantic keys

		Templates reference Simple-prefixed keys (SimpleCheckBox*) so that consumers
		can override EITHER the Simple key or the semantic key.

		States: Unchecked/Checked/Indeterminate × Normal/PointerOver/Pressed/Disabled
		SDS source: Checkbox/checkbox.css

		Style mapping: CheckBoxStyle → SimpleCheckBoxStyle (1:1)

		Skipped Material-specific keys (no Simple equivalent):
		  CheckBoxStateCircle*, CheckBoxFocusArea*, CheckBoxCheckBackgroundStroke*,
		  CheckBoxCheckBackgroundFill*, CheckBoxCheckArea*
	-->

	<!-- ═══════════════════════════════════════════════════════════════════════ -->
	<!-- Lightweight styling ThemeResource aliases                              -->
	<!-- ═══════════════════════════════════════════════════════════════════════ -->
	<ResourceDictionary.ThemeDictionaries>

		<!-- ─── Light Theme ─── -->
		<ResourceDictionary x:Key="Light">

			<!-- ── CheckBox — semantic keys (source of truth) ── -->

			<!-- Unchecked Background -->
			<StaticResource x:Key="CheckBoxBackgroundUnchecked"                ResourceKey="SimpleBackgroundDefaultDefaultBrush" />
			<StaticResource x:Key="CheckBoxBackgroundUncheckedPointerOver"     ResourceKey="SimpleBackgroundDefaultDefaultBrush" />
			<StaticResource x:Key="CheckBoxBackgroundUncheckedPressed"         ResourceKey="SimpleBackgroundDefaultDefaultPressedBrush" />
			<StaticResource x:Key="CheckBoxBackgroundUncheckedDisabled"        ResourceKey="SimpleBackgroundDisabledDefaultBrush" />

			<!-- Unchecked BorderBrush -->
			<StaticResource x:Key="CheckBoxBorderBrushUnchecked"              ResourceKey="SimpleBorderDefaultDefaultBrush" />
			<StaticResource x:Key="CheckBoxBorderBrushUncheckedPointerOver"   ResourceKey="SimpleBorderDefaultDefaultBrush" />
			<StaticResource x:Key="CheckBoxBorderBrushUncheckedPressed"       ResourceKey="SimpleBorderDefaultDefaultBrush" />
			<StaticResource x:Key="CheckBoxBorderBrushUncheckedDisabled"      ResourceKey="SimpleBorderDisabledDefaultBrush" />

			<!-- Checked Background -->
			<StaticResource x:Key="CheckBoxBackgroundChecked"                  ResourceKey="SimpleBackgroundBrandDefaultBrush" />
			<StaticResource x:Key="CheckBoxBackgroundCheckedPointerOver"       ResourceKey="SimpleBackgroundBrandDefaultBrush" />
			<StaticResource x:Key="CheckBoxBackgroundCheckedPressed"           ResourceKey="SimpleBackgroundBrandPressedBrush" />
			<StaticResource x:Key="CheckBoxBackgroundCheckedDisabled"          ResourceKey="SimpleBackgroundDisabledDefaultBrush" />

			<!-- Checked BorderBrush -->
			<StaticResource x:Key="CheckBoxBorderBrushChecked"                ResourceKey="SimpleBackgroundBrandDefaultBrush" />
			<StaticResource x:Key="CheckBoxBorderBrushCheckedPointerOver"     ResourceKey="SimpleBackgroundBrandDefaultBrush" />
			<StaticResource x:Key="CheckBoxBorderBrushCheckedPressed"         ResourceKey="SimpleBackgroundBrandPressedBrush" />
			<StaticResource x:Key="CheckBoxBorderBrushCheckedDisabled"        ResourceKey="SimpleBorderDisabledDefaultBrush" />

			<!-- Checked Glyph -->
			<StaticResource x:Key="CheckBoxGlyphForegroundChecked"            ResourceKey="SimpleIconBrandOnBrandBrush" />
			<StaticResource x:Key="CheckBoxGlyphForegroundCheckedPointerOver" ResourceKey="SimpleIconBrandOnBrandBrush" />
			<StaticResource x:Key="CheckBoxGlyphForegroundCheckedPressed"     ResourceKey="SimpleIconBrandOnBrandBrush" />
			<StaticResource x:Key="CheckBoxGlyphForegroundCheckedDisabled"    ResourceKey="SimpleIconDisabledOnDisabledBrush" />

			<!-- Indeterminate Background -->
			<StaticResource x:Key="CheckBoxBackgroundIndeterminate"            ResourceKey="SimpleBackgroundBrandDefaultBrush" />
			<StaticResource x:Key="CheckBoxBackgroundIndeterminatePointerOver" ResourceKey="SimpleBackgroundBrandDefaultBrush" />
			<StaticResource x:Key="CheckBoxBackgroundIndeterminatePressed"     ResourceKey="SimpleBackgroundBrandPressedBrush" />
			<StaticResource x:Key="CheckBoxBackgroundIndeterminateDisabled"    ResourceKey="SimpleBackgroundDisabledDefaultBrush" />

			<!-- Indeterminate BorderBrush -->
			<StaticResource x:Key="CheckBoxBorderBrushIndeterminate"           ResourceKey="SimpleBackgroundBrandDefaultBrush" />
			<StaticResource x:Key="CheckBoxBorderBrushIndeterminatePointerOver" ResourceKey="SimpleBackgroundBrandDefaultBrush" />
			<StaticResource x:Key="CheckBoxBorderBrushIndeterminatePressed"    ResourceKey="SimpleBackgroundBrandPressedBrush" />
			<StaticResource x:Key="CheckBoxBorderBrushIndeterminateDisabled"   ResourceKey="SimpleBorderDisabledDefaultBrush" />

			<!-- Indeterminate Glyph -->
			<StaticResource x:Key="CheckBoxGlyphForegroundIndeterminate"            ResourceKey="SimpleIconBrandOnBrandBrush" />
			<StaticResource x:Key="CheckBoxGlyphForegroundIndeterminatePointerOver" ResourceKey="SimpleIconBrandOnBrandBrush" />
			<StaticResource x:Key="CheckBoxGlyphForegroundIndeterminatePressed"     ResourceKey="SimpleIconBrandOnBrandBrush" />
			<StaticResource x:Key="CheckBoxGlyphForegroundIndeterminateDisabled"    ResourceKey="SimpleIconDisabledOnDisabledBrush" />

			<!-- Foreground (label) -->
			<StaticResource x:Key="CheckBoxForegroundUnchecked"               ResourceKey="SimpleTextDefaultDefaultBrush" />
			<StaticResource x:Key="CheckBoxForegroundUncheckedPointerOver"    ResourceKey="SimpleTextDefaultDefaultBrush" />
			<StaticResource x:Key="CheckBoxForegroundUncheckedPressed"        ResourceKey="SimpleTextDefaultDefaultBrush" />
			<StaticResource x:Key="CheckBoxForegroundUncheckedDisabled"       ResourceKey="SimpleTextDisabledDefaultBrush" />
			<StaticResource x:Key="CheckBoxForegroundChecked"                 ResourceKey="SimpleTextDefaultDefaultBrush" />
			<StaticResource x:Key="CheckBoxForegroundCheckedPointerOver"      ResourceKey="SimpleTextDefaultDefaultBrush" />
			<StaticResource x:Key="CheckBoxForegroundCheckedPressed"          ResourceKey="SimpleTextDefaultDefaultBrush" />
			<StaticResource x:Key="CheckBoxForegroundCheckedDisabled"         ResourceKey="SimpleTextDisabledDefaultBrush" />
			<StaticResource x:Key="CheckBoxForegroundIndeterminate"           ResourceKey="SimpleTextDefaultDefaultBrush" />
			<StaticResource x:Key="CheckBoxForegroundIndeterminatePointerOver" ResourceKey="SimpleTextDefaultDefaultBrush" />
			<StaticResource x:Key="CheckBoxForegroundIndeterminatePressed"    ResourceKey="SimpleTextDefaultDefaultBrush" />
			<StaticResource x:Key="CheckBoxForegroundIndeterminateDisabled"   ResourceKey="SimpleTextDisabledDefaultBrush" />

			<!-- ── Backwards-compat aliases (SimpleCheckBox* → CheckBox*) ── -->

			<!-- Unchecked -->
			<StaticResource x:Key="SimpleCheckBoxUncheckedBackground"                ResourceKey="CheckBoxBackgroundUnchecked" />
			<StaticResource x:Key="SimpleCheckBoxUncheckedBackgroundPointerOver"     ResourceKey="CheckBoxBackgroundUncheckedPointerOver" />
			<StaticResource x:Key="SimpleCheckBoxUncheckedBackgroundPressed"         ResourceKey="CheckBoxBackgroundUncheckedPressed" />
			<StaticResource x:Key="SimpleCheckBoxUncheckedBackgroundDisabled"        ResourceKey="CheckBoxBackgroundUncheckedDisabled" />
			<StaticResource x:Key="SimpleCheckBoxUncheckedBorderBrush"               ResourceKey="CheckBoxBorderBrushUnchecked" />
			<StaticResource x:Key="SimpleCheckBoxUncheckedBorderBrushPointerOver"    ResourceKey="CheckBoxBorderBrushUncheckedPointerOver" />
			<StaticResource x:Key="SimpleCheckBoxUncheckedBorderBrushPressed"        ResourceKey="CheckBoxBorderBrushUncheckedPressed" />
			<StaticResource x:Key="SimpleCheckBoxUncheckedBorderBrushDisabled"       ResourceKey="CheckBoxBorderBrushUncheckedDisabled" />

			<!-- Checked -->
			<StaticResource x:Key="SimpleCheckBoxCheckedBackground"                  ResourceKey="CheckBoxBackgroundChecked" />
			<StaticResource x:Key="SimpleCheckBoxCheckedBackgroundPointerOver"       ResourceKey="CheckBoxBackgroundCheckedPointerOver" />
			<StaticResource x:Key="SimpleCheckBoxCheckedBackgroundPressed"           ResourceKey="CheckBoxBackgroundCheckedPressed" />
			<StaticResource x:Key="SimpleCheckBoxCheckedBackgroundDisabled"          ResourceKey="CheckBoxBackgroundCheckedDisabled" />
			<StaticResource x:Key="SimpleCheckBoxCheckedBorderBrush"                 ResourceKey="CheckBoxBorderBrushChecked" />
			<StaticResource x:Key="SimpleCheckBoxCheckedBorderBrushPointerOver"      ResourceKey="CheckBoxBorderBrushCheckedPointerOver" />
			<StaticResource x:Key="SimpleCheckBoxCheckedBorderBrushPressed"          ResourceKey="CheckBoxBorderBrushCheckedPressed" />
			<StaticResource x:Key="SimpleCheckBoxCheckedBorderBrushDisabled"         ResourceKey="CheckBoxBorderBrushCheckedDisabled" />
			<StaticResource x:Key="SimpleCheckBoxCheckedGlyphFill"                   ResourceKey="CheckBoxGlyphForegroundChecked" />
			<StaticResource x:Key="SimpleCheckBoxCheckedGlyphFillPointerOver"        ResourceKey="CheckBoxGlyphForegroundCheckedPointerOver" />
			<StaticResource x:Key="SimpleCheckBoxCheckedGlyphFillPressed"            ResourceKey="CheckBoxGlyphForegroundCheckedPressed" />
			<StaticResource x:Key="SimpleCheckBoxCheckedGlyphFillDisabled"           ResourceKey="CheckBoxGlyphForegroundCheckedDisabled" />

			<!-- Indeterminate -->
			<StaticResource x:Key="SimpleCheckBoxIndeterminateBackground"            ResourceKey="CheckBoxBackgroundIndeterminate" />
			<StaticResource x:Key="SimpleCheckBoxIndeterminateBackgroundPointerOver" ResourceKey="CheckBoxBackgroundIndeterminatePointerOver" />
			<StaticResource x:Key="SimpleCheckBoxIndeterminateBackgroundPressed"     ResourceKey="CheckBoxBackgroundIndeterminatePressed" />
			<StaticResource x:Key="SimpleCheckBoxIndeterminateBackgroundDisabled"    ResourceKey="CheckBoxBackgroundIndeterminateDisabled" />
			<StaticResource x:Key="SimpleCheckBoxIndeterminateBorderBrush"           ResourceKey="CheckBoxBorderBrushIndeterminate" />
			<StaticResource x:Key="SimpleCheckBoxIndeterminateBorderBrushPointerOver" ResourceKey="CheckBoxBorderBrushIndeterminatePointerOver" />
			<StaticResource x:Key="SimpleCheckBoxIndeterminateBorderBrushPressed"    ResourceKey="CheckBoxBorderBrushIndeterminatePressed" />
			<StaticResource x:Key="SimpleCheckBoxIndeterminateBorderBrushDisabled"   ResourceKey="CheckBoxBorderBrushIndeterminateDisabled" />
			<StaticResource x:Key="SimpleCheckBoxIndeterminateGlyphFill"             ResourceKey="CheckBoxGlyphForegroundIndeterminate" />
			<StaticResource x:Key="SimpleCheckBoxIndeterminateGlyphFillPointerOver"  ResourceKey="CheckBoxGlyphForegroundIndeterminatePointerOver" />
			<StaticResource x:Key="SimpleCheckBoxIndeterminateGlyphFillPressed"      ResourceKey="CheckBoxGlyphForegroundIndeterminatePressed" />
			<StaticResource x:Key="SimpleCheckBoxIndeterminateGlyphFillDisabled"     ResourceKey="CheckBoxGlyphForegroundIndeterminateDisabled" />

			<!-- Foreground (label) -->
			<StaticResource x:Key="SimpleCheckBoxForeground"                         ResourceKey="CheckBoxForegroundUnchecked" />
			<StaticResource x:Key="SimpleCheckBoxForegroundPointerOver"              ResourceKey="CheckBoxForegroundUncheckedPointerOver" />
			<StaticResource x:Key="SimpleCheckBoxForegroundPressed"                  ResourceKey="CheckBoxForegroundUncheckedPressed" />
			<StaticResource x:Key="SimpleCheckBoxForegroundDisabled"                 ResourceKey="CheckBoxForegroundUncheckedDisabled" />
		</ResourceDictionary>

		<!-- ─── Dark Theme (Default) ─── -->
		<ResourceDictionary x:Key="Default">

			<!-- ── CheckBox — semantic keys (source of truth) ── -->

			<!-- Unchecked Background -->
			<StaticResource x:Key="CheckBoxBackgroundUnchecked"                ResourceKey="SimpleBackgroundDefaultDefaultBrush" />
			<StaticResource x:Key="CheckBoxBackgroundUncheckedPointerOver"     ResourceKey="SimpleBackgroundDefaultDefaultBrush" />
			<StaticResource x:Key="CheckBoxBackgroundUncheckedPressed"         ResourceKey="SimpleBackgroundDefaultDefaultPressedBrush" />
			<StaticResource x:Key="CheckBoxBackgroundUncheckedDisabled"        ResourceKey="SimpleBackgroundDisabledDefaultBrush" />

			<!-- Unchecked BorderBrush -->
			<StaticResource x:Key="CheckBoxBorderBrushUnchecked"              ResourceKey="SimpleBorderDefaultDefaultBrush" />
			<StaticResource x:Key="CheckBoxBorderBrushUncheckedPointerOver"   ResourceKey="SimpleBorderDefaultDefaultBrush" />
			<StaticResource x:Key="CheckBoxBorderBrushUncheckedPressed"       ResourceKey="SimpleBorderDefaultDefaultBrush" />
			<StaticResource x:Key="CheckBoxBorderBrushUncheckedDisabled"      ResourceKey="SimpleBorderDisabledDefaultBrush" />

			<!-- Checked Background -->
			<StaticResource x:Key="CheckBoxBackgroundChecked"                  ResourceKey="SimpleBackgroundBrandDefaultBrush" />
			<StaticResource x:Key="CheckBoxBackgroundCheckedPointerOver"       ResourceKey="SimpleBackgroundBrandDefaultBrush" />
			<StaticResource x:Key="CheckBoxBackgroundCheckedPressed"           ResourceKey="SimpleBackgroundBrandPressedBrush" />
