	<!-- ═══════════════════════════════════════════════════════════════════════ -->
	<!-- Layout / sizing resources (theme-agnostic)                            -->
	<!-- ═══════════════════════════════════════════════════════════════════════ -->
	<!-- sds-size-space-400 = 16 px -->
	<StaticResource x:Key="SimpleCheckBoxSize" ResourceKey="SimpleSpace400" />

	<!-- sds-size-radius-100 = 4 px -->
	<StaticResource x:Key="SimpleCheckBoxCornerRadius" ResourceKey="SimpleRadius100CornerRadius" />

	<!-- sds-size-stroke-border = 1 px -->
	<StaticResource x:Key="SimpleCheckBoxStrokeThickness" ResourceKey="SimpleStrokeBorder" />

	<!-- sds-size-space-400,0,0,0 -->
	<Thickness x:Key="SimpleCheckBoxContentMargin">16,0,0,0</Thickness>
	<GridLength x:Key="SimpleCheckBoxColumnWidth">20</GridLength>
	<x:Double x:Key="SimpleCheckBoxGlyphSize">10</x:Double>
	<x:String x:Key="SimpleCheckBoxCheckGlyphPathData">M28.718018,0L32,3.2819897 10.666016,24.616999 0,13.951997 3.2810059,10.670007 10.666016,18.055033z</x:String>
	<x:String x:Key="SimpleCheckBoxHyphenGlyphPathData">M0,0L32,0 32,5.3 0,5.3z</x:String>

	<!-- ═══════════════════════════════════════════════════════════════════════ -->
	<!-- SimpleCheckBoxStyle                                                    -->
	<!-- ═══════════════════════════════════════════════════════════════════════ -->
	<Style x:Key="SimpleCheckBoxStyle"
		   TargetType="CheckBox">
		<Setter Property="Background" Value="Transparent" />
		<Setter Property="Foreground" Value="{ThemeResource SimpleCheckBoxForeground}" />
		<Setter Property="BorderBrush" Value="Transparent" />
		<Setter Property="BorderThickness" Value="0" />
		<Setter Property="FontFamily" Value="{ThemeResource SimpleFontFamily}" />
		<!-- sds-typography-scale-03 = 16 px -->
		<Setter Property="FontSize" Value="{StaticResource SimpleTypographyScale03}" />
		<Setter Property="FontWeight" Value="Normal" />
		<Setter Property="HorizontalAlignment" Value="Left" />
		<Setter Property="VerticalAlignment" Value="Center" />
		<Setter Property="HorizontalContentAlignment" Value="Left" />
		<Setter Property="VerticalContentAlignment" Value="Center" />
		<Setter Property="MinWidth" Value="0" />
		<!-- sds-size-space-800 = 32 px -->
		<Setter Property="MinHeight" Value="{ThemeResource SimpleSpace800}" />
		<Setter Property="UseSystemFocusVisuals" Value="{StaticResource UseSystemFocusVisuals}" />
		<Setter Property="FocusVisualMargin" Value="-3" />
		<Setter Property="Template">
			<Setter.Value>
				<ControlTemplate TargetType="CheckBox">
					<Grid x:Name="RootGrid"
						  Background="{TemplateBinding Background}"
						  BorderBrush="{TemplateBinding BorderBrush}"
						  BorderThickness="{TemplateBinding BorderThickness}">
						<Grid.ColumnDefinitions>
							<ColumnDefinition Width="{StaticResource SimpleCheckBoxColumnWidth}" />
							<ColumnDefinition Width="*" />
						</Grid.ColumnDefinitions>

						<VisualStateManager.VisualStateGroups>
							<VisualStateGroup x:Name="CombinedStates">

								<!-- ── Unchecked ── -->
								<VisualState x:Name="UncheckedNormal">
									<VisualState.Setters>
										<Setter Target="CheckBoxBorder.Fill" Value="{ThemeResource SimpleCheckBoxUncheckedBackground}" />
										<Setter Target="CheckBoxBorder.Stroke" Value="{ThemeResource SimpleCheckBoxUncheckedBorderBrush}" />
									</VisualState.Setters>
								</VisualState>
								<VisualState x:Name="UncheckedPointerOver">
									<VisualState.Setters>
										<Setter Target="CheckBoxBorder.Fill" Value="{ThemeResource SimpleCheckBoxUncheckedBackgroundPointerOver}" />
										<Setter Target="CheckBoxBorder.Stroke" Value="{ThemeResource SimpleCheckBoxUncheckedBorderBrushPointerOver}" />
										<Setter Target="ContentPresenter.Foreground" Value="{ThemeResource SimpleCheckBoxForegroundPointerOver}" />
									</VisualState.Setters>
								</VisualState>
								<VisualState x:Name="UncheckedPressed">
									<VisualState.Setters>
										<Setter Target="CheckBoxBorder.Fill" Value="{ThemeResource SimpleCheckBoxUncheckedBackgroundPressed}" />
										<Setter Target="CheckBoxBorder.Stroke" Value="{ThemeResource SimpleCheckBoxUncheckedBorderBrushPressed}" />
										<Setter Target="ContentPresenter.Foreground" Value="{ThemeResource SimpleCheckBoxForegroundPressed}" />
									</VisualState.Setters>
								</VisualState>
								<VisualState x:Name="UncheckedDisabled">
									<VisualState.Setters>
										<Setter Target="CheckBoxBorder.Fill" Value="{ThemeResource SimpleCheckBoxUncheckedBackgroundDisabled}" />
										<Setter Target="CheckBoxBorder.Stroke" Value="{ThemeResource SimpleCheckBoxUncheckedBorderBrushDisabled}" />
										<Setter Target="ContentPresenter.Foreground" Value="{ThemeResource SimpleCheckBoxForegroundDisabled}" />
									</VisualState.Setters>
								</VisualState>

								<!-- ── Checked ── -->
								<VisualState x:Name="CheckedNormal">
									<VisualState.Setters>
										<Setter Target="CheckBoxBorder.Fill" Value="{ThemeResource SimpleCheckBoxCheckedBackground}" />
										<Setter Target="CheckBoxBorder.Stroke" Value="{ThemeResource SimpleCheckBoxCheckedBorderBrush}" />
										<Setter Target="CheckGlyph.Opacity" Value="1" />
										<Setter Target="CheckGlyph.Fill" Value="{ThemeResource SimpleCheckBoxCheckedGlyphFill}" />
									</VisualState.Setters>
								</VisualState>
								<VisualState x:Name="CheckedPointerOver">
									<VisualState.Setters>
										<Setter Target="CheckBoxBorder.Fill" Value="{ThemeResource SimpleCheckBoxCheckedBackgroundPointerOver}" />
										<Setter Target="CheckBoxBorder.Stroke" Value="{ThemeResource SimpleCheckBoxCheckedBorderBrushPointerOver}" />
										<Setter Target="CheckGlyph.Opacity" Value="1" />
										<Setter Target="CheckGlyph.Fill" Value="{ThemeResource SimpleCheckBoxCheckedGlyphFillPointerOver}" />
										<Setter Target="ContentPresenter.Foreground" Value="{ThemeResource SimpleCheckBoxForegroundPointerOver}" />
									</VisualState.Setters>
								</VisualState>
								<VisualState x:Name="CheckedPressed">
									<VisualState.Setters>
										<Setter Target="CheckBoxBorder.Fill" Value="{ThemeResource SimpleCheckBoxCheckedBackgroundPressed}" />
										<Setter Target="CheckBoxBorder.Stroke" Value="{ThemeResource SimpleCheckBoxCheckedBorderBrushPressed}" />
										<Setter Target="CheckGlyph.Opacity" Value="1" />
										<Setter Target="CheckGlyph.Fill" Value="{ThemeResource SimpleCheckBoxCheckedGlyphFillPressed}" />
										<Setter Target="ContentPresenter.Foreground" Value="{ThemeResource SimpleCheckBoxForegroundPressed}" />
									</VisualState.Setters>
								</VisualState>
								<VisualState x:Name="CheckedDisabled">
									<VisualState.Setters>
										<Setter Target="CheckBoxBorder.Fill" Value="{ThemeResource SimpleCheckBoxCheckedBackgroundDisabled}" />
										<Setter Target="CheckBoxBorder.Stroke" Value="{ThemeResource SimpleCheckBoxCheckedBorderBrushDisabled}" />
										<Setter Target="CheckGlyph.Opacity" Value="1" />
										<Setter Target="CheckGlyph.Fill" Value="{ThemeResource SimpleCheckBoxCheckedGlyphFillDisabled}" />
										<Setter Target="ContentPresenter.Foreground" Value="{ThemeResource SimpleCheckBoxForegroundDisabled}" />
									</VisualState.Setters>
								</VisualState>

								<!-- ── Indeterminate ── -->
								<VisualState x:Name="IndeterminateNormal">
									<VisualState.Setters>
										<Setter Target="CheckBoxBorder.Fill" Value="{ThemeResource SimpleCheckBoxIndeterminateBackground}" />
										<Setter Target="CheckBoxBorder.Stroke" Value="{ThemeResource SimpleCheckBoxIndeterminateBorderBrush}" />
										<Setter Target="IndeterminateGlyph.Opacity" Value="1" />
										<Setter Target="IndeterminateGlyph.Fill" Value="{ThemeResource SimpleCheckBoxIndeterminateGlyphFill}" />
									</VisualState.Setters>
								</VisualState>
								<VisualState x:Name="IndeterminatePointerOver">
									<VisualState.Setters>
										<Setter Target="CheckBoxBorder.Fill" Value="{ThemeResource SimpleCheckBoxIndeterminateBackgroundPointerOver}" />
										<Setter Target="CheckBoxBorder.Stroke" Value="{ThemeResource SimpleCheckBoxIndeterminateBorderBrushPointerOver}" />
										<Setter Target="IndeterminateGlyph.Opacity" Value="1" />
										<Setter Target="IndeterminateGlyph.Fill" Value="{ThemeResource SimpleCheckBoxIndeterminateGlyphFillPointerOver}" />
										<Setter Target="ContentPresenter.Foreground" Value="{ThemeResource SimpleCheckBoxForegroundPointerOver}" />
									</VisualState.Setters>
								</VisualState>
								<VisualState x:Name="IndeterminatePressed">
									<VisualState.Setters>
										<Setter Target="CheckBoxBorder.Fill" Value="{ThemeResource SimpleCheckBoxIndeterminateBackgroundPressed}" />
										<Setter Target="CheckBoxBorder.Stroke" Value="{ThemeResource SimpleCheckBoxIndeterminateBorderBrushPressed}" />
										<Setter Target="IndeterminateGlyph.Opacity" Value="1" />
										<Setter Target="IndeterminateGlyph.Fill" Value="{ThemeResource SimpleCheckBoxIndeterminateGlyphFillPressed}" />
										<Setter Target="ContentPresenter.Foreground" Value="{ThemeResource SimpleCheckBoxForegroundPressed}" />
									</VisualState.Setters>
								</VisualState>
								<VisualState x:Name="IndeterminateDisabled">
									<VisualState.Setters>
										<Setter Target="CheckBoxBorder.Fill" Value="{ThemeResource SimpleCheckBoxIndeterminateBackgroundDisabled}" />
										<Setter Target="CheckBoxBorder.Stroke" Value="{ThemeResource SimpleCheckBoxIndeterminateBorderBrushDisabled}" />
										<Setter Target="IndeterminateGlyph.Opacity" Value="1" />
										<Setter Target="IndeterminateGlyph.Fill" Value="{ThemeResource SimpleCheckBoxIndeterminateGlyphFillDisabled}" />
										<Setter Target="ContentPresenter.Foreground" Value="{ThemeResource SimpleCheckBoxForegroundDisabled}" />
									</VisualState.Setters>
								</VisualState>

							</VisualStateGroup>
						</VisualStateManager.VisualStateGroups>

						<!-- CheckBox Visual -->
						<Grid x:Name="CheckBoxContainer"
							  Grid.Column="0"
							  Width="{StaticResource SimpleCheckBoxSize}"
							  Height="{StaticResource SimpleCheckBoxSize}"
							  HorizontalAlignment="Center"
							  VerticalAlignment="Center">

							<!-- sds-size-radius-100 = 4 px -->
							<Rectangle x:Name="CheckBoxBorder"
									   Fill="{ThemeResource SimpleCheckBoxUncheckedBackground}"
									   Stroke="{ThemeResource SimpleCheckBoxUncheckedBorderBrush}"
									   StrokeThickness="{StaticResource SimpleCheckBoxStrokeThickness}"
									   RadiusX="{ThemeResource SimpleRadius100}"
									   RadiusY="{ThemeResource SimpleRadius100}" />

							<!-- Checkmark Glyph -->
							<Path x:Name="CheckGlyph"
								  Data="{StaticResource SimpleCheckBoxCheckGlyphPathData}"
								  Fill="{ThemeResource SimpleCheckBoxCheckedGlyphFill}"
								  Stretch="Uniform"
								  Width="{StaticResource SimpleCheckBoxGlyphSize}"
								  Height="{StaticResource SimpleCheckBoxGlyphSize}"
								  HorizontalAlignment="Center"
								  VerticalAlignment="Center"
								  Opacity="0" />

							<!-- Dash Glyph (Indeterminate) -->
							<Path x:Name="IndeterminateGlyph"
								  Data="{StaticResource SimpleCheckBoxHyphenGlyphPathData}"
								  Fill="{ThemeResource SimpleCheckBoxIndeterminateGlyphFill}"
								  Stretch="Uniform"
								  Width="{StaticResource SimpleCheckBoxGlyphSize}"
								  Height="{StaticResource SimpleCheckBoxGlyphSize}"
								  HorizontalAlignment="Center"
								  VerticalAlignment="Center"
								  Opacity="0" />
						</Grid>

						<!-- Content -->
						<ContentPresenter x:Name="ContentPresenter"
										  Grid.Column="1"
										  Margin="{StaticResource SimpleCheckBoxContentMargin}"
										  Content="{TemplateBinding Content}"
										  ContentTemplate="{TemplateBinding ContentTemplate}"
										  ContentTransitions="{TemplateBinding ContentTransitions}"
										  Foreground="{TemplateBinding Foreground}"
										  HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
										  VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
										  AutomationProperties.AccessibilityView="Raw"
										  TextWrapping="Wrap" />
					</Grid>
				</ControlTemplate>
			</Setter.Value>
		</Setter>
	</Style>

</ResourceDictionary>
