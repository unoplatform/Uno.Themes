			<StaticResource x:Key="SimpleCheckBoxIndeterminateGlyphFill"             ResourceKey="CheckBoxGlyphForegroundIndeterminate" />
			<StaticResource x:Key="SimpleCheckBoxIndeterminateGlyphFillPointerOver"  ResourceKey="CheckBoxGlyphForegroundIndeterminatePointerOver" />
