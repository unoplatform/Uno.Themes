<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
					xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

	<!--
		Simple Design System — CheckBox Style
		Lightweight styling: every visual-state brush is exposed via ThemeResource.
		
		Semantic resource layer:
		CheckBox{Property}{State}  = semantic keys (Material naming, source of truth)
		SimpleCheckBox{State}{Property} = Simple-prefixed keys that alias → semantic keys
		
		Templates reference Simple-prefixed keys (SimpleCheckBox*) so that consumers
		can override EITHER the Simple key or the semantic key.
		
		States: Unchecked/Checked/Indeterminate × Normal/PointerOver/Pressed/Disabled
		SDS source: Checkbox/checkbox.css
		
		Style mapping: CheckBoxStyle → SimpleCheckBoxStyle (1:1)
		
		Skipped Material-specific keys (no Simple equivalent):
		CheckBoxStateCircle*, CheckBoxFocusArea*, CheckBoxCheckBackgroundStroke*,
		CheckBoxCheckBackgroundFill*, CheckBoxCheckArea*
	-->

	<!-- ═══════════════════════════════════════════════════════════════════════ -->
	<!-- Lightweight styling ThemeResource aliases -->
	<!-- ═══════════════════════════════════════════════════════════════════════ -->
	<ResourceDictionary.ThemeDictionaries>

		<!-- ─── Light Theme ─── -->
		<ResourceDictionary x:Key="Light">

			<!-- ── CheckBox — semantic keys (source of truth) ── -->

			<!-- Unchecked Background -->
			<StaticResource x:Key="CheckBoxBackgroundUnchecked" ResourceKey="SurfaceBrush" />
			<StaticResource x:Key="CheckBoxBackgroundUncheckedPointerOver" ResourceKey="SurfaceBrush" />
			<StaticResource x:Key="CheckBoxBackgroundUncheckedPressed" ResourceKey="PrimaryContainerBrush" />
			<StaticResource x:Key="CheckBoxBackgroundUncheckedDisabled" ResourceKey="OnSurfaceDisabledBrush" />

			<!-- Unchecked BorderBrush -->
			<StaticResource x:Key="CheckBoxBorderBrushUnchecked" ResourceKey="OutlineBrush" />
			<StaticResource x:Key="CheckBoxBorderBrushUncheckedPointerOver" ResourceKey="OutlineBrush" />
			<StaticResource x:Key="CheckBoxBorderBrushUncheckedPressed" ResourceKey="OutlineBrush" />
			<StaticResource x:Key="CheckBoxBorderBrushUncheckedDisabled" ResourceKey="OutlineDisabledBrush" />

			<!-- Checked Background -->
			<StaticResource x:Key="CheckBoxBackgroundChecked" ResourceKey="PrimaryBrush" />
			<StaticResource x:Key="CheckBoxBackgroundCheckedPointerOver" ResourceKey="PrimaryBrush" />
			<StaticResource x:Key="CheckBoxBackgroundCheckedPressed" ResourceKey="PrimaryVariantDarkBrush" />
			<StaticResource x:Key="CheckBoxBackgroundCheckedDisabled" ResourceKey="OnSurfaceDisabledBrush" />

			<!-- Checked BorderBrush -->
			<StaticResource x:Key="CheckBoxBorderBrushChecked" ResourceKey="PrimaryBrush" />
			<StaticResource x:Key="CheckBoxBorderBrushCheckedPointerOver" ResourceKey="PrimaryBrush" />
			<StaticResource x:Key="CheckBoxBorderBrushCheckedPressed" ResourceKey="PrimaryVariantDarkBrush" />
			<StaticResource x:Key="CheckBoxBorderBrushCheckedDisabled" ResourceKey="OutlineDisabledBrush" />

			<!-- Checked Glyph -->
			<StaticResource x:Key="CheckBoxGlyphForegroundChecked" ResourceKey="OnPrimaryBrush" />
			<StaticResource x:Key="CheckBoxGlyphForegroundCheckedPointerOver" ResourceKey="OnPrimaryBrush" />
			<StaticResource x:Key="CheckBoxGlyphForegroundCheckedPressed" ResourceKey="OnPrimaryBrush" />
			<StaticResource x:Key="CheckBoxGlyphForegroundCheckedDisabled" ResourceKey="OnSurfaceDisabledBrush" />

			<!-- Indeterminate Background -->
			<StaticResource x:Key="CheckBoxBackgroundIndeterminate" ResourceKey="PrimaryBrush" />
			<StaticResource x:Key="CheckBoxBackgroundIndeterminatePointerOver" ResourceKey="PrimaryBrush" />
			<StaticResource x:Key="CheckBoxBackgroundIndeterminatePressed" ResourceKey="PrimaryVariantDarkBrush" />
			<StaticResource x:Key="CheckBoxBackgroundIndeterminateDisabled" ResourceKey="OnSurfaceDisabledBrush" />

			<!-- Indeterminate BorderBrush -->
			<StaticResource x:Key="CheckBoxBorderBrushIndeterminate" ResourceKey="PrimaryBrush" />
			<StaticResource x:Key="CheckBoxBorderBrushIndeterminatePointerOver" ResourceKey="PrimaryBrush" />
			<StaticResource x:Key="CheckBoxBorderBrushIndeterminatePressed" ResourceKey="PrimaryVariantDarkBrush" />
			<StaticResource x:Key="CheckBoxBorderBrushIndeterminateDisabled" ResourceKey="OutlineDisabledBrush" />

			<!-- Indeterminate Glyph -->
			<StaticResource x:Key="CheckBoxGlyphForegroundIndeterminate" ResourceKey="OnPrimaryBrush" />
			<StaticResource x:Key="CheckBoxGlyphForegroundIndeterminatePointerOver" ResourceKey="OnPrimaryBrush" />
			<StaticResource x:Key="CheckBoxGlyphForegroundIndeterminatePressed" ResourceKey="OnPrimaryBrush" />
			<StaticResource x:Key="CheckBoxGlyphForegroundIndeterminateDisabled" ResourceKey="OnSurfaceDisabledBrush" />

			<!-- Foreground (label) -->
			<StaticResource x:Key="CheckBoxForegroundUnchecked" ResourceKey="OnSurfaceBrush" />
			<StaticResource x:Key="CheckBoxForegroundUncheckedPointerOver" ResourceKey="OnSurfaceBrush" />
			<StaticResource x:Key="CheckBoxForegroundUncheckedPressed" ResourceKey="OnSurfaceBrush" />
			<StaticResource x:Key="CheckBoxForegroundUncheckedDisabled" ResourceKey="OnSurfaceDisabledBrush" />
			<StaticResource x:Key="CheckBoxForegroundChecked" ResourceKey="OnSurfaceBrush" />
			<StaticResource x:Key="CheckBoxForegroundCheckedPointerOver" ResourceKey="OnSurfaceBrush" />
			<StaticResource x:Key="CheckBoxForegroundCheckedPressed" ResourceKey="OnSurfaceBrush" />
			<StaticResource x:Key="CheckBoxForegroundCheckedDisabled" ResourceKey="OnSurfaceDisabledBrush" />
			<StaticResource x:Key="CheckBoxForegroundIndeterminate" ResourceKey="OnSurfaceBrush" />
			<StaticResource x:Key="CheckBoxForegroundIndeterminatePointerOver" ResourceKey="OnSurfaceBrush" />
			<StaticResource x:Key="CheckBoxForegroundIndeterminatePressed" ResourceKey="OnSurfaceBrush" />
			<StaticResource x:Key="CheckBoxForegroundIndeterminateDisabled" ResourceKey="OnSurfaceDisabledBrush" />

			<!-- ── Backwards-compat aliases (SimpleCheckBox* → CheckBox*) ── -->

			<!-- Unchecked -->
			<!-- Checked -->
			<!-- Indeterminate -->
			<!-- Foreground (label) -->
		</ResourceDictionary>

		<!-- ─── Dark Theme (Default) ─── -->
		<ResourceDictionary x:Key="Default">

			<!-- ── CheckBox — semantic keys (source of truth) ── -->

			<!-- Unchecked Background -->
			<StaticResource x:Key="CheckBoxBackgroundUnchecked" ResourceKey="SurfaceBrush" />
			<StaticResource x:Key="CheckBoxBackgroundUncheckedPointerOver" ResourceKey="SurfaceBrush" />
			<StaticResource x:Key="CheckBoxBackgroundUncheckedPressed" ResourceKey="PrimaryContainerBrush" />
			<StaticResource x:Key="CheckBoxBackgroundUncheckedDisabled" ResourceKey="OnSurfaceDisabledBrush" />

			<!-- Unchecked BorderBrush -->
			<StaticResource x:Key="CheckBoxBorderBrushUnchecked" ResourceKey="OutlineBrush" />
			<StaticResource x:Key="CheckBoxBorderBrushUncheckedPointerOver" ResourceKey="OutlineBrush" />
			<StaticResource x:Key="CheckBoxBorderBrushUncheckedPressed" ResourceKey="OutlineBrush" />
			<StaticResource x:Key="CheckBoxBorderBrushUncheckedDisabled" ResourceKey="OutlineDisabledBrush" />

			<!-- Checked Background -->
			<StaticResource x:Key="CheckBoxBackgroundChecked" ResourceKey="PrimaryBrush" />
			<StaticResource x:Key="CheckBoxBackgroundCheckedPointerOver" ResourceKey="PrimaryBrush" />
			<StaticResource x:Key="CheckBoxBackgroundCheckedPressed" ResourceKey="PrimaryVariantDarkBrush" />
			<StaticResource x:Key="CheckBoxBackgroundCheckedDisabled" ResourceKey="OnSurfaceDisabledBrush" />

			<!-- Checked BorderBrush -->
			<StaticResource x:Key="CheckBoxBorderBrushChecked" ResourceKey="PrimaryBrush" />
			<StaticResource x:Key="CheckBoxBorderBrushCheckedPointerOver" ResourceKey="PrimaryBrush" />
			<StaticResource x:Key="CheckBoxBorderBrushCheckedPressed" ResourceKey="PrimaryVariantDarkBrush" />
			<StaticResource x:Key="CheckBoxBorderBrushCheckedDisabled" ResourceKey="OutlineDisabledBrush" />

			<!-- Checked Glyph -->
			<StaticResource x:Key="CheckBoxGlyphForegroundChecked" ResourceKey="OnPrimaryBrush" />
			<StaticResource x:Key="CheckBoxGlyphForegroundCheckedPointerOver" ResourceKey="OnPrimaryBrush" />
			<StaticResource x:Key="CheckBoxGlyphForegroundCheckedPressed" ResourceKey="OnPrimaryBrush" />
			<StaticResource x:Key="CheckBoxGlyphForegroundCheckedDisabled" ResourceKey="OnSurfaceDisabledBrush" />

			<!-- Indeterminate Background -->
			<StaticResource x:Key="CheckBoxBackgroundIndeterminate" ResourceKey="PrimaryBrush" />
			<StaticResource x:Key="CheckBoxBackgroundIndeterminatePointerOver" ResourceKey="PrimaryBrush" />
			<StaticResource x:Key="CheckBoxBackgroundIndeterminatePressed" ResourceKey="PrimaryVariantDarkBrush" />
			<StaticResource x:Key="CheckBoxBackgroundIndeterminateDisabled" ResourceKey="OnSurfaceDisabledBrush" />

			<!-- Indeterminate BorderBrush -->
			<StaticResource x:Key="CheckBoxBorderBrushIndeterminate" ResourceKey="PrimaryBrush" />
			<StaticResource x:Key="CheckBoxBorderBrushIndeterminatePointerOver" ResourceKey="PrimaryBrush" />
			<StaticResource x:Key="CheckBoxBorderBrushIndeterminatePressed" ResourceKey="PrimaryVariantDarkBrush" />
			<StaticResource x:Key="CheckBoxBorderBrushIndeterminateDisabled" ResourceKey="OutlineDisabledBrush" />

			<!-- Indeterminate Glyph -->
			<StaticResource x:Key="CheckBoxGlyphForegroundIndeterminate" ResourceKey="OnPrimaryBrush" />
			<StaticResource x:Key="CheckBoxGlyphForegroundIndeterminatePointerOver" ResourceKey="OnPrimaryBrush" />
			<StaticResource x:Key="CheckBoxGlyphForegroundIndeterminatePressed" ResourceKey="OnPrimaryBrush" />
			<StaticResource x:Key="CheckBoxGlyphForegroundIndeterminateDisabled" ResourceKey="OnSurfaceDisabledBrush" />

			<!-- Foreground (label) -->
			<StaticResource x:Key="CheckBoxForegroundUnchecked" ResourceKey="OnSurfaceBrush" />
			<StaticResource x:Key="CheckBoxForegroundUncheckedPointerOver" ResourceKey="OnSurfaceBrush" />
			<StaticResource x:Key="CheckBoxForegroundUncheckedPressed" ResourceKey="OnSurfaceBrush" />
			<StaticResource x:Key="CheckBoxForegroundUncheckedDisabled" ResourceKey="OnSurfaceDisabledBrush" />
			<StaticResource x:Key="CheckBoxForegroundChecked" ResourceKey="OnSurfaceBrush" />
			<StaticResource x:Key="CheckBoxForegroundCheckedPointerOver" ResourceKey="OnSurfaceBrush" />
			<StaticResource x:Key="CheckBoxForegroundCheckedPressed" ResourceKey="OnSurfaceBrush" />
			<StaticResource x:Key="CheckBoxForegroundCheckedDisabled" ResourceKey="OnSurfaceDisabledBrush" />
			<StaticResource x:Key="CheckBoxForegroundIndeterminate" ResourceKey="OnSurfaceBrush" />
			<StaticResource x:Key="CheckBoxForegroundIndeterminatePointerOver" ResourceKey="OnSurfaceBrush" />
			<StaticResource x:Key="CheckBoxForegroundIndeterminatePressed" ResourceKey="OnSurfaceBrush" />
			<StaticResource x:Key="CheckBoxForegroundIndeterminateDisabled" ResourceKey="OnSurfaceDisabledBrush" />

			<!-- ── Backwards-compat aliases (SimpleCheckBox* → CheckBox*) ── -->

			<!-- Unchecked -->
			<!-- Checked -->
			<!-- Indeterminate -->
			<!-- Foreground (label) -->
		</ResourceDictionary>

	</ResourceDictionary.ThemeDictionaries>

	<!-- ═══════════════════════════════════════════════════════════════════════ -->
	<!-- Layout / sizing resources (theme-agnostic) -->
	<!-- ═══════════════════════════════════════════════════════════════════════ -->
	<Thickness x:Key="SimpleCheckBoxContentMargin">16,0,0,0</Thickness>
	<GridLength x:Key="SimpleCheckBoxColumnWidth">20</GridLength>
	<x:Double x:Key="SimpleCheckBoxGlyphSize">10</x:Double>
	<x:String x:Key="SimpleCheckBoxCheckGlyphPathData">M28.718018,0L32,3.2819897 10.666016,24.616999 0,13.951997 3.2810059,10.670007 10.666016,18.055033z</x:String>
	<x:String x:Key="SimpleCheckBoxHyphenGlyphPathData">M0,0L32,0 32,5.3 0,5.3z</x:String>

	<!-- ═══════════════════════════════════════════════════════════════════════ -->
	<!-- SimpleCheckBoxStyle -->
	<!-- ═══════════════════════════════════════════════════════════════════════ -->
	<Style x:Key="SimpleCheckBoxStyle"
		   TargetType="CheckBox">
		<Setter Property="Background" Value="Transparent" />
		<Setter Property="Foreground" Value="{ThemeResource CheckBoxForegroundUnchecked}" />
		<Setter Property="BorderBrush" Value="Transparent" />
		<Setter Property="BorderThickness" Value="0" />
		<Setter Property="FontFamily" Value="{ThemeResource SimpleFontFamily}" />
		<Setter Property="FontSize" Value="{StaticResource SimpleTypographyScale03}" />
		<Setter Property="FontWeight" Value="Normal" />
		<Setter Property="HorizontalAlignment" Value="Left" />
		<Setter Property="VerticalAlignment" Value="Center" />
		<Setter Property="HorizontalContentAlignment" Value="Left" />
		<Setter Property="VerticalContentAlignment" Value="Center" />
		<Setter Property="MinWidth" Value="0" />
		<Setter Property="MinHeight" Value="{ThemeResource SimpleSpace800}" />
		<Setter Property="UseSystemFocusVisuals" Value="{StaticResource UseSystemFocusVisuals}" />
		<Setter Property="FocusVisualMargin" Value="-3" />
		<Setter Property="Template">
			<Setter.Value>
				<ControlTemplate TargetType="CheckBox">
					<Grid x:Name="RootGrid"
						  Background="{TemplateBinding Background}"
						  BorderBrush="{TemplateBinding BorderBrush}"
						  BorderThickness="{TemplateBinding BorderThickness}">
						<Grid.ColumnDefinitions>
							<ColumnDefinition Width="{StaticResource SimpleCheckBoxColumnWidth}" />
							<ColumnDefinition Width="*" />
						</Grid.ColumnDefinitions>

						<VisualStateManager.VisualStateGroups>
							<VisualStateGroup x:Name="CombinedStates">

								<!-- ── Unchecked ── -->
								<VisualState x:Name="UncheckedNormal">
									<VisualState.Setters>
										<Setter Target="CheckBoxBorder.Fill" Value="{ThemeResource CheckBoxBackgroundUnchecked}" />
										<Setter Target="CheckBoxBorder.Stroke" Value="{ThemeResource CheckBoxBorderBrushUnchecked}" />
									</VisualState.Setters>
								</VisualState>
								<VisualState x:Name="UncheckedPointerOver">
									<VisualState.Setters>
										<Setter Target="CheckBoxBorder.Fill" Value="{ThemeResource CheckBoxBackgroundUncheckedPointerOver}" />
										<Setter Target="CheckBoxBorder.Stroke" Value="{ThemeResource CheckBoxBorderBrushUncheckedPointerOver}" />
										<Setter Target="ContentPresenter.Foreground" Value="{ThemeResource CheckBoxForegroundUncheckedPointerOver}" />
									</VisualState.Setters>
								</VisualState>
								<VisualState x:Name="UncheckedPressed">
									<VisualState.Setters>
										<Setter Target="CheckBoxBorder.Fill" Value="{ThemeResource CheckBoxBackgroundUncheckedPressed}" />
										<Setter Target="CheckBoxBorder.Stroke" Value="{ThemeResource CheckBoxBorderBrushUncheckedPressed}" />
										<Setter Target="ContentPresenter.Foreground" Value="{ThemeResource CheckBoxForegroundUncheckedPressed}" />
									</VisualState.Setters>
								</VisualState>
								<VisualState x:Name="UncheckedDisabled">
									<VisualState.Setters>
										<Setter Target="CheckBoxBorder.Fill" Value="{ThemeResource CheckBoxBackgroundUncheckedDisabled}" />
										<Setter Target="CheckBoxBorder.Stroke" Value="{ThemeResource CheckBoxBorderBrushUncheckedDisabled}" />
										<Setter Target="ContentPresenter.Foreground" Value="{ThemeResource CheckBoxForegroundUncheckedDisabled}" />
									</VisualState.Setters>
								</VisualState>

								<!-- ── Checked ── -->
								<VisualState x:Name="CheckedNormal">
									<VisualState.Setters>
										<Setter Target="CheckBoxBorder.Fill" Value="{ThemeResource CheckBoxBackgroundChecked}" />
										<Setter Target="CheckBoxBorder.Stroke" Value="{ThemeResource CheckBoxBorderBrushChecked}" />
										<Setter Target="CheckGlyph.Opacity" Value="1" />
										<Setter Target="CheckGlyph.Fill" Value="{ThemeResource CheckBoxGlyphForegroundChecked}" />
									</VisualState.Setters>
								</VisualState>
								<VisualState x:Name="CheckedPointerOver">
									<VisualState.Setters>
										<Setter Target="CheckBoxBorder.Fill" Value="{ThemeResource CheckBoxBackgroundCheckedPointerOver}" />
										<Setter Target="CheckBoxBorder.Stroke" Value="{ThemeResource CheckBoxBorderBrushCheckedPointerOver}" />
										<Setter Target="CheckGlyph.Opacity" Value="1" />
										<Setter Target="CheckGlyph.Fill" Value="{ThemeResource CheckBoxGlyphForegroundCheckedPointerOver}" />
										<Setter Target="ContentPresenter.Foreground" Value="{ThemeResource CheckBoxForegroundUncheckedPointerOver}" />
									</VisualState.Setters>
								</VisualState>
								<VisualState x:Name="CheckedPressed">
									<VisualState.Setters>
										<Setter Target="CheckBoxBorder.Fill" Value="{ThemeResource CheckBoxBackgroundCheckedPressed}" />
										<Setter Target="CheckBoxBorder.Stroke" Value="{ThemeResource CheckBoxBorderBrushCheckedPressed}" />
										<Setter Target="CheckGlyph.Opacity" Value="1" />
										<Setter Target="CheckGlyph.Fill" Value="{ThemeResource CheckBoxGlyphForegroundCheckedPressed}" />
										<Setter Target="ContentPresenter.Foreground" Value="{ThemeResource CheckBoxForegroundUncheckedPressed}" />
									</VisualState.Setters>
								</VisualState>
								<VisualState x:Name="CheckedDisabled">
									<VisualState.Setters>
										<Setter Target="CheckBoxBorder.Fill" Value="{ThemeResource CheckBoxBackgroundCheckedDisabled}" />
										<Setter Target="CheckBoxBorder.Stroke" Value="{ThemeResource CheckBoxBorderBrushCheckedDisabled}" />
										<Setter Target="CheckGlyph.Opacity" Value="1" />
										<Setter Target="CheckGlyph.Fill" Value="{ThemeResource CheckBoxGlyphForegroundCheckedDisabled}" />
										<Setter Target="ContentPresenter.Foreground" Value="{ThemeResource CheckBoxForegroundUncheckedDisabled}" />
									</VisualState.Setters>
								</VisualState>

								<!-- ── Indeterminate ── -->
								<VisualState x:Name="IndeterminateNormal">
									<VisualState.Setters>
										<Setter Target="CheckBoxBorder.Fill" Value="{ThemeResource CheckBoxBackgroundIndeterminate}" />
										<Setter Target="CheckBoxBorder.Stroke" Value="{ThemeResource CheckBoxBorderBrushIndeterminate}" />
										<Setter Target="IndeterminateGlyph.Opacity" Value="1" />
										<Setter Target="IndeterminateGlyph.Fill" Value="{ThemeResource CheckBoxGlyphForegroundIndeterminate}" />
									</VisualState.Setters>
								</VisualState>
								<VisualState x:Name="IndeterminatePointerOver">
									<VisualState.Setters>
										<Setter Target="CheckBoxBorder.Fill" Value="{ThemeResource CheckBoxBackgroundIndeterminatePointerOver}" />
										<Setter Target="CheckBoxBorder.Stroke" Value="{ThemeResource CheckBoxBorderBrushIndeterminatePointerOver}" />
										<Setter Target="IndeterminateGlyph.Opacity" Value="1" />
										<Setter Target="IndeterminateGlyph.Fill" Value="{ThemeResource CheckBoxGlyphForegroundIndeterminatePointerOver}" />
										<Setter Target="ContentPresenter.Foreground" Value="{ThemeResource CheckBoxForegroundUncheckedPointerOver}" />
									</VisualState.Setters>
								</VisualState>
								<VisualState x:Name="IndeterminatePressed">
									<VisualState.Setters>
										<Setter Target="CheckBoxBorder.Fill" Value="{ThemeResource CheckBoxBackgroundIndeterminatePressed}" />
										<Setter Target="CheckBoxBorder.Stroke" Value="{ThemeResource CheckBoxBorderBrushIndeterminatePressed}" />
										<Setter Target="IndeterminateGlyph.Opacity" Value="1" />
										<Setter Target="IndeterminateGlyph.Fill" Value="{ThemeResource CheckBoxGlyphForegroundIndeterminatePressed}" />
										<Setter Target="ContentPresenter.Foreground" Value="{ThemeResource CheckBoxForegroundUncheckedPressed}" />
									</VisualState.Setters>
								</VisualState>
								<VisualState x:Name="IndeterminateDisabled">
									<VisualState.Setters>
										<Setter Target="CheckBoxBorder.Fill" Value="{ThemeResource CheckBoxBackgroundIndeterminateDisabled}" />
										<Setter Target="CheckBoxBorder.Stroke" Value="{ThemeResource CheckBoxBorderBrushIndeterminateDisabled}" />
										<Setter Target="IndeterminateGlyph.Opacity" Value="1" />
										<Setter Target="IndeterminateGlyph.Fill" Value="{ThemeResource CheckBoxGlyphForegroundIndeterminateDisabled}" />
										<Setter Target="ContentPresenter.Foreground" Value="{ThemeResource CheckBoxForegroundUncheckedDisabled}" />
									</VisualState.Setters>
								</VisualState>

							</VisualStateGroup>
						</VisualStateManager.VisualStateGroups>

						<!-- CheckBox Visual -->
						<Grid x:Name="CheckBoxContainer"
							  Grid.Column="0"
							  Width="{StaticResource SimpleCheckBoxSize}"
							  Height="{StaticResource SimpleCheckBoxSize}"
							  HorizontalAlignment="Center"
							  VerticalAlignment="Center">

							<Rectangle x:Name="CheckBoxBorder"
									   Fill="{ThemeResource CheckBoxBackgroundUnchecked}"
									   Stroke="{ThemeResource CheckBoxBorderBrushUnchecked}"
									   StrokeThickness="{StaticResource SimpleCheckBoxStrokeThickness}"
									   RadiusX="{ThemeResource SimpleRadius100}"
									   RadiusY="{ThemeResource SimpleRadius100}" />

							<!-- Checkmark Glyph -->
							<Path x:Name="CheckGlyph"
								  Data="{StaticResource SimpleCheckBoxCheckGlyphPathData}"
								  Fill="{ThemeResource CheckBoxGlyphForegroundChecked}"
								  Stretch="Uniform"
								  Width="{StaticResource SimpleCheckBoxGlyphSize}"
								  Height="{StaticResource SimpleCheckBoxGlyphSize}"
								  HorizontalAlignment="Center"
								  VerticalAlignment="Center"
								  Opacity="0" />

							<!-- Dash Glyph (Indeterminate) -->
							<Path x:Name="IndeterminateGlyph"
								  Data="{StaticResource SimpleCheckBoxHyphenGlyphPathData}"
								  Fill="{ThemeResource CheckBoxGlyphForegroundIndeterminate}"
								  Stretch="Uniform"
								  Width="{StaticResource SimpleCheckBoxGlyphSize}"
								  Height="{StaticResource SimpleCheckBoxGlyphSize}"
								  HorizontalAlignment="Center"
								  VerticalAlignment="Center"
								  Opacity="0" />
						</Grid>

						<!-- Content -->
						<ContentPresenter x:Name="ContentPresenter"
										  Grid.Column="1"
										  Margin="{StaticResource SimpleCheckBoxContentMargin}"
										  Content="{TemplateBinding Content}"
										  ContentTemplate="{TemplateBinding ContentTemplate}"
										  ContentTransitions="{TemplateBinding ContentTransitions}"
										  Foreground="{TemplateBinding Foreground}"
										  HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
										  VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
										  AutomationProperties.AccessibilityView="Raw"
										  TextWrapping="Wrap" />
					</Grid>
				</ControlTemplate>
			</Setter.Value>
		</Setter>
	</Style>

</ResourceDictionary>
