<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
					xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

	<ResourceDictionary.ThemeDictionaries>
		<!-- Light Theme -->
		<ResourceDictionary x:Key="Light">
			<StaticResource x:Key="CalendarDatePickerForeground" ResourceKey="OnSurfaceBrush" />
			<StaticResource x:Key="CalendarDatePickerForegroundDisabled" ResourceKey="OnSurfaceLowBrush" />
			<StaticResource x:Key="CalendarDatePickerBackground" ResourceKey="SurfaceVariantBrush" />
			<StaticResource x:Key="CalendarDatePickerBackgroundPointerOver" ResourceKey="SurfaceVariantBrush" />
			<StaticResource x:Key="CalendarDatePickerBackgroundPressed" ResourceKey="SurfaceVariantBrush" />
			<StaticResource x:Key="CalendarDatePickerBackgroundDisabled" ResourceKey="DisabledBrush" />
			<StaticResource x:Key="CalendarDatePickerBorderBrush" ResourceKey="OutlineBrush" />
			<StaticResource x:Key="CalendarDatePickerBorderBrushPointerOver" ResourceKey="OnSurfaceBrush" />
			<StaticResource x:Key="CalendarDatePickerBorderBrushPressed" ResourceKey="PrimaryBrush" />
			<StaticResource x:Key="CalendarDatePickerBorderBrushDisabled" ResourceKey="OnSurfaceLowBrush" />
			<StaticResource x:Key="CalendarDatePickerHeaderForeground" ResourceKey="OnSurfaceBrush" />
			<StaticResource x:Key="CalendarDatePickerCalendarGlyphForeground" ResourceKey="OnSurfaceMediumBrush" />
			<StaticResource x:Key="CalendarDatePickerTextForeground" ResourceKey="OnSurfaceBrush" />
			<StaticResource x:Key="CalendarDatePickerTextForegroundDisabled" ResourceKey="OnSurfaceLowBrush" />
			<StaticResource x:Key="CalendarDatePickerTextForegroundSelected" ResourceKey="OnSurfaceBrush" />

			<CornerRadius x:Key="CalendarDatePickerCornerRadius">8</CornerRadius>
			<Thickness x:Key="CalendarDatePickerBorderThickness">1</Thickness>
			<x:Double x:Key="CalendarDatePickerHeight">40</x:Double>
		</ResourceDictionary>

		<!-- Dark Theme -->
		<ResourceDictionary x:Key="Default">
			<StaticResource x:Key="CalendarDatePickerForeground" ResourceKey="OnSurfaceBrush" />
			<StaticResource x:Key="CalendarDatePickerForegroundDisabled" ResourceKey="OnSurfaceLowBrush" />
			<StaticResource x:Key="CalendarDatePickerBackground" ResourceKey="SurfaceVariantBrush" />
			<StaticResource x:Key="CalendarDatePickerBackgroundPointerOver" ResourceKey="SurfaceVariantBrush" />
			<StaticResource x:Key="CalendarDatePickerBackgroundPressed" ResourceKey="SurfaceVariantBrush" />
			<StaticResource x:Key="CalendarDatePickerBackgroundDisabled" ResourceKey="DisabledBrush" />
			<StaticResource x:Key="CalendarDatePickerBorderBrush" ResourceKey="OutlineBrush" />
			<StaticResource x:Key="CalendarDatePickerBorderBrushPointerOver" ResourceKey="OnSurfaceBrush" />
			<StaticResource x:Key="CalendarDatePickerBorderBrushPressed" ResourceKey="PrimaryBrush" />
			<StaticResource x:Key="CalendarDatePickerBorderBrushDisabled" ResourceKey="OnSurfaceLowBrush" />
			<StaticResource x:Key="CalendarDatePickerHeaderForeground" ResourceKey="OnSurfaceBrush" />
			<StaticResource x:Key="CalendarDatePickerCalendarGlyphForeground" ResourceKey="OnSurfaceMediumBrush" />
			<StaticResource x:Key="CalendarDatePickerTextForeground" ResourceKey="OnSurfaceBrush" />
			<StaticResource x:Key="CalendarDatePickerTextForegroundDisabled" ResourceKey="OnSurfaceLowBrush" />
			<StaticResource x:Key="CalendarDatePickerTextForegroundSelected" ResourceKey="OnSurfaceBrush" />

			<CornerRadius x:Key="CalendarDatePickerCornerRadius">8</CornerRadius>
			<Thickness x:Key="CalendarDatePickerBorderThickness">1</Thickness>
			<x:Double x:Key="CalendarDatePickerHeight">40</x:Double>
		</ResourceDictionary>
	</ResourceDictionary.ThemeDictionaries>

	<Style x:Key="SimpleCalendarDatePickerStyle"
		   TargetType="CalendarDatePicker">
		<Setter Property="Foreground" Value="{ThemeResource CalendarDatePickerForeground}" />
		<Setter Property="Background" Value="{ThemeResource CalendarDatePickerBackground}" />
		<Setter Property="BorderBrush" Value="{ThemeResource CalendarDatePickerBorderBrush}" />
		<Setter Property="BorderThickness" Value="{ThemeResource CalendarDatePickerBorderThickness}" />
		<Setter Property="CornerRadius" Value="{ThemeResource CalendarDatePickerCornerRadius}" />
		<Setter Property="Height" Value="{ThemeResource CalendarDatePickerHeight}" />
		<Setter Property="HorizontalAlignment" Value="Left" />
	</Style>

	<Style x:Key="SimpleDefaultCalendarDatePickerStyle"
		   TargetType="CalendarDatePicker"
		   BasedOn="{StaticResource SimpleCalendarDatePickerStyle}" />
</ResourceDictionary>
