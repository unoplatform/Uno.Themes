<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
					xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
					xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
					xmlns:not_win="http://uno.ui/not_win"
					mc:Ignorable="not_win">

	<!--
		Simple Design System — CalendarDatePicker Style
		Mapped from SDS DatePicker component.

		SDS DatePicker CSS mapping:
		  Field:       background-default-default bg, border-default-default border, radius-200 (8px), text-default-default
		  Hover:       same as normal (SDS field doesn't change on hover)
		  Focus:       border-brand-secondary
		  Disabled:    background-disabled-default, border-disabled-default, text-disabled-default, icon-disabled-on-disabled
		  Placeholder: text-default-tertiary
		  Header:      text-default-default
		  Glyph icon:  icon-default-default, disabled → icon-disabled-on-disabled
		  Popover:     background-default-default, border-default-default, radius-400 (16px), shadow-200
		  CalendarView popup uses SimpleCalendarViewStyle.

		Semantic resource layer:
		  CalendarDatePicker* = canonical semantic keys (source of truth)
		  SimpleCalendarDatePicker* = backwards-compat aliases that point to the semantic keys

		Templates reference Simple-prefixed keys (which alias to semantic keys),
		so consumers can override EITHER key.

		Lightweight styling pattern: every visual-state brush is exposed via
		ThemeResource so consumers can override any individual key.
	-->

	<!-- ═══════════════════════════════════════════════════════════════════════ -->
	<!-- Lightweight styling ThemeResource aliases                              -->
	<!-- ═══════════════════════════════════════════════════════════════════════ -->
	<ResourceDictionary.ThemeDictionaries>

		<!-- ─── Light Theme ─── -->
		<ResourceDictionary x:Key="Light">

			<!-- ── CalendarDatePicker — semantic keys (source of truth) ── -->

			<!-- Dimensions -->
			<!-- sds-size-radius-200 -->
			<StaticResource x:Key="CalendarDatePickerCornerRadius" ResourceKey="SimpleRadius200CornerRadius" />
			<!-- sds-size-radius-400 -->
			<StaticResource x:Key="CalendarDatePickerFlyoutPresenterCornerRadius" ResourceKey="SimpleRadius400CornerRadius" />
			<!-- sds-size-stroke-border -->
			<StaticResource x:Key="CalendarDatePickerBorderThemeThickness" ResourceKey="SimpleStrokeBorderThickness" />
			<!-- sds-size-space-0 -->
			<StaticResource x:Key="CalendarDatePickerFlyoutPresenterPadding" ResourceKey="SimpleSpace0Thickness" />
			<!-- sds-size-space-300,0,sds-size-space-300,0 -->
			<Thickness x:Key="CalendarDatePickerContentMargin">12,0,12,0</Thickness>
			<!-- sds-size-icon-large -->
			<StaticResource x:Key="CalendarDatePickerHeight" ResourceKey="SimpleIconLarge" />
			<!-- sds-size-icon-large -->
			<StaticResource x:Key="CalendarDatePickerMinHeight" ResourceKey="SimpleIconLarge" />
			<!-- sds: 0,0,0,sds-size-space-200 -->
			<Thickness x:Key="CalendarDatePickerHeaderMargin">0,0,0,8</Thickness>
			<!-- sds-size-space-300,0,0,0 -->
			<Thickness x:Key="CalendarDatePickerCalendarGlyphMargin">12,0,0,0</Thickness>

			<!-- Foreground (selected date text) -->
			<StaticResource x:Key="CalendarDatePickerForeground"                    ResourceKey="OnSurfaceBrush" />
			<StaticResource x:Key="CalendarDatePickerForegroundDisabled"             ResourceKey="OnSurfaceDisabledBrush" />

			<!-- Placeholder text -->
			<StaticResource x:Key="CalendarDatePickerTextForeground"                 ResourceKey="OnSurfaceLowBrush" />
			<StaticResource x:Key="CalendarDatePickerTextForegroundDisabled"          ResourceKey="OnSurfaceDisabledBrush" />
			<StaticResource x:Key="CalendarDatePickerTextForegroundSelected"          ResourceKey="OnSurfaceBrush" />

			<!-- Calendar glyph icon -->
			<StaticResource x:Key="CalendarDatePickerCalendarGlyphForeground"         ResourceKey="OnSurfaceBrush" />
			<StaticResource x:Key="CalendarDatePickerCalendarGlyphForegroundDisabled"  ResourceKey="OnSurfaceDisabledBrush" />

			<!-- Header -->
			<StaticResource x:Key="CalendarDatePickerHeaderForeground"                ResourceKey="OnSurfaceBrush" />
			<StaticResource x:Key="CalendarDatePickerHeaderForegroundDisabled"         ResourceKey="OnSurfaceDisabledBrush" />

			<!-- Background -->
			<StaticResource x:Key="CalendarDatePickerBackground"                      ResourceKey="SurfaceBrush" />
			<StaticResource x:Key="CalendarDatePickerBackgroundPointerOver"            ResourceKey="SurfaceBrush" />
			<StaticResource x:Key="CalendarDatePickerBackgroundPressed"                ResourceKey="SurfaceBrush" />
			<StaticResource x:Key="CalendarDatePickerBackgroundDisabled"               ResourceKey="OnSurfaceDisabledBrush" />
			<StaticResource x:Key="CalendarDatePickerBackgroundFocused"                ResourceKey="SurfaceBrush" />

			<!-- Border -->
			<StaticResource x:Key="CalendarDatePickerBorderBrush"                     ResourceKey="OutlineBrush" />
			<StaticResource x:Key="CalendarDatePickerBorderBrushPointerOver"           ResourceKey="OutlineBrush" />
			<StaticResource x:Key="CalendarDatePickerBorderBrushPressed"               ResourceKey="OutlineBrush" />
			<StaticResource x:Key="CalendarDatePickerBorderBrushDisabled"              ResourceKey="OutlineDisabledBrush" />
			<StaticResource x:Key="CalendarDatePickerBorderBrushFocused"               ResourceKey="PrimaryMediumBrush" />

			<!-- ── Backwards-compat aliases (SimpleCalendarDatePicker* → CalendarDatePicker*) ── -->

			<!-- Dimensions -->
			<StaticResource x:Key="SimpleCalendarDatePickerCornerRadius" ResourceKey="CalendarDatePickerCornerRadius" />
			<StaticResource x:Key="SimpleCalendarDatePickerFlyoutPresenterCornerRadius" ResourceKey="CalendarDatePickerFlyoutPresenterCornerRadius" />
			<StaticResource x:Key="SimpleCalendarDatePickerBorderThemeThickness" ResourceKey="CalendarDatePickerBorderThemeThickness" />
			<StaticResource x:Key="SimpleCalendarDatePickerFlyoutPresenterPadding" ResourceKey="CalendarDatePickerFlyoutPresenterPadding" />
			<StaticResource x:Key="SimpleCalendarDatePickerHeight" ResourceKey="CalendarDatePickerHeight" />
			<StaticResource x:Key="SimpleCalendarDatePickerMinHeight" ResourceKey="CalendarDatePickerMinHeight" />

			<!-- Foreground -->
			<StaticResource x:Key="SimpleCalendarDatePickerForeground" ResourceKey="CalendarDatePickerForeground" />
			<StaticResource x:Key="SimpleCalendarDatePickerForegroundDisabled" ResourceKey="CalendarDatePickerForegroundDisabled" />

			<!-- Placeholder text -->
			<StaticResource x:Key="SimpleCalendarDatePickerTextForeground" ResourceKey="CalendarDatePickerTextForeground" />
			<StaticResource x:Key="SimpleCalendarDatePickerTextForegroundDisabled" ResourceKey="CalendarDatePickerTextForegroundDisabled" />
			<StaticResource x:Key="SimpleCalendarDatePickerTextForegroundSelected" ResourceKey="CalendarDatePickerTextForegroundSelected" />

			<!-- Calendar glyph icon -->
			<StaticResource x:Key="SimpleCalendarDatePickerCalendarGlyphForeground" ResourceKey="CalendarDatePickerCalendarGlyphForeground" />
			<StaticResource x:Key="SimpleCalendarDatePickerCalendarGlyphForegroundDisabled" ResourceKey="CalendarDatePickerCalendarGlyphForegroundDisabled" />

			<!-- Header -->
			<StaticResource x:Key="SimpleCalendarDatePickerHeaderForeground" ResourceKey="CalendarDatePickerHeaderForeground" />
			<StaticResource x:Key="SimpleCalendarDatePickerHeaderForegroundDisabled" ResourceKey="CalendarDatePickerHeaderForegroundDisabled" />

			<!-- Background -->
			<StaticResource x:Key="SimpleCalendarDatePickerBackground" ResourceKey="CalendarDatePickerBackground" />
			<StaticResource x:Key="SimpleCalendarDatePickerBackgroundPointerOver" ResourceKey="CalendarDatePickerBackgroundPointerOver" />
			<StaticResource x:Key="SimpleCalendarDatePickerBackgroundPressed" ResourceKey="CalendarDatePickerBackgroundPressed" />
			<StaticResource x:Key="SimpleCalendarDatePickerBackgroundDisabled" ResourceKey="CalendarDatePickerBackgroundDisabled" />
			<StaticResource x:Key="SimpleCalendarDatePickerBackgroundFocused" ResourceKey="CalendarDatePickerBackgroundFocused" />

			<!-- Border -->
			<StaticResource x:Key="SimpleCalendarDatePickerBorderBrush" ResourceKey="CalendarDatePickerBorderBrush" />
			<StaticResource x:Key="SimpleCalendarDatePickerBorderBrushPointerOver" ResourceKey="CalendarDatePickerBorderBrushPointerOver" />
			<StaticResource x:Key="SimpleCalendarDatePickerBorderBrushPressed" ResourceKey="CalendarDatePickerBorderBrushPressed" />
			<StaticResource x:Key="SimpleCalendarDatePickerBorderBrushDisabled" ResourceKey="CalendarDatePickerBorderBrushDisabled" />
			<StaticResource x:Key="SimpleCalendarDatePickerBorderBrushFocused" ResourceKey="CalendarDatePickerBorderBrushFocused" />

		</ResourceDictionary>

		<!-- ─── Dark Theme (Default) ─── -->
		<ResourceDictionary x:Key="Default">

			<!-- ── CalendarDatePicker — semantic keys (source of truth) ── -->

			<!-- Dimensions -->
			<!-- sds-size-radius-200 -->
			<StaticResource x:Key="CalendarDatePickerCornerRadius" ResourceKey="SimpleRadius200CornerRadius" />
			<!-- sds-size-radius-400 -->
			<StaticResource x:Key="CalendarDatePickerFlyoutPresenterCornerRadius" ResourceKey="SimpleRadius400CornerRadius" />
			<!-- sds-size-stroke-border -->
			<StaticResource x:Key="CalendarDatePickerBorderThemeThickness" ResourceKey="SimpleStrokeBorderThickness" />
			<!-- sds-size-space-0 -->
			<StaticResource x:Key="CalendarDatePickerFlyoutPresenterPadding" ResourceKey="SimpleSpace0Thickness" />
			<!-- sds-size-space-400,10,sds-size-space-400,10 -->
			<Thickness x:Key="CalendarDatePickerContentMargin">16,10,16,10</Thickness>
			<!-- sds: no exact token (44) -->
			<x:Double x:Key="CalendarDatePickerMinHeight">44</x:Double>
			<!-- sds: 0,0,0,sds-size-space-200 -->
			<Thickness x:Key="CalendarDatePickerHeaderMargin">0,0,0,8</Thickness>
			<!-- sds-size-space-300,0,0,0 -->
			<Thickness x:Key="CalendarDatePickerCalendarGlyphMargin">12,0,0,0</Thickness>

			<!-- Foreground (selected date text) -->
			<StaticResource x:Key="CalendarDatePickerForeground"                    ResourceKey="OnSurfaceBrush" />
			<StaticResource x:Key="CalendarDatePickerForegroundDisabled"             ResourceKey="OnSurfaceDisabledBrush" />

			<!-- Placeholder text -->
			<StaticResource x:Key="CalendarDatePickerTextForeground"                 ResourceKey="OnSurfaceLowBrush" />
			<StaticResource x:Key="CalendarDatePickerTextForegroundDisabled"          ResourceKey="OnSurfaceDisabledBrush" />
			<StaticResource x:Key="CalendarDatePickerTextForegroundSelected"          ResourceKey="OnSurfaceBrush" />

			<!-- Calendar glyph icon -->
			<StaticResource x:Key="CalendarDatePickerCalendarGlyphForeground"         ResourceKey="OnSurfaceBrush" />
			<StaticResource x:Key="CalendarDatePickerCalendarGlyphForegroundDisabled"  ResourceKey="OnSurfaceDisabledBrush" />

			<!-- Header -->
			<StaticResource x:Key="CalendarDatePickerHeaderForeground"                ResourceKey="OnSurfaceBrush" />
			<StaticResource x:Key="CalendarDatePickerHeaderForegroundDisabled"         ResourceKey="OnSurfaceDisabledBrush" />

			<!-- Background -->
			<StaticResource x:Key="CalendarDatePickerBackground"                      ResourceKey="SurfaceBrush" />
			<StaticResource x:Key="CalendarDatePickerBackgroundPointerOver"            ResourceKey="SurfaceBrush" />
			<StaticResource x:Key="CalendarDatePickerBackgroundPressed"                ResourceKey="SurfaceBrush" />
			<StaticResource x:Key="CalendarDatePickerBackgroundDisabled"               ResourceKey="OnSurfaceDisabledBrush" />
			<StaticResource x:Key="CalendarDatePickerBackgroundFocused"                ResourceKey="SurfaceBrush" />

			<!-- Border -->
			<StaticResource x:Key="CalendarDatePickerBorderBrush"                     ResourceKey="OutlineBrush" />
			<StaticResource x:Key="CalendarDatePickerBorderBrushPointerOver"           ResourceKey="OutlineBrush" />
			<StaticResource x:Key="CalendarDatePickerBorderBrushPressed"               ResourceKey="OutlineBrush" />
			<StaticResource x:Key="CalendarDatePickerBorderBrushDisabled"              ResourceKey="OutlineDisabledBrush" />
			<StaticResource x:Key="CalendarDatePickerBorderBrushFocused"               ResourceKey="PrimaryMediumBrush" />

			<!-- ── Backwards-compat aliases (SimpleCalendarDatePicker* → CalendarDatePicker*) ── -->

			<!-- Dimensions -->
			<StaticResource x:Key="SimpleCalendarDatePickerCornerRadius" ResourceKey="CalendarDatePickerCornerRadius" />
			<StaticResource x:Key="SimpleCalendarDatePickerFlyoutPresenterCornerRadius" ResourceKey="CalendarDatePickerFlyoutPresenterCornerRadius" />
			<StaticResource x:Key="SimpleCalendarDatePickerBorderThemeThickness" ResourceKey="CalendarDatePickerBorderThemeThickness" />
			<StaticResource x:Key="SimpleCalendarDatePickerFlyoutPresenterPadding" ResourceKey="CalendarDatePickerFlyoutPresenterPadding" />
			<StaticResource x:Key="SimpleCalendarDatePickerMinHeight" ResourceKey="CalendarDatePickerMinHeight" />

			<!-- Foreground -->
			<StaticResource x:Key="SimpleCalendarDatePickerForeground" ResourceKey="CalendarDatePickerForeground" />
			<StaticResource x:Key="SimpleCalendarDatePickerForegroundDisabled" ResourceKey="CalendarDatePickerForegroundDisabled" />

			<!-- Placeholder text -->
			<StaticResource x:Key="SimpleCalendarDatePickerTextForeground" ResourceKey="CalendarDatePickerTextForeground" />
			<StaticResource x:Key="SimpleCalendarDatePickerTextForegroundDisabled" ResourceKey="CalendarDatePickerTextForegroundDisabled" />
			<StaticResource x:Key="SimpleCalendarDatePickerTextForegroundSelected" ResourceKey="CalendarDatePickerTextForegroundSelected" />

			<!-- Calendar glyph icon -->
			<StaticResource x:Key="SimpleCalendarDatePickerCalendarGlyphForeground" ResourceKey="CalendarDatePickerCalendarGlyphForeground" />
			<StaticResource x:Key="SimpleCalendarDatePickerCalendarGlyphForegroundDisabled" ResourceKey="CalendarDatePickerCalendarGlyphForegroundDisabled" />

			<!-- Header -->
			<StaticResource x:Key="SimpleCalendarDatePickerHeaderForeground" ResourceKey="CalendarDatePickerHeaderForeground" />
			<StaticResource x:Key="SimpleCalendarDatePickerHeaderForegroundDisabled" ResourceKey="CalendarDatePickerHeaderForegroundDisabled" />

			<!-- Background -->
			<StaticResource x:Key="SimpleCalendarDatePickerBackground" ResourceKey="CalendarDatePickerBackground" />
			<StaticResource x:Key="SimpleCalendarDatePickerBackgroundPointerOver" ResourceKey="CalendarDatePickerBackgroundPointerOver" />
			<StaticResource x:Key="SimpleCalendarDatePickerBackgroundPressed" ResourceKey="CalendarDatePickerBackgroundPressed" />
			<StaticResource x:Key="SimpleCalendarDatePickerBackgroundDisabled" ResourceKey="CalendarDatePickerBackgroundDisabled" />
			<StaticResource x:Key="SimpleCalendarDatePickerBackgroundFocused" ResourceKey="CalendarDatePickerBackgroundFocused" />

			<!-- Border -->
			<StaticResource x:Key="SimpleCalendarDatePickerBorderBrush" ResourceKey="CalendarDatePickerBorderBrush" />
			<StaticResource x:Key="SimpleCalendarDatePickerBorderBrushPointerOver" ResourceKey="CalendarDatePickerBorderBrushPointerOver" />
			<StaticResource x:Key="SimpleCalendarDatePickerBorderBrushPressed" ResourceKey="CalendarDatePickerBorderBrushPressed" />
			<StaticResource x:Key="SimpleCalendarDatePickerBorderBrushDisabled" ResourceKey="CalendarDatePickerBorderBrushDisabled" />
			<StaticResource x:Key="SimpleCalendarDatePickerBorderBrushFocused" ResourceKey="CalendarDatePickerBorderBrushFocused" />

		</ResourceDictionary>

	</ResourceDictionary.ThemeDictionaries>

	<!-- ═══════════════════════════════════════════════════════════════════════ -->
	<!-- SimpleCalendarDatePickerStyle                                          -->
	<!-- Maps from SDS DatePicker (field + calendar popover)                    -->
	<!-- ═══════════════════════════════════════════════════════════════════════ -->
	<Style x:Key="SimpleCalendarDatePickerStyle"
		   TargetType="CalendarDatePicker">
		<Setter Property="Foreground" Value="{ThemeResource SimpleCalendarDatePickerForeground}" />
		<Setter Property="Background" Value="{ThemeResource SimpleCalendarDatePickerBackground}" />
		<Setter Property="BorderBrush" Value="{ThemeResource SimpleCalendarDatePickerBorderBrush}" />
		<Setter Property="BorderThickness" Value="{ThemeResource SimpleCalendarDatePickerBorderThemeThickness}" />
		<Setter Property="CalendarViewStyle" Value="{StaticResource SimpleCalendarViewStyle}" />
		<Setter Property="HorizontalAlignment" Value="Left" />
		<Setter Property="VerticalAlignment" Value="Center" />
		<Setter Property="MinHeight" Value="{ThemeResource SimpleCalendarDatePickerMinHeight}" />
		<Setter Property="FontFamily" Value="{ThemeResource SimpleFontFamily}" />
		<Setter Property="FontSize" Value="{ThemeResource SimpleTypographyScale03}" />
		<Setter Property="UseSystemFocusVisuals" Value="{StaticResource UseSystemFocusVisuals}" />
		<not_win:Setter Property="CornerRadius"
					    Value="{ThemeResource SimpleCalendarDatePickerCornerRadius}" />

		<Setter Property="Template">
			<Setter.Value>
				<ControlTemplate TargetType="CalendarDatePicker">
					<Grid x:Name="Root"
						  MinHeight="{TemplateBinding MinHeight}">

						<VisualStateManager.VisualStateGroups>
							<VisualStateGroup x:Name="CommonStates">
								<VisualState x:Name="Normal" />

								<VisualState x:Name="PointerOver">
									<VisualState.Setters>
										<Setter Target="Background.Background" Value="{ThemeResource SimpleCalendarDatePickerBackgroundPointerOver}" />
										<Setter Target="Background.BorderBrush" Value="{ThemeResource SimpleCalendarDatePickerBorderBrushPointerOver}" />
									</VisualState.Setters>
								</VisualState>

								<VisualState x:Name="Pressed">
									<VisualState.Setters>
										<Setter Target="Background.Background" Value="{ThemeResource SimpleCalendarDatePickerBackgroundPressed}" />
										<Setter Target="Background.BorderBrush" Value="{ThemeResource SimpleCalendarDatePickerBorderBrushPressed}" />
									</VisualState.Setters>
								</VisualState>

								<VisualState x:Name="Disabled">
									<VisualState.Setters>
										<Setter Target="Background.Background" Value="{ThemeResource SimpleCalendarDatePickerBackgroundDisabled}" />
										<Setter Target="Background.BorderBrush" Value="{ThemeResource SimpleCalendarDatePickerBorderBrushDisabled}" />
										<Setter Target="HeaderContentPresenter.Foreground" Value="{ThemeResource SimpleCalendarDatePickerHeaderForegroundDisabled}" />
										<Setter Target="DateText.Foreground" Value="{ThemeResource SimpleCalendarDatePickerTextForegroundDisabled}" />
										<Setter Target="CalendarGlyph.Foreground" Value="{ThemeResource SimpleCalendarDatePickerCalendarGlyphForegroundDisabled}" />
									</VisualState.Setters>
								</VisualState>
							</VisualStateGroup>

							<VisualStateGroup x:Name="FocusStates">
								<VisualState x:Name="Unfocused" />
								<VisualState x:Name="PointerFocused" />
								<VisualState x:Name="Focused">
									<VisualState.Setters>
										<Setter Target="Background.Background" Value="{ThemeResource SimpleCalendarDatePickerBackgroundFocused}" />
										<Setter Target="Background.BorderBrush" Value="{ThemeResource SimpleCalendarDatePickerBorderBrushFocused}" />
									</VisualState.Setters>
								</VisualState>
							</VisualStateGroup>

							<VisualStateGroup x:Name="SelectionStates">
								<VisualState x:Name="Unselected" />
								<VisualState x:Name="Selected">
									<VisualState.Setters>
										<Setter Target="DateText.Foreground" Value="{ThemeResource SimpleCalendarDatePickerTextForegroundSelected}" />
									</VisualState.Setters>
								</VisualState>
							</VisualStateGroup>

							<VisualStateGroup x:Name="HeaderStates">
								<VisualState x:Name="TopHeader" />
								<VisualState x:Name="LeftHeader" />
							</VisualStateGroup>
						</VisualStateManager.VisualStateGroups>

						<FlyoutBase.AttachedFlyout>
							<Flyout Placement="Bottom"
									ShouldConstrainToRootBounds="False">
								<Flyout.FlyoutPresenterStyle>
									<Style TargetType="FlyoutPresenter">
										<Setter Property="Padding" Value="{ThemeResource SimpleCalendarDatePickerFlyoutPresenterPadding}" />
										<Setter Property="BorderThickness" Value="0" />
										<Setter Property="IsDefaultShadowEnabled" Value="True" />
										<Setter Property="CornerRadius" Value="{ThemeResource SimpleCalendarDatePickerFlyoutPresenterCornerRadius}" />
										<Setter Property="Template">
											<Setter.Value>
												<ControlTemplate TargetType="FlyoutPresenter">
													<ContentPresenter Background="{TemplateBinding Background}"
																	  BorderBrush="{TemplateBinding BorderBrush}"
																	  BorderThickness="{TemplateBinding BorderThickness}"
																	  Content="{TemplateBinding Content}"
																	  ContentTemplate="{TemplateBinding ContentTemplate}"
																	  ContentTransitions="{TemplateBinding ContentTransitions}"
																	  Margin="{TemplateBinding Padding}"
																	  HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
																	  VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
																	  CornerRadius="{TemplateBinding CornerRadius}" />
												</ControlTemplate>
											</Setter.Value>
										</Setter>
									</Style>
								</Flyout.FlyoutPresenterStyle>
								<CalendarView x:Name="CalendarView"
											  Style="{TemplateBinding CalendarViewStyle}"
											  MinDate="{TemplateBinding MinDate}"
											  MaxDate="{TemplateBinding MaxDate}"
											  IsTodayHighlighted="{TemplateBinding IsTodayHighlighted}"
											  DisplayMode="{TemplateBinding DisplayMode}"
											  FirstDayOfWeek="{TemplateBinding FirstDayOfWeek}"
											  DayOfWeekFormat="{TemplateBinding DayOfWeekFormat}"
											  IsOutOfScopeEnabled="{TemplateBinding IsOutOfScopeEnabled}"
											  IsGroupLabelVisible="{TemplateBinding IsGroupLabelVisible}"
											  CornerRadius="{ThemeResource SimpleCalendarDatePickerFlyoutPresenterCornerRadius}" />
							</Flyout>
						</FlyoutBase.AttachedFlyout>

						<!-- Background field border -->
						<Border x:Name="Background"
								Background="{ThemeResource SimpleCalendarDatePickerBackground}"
								BorderBrush="{ThemeResource SimpleCalendarDatePickerBorderBrush}"
								BorderThickness="{TemplateBinding BorderThickness}"
								CornerRadius="{ThemeResource SimpleCalendarDatePickerCornerRadius}"
Control.IsTemplateFocusTarget="True" />

						<!-- Content row: header/date text + calendar icon -->
						<Grid Margin="{ThemeResource CalendarDatePickerContentMargin}"
							  VerticalAlignment="Center">
							<Grid.ColumnDefinitions>
								<ColumnDefinition Width="*" />
								<ColumnDefinition Width="Auto" />
							</Grid.ColumnDefinitions>
							<Grid.RowDefinitions>
								<RowDefinition Height="Auto" />
								<RowDefinition Height="Auto" />
							</Grid.RowDefinitions>

							<!-- Header -->
							<ContentPresenter x:Name="HeaderContentPresenter"
											  Grid.ColumnSpan="2"
											  Content="{TemplateBinding Header}"
											  ContentTemplate="{TemplateBinding HeaderTemplate}"
											  Foreground="{ThemeResource SimpleCalendarDatePickerHeaderForeground}"
											  FontSize="{ThemeResource SimpleTypographyScale02}"
											  FontFamily="{ThemeResource SimpleFontFamily}"
											  TextWrapping="Wrap"
											  Margin="{ThemeResource CalendarDatePickerHeaderMargin}"
											  Visibility="Collapsed"
											  AutomationProperties.AccessibilityView="Raw" />

							<!-- Date text / placeholder -->
							<TextBlock x:Name="DateText"
									   Grid.Row="1"
									   Grid.Column="0"
									   Text="{TemplateBinding PlaceholderText}"
									   Foreground="{ThemeResource SimpleCalendarDatePickerTextForeground}"
									   FontSize="{TemplateBinding FontSize}"
									   FontFamily="{TemplateBinding FontFamily}"
									   VerticalAlignment="Center" />

							<!-- Calendar glyph icon -->
							<FontIcon x:Name="CalendarGlyph"
									  Grid.Row="1"
									  Grid.Column="1"
									  Glyph="&#xE787;"
									  FontSize="{ThemeResource SimpleTypographyScale03}"
									  Foreground="{ThemeResource SimpleCalendarDatePickerCalendarGlyphForeground}"
									  VerticalAlignment="Center"
									  Margin="{ThemeResource CalendarDatePickerCalendarGlyphMargin}" />
						</Grid>

						<!-- Hidden elements expected by the control -->
						<Grid Visibility="Collapsed">
							<ContentPresenter x:Name="DescriptionPresenter" />
						</Grid>

					</Grid>
				</ControlTemplate>
			</Setter.Value>
		</Setter>
	</Style>

	<!-- ═══════════════════════════════════════════════════════════════════════ -->
	<!-- Default alias (for implicit style)                                     -->
	<!-- ═══════════════════════════════════════════════════════════════════════ -->
	<Style x:Key="SimpleDefaultCalendarDatePickerStyle"
		   TargetType="CalendarDatePicker"
		   BasedOn="{StaticResource SimpleCalendarDatePickerStyle}" />

</ResourceDictionary>
