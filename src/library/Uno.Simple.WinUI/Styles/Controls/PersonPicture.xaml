<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
					xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

	<!--
		Simple Design System — PersonPicture (Avatar) Styles
		Maps SDS Avatar component tokens to WinUI PersonPicture.

		SDS Avatar: sizes small(24)/medium(32)/large(40),
		shapes circle(radius-full)/square(radius-200=8px),
		initials bg = background-brand-default, text = text-brand-on-brand
	-->

	<!-- ═══════════════════════════════════════════════════════════════════════ -->
	<!-- Lightweight styling ThemeResource aliases                              -->
	<!-- ═══════════════════════════════════════════════════════════════════════ -->
	<ResourceDictionary.ThemeDictionaries>

		<!-- ─── Light Theme ─── -->
		<ResourceDictionary x:Key="Light">
			<!-- Sizing (identical both themes) -->
			<StaticResource x:Key="SimplePersonPictureSmallSize" ResourceKey="SimpleSizeIconSmall" /> <!-- sds-size-icon-small -->
			<StaticResource x:Key="SimplePersonPictureMediumSize" ResourceKey="SimpleSizeIconMedium" /> <!-- sds-size-icon-medium -->
			<StaticResource x:Key="SimplePersonPictureLargeSize" ResourceKey="SimpleSizeIconLarge" /> <!-- sds-size-icon-large -->
			<StaticResource x:Key="SimplePersonPictureSquareSmallRadius" ResourceKey="SimpleSizeRadius100CornerRadius" /> <!-- sds-size-radius-100 -->
			<StaticResource x:Key="SimplePersonPictureSquareMediumRadius" ResourceKey="SimpleSizeRadius200CornerRadius" /> <!-- sds-size-radius-200 -->
			<StaticResource x:Key="SimplePersonPictureSquareLargeRadius" ResourceKey="SimpleSizeRadius200CornerRadius" /> <!-- sds-size-radius-200 -->
			<x:Double x:Key="SimplePersonPictureInitialsSmallFontSize">10</x:Double> <!-- no exact SDS token (10) -->
			<StaticResource x:Key="SimplePersonPictureInitialsMediumFontSize" ResourceKey="SimpleTypographyScale02" /> <!-- sds-typography-scale-02 -->
			<StaticResource x:Key="SimplePersonPictureInitialsLargeFontSize" ResourceKey="SimpleTypographyScale03" /> <!-- sds-typography-scale-03 -->

			<!-- Color tokens -->
			<StaticResource x:Key="SimplePersonPictureBackground" ResourceKey="SimpleBackgroundBrandDefaultBrush" />
			<StaticResource x:Key="SimplePersonPictureForeground" ResourceKey="SimpleTextBrandOnBrandBrush" />
			<StaticResource x:Key="SimplePersonPictureBadgeBackground" ResourceKey="SimpleBackgroundBrandDefaultBrush" />
			<StaticResource x:Key="SimplePersonPictureBadgeForeground" ResourceKey="SimpleTextBrandOnBrandBrush" />
		</ResourceDictionary>

		<!-- ─── Dark Theme (Default) ─── -->
		<ResourceDictionary x:Key="Default">
			<StaticResource x:Key="SimplePersonPictureSmallSize" ResourceKey="SimpleSizeIconSmall" /> <!-- sds-size-icon-small -->
			<StaticResource x:Key="SimplePersonPictureMediumSize" ResourceKey="SimpleSizeIconMedium" /> <!-- sds-size-icon-medium -->
			<StaticResource x:Key="SimplePersonPictureLargeSize" ResourceKey="SimpleSizeIconLarge" /> <!-- sds-size-icon-large -->
			<StaticResource x:Key="SimplePersonPictureSquareSmallRadius" ResourceKey="SimpleSizeRadius100CornerRadius" /> <!-- sds-size-radius-100 -->
			<StaticResource x:Key="SimplePersonPictureSquareMediumRadius" ResourceKey="SimpleSizeRadius200CornerRadius" /> <!-- sds-size-radius-200 -->
			<StaticResource x:Key="SimplePersonPictureSquareLargeRadius" ResourceKey="SimpleSizeRadius200CornerRadius" /> <!-- sds-size-radius-200 -->
			<x:Double x:Key="SimplePersonPictureInitialsSmallFontSize">10</x:Double> <!-- no exact SDS token (10) -->
			<StaticResource x:Key="SimplePersonPictureInitialsMediumFontSize" ResourceKey="SimpleTypographyScale02" /> <!-- sds-typography-scale-02 -->
			<StaticResource x:Key="SimplePersonPictureInitialsLargeFontSize" ResourceKey="SimpleTypographyScale03" /> <!-- sds-typography-scale-03 -->

			<StaticResource x:Key="SimplePersonPictureBackground" ResourceKey="SimpleBackgroundBrandDefaultBrush" />
			<StaticResource x:Key="SimplePersonPictureForeground" ResourceKey="SimpleTextBrandOnBrandBrush" />
			<StaticResource x:Key="SimplePersonPictureBadgeBackground" ResourceKey="SimpleBackgroundBrandDefaultBrush" />
			<StaticResource x:Key="SimplePersonPictureBadgeForeground" ResourceKey="SimpleTextBrandOnBrandBrush" />
		</ResourceDictionary>

	</ResourceDictionary.ThemeDictionaries>

	<!-- ═══════════════════════════════════════════════════════════════════════ -->
	<!-- Circle PersonPicture — Medium (default)                               -->
	<!-- ═══════════════════════════════════════════════════════════════════════ -->
	<Style x:Key="SimplePersonPictureStyle"
		   TargetType="PersonPicture">
		<Setter Property="Width" Value="{ThemeResource SimplePersonPictureMediumSize}" />
		<Setter Property="Height" Value="{ThemeResource SimplePersonPictureMediumSize}" />
		<Setter Property="FontFamily" Value="{ThemeResource SimpleFontFamily}" />
		<Setter Property="FontSize" Value="{ThemeResource SimplePersonPictureInitialsMediumFontSize}" />
		<Setter Property="Foreground" Value="{ThemeResource SimplePersonPictureForeground}" />
		<Setter Property="Background" Value="{ThemeResource SimplePersonPictureBackground}" />
		<Setter Property="Template">
			<Setter.Value>
				<ControlTemplate TargetType="PersonPicture">
					<Grid x:Name="RootGrid">
						<VisualStateManager.VisualStateGroups>
							<VisualStateGroup x:Name="CommonStates">
								<VisualState x:Name="Photo">
									<VisualState.Setters>
										<Setter Target="PersonPictureEllipse.Opacity" Value="0" />
										<Setter Target="InitialsTextBlock.Opacity" Value="0" />
									</VisualState.Setters>
								</VisualState>
								<VisualState x:Name="Initials" />
								<VisualState x:Name="NoPhotoOrInitials">
									<VisualState.Setters>
										<Setter Target="InitialsTextBlock.Opacity" Value="0" />
									</VisualState.Setters>
								</VisualState>
								<VisualState x:Name="Group">
									<VisualState.Setters>
										<Setter Target="InitialsTextBlock.Opacity" Value="0" />
									</VisualState.Setters>
								</VisualState>
							</VisualStateGroup>
							<VisualStateGroup x:Name="BadgeStates">
								<VisualState x:Name="NoBadge" />
								<VisualState x:Name="BadgeWithoutImageSource">
									<VisualState.Setters>
										<Setter Target="BadgeGrid.Visibility" Value="Visible" />
									</VisualState.Setters>
								</VisualState>
								<VisualState x:Name="BadgeWithImageSource">
									<VisualState.Setters>
										<Setter Target="BadgeGrid.Visibility" Value="Visible" />
										<Setter Target="BadgeImage.Visibility" Value="Visible" />
									</VisualState.Setters>
								</VisualState>
							</VisualStateGroup>
						</VisualStateManager.VisualStateGroups>

						<Ellipse x:Name="PersonPictureEllipse"
								 Fill="{TemplateBinding Background}"
								 Width="{TemplateBinding Width}"
								 Height="{TemplateBinding Height}" />

						<Ellipse x:Name="BadgeClipEllipse"
								 Width="{TemplateBinding Width}"
								 Height="{TemplateBinding Height}">
							<Ellipse.Fill>
								<ImageBrush x:Name="PersonPicture"
											ImageSource="{TemplateBinding ProfilePicture}"
											Stretch="UniformToFill" />
							</Ellipse.Fill>
						</Ellipse>

						<TextBlock x:Name="InitialsTextBlock"
								   AutomationProperties.AccessibilityView="Raw"
								   FontFamily="{TemplateBinding FontFamily}"
								   FontSize="{TemplateBinding FontSize}"
								   FontWeight="SemiBold"
								   Foreground="{TemplateBinding Foreground}"
								   HorizontalAlignment="Center"
								   VerticalAlignment="Center"
								   TextAlignment="Center"
								   IsTextScaleFactorEnabled="False"
								   Text="{TemplateBinding Initials}" />

						<Grid x:Name="BadgeGrid"
							  Visibility="Collapsed"
							  HorizontalAlignment="Right"
							  VerticalAlignment="Bottom">
							<Ellipse x:Name="BadgeBackground"
									 Fill="{ThemeResource SimplePersonPictureBadgeBackground}"
									 Width="{StaticResource SimpleSizeSpace400}"
									 Height="{StaticResource SimpleSizeSpace400}" />
							<Image x:Name="BadgeImage"
								   Visibility="Collapsed"
								   Source="{TemplateBinding BadgeImageSource}"
								   Width="{StaticResource SimpleSizeSpace400}"
								   Height="{StaticResource SimpleSizeSpace400}"
								   Stretch="UniformToFill" />
							<TextBlock x:Name="BadgeNumberTextBlock"
									   AutomationProperties.AccessibilityView="Raw"
									   FontFamily="{ThemeResource SimpleFontFamily}"
									   FontSize="10"
									   Foreground="{ThemeResource SimplePersonPictureBadgeForeground}"
									   HorizontalAlignment="Center"
									   VerticalAlignment="Center"
									   TextAlignment="Center"
									   IsTextScaleFactorEnabled="False"
									   Text="{TemplateBinding BadgeNumber}" />
							<TextBlock x:Name="BadgeGlyphTextBlock"
									   AutomationProperties.AccessibilityView="Raw"
									   FontFamily="{ThemeResource SimpleFontFamily}"
									   FontSize="10"
									   Foreground="{ThemeResource SimplePersonPictureBadgeForeground}"
									   HorizontalAlignment="Center"
									   VerticalAlignment="Center"
									   TextAlignment="Center"
									   IsTextScaleFactorEnabled="False"
									   Text="{TemplateBinding BadgeGlyph}" />
							<TextBlock x:Name="BadgeTextTextBlock"
									   AutomationProperties.AccessibilityView="Raw"
									   FontFamily="{ThemeResource SimpleFontFamily}"
									   FontSize="10"
									   Foreground="{ThemeResource SimplePersonPictureBadgeForeground}"
									   HorizontalAlignment="Center"
									   VerticalAlignment="Center"
									   TextAlignment="Center"
									   IsTextScaleFactorEnabled="False"
									   Text="{TemplateBinding BadgeText}" />
						</Grid>
					</Grid>
				</ControlTemplate>
			</Setter.Value>
		</Setter>
	</Style>

	<!-- Circle — Small -->
	<Style x:Key="SimplePersonPictureSmallStyle"
		   TargetType="PersonPicture"
		   BasedOn="{StaticResource SimplePersonPictureStyle}">
		<Setter Property="Width" Value="{ThemeResource SimplePersonPictureSmallSize}" />
		<Setter Property="Height" Value="{ThemeResource SimplePersonPictureSmallSize}" />
		<Setter Property="FontSize" Value="{ThemeResource SimplePersonPictureInitialsSmallFontSize}" />
	</Style>

	<!-- Circle — Large -->
	<Style x:Key="SimplePersonPictureLargeStyle"
		   TargetType="PersonPicture"
		   BasedOn="{StaticResource SimplePersonPictureStyle}">
		<Setter Property="Width" Value="{ThemeResource SimplePersonPictureLargeSize}" />
		<Setter Property="Height" Value="{ThemeResource SimplePersonPictureLargeSize}" />
		<Setter Property="FontSize" Value="{ThemeResource SimplePersonPictureInitialsLargeFontSize}" />
	</Style>

	<!-- ═══════════════════════════════════════════════════════════════════════ -->
	<!-- Square PersonPicture — Medium (default)                               -->
	<!-- ═══════════════════════════════════════════════════════════════════════ -->
	<Style x:Key="SimplePersonPictureSquareStyle"
		   TargetType="PersonPicture">
		<Setter Property="Width" Value="{ThemeResource SimplePersonPictureMediumSize}" />
		<Setter Property="Height" Value="{ThemeResource SimplePersonPictureMediumSize}" />
		<Setter Property="FontFamily" Value="{ThemeResource SimpleFontFamily}" />
		<Setter Property="FontSize" Value="{ThemeResource SimplePersonPictureInitialsMediumFontSize}" />
		<Setter Property="Foreground" Value="{ThemeResource SimplePersonPictureForeground}" />
		<Setter Property="Background" Value="{ThemeResource SimplePersonPictureBackground}" />
		<Setter Property="Template">
			<Setter.Value>
				<ControlTemplate TargetType="PersonPicture">
					<Grid x:Name="RootGrid">
						<VisualStateManager.VisualStateGroups>
							<VisualStateGroup x:Name="CommonStates">
								<VisualState x:Name="Photo">
									<VisualState.Setters>
										<Setter Target="PersonPictureBorder.Opacity" Value="0" />
										<Setter Target="InitialsTextBlock.Opacity" Value="0" />
									</VisualState.Setters>
								</VisualState>
								<VisualState x:Name="Initials" />
								<VisualState x:Name="NoPhotoOrInitials">
									<VisualState.Setters>
										<Setter Target="InitialsTextBlock.Opacity" Value="0" />
									</VisualState.Setters>
								</VisualState>
								<VisualState x:Name="Group">
									<VisualState.Setters>
										<Setter Target="InitialsTextBlock.Opacity" Value="0" />
									</VisualState.Setters>
								</VisualState>
							</VisualStateGroup>
							<VisualStateGroup x:Name="BadgeStates">
								<VisualState x:Name="NoBadge" />
								<VisualState x:Name="BadgeWithoutImageSource">
									<VisualState.Setters>
										<Setter Target="BadgeGrid.Visibility" Value="Visible" />
									</VisualState.Setters>
								</VisualState>
								<VisualState x:Name="BadgeWithImageSource">
									<VisualState.Setters>
										<Setter Target="BadgeGrid.Visibility" Value="Visible" />
										<Setter Target="BadgeImage.Visibility" Value="Visible" />
									</VisualState.Setters>
								</VisualState>
							</VisualStateGroup>
						</VisualStateManager.VisualStateGroups>

						<Border x:Name="PersonPictureBorder"
								Background="{TemplateBinding Background}"
								Width="{TemplateBinding Width}"
								Height="{TemplateBinding Height}"
								CornerRadius="{ThemeResource SimplePersonPictureSquareMediumRadius}" />

						<Border x:Name="BadgeClipBorder"
								Width="{TemplateBinding Width}"
								Height="{TemplateBinding Height}"
								CornerRadius="{ThemeResource SimplePersonPictureSquareMediumRadius}">
							<Border.Background>
								<ImageBrush x:Name="PersonPicture"
											ImageSource="{TemplateBinding ProfilePicture}"
											Stretch="UniformToFill" />
							</Border.Background>
						</Border>

						<TextBlock x:Name="InitialsTextBlock"
								   AutomationProperties.AccessibilityView="Raw"
								   FontFamily="{TemplateBinding FontFamily}"
								   FontSize="{TemplateBinding FontSize}"
								   FontWeight="SemiBold"
								   Foreground="{TemplateBinding Foreground}"
								   HorizontalAlignment="Center"
								   VerticalAlignment="Center"
								   TextAlignment="Center"
								   IsTextScaleFactorEnabled="False"
								   Text="{TemplateBinding Initials}" />

						<Grid x:Name="BadgeGrid"
							  Visibility="Collapsed"
							  HorizontalAlignment="Right"
							  VerticalAlignment="Bottom">
							<Ellipse x:Name="BadgeBackground"
									 Fill="{ThemeResource SimplePersonPictureBadgeBackground}"
									 Width="{StaticResource SimpleSizeSpace400}"
									 Height="{StaticResource SimpleSizeSpace400}" />
							<Image x:Name="BadgeImage"
								   Visibility="Collapsed"
								   Source="{TemplateBinding BadgeImageSource}"
								   Width="{StaticResource SimpleSizeSpace400}"
								   Height="{StaticResource SimpleSizeSpace400}"
								   Stretch="UniformToFill" />
							<TextBlock x:Name="BadgeNumberTextBlock"
									   AutomationProperties.AccessibilityView="Raw"
									   FontFamily="{ThemeResource SimpleFontFamily}"
									   FontSize="10"
									   Foreground="{ThemeResource SimplePersonPictureBadgeForeground}"
									   HorizontalAlignment="Center"
									   VerticalAlignment="Center"
									   TextAlignment="Center"
									   IsTextScaleFactorEnabled="False"
									   Text="{TemplateBinding BadgeNumber}" />
							<TextBlock x:Name="BadgeGlyphTextBlock"
									   AutomationProperties.AccessibilityView="Raw"
									   FontFamily="{ThemeResource SimpleFontFamily}"
									   FontSize="10"
									   Foreground="{ThemeResource SimplePersonPictureBadgeForeground}"
									   HorizontalAlignment="Center"
									   VerticalAlignment="Center"
									   TextAlignment="Center"
									   IsTextScaleFactorEnabled="False"
									   Text="{TemplateBinding BadgeGlyph}" />
							<TextBlock x:Name="BadgeTextTextBlock"
									   AutomationProperties.AccessibilityView="Raw"
									   FontFamily="{ThemeResource SimpleFontFamily}"
									   FontSize="10"
									   Foreground="{ThemeResource SimplePersonPictureBadgeForeground}"
									   HorizontalAlignment="Center"
									   VerticalAlignment="Center"
									   TextAlignment="Center"
									   IsTextScaleFactorEnabled="False"
									   Text="{TemplateBinding BadgeText}" />
						</Grid>
					</Grid>
				</ControlTemplate>
			</Setter.Value>
		</Setter>
	</Style>

	<!-- Square — Small -->
	<Style x:Key="SimplePersonPictureSquareSmallStyle"
		   TargetType="PersonPicture"
		   BasedOn="{StaticResource SimplePersonPictureSquareStyle}">
		<Setter Property="Width" Value="{ThemeResource SimplePersonPictureSmallSize}" />
		<Setter Property="Height" Value="{ThemeResource SimplePersonPictureSmallSize}" />
		<Setter Property="FontSize" Value="{ThemeResource SimplePersonPictureInitialsSmallFontSize}" />
		<Setter Property="Template">
			<Setter.Value>
				<ControlTemplate TargetType="PersonPicture">
					<Grid x:Name="RootGrid">
						<VisualStateManager.VisualStateGroups>
							<VisualStateGroup x:Name="CommonStates">
								<VisualState x:Name="Photo">
									<VisualState.Setters>
										<Setter Target="PersonPictureBorder.Opacity" Value="0" />
										<Setter Target="InitialsTextBlock.Opacity" Value="0" />
									</VisualState.Setters>
								</VisualState>
								<VisualState x:Name="Initials">
									<VisualState.Setters>
										<Setter Target="PersonPictureBorder.Opacity" Value="1" />
										<Setter Target="InitialsTextBlock.Opacity" Value="1" />
									</VisualState.Setters>
								</VisualState>
								<VisualState x:Name="NoPhotoOrInitials">
									<VisualState.Setters>
										<Setter Target="PersonPictureBorder.Opacity" Value="1" />
										<Setter Target="InitialsTextBlock.Opacity" Value="0" />
									</VisualState.Setters>
								</VisualState>
								<VisualState x:Name="Group">
									<VisualState.Setters>
										<Setter Target="PersonPictureBorder.Opacity" Value="1" />
										<Setter Target="InitialsTextBlock.Opacity" Value="0" />
									</VisualState.Setters>
								</VisualState>
							</VisualStateGroup>
							<VisualStateGroup x:Name="BadgeStates">
								<VisualState x:Name="NoBadge" />
								<VisualState x:Name="BadgeWithoutImageSource">
									<VisualState.Setters>
										<Setter Target="BadgeGrid.Visibility" Value="Visible" />
									</VisualState.Setters>
								</VisualState>
								<VisualState x:Name="BadgeWithImageSource">
									<VisualState.Setters>
										<Setter Target="BadgeGrid.Visibility" Value="Visible" />
										<Setter Target="BadgeImage.Visibility" Value="Visible" />
									</VisualState.Setters>
								</VisualState>
							</VisualStateGroup>
						</VisualStateManager.VisualStateGroups>

						<!-- Background Border (Square Small - 4px radius) -->
						<Border x:Name="PersonPictureBorder"
								Background="{TemplateBinding Background}"
								Width="{TemplateBinding Width}"
								Height="{TemplateBinding Height}"
								CornerRadius="{ThemeResource SimplePersonPictureSquareSmallRadius}" />

						<!-- Profile Photo (Square Small) -->
						<Border x:Name="BadgeClipBorder"
								Width="{TemplateBinding Width}"
								Height="{TemplateBinding Height}"
								CornerRadius="{ThemeResource SimplePersonPictureSquareSmallRadius}">
							<Border.Background>
								<ImageBrush x:Name="PersonPicture"
											ImageSource="{TemplateBinding ProfilePicture}"
											Stretch="UniformToFill" />
							</Border.Background>
						</Border>

						<!-- Initials -->
						<TextBlock x:Name="InitialsTextBlock"
								   AutomationProperties.AccessibilityView="Raw"
								   FontFamily="{TemplateBinding FontFamily}"
								   FontSize="{TemplateBinding FontSize}"
								   FontWeight="Normal"
								   Foreground="{TemplateBinding Foreground}"
								   HorizontalAlignment="Center"
								   VerticalAlignment="Center"
								   TextAlignment="Center"
								   IsTextScaleFactorEnabled="False"
								   Text="{TemplateBinding Initials}" />

						<!-- Badge -->
						<Grid x:Name="BadgeGrid"
							  Visibility="Collapsed"
							  HorizontalAlignment="Right"
							  VerticalAlignment="Bottom">
							<Ellipse x:Name="BadgeBackground"
									 Fill="{ThemeResource PrimaryBrush}"
									 Width="{StaticResource SimpleSizeSpace400}"
									 Height="{StaticResource SimpleSizeSpace400}" />
							<Image x:Name="BadgeImage"
								   Visibility="Collapsed"
								   Source="{TemplateBinding BadgeImageSource}"
								   Width="{StaticResource SimpleSizeSpace400}"
								   Height="{StaticResource SimpleSizeSpace400}"
								   Stretch="UniformToFill" />
							<TextBlock x:Name="BadgeNumberTextBlock"
									   AutomationProperties.AccessibilityView="Raw"
									   FontFamily="{ThemeResource SimpleFontFamily}"
									   FontSize="10"
									   Foreground="{ThemeResource OnPrimaryBrush}"
									   HorizontalAlignment="Center"
									   VerticalAlignment="Center"
									   TextAlignment="Center"
									   IsTextScaleFactorEnabled="False"
									   Text="{TemplateBinding BadgeNumber}" />
							<TextBlock x:Name="BadgeGlyphTextBlock"
									   AutomationProperties.AccessibilityView="Raw"
									   FontFamily="{ThemeResource SimpleFontFamily}"
									   FontSize="10"
									   Foreground="{ThemeResource OnPrimaryBrush}"
									   HorizontalAlignment="Center"
									   VerticalAlignment="Center"
									   TextAlignment="Center"
									   IsTextScaleFactorEnabled="False"
									   Text="{TemplateBinding BadgeGlyph}" />
							<TextBlock x:Name="BadgeTextTextBlock"
									   AutomationProperties.AccessibilityView="Raw"
									   FontFamily="{ThemeResource SimpleFontFamily}"
									   FontSize="10"
									   Foreground="{ThemeResource OnPrimaryBrush}"
									   HorizontalAlignment="Center"
									   VerticalAlignment="Center"
									   TextAlignment="Center"
									   IsTextScaleFactorEnabled="False"
									   Text="{TemplateBinding BadgeText}" />
						</Grid>
					</Grid>
				</ControlTemplate>
			</Setter.Value>
		</Setter>
	</Style>

	<!-- Square — Large -->
	<Style x:Key="SimplePersonPictureSquareLargeStyle"
		   TargetType="PersonPicture"
		   BasedOn="{StaticResource SimplePersonPictureSquareStyle}">
		<Setter Property="Width" Value="{ThemeResource SimplePersonPictureLargeSize}" />
		<Setter Property="Height" Value="{ThemeResource SimplePersonPictureLargeSize}" />
		<Setter Property="FontSize" Value="{ThemeResource SimplePersonPictureInitialsLargeFontSize}" />
	</Style>

</ResourceDictionary>
