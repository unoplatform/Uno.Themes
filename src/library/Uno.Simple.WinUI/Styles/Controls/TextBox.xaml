<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
					xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

	<!--
		Simple Design System — TextBox Styles
		Maps SDS Input component tokens to WinUI TextBox.

		SDS Input: outlined box with 8px radius, 1px border
		States: Normal, Hover, Focus (brand-secondary border), Disabled, Error (danger border)
		Padding: horizontal=16, vertical=10 (space-300 minus stroke-border*2 = 12-2)
	-->

	<!-- ═══════════════════════════════════════════════════════════════════════ -->
	<!-- Lightweight styling ThemeResource aliases                              -->
	<!-- ═══════════════════════════════════════════════════════════════════════ -->
	<ResourceDictionary.ThemeDictionaries>

		<!-- ─── Light Theme ─── -->
		<ResourceDictionary x:Key="Light">
			<!-- Sizing -->
			<CornerRadius x:Key="SimpleTextBoxCornerRadius">8</CornerRadius>
			<Thickness x:Key="SimpleTextBoxBorderThickness">1</Thickness>
			<Thickness x:Key="SimpleTextBoxFocusedBorderThickness">2</Thickness>
			<Thickness x:Key="SimpleTextBoxPadding">16,10,16,10</Thickness>
			<x:Double x:Key="SimpleTextBoxMinHeight">40</x:Double>
			<x:Double x:Key="SimpleTextBoxSmallMinHeight">32</x:Double>

			<!-- Normal state -->
			<StaticResource x:Key="SimpleTextBoxForeground" ResourceKey="SimpleTextDefaultDefaultBrush" />
			<StaticResource x:Key="SimpleTextBoxBackground" ResourceKey="SimpleBackgroundDefaultDefaultBrush" />
			<StaticResource x:Key="SimpleTextBoxBorderBrush" ResourceKey="SimpleBorderDefaultDefaultBrush" />
			<StaticResource x:Key="SimpleTextBoxPlaceholderForeground" ResourceKey="SimpleTextDefaultTertiaryBrush" />

			<!-- PointerOver state -->
			<StaticResource x:Key="SimpleTextBoxForegroundPointerOver" ResourceKey="SimpleTextDefaultDefaultBrush" />
			<StaticResource x:Key="SimpleTextBoxBackgroundPointerOver" ResourceKey="SimpleBackgroundDefaultDefaultBrush" />
			<StaticResource x:Key="SimpleTextBoxBorderBrushPointerOver" ResourceKey="SimpleBorderDefaultDefaultBrush" />

			<!-- Focused state -->
			<StaticResource x:Key="SimpleTextBoxForegroundFocused" ResourceKey="SimpleTextDefaultDefaultBrush" />
			<StaticResource x:Key="SimpleTextBoxBackgroundFocused" ResourceKey="SimpleBackgroundDefaultDefaultBrush" />
			<StaticResource x:Key="SimpleTextBoxBorderBrushFocused" ResourceKey="SimpleBorderBrandSecondaryBrush" />

			<!-- Disabled state -->
			<StaticResource x:Key="SimpleTextBoxForegroundDisabled" ResourceKey="SimpleTextDisabledDefaultBrush" />
			<StaticResource x:Key="SimpleTextBoxBackgroundDisabled" ResourceKey="SimpleBackgroundDisabledDefaultBrush" />
			<StaticResource x:Key="SimpleTextBoxBorderBrushDisabled" ResourceKey="SimpleBorderDisabledDefaultBrush" />
			<StaticResource x:Key="SimpleTextBoxPlaceholderForegroundDisabled" ResourceKey="SimpleTextDisabledDefaultBrush" />

			<!-- Error state overrides -->
			<StaticResource x:Key="SimpleTextBoxErrorBorderBrush" ResourceKey="SimpleBorderDangerDefaultBrush" />
			<StaticResource x:Key="SimpleTextBoxErrorBorderBrushPointerOver" ResourceKey="SimpleBorderDangerDefaultBrush" />
			<StaticResource x:Key="SimpleTextBoxErrorBorderBrushFocused" ResourceKey="SimpleBorderDangerDefaultBrush" />

			<!-- Header / label -->
			<StaticResource x:Key="SimpleTextBoxHeaderForeground" ResourceKey="SimpleTextDefaultDefaultBrush" />
			<StaticResource x:Key="SimpleTextBoxHeaderForegroundDisabled" ResourceKey="SimpleTextDisabledDefaultBrush" />
		</ResourceDictionary>

		<!-- ─── Dark Theme (Default) ─── -->
		<ResourceDictionary x:Key="Default">
			<CornerRadius x:Key="SimpleTextBoxCornerRadius">8</CornerRadius>
			<Thickness x:Key="SimpleTextBoxBorderThickness">1</Thickness>
			<Thickness x:Key="SimpleTextBoxFocusedBorderThickness">2</Thickness>
			<Thickness x:Key="SimpleTextBoxPadding">16,10,16,10</Thickness>
			<x:Double x:Key="SimpleTextBoxMinHeight">40</x:Double>
			<x:Double x:Key="SimpleTextBoxSmallMinHeight">32</x:Double>

			<StaticResource x:Key="SimpleTextBoxForeground" ResourceKey="SimpleTextDefaultDefaultBrush" />
			<StaticResource x:Key="SimpleTextBoxBackground" ResourceKey="SimpleBackgroundDefaultDefaultBrush" />
			<StaticResource x:Key="SimpleTextBoxBorderBrush" ResourceKey="SimpleBorderDefaultDefaultBrush" />
			<StaticResource x:Key="SimpleTextBoxPlaceholderForeground" ResourceKey="SimpleTextDefaultTertiaryBrush" />

			<StaticResource x:Key="SimpleTextBoxForegroundPointerOver" ResourceKey="SimpleTextDefaultDefaultBrush" />
			<StaticResource x:Key="SimpleTextBoxBackgroundPointerOver" ResourceKey="SimpleBackgroundDefaultDefaultBrush" />
			<StaticResource x:Key="SimpleTextBoxBorderBrushPointerOver" ResourceKey="SimpleBorderDefaultDefaultBrush" />

			<StaticResource x:Key="SimpleTextBoxForegroundFocused" ResourceKey="SimpleTextDefaultDefaultBrush" />
			<StaticResource x:Key="SimpleTextBoxBackgroundFocused" ResourceKey="SimpleBackgroundDefaultDefaultBrush" />
			<StaticResource x:Key="SimpleTextBoxBorderBrushFocused" ResourceKey="SimpleBorderBrandSecondaryBrush" />

			<StaticResource x:Key="SimpleTextBoxForegroundDisabled" ResourceKey="SimpleTextDisabledDefaultBrush" />
			<StaticResource x:Key="SimpleTextBoxBackgroundDisabled" ResourceKey="SimpleBackgroundDisabledDefaultBrush" />
			<StaticResource x:Key="SimpleTextBoxBorderBrushDisabled" ResourceKey="SimpleBorderDisabledDefaultBrush" />
			<StaticResource x:Key="SimpleTextBoxPlaceholderForegroundDisabled" ResourceKey="SimpleTextDisabledDefaultBrush" />

			<StaticResource x:Key="SimpleTextBoxErrorBorderBrush" ResourceKey="SimpleBorderDangerDefaultBrush" />
			<StaticResource x:Key="SimpleTextBoxErrorBorderBrushPointerOver" ResourceKey="SimpleBorderDangerDefaultBrush" />
			<StaticResource x:Key="SimpleTextBoxErrorBorderBrushFocused" ResourceKey="SimpleBorderDangerDefaultBrush" />

			<StaticResource x:Key="SimpleTextBoxHeaderForeground" ResourceKey="SimpleTextDefaultDefaultBrush" />
			<StaticResource x:Key="SimpleTextBoxHeaderForegroundDisabled" ResourceKey="SimpleTextDisabledDefaultBrush" />
		</ResourceDictionary>

	</ResourceDictionary.ThemeDictionaries>

	<!-- ═══════════════════════════════════════════════════════════════════════ -->
	<!-- Default Input TextBox (SDS outlined input)                            -->
	<!-- ═══════════════════════════════════════════════════════════════════════ -->
	<Style x:Key="SimpleInputTextBoxStyle"
		   TargetType="TextBox">
		<Setter Property="Foreground" Value="{ThemeResource SimpleTextBoxForeground}" />
		<Setter Property="Background" Value="{ThemeResource SimpleTextBoxBackground}" />
		<Setter Property="BorderBrush" Value="{ThemeResource SimpleTextBoxBorderBrush}" />
		<Setter Property="BorderThickness" Value="{ThemeResource SimpleTextBoxBorderThickness}" />
		<Setter Property="CornerRadius" Value="{ThemeResource SimpleTextBoxCornerRadius}" />
		<Setter Property="Padding" Value="{ThemeResource SimpleTextBoxPadding}" />
		<Setter Property="MinHeight" Value="{ThemeResource SimpleTextBoxMinHeight}" />
		<Setter Property="FontFamily" Value="{ThemeResource SimpleFontFamily}" />
		<Setter Property="FontSize" Value="16" />
		<Setter Property="FontWeight" Value="Normal" />
		<Setter Property="HorizontalAlignment" Value="Stretch" />
		<Setter Property="VerticalAlignment" Value="Center" />
		<Setter Property="HorizontalContentAlignment" Value="Left" />
		<Setter Property="VerticalContentAlignment" Value="Center" />
		<Setter Property="UseSystemFocusVisuals" Value="{StaticResource UseSystemFocusVisuals}" />
		<Setter Property="FocusVisualMargin" Value="-3" />
		<Setter Property="Template">
			<Setter.Value>
				<ControlTemplate TargetType="TextBox">
					<Grid>
						<Grid.RowDefinitions>
							<RowDefinition Height="Auto" />
							<RowDefinition Height="*" />
						</Grid.RowDefinitions>

						<VisualStateManager.VisualStateGroups>
							<VisualStateGroup x:Name="CommonStates">
								<VisualState x:Name="Normal" />

								<VisualState x:Name="PointerOver">
									<VisualState.Setters>
										<Setter Target="BorderElement.Background" Value="{ThemeResource SimpleTextBoxBackgroundPointerOver}" />
										<Setter Target="BorderElement.BorderBrush" Value="{ThemeResource SimpleTextBoxBorderBrushPointerOver}" />
										<Setter Target="ContentElement.Foreground" Value="{ThemeResource SimpleTextBoxForegroundPointerOver}" />
									</VisualState.Setters>
								</VisualState>

								<VisualState x:Name="Focused">
									<VisualState.Setters>
										<Setter Target="BorderElement.Background" Value="{ThemeResource SimpleTextBoxBackgroundFocused}" />
										<Setter Target="BorderElement.BorderBrush" Value="{ThemeResource SimpleTextBoxBorderBrushFocused}" />
										<Setter Target="BorderElement.BorderThickness" Value="{ThemeResource SimpleTextBoxFocusedBorderThickness}" />
										<Setter Target="ContentElement.Foreground" Value="{ThemeResource SimpleTextBoxForegroundFocused}" />
										<Setter Target="PlaceholderTextContentPresenter.Visibility" Value="Collapsed" />
									</VisualState.Setters>
								</VisualState>

								<VisualState x:Name="Disabled">
									<VisualState.Setters>
										<Setter Target="BorderElement.Background" Value="{ThemeResource SimpleTextBoxBackgroundDisabled}" />
										<Setter Target="BorderElement.BorderBrush" Value="{ThemeResource SimpleTextBoxBorderBrushDisabled}" />
										<Setter Target="ContentElement.Foreground" Value="{ThemeResource SimpleTextBoxForegroundDisabled}" />
										<Setter Target="PlaceholderTextContentPresenter.Foreground" Value="{ThemeResource SimpleTextBoxPlaceholderForegroundDisabled}" />
										<Setter Target="HeaderContentPresenter.Foreground" Value="{ThemeResource SimpleTextBoxHeaderForegroundDisabled}" />
									</VisualState.Setters>
								</VisualState>
							</VisualStateGroup>
						</VisualStateManager.VisualStateGroups>

						<!-- Header -->
						<ContentPresenter x:Name="HeaderContentPresenter"
										  Grid.Row="0"
										  Content="{TemplateBinding Header}"
										  ContentTemplate="{TemplateBinding HeaderTemplate}"
										  FontFamily="{ThemeResource SimpleFontFamily}"
										  FontSize="14"
										  FontWeight="SemiBold"
										  Foreground="{ThemeResource SimpleTextBoxHeaderForeground}"
										  Margin="0,0,0,4"
										  TextWrapping="Wrap"
										  Visibility="Collapsed"
										  x:DeferLoadStrategy="Lazy" />

						<!-- Input field -->
						<Border x:Name="BorderElement"
								Grid.Row="1"
								Background="{TemplateBinding Background}"
								BorderBrush="{TemplateBinding BorderBrush}"
								BorderThickness="{TemplateBinding BorderThickness}"
								CornerRadius="{TemplateBinding CornerRadius}"
								MinHeight="{TemplateBinding MinHeight}">

							<Grid VerticalAlignment="Center">
								<ContentControl x:Name="PlaceholderTextContentPresenter"
												Content="{TemplateBinding PlaceholderText}"
												Foreground="{ThemeResource SimpleTextBoxPlaceholderForeground}"
												FontFamily="{TemplateBinding FontFamily}"
												FontSize="{TemplateBinding FontSize}"
												Padding="{TemplateBinding Padding}"
												IsHitTestVisible="False"
												IsTabStop="False" />

								<ScrollViewer x:Name="ContentElement"
											  HorizontalScrollMode="{TemplateBinding ScrollViewer.HorizontalScrollMode}"
											  HorizontalScrollBarVisibility="{TemplateBinding ScrollViewer.HorizontalScrollBarVisibility}"
											  VerticalScrollMode="{TemplateBinding ScrollViewer.VerticalScrollMode}"
											  VerticalScrollBarVisibility="{TemplateBinding ScrollViewer.VerticalScrollBarVisibility}"
											  Padding="{TemplateBinding Padding}"
											  VerticalAlignment="Center"
											  IsHorizontalRailEnabled="False"
											  IsVerticalRailEnabled="False"
											  IsTabStop="False"
											  ZoomMode="Disabled"
											  AutomationProperties.AccessibilityView="Raw" />
							</Grid>
						</Border>
					</Grid>
				</ControlTemplate>
			</Setter.Value>
		</Setter>
	</Style>

	<!-- ═══════════════════════════════════════════════════════════════════════ -->
	<!-- Outlined Input (alias — same as default in SDS)                       -->
	<!-- ═══════════════════════════════════════════════════════════════════════ -->
	<Style x:Key="SimpleOutlinedInputTextBoxStyle"
		   TargetType="TextBox"
		   BasedOn="{StaticResource SimpleInputTextBoxStyle}" />

	<!-- ═══════════════════════════════════════════════════════════════════════ -->
	<!-- Error variant (danger border)                                         -->
	<!-- ═══════════════════════════════════════════════════════════════════════ -->
	<Style x:Key="SimpleInputTextBoxErrorStyle"
		   TargetType="TextBox"
		   BasedOn="{StaticResource SimpleInputTextBoxStyle}">
		<Setter Property="BorderBrush" Value="{ThemeResource SimpleTextBoxErrorBorderBrush}" />
	</Style>

	<!-- ═══════════════════════════════════════════════════════════════════════ -->
	<!-- Small size variant                                                    -->
	<!-- ═══════════════════════════════════════════════════════════════════════ -->
	<Style x:Key="SimpleInputTextBoxSmallStyle"
		   TargetType="TextBox"
		   BasedOn="{StaticResource SimpleInputTextBoxStyle}">
		<Setter Property="MinHeight" Value="{ThemeResource SimpleTextBoxSmallMinHeight}" />
		<Setter Property="FontSize" Value="14" />
	</Style>

</ResourceDictionary>
