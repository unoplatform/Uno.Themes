<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
					xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

	<!--
		Simple Design System — TextBox Styles
		Maps SDS Input component tokens to WinUI TextBox.

		Resource layers:
		  FilledTextBox*    = semantic keys (source of truth)
		  SimpleTextBox*    = Simple-prefixed aliases → FilledTextBox*
		  OutlinedTextBox*  = outlined input variant semantic keys

		Templates reference Simple-prefixed keys (which alias to semantic keys).
		This allows overriding EITHER the Simple-prefixed key OR the semantic key.

		Simple-only variants (no semantic rename):
		  SimpleTextBoxError*  — danger border overrides
		  SimpleTextBoxSmall*  — small size variant

		SDS Input: outlined box with 8px radius, 1px border
		States: Normal, Hover, Focus (brand-secondary border), Disabled, Error (danger border)
		Padding: horizontal=16, vertical=10 (space-300 minus stroke-border*2 = 12-2)
	-->

	<!-- ═══════════════════════════════════════════════════════════════════════ -->
	<!-- Lightweight styling ThemeResource aliases                              -->
	<!-- ═══════════════════════════════════════════════════════════════════════ -->
	<ResourceDictionary.ThemeDictionaries>

		<!-- ─── Light Theme ─── -->
		<ResourceDictionary x:Key="Light">

			<!-- ── FilledTextBox — semantic keys (source of truth) ── -->
			<!-- Sizing -->
			<StaticResource x:Key="FilledTextBoxCornerRadius" ResourceKey="SimpleRadius200CornerRadius" /> <!-- sds-size-radius-200 -->
			<StaticResource x:Key="FilledTextBoxBorderThicknessNormal" ResourceKey="SimpleStrokeBorderThickness" /> <!-- sds-size-stroke-border -->
			<StaticResource x:Key="FilledTextBoxBorderThicknessFocused" ResourceKey="SimpleStrokeFocusRingThickness" /> <!-- sds-size-stroke-focus-ring -->
			<!-- sds: h=SimpleSpace400 (16), v=10 (no exact token) -->
			<Thickness x:Key="FilledTextBoxPadding">16,10,16,10</Thickness>
			<StaticResource x:Key="FilledTextBoxMinHeight" ResourceKey="SimpleIconLarge" /> <!-- sds-size-icon-large -->

			<!-- Normal state -->
			<StaticResource x:Key="FilledTextBoxForeground" ResourceKey="SimpleTextDefaultDefaultBrush" />
			<StaticResource x:Key="FilledTextBoxBackground" ResourceKey="SimpleBackgroundDefaultDefaultBrush" />
			<StaticResource x:Key="FilledTextBoxBorderBrush" ResourceKey="SimpleBorderDefaultDefaultBrush" />
			<StaticResource x:Key="FilledTextBoxPlaceholderForeground" ResourceKey="SimpleTextDefaultTertiaryBrush" />

			<!-- PointerOver state -->
			<StaticResource x:Key="FilledTextBoxForegroundPointerOver" ResourceKey="SimpleTextDefaultDefaultBrush" />
			<StaticResource x:Key="FilledTextBoxBackgroundPointerOver" ResourceKey="SimpleBackgroundDefaultDefaultBrush" />
			<StaticResource x:Key="FilledTextBoxBorderBrushPointerOver" ResourceKey="SimpleBorderDefaultDefaultBrush" />
			<StaticResource x:Key="FilledTextBoxPlaceholderForegroundPointerOver" ResourceKey="SimpleTextDefaultTertiaryBrush" />

			<!-- Focused state -->
			<StaticResource x:Key="FilledTextBoxForegroundFocused" ResourceKey="SimpleTextDefaultDefaultBrush" />
			<StaticResource x:Key="FilledTextBoxBackgroundFocused" ResourceKey="SimpleBackgroundDefaultDefaultBrush" />
			<StaticResource x:Key="FilledTextBoxBorderBrushFocused" ResourceKey="SimpleBorderBrandSecondaryBrush" />
			<StaticResource x:Key="FilledTextBoxPlaceholderForegroundFocused" ResourceKey="SimpleTextDefaultTertiaryBrush" />

			<!-- Disabled state -->
			<StaticResource x:Key="FilledTextBoxForegroundDisabled" ResourceKey="SimpleTextDisabledDefaultBrush" />
			<StaticResource x:Key="FilledTextBoxBackgroundDisabled" ResourceKey="SimpleBackgroundDisabledDefaultBrush" />
			<StaticResource x:Key="FilledTextBoxBorderBrushDisabled" ResourceKey="SimpleBorderDisabledDefaultBrush" />
			<StaticResource x:Key="FilledTextBoxPlaceholderForegroundDisabled" ResourceKey="SimpleTextDisabledDefaultBrush" />

			<!-- Header / label -->
			<StaticResource x:Key="FilledTextBoxHeaderForeground" ResourceKey="SimpleTextDefaultDefaultBrush" />
			<StaticResource x:Key="FilledTextBoxHeaderForegroundPointerOver" ResourceKey="SimpleTextDefaultDefaultBrush" />
			<StaticResource x:Key="FilledTextBoxHeaderForegroundFocused" ResourceKey="SimpleTextDefaultDefaultBrush" />
			<StaticResource x:Key="FilledTextBoxHeaderForegroundDisabled" ResourceKey="SimpleTextDisabledDefaultBrush" />

			<!-- Backwards-compat aliases (SimpleTextBox* → FilledTextBox*) -->
			<StaticResource x:Key="SimpleTextBoxCornerRadius" ResourceKey="FilledTextBoxCornerRadius" />
			<StaticResource x:Key="SimpleTextBoxBorderThickness" ResourceKey="FilledTextBoxBorderThicknessNormal" />
			<StaticResource x:Key="SimpleTextBoxFocusedBorderThickness" ResourceKey="FilledTextBoxBorderThicknessFocused" />
			<StaticResource x:Key="SimpleTextBoxPadding" ResourceKey="FilledTextBoxPadding" />
			<StaticResource x:Key="SimpleTextBoxMinHeight" ResourceKey="FilledTextBoxMinHeight" />
			<StaticResource x:Key="SimpleTextBoxForeground" ResourceKey="FilledTextBoxForeground" />
			<StaticResource x:Key="SimpleTextBoxBackground" ResourceKey="FilledTextBoxBackground" />
			<StaticResource x:Key="SimpleTextBoxBorderBrush" ResourceKey="FilledTextBoxBorderBrush" />
			<StaticResource x:Key="SimpleTextBoxPlaceholderForeground" ResourceKey="FilledTextBoxPlaceholderForeground" />
			<StaticResource x:Key="SimpleTextBoxForegroundPointerOver" ResourceKey="FilledTextBoxForegroundPointerOver" />
			<StaticResource x:Key="SimpleTextBoxBackgroundPointerOver" ResourceKey="FilledTextBoxBackgroundPointerOver" />
			<StaticResource x:Key="SimpleTextBoxBorderBrushPointerOver" ResourceKey="FilledTextBoxBorderBrushPointerOver" />
			<StaticResource x:Key="SimpleTextBoxForegroundFocused" ResourceKey="FilledTextBoxForegroundFocused" />
			<StaticResource x:Key="SimpleTextBoxBackgroundFocused" ResourceKey="FilledTextBoxBackgroundFocused" />
			<StaticResource x:Key="SimpleTextBoxBorderBrushFocused" ResourceKey="FilledTextBoxBorderBrushFocused" />
			<StaticResource x:Key="SimpleTextBoxForegroundDisabled" ResourceKey="FilledTextBoxForegroundDisabled" />
			<StaticResource x:Key="SimpleTextBoxBackgroundDisabled" ResourceKey="FilledTextBoxBackgroundDisabled" />
			<StaticResource x:Key="SimpleTextBoxBorderBrushDisabled" ResourceKey="FilledTextBoxBorderBrushDisabled" />
			<StaticResource x:Key="SimpleTextBoxPlaceholderForegroundDisabled" ResourceKey="FilledTextBoxPlaceholderForegroundDisabled" />
			<StaticResource x:Key="SimpleTextBoxHeaderForeground" ResourceKey="FilledTextBoxHeaderForeground" />
			<StaticResource x:Key="SimpleTextBoxHeaderForegroundPointerOver" ResourceKey="FilledTextBoxHeaderForegroundPointerOver" />
			<StaticResource x:Key="SimpleTextBoxHeaderForegroundFocused" ResourceKey="FilledTextBoxHeaderForegroundFocused" />
			<StaticResource x:Key="SimpleTextBoxHeaderForegroundDisabled" ResourceKey="FilledTextBoxHeaderForegroundDisabled" />
			<StaticResource x:Key="SimpleTextBoxPlaceholderForegroundPointerOver" ResourceKey="FilledTextBoxPlaceholderForegroundPointerOver" />
			<StaticResource x:Key="SimpleTextBoxPlaceholderForegroundFocused" ResourceKey="FilledTextBoxPlaceholderForegroundFocused" />

			<!-- ── OutlinedTextBox — semantic keys (source of truth) ── -->
			<!-- Sizing -->
			<StaticResource x:Key="OutlinedTextBoxCornerRadius" ResourceKey="SimpleRadius200CornerRadius" />
			<StaticResource x:Key="OutlinedTextBoxBorderThickness" ResourceKey="SimpleStrokeBorderThickness" />
			<StaticResource x:Key="OutlinedTextBoxBorderThicknessFocused" ResourceKey="SimpleStrokeFocusRingThickness" />
			<StaticResource x:Key="OutlinedTextBoxBorderThicknessPointerOver" ResourceKey="SimpleStrokeBorderThickness" />
			<Thickness x:Key="OutlinedTextBoxPadding">16,10,16,10</Thickness>
			<StaticResource x:Key="OutlinedTextBoxMinHeight" ResourceKey="SimpleIconLarge" />

			<!-- Normal state -->
			<StaticResource x:Key="OutlinedTextBoxForeground" ResourceKey="SimpleTextDefaultDefaultBrush" />
			<StaticResource x:Key="OutlinedTextBoxBorderBrush" ResourceKey="SimpleBorderDefaultDefaultBrush" />
			<StaticResource x:Key="OutlinedTextBoxPlaceholderForeground" ResourceKey="SimpleTextDefaultTertiaryBrush" />

			<!-- PointerOver state -->
			<StaticResource x:Key="OutlinedTextBoxForegroundPointerOver" ResourceKey="SimpleTextDefaultDefaultBrush" />
			<StaticResource x:Key="OutlinedTextBoxBorderBrushPointerOver" ResourceKey="SimpleBorderDefaultDefaultBrush" />
			<StaticResource x:Key="OutlinedTextBoxPlaceholderForegroundPointerOver" ResourceKey="SimpleTextDefaultTertiaryBrush" />

			<!-- Focused state -->
			<StaticResource x:Key="OutlinedTextBoxForegroundFocused" ResourceKey="SimpleTextDefaultDefaultBrush" />
			<StaticResource x:Key="OutlinedTextBoxBorderBrushFocused" ResourceKey="SimpleBorderBrandSecondaryBrush" />
			<StaticResource x:Key="OutlinedTextBoxPlaceholderForegroundFocused" ResourceKey="SimpleTextDefaultTertiaryBrush" />

			<!-- Disabled state -->
			<StaticResource x:Key="OutlinedTextBoxForegroundDisabled" ResourceKey="SimpleTextDisabledDefaultBrush" />
			<StaticResource x:Key="OutlinedTextBoxBorderBrushDisabled" ResourceKey="SimpleBorderDisabledDefaultBrush" />
			<StaticResource x:Key="OutlinedTextBoxPlaceholderForegroundDisabled" ResourceKey="SimpleTextDisabledDefaultBrush" />

			<!-- Header / label -->
			<StaticResource x:Key="OutlinedTextBoxHeaderForeground" ResourceKey="SimpleTextDefaultDefaultBrush" />
			<StaticResource x:Key="OutlinedTextBoxHeaderForegroundPointerOver" ResourceKey="SimpleTextDefaultDefaultBrush" />
			<StaticResource x:Key="OutlinedTextBoxHeaderForegroundFocused" ResourceKey="SimpleTextDefaultDefaultBrush" />
			<StaticResource x:Key="OutlinedTextBoxHeaderForegroundDisabled" ResourceKey="SimpleTextDisabledDefaultBrush" />

			<!-- Backwards-compat aliases (SimpleOutlinedTextBox* → OutlinedTextBox*) -->
			<StaticResource x:Key="SimpleOutlinedTextBoxForeground" ResourceKey="OutlinedTextBoxForeground" />
			<StaticResource x:Key="SimpleOutlinedTextBoxBorderBrush" ResourceKey="OutlinedTextBoxBorderBrush" />
			<StaticResource x:Key="SimpleOutlinedTextBoxBorderThickness" ResourceKey="OutlinedTextBoxBorderThickness" />
			<StaticResource x:Key="SimpleOutlinedTextBoxCornerRadius" ResourceKey="OutlinedTextBoxCornerRadius" />
			<StaticResource x:Key="SimpleOutlinedTextBoxPadding" ResourceKey="OutlinedTextBoxPadding" />
			<StaticResource x:Key="SimpleOutlinedTextBoxMinHeight" ResourceKey="OutlinedTextBoxMinHeight" />

			<!-- ── Simple-only: Error state overrides (no semantic rename) ── -->
			<StaticResource x:Key="SimpleTextBoxErrorBorderBrush" ResourceKey="SimpleBorderDangerDefaultBrush" />
			<StaticResource x:Key="SimpleTextBoxErrorBorderBrushPointerOver" ResourceKey="SimpleBorderDangerDefaultBrush" />
			<StaticResource x:Key="SimpleTextBoxErrorBorderBrushFocused" ResourceKey="SimpleBorderDangerDefaultBrush" />

			<!-- ── Simple-only: Small size variant ── -->
			<StaticResource x:Key="SimpleTextBoxSmallMinHeight" ResourceKey="SimpleIconMedium" /> <!-- sds-size-icon-medium -->
		</ResourceDictionary>

		<!-- ─── Dark Theme (Default) ─── -->
		<ResourceDictionary x:Key="Default">

			<!-- ── FilledTextBox — semantic keys (source of truth) ── -->
			<!-- Sizing -->
			<StaticResource x:Key="FilledTextBoxCornerRadius" ResourceKey="SimpleRadius200CornerRadius" />
			<StaticResource x:Key="FilledTextBoxBorderThicknessNormal" ResourceKey="SimpleStrokeBorderThickness" />
			<StaticResource x:Key="FilledTextBoxBorderThicknessFocused" ResourceKey="SimpleStrokeFocusRingThickness" />
			<Thickness x:Key="FilledTextBoxPadding">16,10,16,10</Thickness>
			<StaticResource x:Key="FilledTextBoxMinHeight" ResourceKey="SimpleIconLarge" />

			<!-- Normal state -->
			<StaticResource x:Key="FilledTextBoxForeground" ResourceKey="SimpleTextDefaultDefaultBrush" />
			<StaticResource x:Key="FilledTextBoxBackground" ResourceKey="SimpleBackgroundDefaultDefaultBrush" />
			<StaticResource x:Key="FilledTextBoxBorderBrush" ResourceKey="SimpleBorderDefaultDefaultBrush" />
			<StaticResource x:Key="FilledTextBoxPlaceholderForeground" ResourceKey="SimpleTextDefaultTertiaryBrush" />

			<!-- PointerOver state -->
			<StaticResource x:Key="FilledTextBoxForegroundPointerOver" ResourceKey="SimpleTextDefaultDefaultBrush" />
			<StaticResource x:Key="FilledTextBoxBackgroundPointerOver" ResourceKey="SimpleBackgroundDefaultDefaultBrush" />
			<StaticResource x:Key="FilledTextBoxBorderBrushPointerOver" ResourceKey="SimpleBorderDefaultDefaultBrush" />
			<StaticResource x:Key="FilledTextBoxPlaceholderForegroundPointerOver" ResourceKey="SimpleTextDefaultTertiaryBrush" />

			<!-- Focused state -->
			<StaticResource x:Key="FilledTextBoxForegroundFocused" ResourceKey="SimpleTextDefaultDefaultBrush" />
			<StaticResource x:Key="FilledTextBoxBackgroundFocused" ResourceKey="SimpleBackgroundDefaultDefaultBrush" />
			<StaticResource x:Key="FilledTextBoxBorderBrushFocused" ResourceKey="SimpleBorderBrandSecondaryBrush" />
			<StaticResource x:Key="FilledTextBoxPlaceholderForegroundFocused" ResourceKey="SimpleTextDefaultTertiaryBrush" />

			<!-- Disabled state -->
			<StaticResource x:Key="FilledTextBoxForegroundDisabled" ResourceKey="SimpleTextDisabledDefaultBrush" />
			<StaticResource x:Key="FilledTextBoxBackgroundDisabled" ResourceKey="SimpleBackgroundDisabledDefaultBrush" />
			<StaticResource x:Key="FilledTextBoxBorderBrushDisabled" ResourceKey="SimpleBorderDisabledDefaultBrush" />
			<StaticResource x:Key="FilledTextBoxPlaceholderForegroundDisabled" ResourceKey="SimpleTextDisabledDefaultBrush" />

			<!-- Header / label -->
			<StaticResource x:Key="FilledTextBoxHeaderForeground" ResourceKey="SimpleTextDefaultDefaultBrush" />
			<StaticResource x:Key="FilledTextBoxHeaderForegroundPointerOver" ResourceKey="SimpleTextDefaultDefaultBrush" />
			<StaticResource x:Key="FilledTextBoxHeaderForegroundFocused" ResourceKey="SimpleTextDefaultDefaultBrush" />
			<StaticResource x:Key="FilledTextBoxHeaderForegroundDisabled" ResourceKey="SimpleTextDisabledDefaultBrush" />

			<!-- Backwards-compat aliases (SimpleTextBox* → FilledTextBox*) -->
			<StaticResource x:Key="SimpleTextBoxCornerRadius" ResourceKey="FilledTextBoxCornerRadius" />
			<StaticResource x:Key="SimpleTextBoxBorderThickness" ResourceKey="FilledTextBoxBorderThicknessNormal" />
			<StaticResource x:Key="SimpleTextBoxFocusedBorderThickness" ResourceKey="FilledTextBoxBorderThicknessFocused" />
			<StaticResource x:Key="SimpleTextBoxPadding" ResourceKey="FilledTextBoxPadding" />
			<StaticResource x:Key="SimpleTextBoxMinHeight" ResourceKey="FilledTextBoxMinHeight" />
			<StaticResource x:Key="SimpleTextBoxForeground" ResourceKey="FilledTextBoxForeground" />
			<StaticResource x:Key="SimpleTextBoxBackground" ResourceKey="FilledTextBoxBackground" />
			<StaticResource x:Key="SimpleTextBoxBorderBrush" ResourceKey="FilledTextBoxBorderBrush" />
			<StaticResource x:Key="SimpleTextBoxPlaceholderForeground" ResourceKey="FilledTextBoxPlaceholderForeground" />
			<StaticResource x:Key="SimpleTextBoxForegroundPointerOver" ResourceKey="FilledTextBoxForegroundPointerOver" />
			<StaticResource x:Key="SimpleTextBoxBackgroundPointerOver" ResourceKey="FilledTextBoxBackgroundPointerOver" />
			<StaticResource x:Key="SimpleTextBoxBorderBrushPointerOver" ResourceKey="FilledTextBoxBorderBrushPointerOver" />
			<StaticResource x:Key="SimpleTextBoxForegroundFocused" ResourceKey="FilledTextBoxForegroundFocused" />
			<StaticResource x:Key="SimpleTextBoxBackgroundFocused" ResourceKey="FilledTextBoxBackgroundFocused" />
			<StaticResource x:Key="SimpleTextBoxBorderBrushFocused" ResourceKey="FilledTextBoxBorderBrushFocused" />
			<StaticResource x:Key="SimpleTextBoxForegroundDisabled" ResourceKey="FilledTextBoxForegroundDisabled" />
			<StaticResource x:Key="SimpleTextBoxBackgroundDisabled" ResourceKey="FilledTextBoxBackgroundDisabled" />
			<StaticResource x:Key="SimpleTextBoxBorderBrushDisabled" ResourceKey="FilledTextBoxBorderBrushDisabled" />
			<StaticResource x:Key="SimpleTextBoxPlaceholderForegroundDisabled" ResourceKey="FilledTextBoxPlaceholderForegroundDisabled" />
			<StaticResource x:Key="SimpleTextBoxHeaderForeground" ResourceKey="FilledTextBoxHeaderForeground" />
			<StaticResource x:Key="SimpleTextBoxHeaderForegroundPointerOver" ResourceKey="FilledTextBoxHeaderForegroundPointerOver" />
			<StaticResource x:Key="SimpleTextBoxHeaderForegroundFocused" ResourceKey="FilledTextBoxHeaderForegroundFocused" />
			<StaticResource x:Key="SimpleTextBoxHeaderForegroundDisabled" ResourceKey="FilledTextBoxHeaderForegroundDisabled" />
			<StaticResource x:Key="SimpleTextBoxPlaceholderForegroundPointerOver" ResourceKey="FilledTextBoxPlaceholderForegroundPointerOver" />
			<StaticResource x:Key="SimpleTextBoxPlaceholderForegroundFocused" ResourceKey="FilledTextBoxPlaceholderForegroundFocused" />

			<!-- ── OutlinedTextBox — semantic keys (source of truth) ── -->
			<!-- Sizing -->
			<StaticResource x:Key="OutlinedTextBoxCornerRadius" ResourceKey="SimpleRadius200CornerRadius" />
			<StaticResource x:Key="OutlinedTextBoxBorderThickness" ResourceKey="SimpleStrokeBorderThickness" />
			<StaticResource x:Key="OutlinedTextBoxBorderThicknessFocused" ResourceKey="SimpleStrokeFocusRingThickness" />
			<StaticResource x:Key="OutlinedTextBoxBorderThicknessPointerOver" ResourceKey="SimpleStrokeBorderThickness" />
			<Thickness x:Key="OutlinedTextBoxPadding">16,10,16,10</Thickness>
			<StaticResource x:Key="OutlinedTextBoxMinHeight" ResourceKey="SimpleIconLarge" />

			<!-- Normal state -->
			<StaticResource x:Key="OutlinedTextBoxForeground" ResourceKey="SimpleTextDefaultDefaultBrush" />
			<StaticResource x:Key="OutlinedTextBoxBorderBrush" ResourceKey="SimpleBorderDefaultDefaultBrush" />
			<StaticResource x:Key="OutlinedTextBoxPlaceholderForeground" ResourceKey="SimpleTextDefaultTertiaryBrush" />

			<!-- PointerOver state -->
			<StaticResource x:Key="OutlinedTextBoxForegroundPointerOver" ResourceKey="SimpleTextDefaultDefaultBrush" />
			<StaticResource x:Key="OutlinedTextBoxBorderBrushPointerOver" ResourceKey="SimpleBorderDefaultDefaultBrush" />
			<StaticResource x:Key="OutlinedTextBoxPlaceholderForegroundPointerOver" ResourceKey="SimpleTextDefaultTertiaryBrush" />

			<!-- Focused state -->
			<StaticResource x:Key="OutlinedTextBoxForegroundFocused" ResourceKey="SimpleTextDefaultDefaultBrush" />
			<StaticResource x:Key="OutlinedTextBoxBorderBrushFocused" ResourceKey="SimpleBorderBrandSecondaryBrush" />
			<StaticResource x:Key="OutlinedTextBoxPlaceholderForegroundFocused" ResourceKey="SimpleTextDefaultTertiaryBrush" />

			<!-- Disabled state -->
			<StaticResource x:Key="OutlinedTextBoxForegroundDisabled" ResourceKey="SimpleTextDisabledDefaultBrush" />
			<StaticResource x:Key="OutlinedTextBoxBorderBrushDisabled" ResourceKey="SimpleBorderDisabledDefaultBrush" />
			<StaticResource x:Key="OutlinedTextBoxPlaceholderForegroundDisabled" ResourceKey="SimpleTextDisabledDefaultBrush" />

			<!-- Header / label -->
			<StaticResource x:Key="OutlinedTextBoxHeaderForeground" ResourceKey="SimpleTextDefaultDefaultBrush" />
			<StaticResource x:Key="OutlinedTextBoxHeaderForegroundPointerOver" ResourceKey="SimpleTextDefaultDefaultBrush" />
			<StaticResource x:Key="OutlinedTextBoxHeaderForegroundFocused" ResourceKey="SimpleTextDefaultDefaultBrush" />
			<StaticResource x:Key="OutlinedTextBoxHeaderForegroundDisabled" ResourceKey="SimpleTextDisabledDefaultBrush" />

			<!-- Backwards-compat aliases (SimpleOutlinedTextBox* → OutlinedTextBox*) -->
			<StaticResource x:Key="SimpleOutlinedTextBoxForeground" ResourceKey="OutlinedTextBoxForeground" />
			<StaticResource x:Key="SimpleOutlinedTextBoxBorderBrush" ResourceKey="OutlinedTextBoxBorderBrush" />
			<StaticResource x:Key="SimpleOutlinedTextBoxBorderThickness" ResourceKey="OutlinedTextBoxBorderThickness" />
			<StaticResource x:Key="SimpleOutlinedTextBoxCornerRadius" ResourceKey="OutlinedTextBoxCornerRadius" />
			<StaticResource x:Key="SimpleOutlinedTextBoxPadding" ResourceKey="OutlinedTextBoxPadding" />
			<StaticResource x:Key="SimpleOutlinedTextBoxMinHeight" ResourceKey="OutlinedTextBoxMinHeight" />

			<!-- ── Simple-only: Error state overrides (no semantic rename) ── -->
			<StaticResource x:Key="SimpleTextBoxErrorBorderBrush" ResourceKey="SimpleBorderDangerDefaultBrush" />
			<StaticResource x:Key="SimpleTextBoxErrorBorderBrushPointerOver" ResourceKey="SimpleBorderDangerDefaultBrush" />
			<StaticResource x:Key="SimpleTextBoxErrorBorderBrushFocused" ResourceKey="SimpleBorderDangerDefaultBrush" />

			<!-- ── Simple-only: Small size variant ── -->
			<StaticResource x:Key="SimpleTextBoxSmallMinHeight" ResourceKey="SimpleIconMedium" />
		</ResourceDictionary>

	</ResourceDictionary.ThemeDictionaries>

	<!-- Header label spacing: bottom = SimpleSpace100 (4) -->
	<Thickness x:Key="SimpleTextBoxHeaderMargin">0,0,0,4</Thickness>

	<!-- ═══════════════════════════════════════════════════════════════════════ -->
	<!-- Default Input TextBox (SDS outlined input) — uses SimpleTextBox* keys -->
	<!-- ═══════════════════════════════════════════════════════════════════════ -->
	<Style x:Key="SimpleInputTextBoxStyle"
		   TargetType="TextBox">
		<Setter Property="Foreground" Value="{ThemeResource SimpleTextBoxForeground}" />
		<Setter Property="Background" Value="{ThemeResource SimpleTextBoxBackground}" />
		<Setter Property="BorderBrush" Value="{ThemeResource SimpleTextBoxBorderBrush}" />
		<Setter Property="BorderThickness" Value="{ThemeResource SimpleTextBoxBorderThickness}" />
		<Setter Property="CornerRadius" Value="{ThemeResource SimpleTextBoxCornerRadius}" />
		<Setter Property="Padding" Value="{ThemeResource SimpleTextBoxPadding}" />
		<Setter Property="MinHeight" Value="{ThemeResource SimpleTextBoxMinHeight}" />
		<Setter Property="FontFamily" Value="{ThemeResource SimpleFontFamily}" />
		<Setter Property="FontSize" Value="{ThemeResource SimpleTypographyScale03}" />
		<Setter Property="FontWeight" Value="Normal" />
		<Setter Property="HorizontalAlignment" Value="Stretch" />
		<Setter Property="VerticalAlignment" Value="Center" />
		<Setter Property="HorizontalContentAlignment" Value="Left" />
		<Setter Property="VerticalContentAlignment" Value="Center" />
		<Setter Property="UseSystemFocusVisuals" Value="{StaticResource UseSystemFocusVisuals}" />
		<Setter Property="FocusVisualMargin" Value="-3" />
		<Setter Property="Template">
			<Setter.Value>
				<ControlTemplate TargetType="TextBox">
					<Grid>
						<Grid.RowDefinitions>
							<RowDefinition Height="Auto" />
							<RowDefinition Height="*" />
						</Grid.RowDefinitions>

						<VisualStateManager.VisualStateGroups>
							<VisualStateGroup x:Name="CommonStates">
								<VisualState x:Name="Normal" />

								<VisualState x:Name="PointerOver">
									<VisualState.Setters>
										<Setter Target="BackgroundElement.Background" Value="{ThemeResource SimpleTextBoxBackgroundPointerOver}" />
										<Setter Target="BorderElement.BorderBrush" Value="{ThemeResource SimpleTextBoxBorderBrushPointerOver}" />
										<Setter Target="ContentElement.Foreground" Value="{ThemeResource SimpleTextBoxForegroundPointerOver}" />
									</VisualState.Setters>
								</VisualState>

								<VisualState x:Name="Focused">
									<VisualState.Setters>
										<Setter Target="BackgroundElement.Background" Value="{ThemeResource SimpleTextBoxBackgroundFocused}" />
										<Setter Target="BorderElement.BorderBrush" Value="{ThemeResource SimpleTextBoxBorderBrushFocused}" />
										<Setter Target="BorderElement.BorderThickness" Value="{ThemeResource SimpleTextBoxFocusedBorderThickness}" />
										<Setter Target="ContentElement.Foreground" Value="{ThemeResource SimpleTextBoxForegroundFocused}" />
									</VisualState.Setters>
								</VisualState>

								<VisualState x:Name="Disabled">
									<VisualState.Setters>
										<Setter Target="BackgroundElement.Background" Value="{ThemeResource SimpleTextBoxBackgroundDisabled}" />
										<Setter Target="BorderElement.BorderBrush" Value="{ThemeResource SimpleTextBoxBorderBrushDisabled}" />
										<Setter Target="ContentElement.Foreground" Value="{ThemeResource SimpleTextBoxForegroundDisabled}" />
										<Setter Target="PlaceholderElement.Foreground" Value="{ThemeResource SimpleTextBoxPlaceholderForegroundDisabled}" />
										<Setter Target="HeaderContentPresenter.Foreground" Value="{ThemeResource SimpleTextBoxHeaderForegroundDisabled}" />
									</VisualState.Setters>
								</VisualState>
							</VisualStateGroup>
						</VisualStateManager.VisualStateGroups>

						<!-- Header -->
						<ContentPresenter x:Name="HeaderContentPresenter"
										  Grid.Row="0"
										  Content="{TemplateBinding Header}"
										  ContentTemplate="{TemplateBinding HeaderTemplate}"
										  FontFamily="{ThemeResource SimpleFontFamily}"
										  FontSize="{ThemeResource SimpleTypographyScale02}"
										  FontWeight="SemiBold"
										  Foreground="{ThemeResource SimpleTextBoxHeaderForeground}"
										  Margin="{StaticResource SimpleTextBoxHeaderMargin}"
										  TextWrapping="Wrap"
										  Visibility="Collapsed"
										  x:DeferLoadStrategy="Lazy" />

						<!-- Input field -->
						<Grid Grid.Row="1"
							  MinHeight="{TemplateBinding MinHeight}">

							<!-- Background fill -->
							<Border x:Name="BackgroundElement"
									Background="{TemplateBinding Background}"
									CornerRadius="{TemplateBinding CornerRadius}" />

							<!-- Content -->
							<Grid VerticalAlignment="Center">
								<ContentControl x:Name="PlaceholderElement"
												Content="{TemplateBinding PlaceholderText}"
												Foreground="{ThemeResource SimpleTextBoxPlaceholderForeground}"
												FontFamily="{TemplateBinding FontFamily}"
												FontSize="{TemplateBinding FontSize}"
												Padding="{TemplateBinding Padding}"
												Visibility="{Binding Text, RelativeSource={RelativeSource TemplatedParent}, Converter={StaticResource EmptyToVisibleConverter}}"
												IsHitTestVisible="False"
												IsTabStop="False" />

								<ScrollViewer x:Name="ContentElement"
											  HorizontalScrollMode="{TemplateBinding ScrollViewer.HorizontalScrollMode}"
											  HorizontalScrollBarVisibility="{TemplateBinding ScrollViewer.HorizontalScrollBarVisibility}"
											  VerticalScrollMode="{TemplateBinding ScrollViewer.VerticalScrollMode}"
											  VerticalScrollBarVisibility="{TemplateBinding ScrollViewer.VerticalScrollBarVisibility}"
											  Padding="{TemplateBinding Padding}"
											  VerticalAlignment="Center"
											  IsHorizontalRailEnabled="False"
											  IsVerticalRailEnabled="False"
											  IsTabStop="False"
											  ZoomMode="Disabled"
											  AutomationProperties.AccessibilityView="Raw" />
							</Grid>

							<!--
								Border overlay — border thickness changes (e.g. 1 px → 2 px on focus)
								don't push inner content, preventing the "shrink" effect.
								Same approach as Material.
							-->
							<Border x:Name="BorderElement"
									BorderBrush="{TemplateBinding BorderBrush}"
									BorderThickness="{TemplateBinding BorderThickness}"
									CornerRadius="{TemplateBinding CornerRadius}" />
						</Grid>
					</Grid>
				</ControlTemplate>
			</Setter.Value>
		</Setter>
	</Style>

	<!-- ═══════════════════════════════════════════════════════════════════════ -->
	<!-- Outlined Input — uses OutlinedTextBox* semantic keys (no Simple alias)-->
	<!-- ═══════════════════════════════════════════════════════════════════════ -->
	<Style x:Key="SimpleOutlinedInputTextBoxStyle"
		   TargetType="TextBox"
		   BasedOn="{StaticResource SimpleInputTextBoxStyle}">
		<Setter Property="Foreground" Value="{ThemeResource SimpleOutlinedTextBoxForeground}" />
		<Setter Property="BorderBrush" Value="{ThemeResource SimpleOutlinedTextBoxBorderBrush}" />
		<Setter Property="BorderThickness" Value="{ThemeResource SimpleOutlinedTextBoxBorderThickness}" />
		<Setter Property="CornerRadius" Value="{ThemeResource SimpleOutlinedTextBoxCornerRadius}" />
		<Setter Property="Padding" Value="{ThemeResource SimpleOutlinedTextBoxPadding}" />
		<Setter Property="MinHeight" Value="{ThemeResource SimpleOutlinedTextBoxMinHeight}" />
	</Style>

	<!-- ═══════════════════════════════════════════════════════════════════════ -->
	<!-- Error variant (danger border) — Simple-only                           -->
	<!-- ═══════════════════════════════════════════════════════════════════════ -->
	<Style x:Key="SimpleInputTextBoxErrorStyle"
		   TargetType="TextBox"
		   BasedOn="{StaticResource SimpleInputTextBoxStyle}">
		<Setter Property="BorderBrush" Value="{ThemeResource SimpleTextBoxErrorBorderBrush}" />
	</Style>

	<!-- ═══════════════════════════════════════════════════════════════════════ -->
	<!-- Small size variant — Simple-only                                      -->
	<!-- ═══════════════════════════════════════════════════════════════════════ -->
	<Style x:Key="SimpleInputTextBoxSmallStyle"
		   TargetType="TextBox"
		   BasedOn="{StaticResource SimpleInputTextBoxStyle}">
		<Setter Property="MinHeight" Value="{ThemeResource SimpleTextBoxSmallMinHeight}" />
		<Setter Property="FontSize" Value="{ThemeResource SimpleTypographyScale02}" />
	</Style>

</ResourceDictionary>
