<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
					xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

	<Style x:Key="SimpleBaseTextBlockStyle"
		   TargetType="TextBlock">
		<Setter Property="TextTrimming" Value="CharacterEllipsis" />
		<Setter Property="TextWrapping" Value="Wrap" />
		<Setter Property="FontWeight" Value="Normal" />
		<Setter Property="FontFamily" Value="{ThemeResource SimpleFontFamily}" />
		<Setter Property="Foreground" Value="{ThemeResource OnSurfaceBrush}" />
	</Style>

	<Style x:Key="SimpleDisplayLarge"
		   TargetType="TextBlock"
		   BasedOn="{StaticResource SimpleBaseTextBlockStyle}">
		<Setter Property="FontSize" Value="72" />
		<Setter Property="FontWeight" Value="Bold" />
	</Style>

	<Style x:Key="SimpleDisplayMedium"
		   TargetType="TextBlock"
		   BasedOn="{StaticResource SimpleBaseTextBlockStyle}">
		<Setter Property="FontSize" Value="48" />
		<Setter Property="FontWeight" Value="Bold" />
	</Style>

	<Style x:Key="SimpleDisplaySmall"
		   TargetType="TextBlock"
		   BasedOn="{StaticResource SimpleBaseTextBlockStyle}">
		<Setter Property="FontSize" Value="40" />
		<Setter Property="FontWeight" Value="Bold" />
	</Style>

	<Style x:Key="SimpleHeadlineLarge"
		   TargetType="TextBlock"
		   BasedOn="{StaticResource SimpleBaseTextBlockStyle}">
		<Setter Property="FontSize" Value="32" />
		<Setter Property="FontWeight" Value="SemiBold" />
	</Style>

	<Style x:Key="SimpleHeadlineMedium"
		   TargetType="TextBlock"
		   BasedOn="{StaticResource SimpleBaseTextBlockStyle}">
		<Setter Property="FontSize" Value="24" />
		<Setter Property="FontWeight" Value="SemiBold" />
	</Style>

	<Style x:Key="SimpleHeadlineSmall"
		   TargetType="TextBlock"
		   BasedOn="{StaticResource SimpleBaseTextBlockStyle}">
		<Setter Property="FontSize" Value="20" />
		<Setter Property="FontWeight" Value="SemiBold" />
	</Style>

	<Style x:Key="SimpleTitleLarge"
		   TargetType="TextBlock"
		   BasedOn="{StaticResource SimpleBaseTextBlockStyle}">
		<Setter Property="FontSize" Value="24" />
		<Setter Property="FontWeight" Value="Normal" />
	</Style>

	<Style x:Key="SimpleTitleMedium"
		   TargetType="TextBlock"
		   BasedOn="{StaticResource SimpleBaseTextBlockStyle}">
		<Setter Property="FontSize" Value="20" />
		<Setter Property="FontWeight" Value="Normal" />
	</Style>

	<Style x:Key="SimpleTitleSmall"
		   TargetType="TextBlock"
		   BasedOn="{StaticResource SimpleBaseTextBlockStyle}">
		<Setter Property="FontSize" Value="16" />
		<Setter Property="FontWeight" Value="Normal" />
	</Style>

	<Style x:Key="SimpleBodyLarge"
		   TargetType="TextBlock"
		   BasedOn="{StaticResource SimpleBaseTextBlockStyle}">
		<Setter Property="FontSize" Value="20" />
		<Setter Property="FontWeight" Value="Normal" />
	</Style>

	<Style x:Key="SimpleBodyMedium"
		   TargetType="TextBlock"
		   BasedOn="{StaticResource SimpleBaseTextBlockStyle}">
		<Setter Property="FontSize" Value="16" />
		<Setter Property="FontWeight" Value="Normal" />
	</Style>

	<Style x:Key="SimpleBodySmall"
		   TargetType="TextBlock"
		   BasedOn="{StaticResource SimpleBaseTextBlockStyle}">
		<Setter Property="FontSize" Value="14" />
		<Setter Property="FontWeight" Value="Normal" />
	</Style>

	<Style x:Key="SimpleLabelLarge"
		   TargetType="TextBlock"
		   BasedOn="{StaticResource SimpleBaseTextBlockStyle}">
		<Setter Property="FontSize" Value="16" />
		<Setter Property="FontWeight" Value="SemiBold" />
	</Style>

	<Style x:Key="SimpleLabelMedium"
		   TargetType="TextBlock"
		   BasedOn="{StaticResource SimpleBaseTextBlockStyle}">
		<Setter Property="FontSize" Value="14" />
		<Setter Property="FontWeight" Value="SemiBold" />
	</Style>

	<Style x:Key="SimpleLabelSmall"
		   TargetType="TextBlock"
		   BasedOn="{StaticResource SimpleBaseTextBlockStyle}">
		<Setter Property="FontSize" Value="12" />
		<Setter Property="FontWeight" Value="SemiBold" />
	</Style>

	<Style x:Key="SimpleLabelExtraSmall"
		   TargetType="TextBlock"
		   BasedOn="{StaticResource SimpleBaseTextBlockStyle}">
		<Setter Property="FontSize" Value="12" />
		<Setter Property="FontWeight" Value="Normal" />
	</Style>

	<Style x:Key="SimpleCaptionLarge"
		   TargetType="TextBlock"
		   BasedOn="{StaticResource SimpleBaseTextBlockStyle}">
		<Setter Property="FontSize" Value="14" />
		<Setter Property="FontWeight" Value="Normal" />
	</Style>

	<Style x:Key="SimpleCaptionMedium"
		   TargetType="TextBlock"
		   BasedOn="{StaticResource SimpleBaseTextBlockStyle}">
		<Setter Property="FontSize" Value="12" />
		<Setter Property="FontWeight" Value="Normal" />
	</Style>

	<Style x:Key="SimpleCaptionSmall"
		   TargetType="TextBlock"
		   BasedOn="{StaticResource SimpleBaseTextBlockStyle}">
		<Setter Property="FontSize" Value="12" />
		<Setter Property="FontWeight" Value="Normal" />
	</Style>

	<Style x:Key="SimpleDefaultTextBlockStyle"
		   TargetType="TextBlock"
		   BasedOn="{StaticResource SimpleBodyMedium}" />
</ResourceDictionary>
