<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
					xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

	<!--
		Simple Design System — TextBlock Typography Styles

		All styles reference the shared semantic typography tokens
		(DisplayLargeFontFamily, BodyLargeFontSize, etc.) from
		SharedTypography.xaml, overridden for Simple in Fonts.xaml.

		The Material-compatible aliases (SimpleDisplayLarge, etc.)
		are referenced from _Resources.xaml to provide the unprefixed
		theme-agnostic keys (DisplayLarge, BodyMedium, etc.).
	-->

	<!-- ═══════════════════════════════════════════════════════════════════════ -->
	<!-- Base TextBlock Style -->
	<!-- ═══════════════════════════════════════════════════════════════════════ -->
	<Style x:Key="SimpleBaseTextBlockStyle"
		   TargetType="TextBlock">
		<Setter Property="FontFamily" Value="{ThemeResource BodyLargeFontFamily}" />
		<Setter Property="FontWeight" Value="Normal" />
		<Setter Property="Foreground" Value="{ThemeResource OnSurfaceBrush}" />
		<Setter Property="TextWrapping" Value="Wrap" />
		<Setter Property="TextTrimming" Value="CharacterEllipsis" />
		<Setter Property="IsTextScaleFactorEnabled" Value="False" />
	</Style>

	<!-- ═══════════════════════════════════════════════════════════════════════ -->
	<!-- DISPLAY -->
	<!-- ═══════════════════════════════════════════════════════════════════════ -->

	<!-- Display Large -->
	<Style x:Key="SimpleDisplayLarge"
		   TargetType="TextBlock"
		   BasedOn="{StaticResource SimpleBaseTextBlockStyle}">
		<Setter Property="FontFamily" Value="{ThemeResource DisplayLargeFontFamily}" />
		<Setter Property="FontWeight" Value="{ThemeResource DisplayLargeFontWeight}" />
		<Setter Property="FontSize" Value="{ThemeResource DisplayLargeFontSize}" />
		<Setter Property="CharacterSpacing" Value="{ThemeResource DisplayLargeCharacterSpacing}" />
	</Style>

	<!-- Display Medium -->
	<Style x:Key="SimpleDisplayMedium"
		   TargetType="TextBlock"
		   BasedOn="{StaticResource SimpleBaseTextBlockStyle}">
