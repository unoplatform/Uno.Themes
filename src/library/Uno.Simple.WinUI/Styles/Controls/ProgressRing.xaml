<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
					xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
					xmlns:muxc="using:Microsoft.UI.Xaml.Controls">

	<!--
		Simple Design System — ProgressRing Style
		Circular/ring progress indicator using Simple's brand (accent) and track colors.
		Supports both determinate and indeterminate states via the built-in ProgressRing control.
		
		Resource layers:
		ProgressRing*       = semantic keys (source of truth)
		SimpleProgressRing* = Simple-prefixed aliases → ProgressRing*
	-->

	<ResourceDictionary.ThemeDictionaries>

		<!-- ─── Light Theme ─── -->
		<ResourceDictionary x:Key="Light">
			<StaticResource x:Key="ProgressRingForeground" ResourceKey="SimpleBackgroundBrandDefaultBrush" />
			<StaticResource x:Key="ProgressRingBackground" ResourceKey="SimpleBackgroundDefaultSecondaryBrush" />

			<!-- Backwards-compat aliases -->
		</ResourceDictionary>

		<!-- ─── Dark Theme (Default) ─── -->
		<ResourceDictionary x:Key="Default">
			<StaticResource x:Key="ProgressRingForeground" ResourceKey="SimpleBackgroundBrandDefaultBrush" />
			<StaticResource x:Key="ProgressRingBackground" ResourceKey="SimpleBackgroundDefaultTertiaryBrush" />

		</ResourceDictionary>

	</ResourceDictionary.ThemeDictionaries>

	<!-- ═══════════════════════════════════════════════════════════════════════ -->
	<!-- ProgressRing Style -->
	<!-- ═══════════════════════════════════════════════════════════════════════ -->
	<Style x:Key="SimpleProgressRingStyle"
		   TargetType="muxc:ProgressRing">
		<Setter Property="Foreground" Value="{ThemeResource ProgressRingForeground}" />
		<Setter Property="Background" Value="{ThemeResource ProgressRingBackground}" />
	</Style>

	<!-- ═══════════════════════════════════════════════════════════════════════ -->
	<!-- Default alias -->
	<!-- ═══════════════════════════════════════════════════════════════════════ -->
	<Style x:Key="SimpleDefaultProgressRingStyle"
		   TargetType="muxc:ProgressRing"
		   BasedOn="{StaticResource SimpleProgressRingStyle}" />

</ResourceDictionary>
