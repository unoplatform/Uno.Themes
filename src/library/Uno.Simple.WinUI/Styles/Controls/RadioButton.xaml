<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
					xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

	<!--
		Simple Design System — RadioButton Style
		Lightweight styling: every visual-state brush is exposed via ThemeResource.

		Semantic resource layer:
		  RadioButtonOuterEllipseFill*          = Unchecked background  (was SimpleRadioButtonUncheckedBackground*)
		  RadioButtonOuterEllipseStroke*        = Unchecked border      (was SimpleRadioButtonUncheckedBorderBrush*)
		  RadioButtonOuterEllipseCheckedFill*   = Checked background    (was SimpleRadioButtonCheckedBackground*)
		  RadioButtonOuterEllipseCheckedStroke* = Checked border        (was SimpleRadioButtonCheckedBorderBrush*)
		  RadioButtonForeground*                = Label text            (was SimpleRadioButtonForeground*)

		Backwards-compat aliases are provided for all old Simple-prefixed names.

		Simple-only keys (no semantic rename):
		  SimpleRadioButtonCheckedDotFill* — no Material equivalent

		States: Unchecked/Checked × Normal/PointerOver/Pressed/Disabled (CombinedStates)
		SDS source: Radio/radio.css
	-->

	<!-- ═══════════════════════════════════════════════════════════════════════ -->
	<!-- Lightweight styling ThemeResource aliases                              -->
	<!-- ═══════════════════════════════════════════════════════════════════════ -->
	<ResourceDictionary.ThemeDictionaries>

		<!-- ─── Light Theme ─── -->
		<ResourceDictionary x:Key="Light">

			<!-- ── Unchecked Background — semantic keys (source of truth) ── -->
			<StaticResource x:Key="RadioButtonOuterEllipseFill"                             ResourceKey="SimpleBackgroundDefaultDefaultBrush" />
			<StaticResource x:Key="RadioButtonOuterEllipseFillPointerOver"                  ResourceKey="SimpleBackgroundDefaultDefaultBrush" />
			<StaticResource x:Key="RadioButtonOuterEllipseFillPressed"                      ResourceKey="SimpleBackgroundDefaultDefaultPressedBrush" />
			<StaticResource x:Key="RadioButtonOuterEllipseFillDisabled"                     ResourceKey="SimpleBackgroundDisabledDefaultBrush" />
			<!-- Backwards-compat aliases (SimpleRadioButtonUncheckedBackground* → RadioButtonOuterEllipseFill*) -->
			<StaticResource x:Key="SimpleRadioButtonUncheckedBackground"                    ResourceKey="RadioButtonOuterEllipseFill" />
			<StaticResource x:Key="SimpleRadioButtonUncheckedBackgroundPointerOver"         ResourceKey="RadioButtonOuterEllipseFillPointerOver" />
			<StaticResource x:Key="SimpleRadioButtonUncheckedBackgroundPressed"             ResourceKey="RadioButtonOuterEllipseFillPressed" />
			<StaticResource x:Key="SimpleRadioButtonUncheckedBackgroundDisabled"            ResourceKey="RadioButtonOuterEllipseFillDisabled" />

			<!-- ── Unchecked Border — semantic keys (source of truth) ── -->
			<StaticResource x:Key="RadioButtonOuterEllipseStroke"                           ResourceKey="SimpleBorderDefaultDefaultBrush" />
			<StaticResource x:Key="RadioButtonOuterEllipseStrokePointerOver"                ResourceKey="SimpleBorderDefaultDefaultBrush" />
			<StaticResource x:Key="RadioButtonOuterEllipseStrokePressed"                    ResourceKey="SimpleBorderDefaultDefaultBrush" />
			<StaticResource x:Key="RadioButtonOuterEllipseStrokeDisabled"                   ResourceKey="SimpleBorderDisabledDefaultBrush" />
			<!-- Backwards-compat aliases (SimpleRadioButtonUncheckedBorderBrush* → RadioButtonOuterEllipseStroke*) -->
			<StaticResource x:Key="SimpleRadioButtonUncheckedBorderBrush"                   ResourceKey="RadioButtonOuterEllipseStroke" />
			<StaticResource x:Key="SimpleRadioButtonUncheckedBorderBrushPointerOver"        ResourceKey="RadioButtonOuterEllipseStrokePointerOver" />
			<StaticResource x:Key="SimpleRadioButtonUncheckedBorderBrushPressed"            ResourceKey="RadioButtonOuterEllipseStrokePressed" />
			<StaticResource x:Key="SimpleRadioButtonUncheckedBorderBrushDisabled"           ResourceKey="RadioButtonOuterEllipseStrokeDisabled" />

			<!-- ── Checked Background — semantic keys (source of truth) ── -->
			<StaticResource x:Key="RadioButtonOuterEllipseCheckedFill"                      ResourceKey="SimpleBackgroundBrandDefaultBrush" />
			<StaticResource x:Key="RadioButtonOuterEllipseCheckedFillPointerOver"           ResourceKey="SimpleBackgroundBrandDefaultBrush" />
			<StaticResource x:Key="RadioButtonOuterEllipseCheckedFillPressed"               ResourceKey="SimpleBackgroundBrandPressedBrush" />
			<StaticResource x:Key="RadioButtonOuterEllipseCheckedFillDisabled"              ResourceKey="SimpleBackgroundDisabledDefaultBrush" />
			<!-- Backwards-compat aliases (SimpleRadioButtonCheckedBackground* → RadioButtonOuterEllipseCheckedFill*) -->
			<StaticResource x:Key="SimpleRadioButtonCheckedBackground"                      ResourceKey="RadioButtonOuterEllipseCheckedFill" />
			<StaticResource x:Key="SimpleRadioButtonCheckedBackgroundPointerOver"           ResourceKey="RadioButtonOuterEllipseCheckedFillPointerOver" />
			<StaticResource x:Key="SimpleRadioButtonCheckedBackgroundPressed"               ResourceKey="RadioButtonOuterEllipseCheckedFillPressed" />
			<StaticResource x:Key="SimpleRadioButtonCheckedBackgroundDisabled"              ResourceKey="RadioButtonOuterEllipseCheckedFillDisabled" />

			<!-- ── Checked Border — semantic keys (source of truth) ── -->
			<StaticResource x:Key="RadioButtonOuterEllipseCheckedStroke"                    ResourceKey="SimpleBackgroundBrandDefaultBrush" />
			<StaticResource x:Key="RadioButtonOuterEllipseCheckedStrokePointerOver"         ResourceKey="SimpleBackgroundBrandDefaultBrush" />
			<StaticResource x:Key="RadioButtonOuterEllipseCheckedStrokePressed"             ResourceKey="SimpleBackgroundBrandPressedBrush" />
			<StaticResource x:Key="RadioButtonOuterEllipseCheckedStrokeDisabled"            ResourceKey="SimpleBorderDisabledDefaultBrush" />
			<!-- Backwards-compat aliases (SimpleRadioButtonCheckedBorderBrush* → RadioButtonOuterEllipseCheckedStroke*) -->
			<StaticResource x:Key="SimpleRadioButtonCheckedBorderBrush"                     ResourceKey="RadioButtonOuterEllipseCheckedStroke" />
			<StaticResource x:Key="SimpleRadioButtonCheckedBorderBrushPointerOver"          ResourceKey="RadioButtonOuterEllipseCheckedStrokePointerOver" />
			<StaticResource x:Key="SimpleRadioButtonCheckedBorderBrushPressed"              ResourceKey="RadioButtonOuterEllipseCheckedStrokePressed" />
			<StaticResource x:Key="SimpleRadioButtonCheckedBorderBrushDisabled"             ResourceKey="RadioButtonOuterEllipseCheckedStrokeDisabled" />

			<!-- ── Checked Dot Fill (Simple-only — no semantic rename) ── -->
			<StaticResource x:Key="SimpleRadioButtonCheckedDotFill"                         ResourceKey="SimpleIconBrandOnBrandBrush" />
			<StaticResource x:Key="SimpleRadioButtonCheckedDotFillPointerOver"              ResourceKey="SimpleIconBrandOnBrandBrush" />
			<StaticResource x:Key="SimpleRadioButtonCheckedDotFillPressed"                  ResourceKey="SimpleIconBrandOnBrandBrush" />
			<StaticResource x:Key="SimpleRadioButtonCheckedDotFillDisabled"                 ResourceKey="SimpleIconDisabledOnDisabledBrush" />

			<!-- ── Foreground (label) — semantic keys (source of truth) ── -->
			<StaticResource x:Key="RadioButtonForeground"                                   ResourceKey="SimpleTextDefaultDefaultBrush" />
			<StaticResource x:Key="RadioButtonForegroundPointerOver"                        ResourceKey="SimpleTextDefaultDefaultBrush" />
			<StaticResource x:Key="RadioButtonForegroundPressed"                            ResourceKey="SimpleTextDefaultDefaultBrush" />
			<StaticResource x:Key="RadioButtonForegroundDisabled"                           ResourceKey="SimpleTextDisabledDefaultBrush" />
			<!-- Backwards-compat aliases (SimpleRadioButtonForeground* → RadioButtonForeground*) -->
			<StaticResource x:Key="SimpleRadioButtonForeground"                             ResourceKey="RadioButtonForeground" />
			<StaticResource x:Key="SimpleRadioButtonForegroundPointerOver"                  ResourceKey="RadioButtonForegroundPointerOver" />
			<StaticResource x:Key="SimpleRadioButtonForegroundPressed"                      ResourceKey="RadioButtonForegroundPressed" />
			<StaticResource x:Key="SimpleRadioButtonForegroundDisabled"                     ResourceKey="RadioButtonForegroundDisabled" />
		</ResourceDictionary>

		<!-- ─── Dark Theme (Default) ─── -->
		<ResourceDictionary x:Key="Default">

			<!-- ── Unchecked Background — semantic keys (source of truth) ── -->
			<StaticResource x:Key="RadioButtonOuterEllipseFill"                             ResourceKey="SimpleBackgroundDefaultDefaultBrush" />
			<StaticResource x:Key="RadioButtonOuterEllipseFillPointerOver"                  ResourceKey="SimpleBackgroundDefaultDefaultBrush" />
			<StaticResource x:Key="RadioButtonOuterEllipseFillPressed"                      ResourceKey="SimpleBackgroundDefaultDefaultPressedBrush" />
			<StaticResource x:Key="RadioButtonOuterEllipseFillDisabled"                     ResourceKey="SimpleBackgroundDisabledDefaultBrush" />
			<!-- Backwards-compat aliases (SimpleRadioButtonUncheckedBackground* → RadioButtonOuterEllipseFill*) -->
			<StaticResource x:Key="SimpleRadioButtonUncheckedBackground"                    ResourceKey="RadioButtonOuterEllipseFill" />
			<StaticResource x:Key="SimpleRadioButtonUncheckedBackgroundPointerOver"         ResourceKey="RadioButtonOuterEllipseFillPointerOver" />
			<StaticResource x:Key="SimpleRadioButtonUncheckedBackgroundPressed"             ResourceKey="RadioButtonOuterEllipseFillPressed" />
			<StaticResource x:Key="SimpleRadioButtonUncheckedBackgroundDisabled"            ResourceKey="RadioButtonOuterEllipseFillDisabled" />

			<!-- ── Unchecked Border — semantic keys (source of truth) ── -->
			<StaticResource x:Key="RadioButtonOuterEllipseStroke"                           ResourceKey="SimpleBorderDefaultDefaultBrush" />
			<StaticResource x:Key="RadioButtonOuterEllipseStrokePointerOver"                ResourceKey="SimpleBorderDefaultDefaultBrush" />
			<StaticResource x:Key="RadioButtonOuterEllipseStrokePressed"                    ResourceKey="SimpleBorderDefaultDefaultBrush" />
			<StaticResource x:Key="RadioButtonOuterEllipseStrokeDisabled"                   ResourceKey="SimpleBorderDisabledDefaultBrush" />
			<!-- Backwards-compat aliases (SimpleRadioButtonUncheckedBorderBrush* → RadioButtonOuterEllipseStroke*) -->
			<StaticResource x:Key="SimpleRadioButtonUncheckedBorderBrush"                   ResourceKey="RadioButtonOuterEllipseStroke" />
			<StaticResource x:Key="SimpleRadioButtonUncheckedBorderBrushPointerOver"        ResourceKey="RadioButtonOuterEllipseStrokePointerOver" />
			<StaticResource x:Key="SimpleRadioButtonUncheckedBorderBrushPressed"            ResourceKey="RadioButtonOuterEllipseStrokePressed" />
			<StaticResource x:Key="SimpleRadioButtonUncheckedBorderBrushDisabled"           ResourceKey="RadioButtonOuterEllipseStrokeDisabled" />

			<!-- ── Checked Background — semantic keys (source of truth) ── -->
			<StaticResource x:Key="RadioButtonOuterEllipseCheckedFill"                      ResourceKey="SimpleBackgroundBrandDefaultBrush" />
			<StaticResource x:Key="RadioButtonOuterEllipseCheckedFillPointerOver"           ResourceKey="SimpleBackgroundBrandDefaultBrush" />
			<StaticResource x:Key="RadioButtonOuterEllipseCheckedFillPressed"               ResourceKey="SimpleBackgroundBrandPressedBrush" />
			<StaticResource x:Key="RadioButtonOuterEllipseCheckedFillDisabled"              ResourceKey="SimpleBackgroundDisabledDefaultBrush" />
			<!-- Backwards-compat aliases (SimpleRadioButtonCheckedBackground* → RadioButtonOuterEllipseCheckedFill*) -->
			<StaticResource x:Key="SimpleRadioButtonCheckedBackground"                      ResourceKey="RadioButtonOuterEllipseCheckedFill" />
			<StaticResource x:Key="SimpleRadioButtonCheckedBackgroundPointerOver"           ResourceKey="RadioButtonOuterEllipseCheckedFillPointerOver" />
			<StaticResource x:Key="SimpleRadioButtonCheckedBackgroundPressed"               ResourceKey="RadioButtonOuterEllipseCheckedFillPressed" />
			<StaticResource x:Key="SimpleRadioButtonCheckedBackgroundDisabled"              ResourceKey="RadioButtonOuterEllipseCheckedFillDisabled" />

			<!-- ── Checked Border — semantic keys (source of truth) ── -->
			<StaticResource x:Key="RadioButtonOuterEllipseCheckedStroke"                    ResourceKey="SimpleBackgroundBrandDefaultBrush" />
			<StaticResource x:Key="RadioButtonOuterEllipseCheckedStrokePointerOver"         ResourceKey="SimpleBackgroundBrandDefaultBrush" />
			<StaticResource x:Key="RadioButtonOuterEllipseCheckedStrokePressed"             ResourceKey="SimpleBackgroundBrandPressedBrush" />
			<StaticResource x:Key="RadioButtonOuterEllipseCheckedStrokeDisabled"            ResourceKey="SimpleBorderDisabledDefaultBrush" />
			<!-- Backwards-compat aliases (SimpleRadioButtonCheckedBorderBrush* → RadioButtonOuterEllipseCheckedStroke*) -->
			<StaticResource x:Key="SimpleRadioButtonCheckedBorderBrush"                     ResourceKey="RadioButtonOuterEllipseCheckedStroke" />
			<StaticResource x:Key="SimpleRadioButtonCheckedBorderBrushPointerOver"          ResourceKey="RadioButtonOuterEllipseCheckedStrokePointerOver" />
			<StaticResource x:Key="SimpleRadioButtonCheckedBorderBrushPressed"              ResourceKey="RadioButtonOuterEllipseCheckedStrokePressed" />
			<StaticResource x:Key="SimpleRadioButtonCheckedBorderBrushDisabled"             ResourceKey="RadioButtonOuterEllipseCheckedStrokeDisabled" />

			<!-- ── Checked Dot Fill (Simple-only — no semantic rename) ── -->
			<StaticResource x:Key="SimpleRadioButtonCheckedDotFill"                         ResourceKey="SimpleIconBrandOnBrandBrush" />
			<StaticResource x:Key="SimpleRadioButtonCheckedDotFillPointerOver"              ResourceKey="SimpleIconBrandOnBrandBrush" />
			<StaticResource x:Key="SimpleRadioButtonCheckedDotFillPressed"                  ResourceKey="SimpleIconBrandOnBrandBrush" />
			<StaticResource x:Key="SimpleRadioButtonCheckedDotFillDisabled"                 ResourceKey="SimpleIconDisabledOnDisabledBrush" />

			<!-- ── Foreground (label) — semantic keys (source of truth) ── -->
			<StaticResource x:Key="RadioButtonForeground"                                   ResourceKey="SimpleTextDefaultDefaultBrush" />
			<StaticResource x:Key="RadioButtonForegroundPointerOver"                        ResourceKey="SimpleTextDefaultDefaultBrush" />
			<StaticResource x:Key="RadioButtonForegroundPressed"                            ResourceKey="SimpleTextDefaultDefaultBrush" />
			<StaticResource x:Key="RadioButtonForegroundDisabled"                           ResourceKey="SimpleTextDisabledDefaultBrush" />
			<!-- Backwards-compat aliases (SimpleRadioButtonForeground* → RadioButtonForeground*) -->
			<StaticResource x:Key="SimpleRadioButtonForeground"                             ResourceKey="RadioButtonForeground" />
			<StaticResource x:Key="SimpleRadioButtonForegroundPointerOver"                  ResourceKey="RadioButtonForegroundPointerOver" />
			<StaticResource x:Key="SimpleRadioButtonForegroundPressed"                      ResourceKey="RadioButtonForegroundPressed" />
			<StaticResource x:Key="SimpleRadioButtonForegroundDisabled"                     ResourceKey="RadioButtonForegroundDisabled" />
		</ResourceDictionary>

	</ResourceDictionary.ThemeDictionaries>

	<!-- ═══════════════════════════════════════════════════════════════════════ -->
	<!-- Layout / sizing resources (theme-agnostic)                            -->
	<!-- ═══════════════════════════════════════════════════════════════════════ -->
	<!-- sds-size-space-400 -->
	<StaticResource x:Key="SimpleRadioButtonSize" ResourceKey="SimpleSpace400" />
	<!-- sds-size-space-200 -->
	<StaticResource x:Key="SimpleRadioButtonDotSize" ResourceKey="SimpleSpace200" />
	<!-- sds-size-stroke-border -->
	<StaticResource x:Key="SimpleRadioButtonStrokeThickness" ResourceKey="SimpleStrokeBorder" />
	<!-- sds-size-space-400,0,0,0 -->
	<Thickness x:Key="SimpleRadioButtonContentMargin">16,0,0,0</Thickness>
	<!-- sds-size-space-400 -->
	<GridLength x:Key="SimpleRadioButtonColumnWidth">16</GridLength>

	<!-- ═══════════════════════════════════════════════════════════════════════ -->
	<!-- SimpleRadioButtonStyle                                                 -->
	<!-- ═══════════════════════════════════════════════════════════════════════ -->
	<Style x:Key="SimpleRadioButtonStyle"
		   TargetType="RadioButton">
		<Setter Property="Background" Value="Transparent" />
		<Setter Property="Foreground" Value="{ThemeResource RadioButtonForeground}" />
		<Setter Property="BorderBrush" Value="Transparent" />
		<Setter Property="BorderThickness" Value="0" />
		<Setter Property="FontFamily" Value="{ThemeResource SimpleFontFamily}" />
		<Setter Property="FontSize" Value="14" />
		<Setter Property="FontWeight" Value="Normal" />
		<Setter Property="HorizontalAlignment" Value="Left" />
		<Setter Property="VerticalAlignment" Value="Center" />
		<Setter Property="HorizontalContentAlignment" Value="Left" />
		<Setter Property="VerticalContentAlignment" Value="Center" />
		<Setter Property="MinWidth" Value="0" />
		<Setter Property="MinHeight" Value="32" />
		<Setter Property="UseSystemFocusVisuals" Value="{StaticResource UseSystemFocusVisuals}" />
		<Setter Property="FocusVisualMargin" Value="-3" />
		<Setter Property="Template">
			<Setter.Value>
				<ControlTemplate TargetType="RadioButton">
					<Grid x:Name="RootGrid"
						  Background="{TemplateBinding Background}"
						  BorderBrush="{TemplateBinding BorderBrush}"
						  BorderThickness="{TemplateBinding BorderThickness}">

						<Grid.ColumnDefinitions>
							<ColumnDefinition Width="{StaticResource SimpleRadioButtonColumnWidth}" />
							<ColumnDefinition Width="*" />
						</Grid.ColumnDefinitions>

						<VisualStateManager.VisualStateGroups>

							<!-- ──── CommonStates ──── -->
							<VisualStateGroup x:Name="CommonStates">
								<VisualState x:Name="Normal" />

								<VisualState x:Name="PointerOver">
									<VisualState.Setters>
										<Setter Target="ContentPresenter.Foreground" Value="{ThemeResource RadioButtonForegroundPointerOver}" />
									</VisualState.Setters>
								</VisualState>

								<VisualState x:Name="Pressed">
									<VisualState.Setters>
										<Setter Target="ContentPresenter.Foreground" Value="{ThemeResource RadioButtonForegroundPressed}" />
									</VisualState.Setters>
								</VisualState>

								<VisualState x:Name="Disabled">
									<VisualState.Setters>
										<!-- Unchecked element disabled colors -->
										<Setter Target="RadioBorder.Fill" Value="{ThemeResource RadioButtonOuterEllipseFillDisabled}" />
										<Setter Target="RadioBorder.Stroke" Value="{ThemeResource RadioButtonOuterEllipseStrokeDisabled}" />
										<!-- Checked element disabled colors -->
										<Setter Target="RadioBorder_Checked.Fill" Value="{ThemeResource RadioButtonOuterEllipseCheckedFillDisabled}" />
										<Setter Target="RadioBorder_Checked.Stroke" Value="{ThemeResource RadioButtonOuterEllipseCheckedStrokeDisabled}" />
										<Setter Target="RadioDot.Fill" Value="{ThemeResource SimpleRadioButtonCheckedDotFillDisabled}" />
										<!-- Label -->
										<Setter Target="ContentPresenter.Foreground" Value="{ThemeResource RadioButtonForegroundDisabled}" />
									</VisualState.Setters>
								</VisualState>
							</VisualStateGroup>

							<!-- ──── CheckStates ──── -->
							<VisualStateGroup x:Name="CheckStates">
								<VisualState x:Name="Checked">
									<VisualState.Setters>
										<Setter Target="RadioBorder_Checked.Opacity" Value="1" />
										<Setter Target="RadioBorder.Opacity" Value="0" />
										<Setter Target="RadioDot.Opacity" Value="1" />
									</VisualState.Setters>
								</VisualState>

								<VisualState x:Name="Unchecked" />

								<VisualState x:Name="Indeterminate" />
							</VisualStateGroup>
						</VisualStateManager.VisualStateGroups>

						<!-- Radio Circle -->
						<Grid x:Name="RadioContainer"
							  Grid.Column="0"
							  Width="{StaticResource SimpleRadioButtonSize}"
							  Height="{StaticResource SimpleRadioButtonSize}"
							  HorizontalAlignment="Center"
							  VerticalAlignment="Center">

							<!-- Unchecked outer circle -->
							<Ellipse x:Name="RadioBorder"
									 Width="{StaticResource SimpleRadioButtonSize}"
									 Height="{StaticResource SimpleRadioButtonSize}"
									 Fill="{ThemeResource RadioButtonOuterEllipseFill}"
									 Stroke="{ThemeResource RadioButtonOuterEllipseStroke}"
									 StrokeThickness="{StaticResource SimpleRadioButtonStrokeThickness}" />

							<!-- Checked outer circle (hidden by default) -->
							<Ellipse x:Name="RadioBorder_Checked"
									 Width="{StaticResource SimpleRadioButtonSize}"
									 Height="{StaticResource SimpleRadioButtonSize}"
									 Fill="{ThemeResource RadioButtonOuterEllipseCheckedFill}"
									 Stroke="{ThemeResource RadioButtonOuterEllipseCheckedStroke}"
									 StrokeThickness="{StaticResource SimpleRadioButtonStrokeThickness}"
									 Opacity="0" />

							<!-- Inner dot (hidden by default) -->
							<Ellipse x:Name="RadioDot"
									 Width="{StaticResource SimpleRadioButtonDotSize}"
									 Height="{StaticResource SimpleRadioButtonDotSize}"
									 Fill="{ThemeResource SimpleRadioButtonCheckedDotFill}"
									 HorizontalAlignment="Center"
									 VerticalAlignment="Center"
									 Opacity="0" />
						</Grid>

						<!-- Content (label) -->
						<ContentPresenter x:Name="ContentPresenter"
										  Grid.Column="1"
										  Margin="{StaticResource SimpleRadioButtonContentMargin}"
										  Content="{TemplateBinding Content}"
										  ContentTemplate="{TemplateBinding ContentTemplate}"
										  ContentTransitions="{TemplateBinding ContentTransitions}"
										  Foreground="{TemplateBinding Foreground}"
										  HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
										  VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
										  AutomationProperties.AccessibilityView="Raw"
										  TextWrapping="Wrap" />
					</Grid>
				</ControlTemplate>
			</Setter.Value>
		</Setter>
	</Style>

</ResourceDictionary>
