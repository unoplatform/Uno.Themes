<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
					xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

	<!--
		Simple Design System — PasswordBox Styles
		Maps SDS Input component tokens to WinUI PasswordBox.
		Same visual treatment as TextBox (SDS Input outlined style).

		Resource layers:
		  FilledPasswordBox*  = semantic keys (source of truth)
		  SimplePasswordBox*  = Simple-prefixed aliases → FilledPasswordBox*

		Templates reference Simple-prefixed keys (which alias to semantic keys).
		This allows overriding EITHER the Simple-prefixed key OR the semantic key.

		OutlinedPasswordBox* is a GAP (no Simple equivalent) — skipped.
	-->

	<!-- ═══════════════════════════════════════════════════════════════════════ -->
	<!-- Lightweight styling ThemeResource aliases                              -->
	<!-- ═══════════════════════════════════════════════════════════════════════ -->
	<ResourceDictionary.ThemeDictionaries>

		<!-- ─── Light Theme ─── -->
		<ResourceDictionary x:Key="Light">

			<!-- ── FilledPasswordBox — semantic keys (source of truth) ── -->

			<!-- Sizing -->
			<StaticResource x:Key="FilledPasswordBoxCornerRadius" ResourceKey="SimpleRadius200CornerRadius" /> <!-- sds-size-radius-200 -->
			<StaticResource x:Key="FilledPasswordBoxBorderThickness" ResourceKey="SimpleStrokeBorderThickness" /> <!-- sds-size-stroke-border -->
			<StaticResource x:Key="FilledPasswordBoxFocusedBorderThickness" ResourceKey="SimpleStrokeFocusRingThickness" /> <!-- sds-size-stroke-focus-ring -->
			<!-- H: sds-size-space-400, V: sds-size-space-100+sds-size-space-150 -->
			<Thickness x:Key="FilledPasswordBoxPadding">16,10,16,10</Thickness>
			<StaticResource x:Key="FilledPasswordBoxMinHeight" ResourceKey="SimpleIconLarge" /> <!-- sds-size-icon-large -->
			<!-- B: sds-size-space-100 -->
			<Thickness x:Key="FilledPasswordBoxHeaderMargin">0,0,0,4</Thickness>

			<!-- Normal state -->
			<StaticResource x:Key="FilledPasswordBoxForeground" ResourceKey="SimpleTextDefaultDefaultBrush" />
			<StaticResource x:Key="FilledPasswordBoxBackground" ResourceKey="SimpleBackgroundDefaultDefaultBrush" />
			<StaticResource x:Key="FilledPasswordBoxBorderBrush" ResourceKey="SimpleBorderDefaultDefaultBrush" />
			<StaticResource x:Key="FilledPasswordBoxPlaceholderForeground" ResourceKey="SimpleTextDefaultTertiaryBrush" />

			<!-- PointerOver state -->
			<StaticResource x:Key="FilledPasswordBoxForegroundPointerOver" ResourceKey="SimpleTextDefaultDefaultBrush" />
			<StaticResource x:Key="FilledPasswordBoxBackgroundPointerOver" ResourceKey="SimpleBackgroundDefaultDefaultBrush" />
			<StaticResource x:Key="FilledPasswordBoxBorderBrushPointerOver" ResourceKey="SimpleBorderDefaultDefaultBrush" />

			<!-- Focused state -->
			<StaticResource x:Key="FilledPasswordBoxForegroundFocused" ResourceKey="SimpleTextDefaultDefaultBrush" />
			<StaticResource x:Key="FilledPasswordBoxBackgroundFocused" ResourceKey="SimpleBackgroundDefaultDefaultBrush" />
			<StaticResource x:Key="FilledPasswordBoxBorderBrushFocused" ResourceKey="SimpleBorderBrandSecondaryBrush" />

			<!-- Disabled state -->
			<StaticResource x:Key="FilledPasswordBoxForegroundDisabled" ResourceKey="SimpleTextDisabledDefaultBrush" />
			<StaticResource x:Key="FilledPasswordBoxBackgroundDisabled" ResourceKey="SimpleBackgroundDisabledDefaultBrush" />
			<StaticResource x:Key="FilledPasswordBoxBorderBrushDisabled" ResourceKey="SimpleBorderDisabledDefaultBrush" />
			<StaticResource x:Key="FilledPasswordBoxPlaceholderForegroundDisabled" ResourceKey="SimpleTextDisabledDefaultBrush" />

			<!-- Reveal button -->
			<StaticResource x:Key="FilledPasswordBoxRevealForeground" ResourceKey="SimpleIconDefaultDefaultBrush" />
			<StaticResource x:Key="FilledPasswordBoxRevealForegroundPointerOver" ResourceKey="SimpleIconDefaultDefaultBrush" />
			<StaticResource x:Key="FilledPasswordBoxRevealForegroundPressed" ResourceKey="SimpleIconDefaultDefaultBrush" />

			<!-- Header / label -->
			<StaticResource x:Key="FilledPasswordBoxHeaderForeground" ResourceKey="SimpleTextDefaultDefaultBrush" />
			<StaticResource x:Key="FilledPasswordBoxHeaderForegroundDisabled" ResourceKey="SimpleTextDisabledDefaultBrush" />

			<!-- Backwards-compat aliases (SimplePasswordBox* → FilledPasswordBox*) -->
			<StaticResource x:Key="SimplePasswordBoxCornerRadius" ResourceKey="FilledPasswordBoxCornerRadius" />
			<StaticResource x:Key="SimplePasswordBoxBorderThickness" ResourceKey="FilledPasswordBoxBorderThickness" />
			<StaticResource x:Key="SimplePasswordBoxFocusedBorderThickness" ResourceKey="FilledPasswordBoxFocusedBorderThickness" />
			<StaticResource x:Key="SimplePasswordBoxPadding" ResourceKey="FilledPasswordBoxPadding" />
			<StaticResource x:Key="SimplePasswordBoxMinHeight" ResourceKey="FilledPasswordBoxMinHeight" />
			<StaticResource x:Key="SimplePasswordBoxHeaderMargin" ResourceKey="FilledPasswordBoxHeaderMargin" />
			<StaticResource x:Key="SimplePasswordBoxForeground" ResourceKey="FilledPasswordBoxForeground" />
			<StaticResource x:Key="SimplePasswordBoxBackground" ResourceKey="FilledPasswordBoxBackground" />
			<StaticResource x:Key="SimplePasswordBoxBorderBrush" ResourceKey="FilledPasswordBoxBorderBrush" />
			<StaticResource x:Key="SimplePasswordBoxPlaceholderForeground" ResourceKey="FilledPasswordBoxPlaceholderForeground" />
			<StaticResource x:Key="SimplePasswordBoxForegroundPointerOver" ResourceKey="FilledPasswordBoxForegroundPointerOver" />
			<StaticResource x:Key="SimplePasswordBoxBackgroundPointerOver" ResourceKey="FilledPasswordBoxBackgroundPointerOver" />
			<StaticResource x:Key="SimplePasswordBoxBorderBrushPointerOver" ResourceKey="FilledPasswordBoxBorderBrushPointerOver" />
			<StaticResource x:Key="SimplePasswordBoxForegroundFocused" ResourceKey="FilledPasswordBoxForegroundFocused" />
			<StaticResource x:Key="SimplePasswordBoxBackgroundFocused" ResourceKey="FilledPasswordBoxBackgroundFocused" />
			<StaticResource x:Key="SimplePasswordBoxBorderBrushFocused" ResourceKey="FilledPasswordBoxBorderBrushFocused" />
			<StaticResource x:Key="SimplePasswordBoxForegroundDisabled" ResourceKey="FilledPasswordBoxForegroundDisabled" />
			<StaticResource x:Key="SimplePasswordBoxBackgroundDisabled" ResourceKey="FilledPasswordBoxBackgroundDisabled" />
			<StaticResource x:Key="SimplePasswordBoxBorderBrushDisabled" ResourceKey="FilledPasswordBoxBorderBrushDisabled" />
			<StaticResource x:Key="SimplePasswordBoxPlaceholderForegroundDisabled" ResourceKey="FilledPasswordBoxPlaceholderForegroundDisabled" />
			<StaticResource x:Key="SimplePasswordBoxRevealForeground" ResourceKey="FilledPasswordBoxRevealForeground" />
			<StaticResource x:Key="SimplePasswordBoxRevealForegroundPointerOver" ResourceKey="FilledPasswordBoxRevealForegroundPointerOver" />
			<StaticResource x:Key="SimplePasswordBoxRevealForegroundPressed" ResourceKey="FilledPasswordBoxRevealForegroundPressed" />
			<StaticResource x:Key="SimplePasswordBoxHeaderForeground" ResourceKey="FilledPasswordBoxHeaderForeground" />
			<StaticResource x:Key="SimplePasswordBoxHeaderForegroundDisabled" ResourceKey="FilledPasswordBoxHeaderForegroundDisabled" />

			<!-- ── OutlinedPasswordBox — semantic keys (outlined variant: transparent bg) ── -->
			<StaticResource x:Key="OutlinedPasswordBoxCornerRadius" ResourceKey="FilledPasswordBoxCornerRadius" />
			<StaticResource x:Key="OutlinedPasswordBoxBorderThickness" ResourceKey="FilledPasswordBoxBorderThickness" />
			<StaticResource x:Key="OutlinedPasswordBoxFocusedBorderThickness" ResourceKey="FilledPasswordBoxFocusedBorderThickness" />
			<StaticResource x:Key="OutlinedPasswordBoxPadding" ResourceKey="FilledPasswordBoxPadding" />
			<StaticResource x:Key="OutlinedPasswordBoxMinHeight" ResourceKey="FilledPasswordBoxMinHeight" />
			<StaticResource x:Key="OutlinedPasswordBoxHeaderMargin" ResourceKey="FilledPasswordBoxHeaderMargin" />
			<StaticResource x:Key="OutlinedPasswordBoxForeground" ResourceKey="FilledPasswordBoxForeground" />
			<SolidColorBrush x:Key="OutlinedPasswordBoxBackground" Color="Transparent" />
			<StaticResource x:Key="OutlinedPasswordBoxBorderBrush" ResourceKey="FilledPasswordBoxBorderBrush" />
			<StaticResource x:Key="OutlinedPasswordBoxPlaceholderForeground" ResourceKey="FilledPasswordBoxPlaceholderForeground" />
			<StaticResource x:Key="OutlinedPasswordBoxForegroundPointerOver" ResourceKey="FilledPasswordBoxForegroundPointerOver" />
			<SolidColorBrush x:Key="OutlinedPasswordBoxBackgroundPointerOver" Color="Transparent" />
			<StaticResource x:Key="OutlinedPasswordBoxBorderBrushPointerOver" ResourceKey="FilledPasswordBoxBorderBrushPointerOver" />
			<StaticResource x:Key="OutlinedPasswordBoxForegroundFocused" ResourceKey="FilledPasswordBoxForegroundFocused" />
			<SolidColorBrush x:Key="OutlinedPasswordBoxBackgroundFocused" Color="Transparent" />
			<StaticResource x:Key="OutlinedPasswordBoxBorderBrushFocused" ResourceKey="FilledPasswordBoxBorderBrushFocused" />
			<StaticResource x:Key="OutlinedPasswordBoxForegroundDisabled" ResourceKey="FilledPasswordBoxForegroundDisabled" />
			<SolidColorBrush x:Key="OutlinedPasswordBoxBackgroundDisabled" Color="Transparent" />
			<StaticResource x:Key="OutlinedPasswordBoxBorderBrushDisabled" ResourceKey="FilledPasswordBoxBorderBrushDisabled" />
			<StaticResource x:Key="OutlinedPasswordBoxPlaceholderForegroundDisabled" ResourceKey="FilledPasswordBoxPlaceholderForegroundDisabled" />
			<StaticResource x:Key="OutlinedPasswordBoxRevealForeground" ResourceKey="FilledPasswordBoxRevealForeground" />
			<StaticResource x:Key="OutlinedPasswordBoxRevealForegroundPointerOver" ResourceKey="FilledPasswordBoxRevealForegroundPointerOver" />
			<StaticResource x:Key="OutlinedPasswordBoxRevealForegroundPressed" ResourceKey="FilledPasswordBoxRevealForegroundPressed" />
			<StaticResource x:Key="OutlinedPasswordBoxHeaderForeground" ResourceKey="FilledPasswordBoxHeaderForeground" />
			<StaticResource x:Key="OutlinedPasswordBoxHeaderForegroundDisabled" ResourceKey="FilledPasswordBoxHeaderForegroundDisabled" />
		</ResourceDictionary>

		<!-- ─── Dark Theme (Default) ─── -->
		<ResourceDictionary x:Key="Default">

			<!-- ── FilledPasswordBox — semantic keys (source of truth) ── -->

			<!-- Sizing -->
			<StaticResource x:Key="FilledPasswordBoxCornerRadius" ResourceKey="SimpleRadius200CornerRadius" /> <!-- sds-size-radius-200 -->
			<StaticResource x:Key="FilledPasswordBoxBorderThickness" ResourceKey="SimpleStrokeBorderThickness" /> <!-- sds-size-stroke-border -->
			<StaticResource x:Key="FilledPasswordBoxFocusedBorderThickness" ResourceKey="SimpleStrokeFocusRingThickness" /> <!-- sds-size-stroke-focus-ring -->
			<!-- H: sds-size-space-400, V: sds-size-space-100+sds-size-space-150 -->
			<Thickness x:Key="FilledPasswordBoxPadding">16,10,16,10</Thickness>
			<StaticResource x:Key="FilledPasswordBoxMinHeight" ResourceKey="SimpleIconLarge" /> <!-- sds-size-icon-large -->
			<!-- B: sds-size-space-100 -->
			<Thickness x:Key="FilledPasswordBoxHeaderMargin">0,0,0,4</Thickness>

			<StaticResource x:Key="FilledPasswordBoxForeground" ResourceKey="SimpleTextDefaultDefaultBrush" />
			<StaticResource x:Key="FilledPasswordBoxBackground" ResourceKey="SimpleBackgroundDefaultDefaultBrush" />
			<StaticResource x:Key="FilledPasswordBoxBorderBrush" ResourceKey="SimpleBorderDefaultDefaultBrush" />
			<StaticResource x:Key="FilledPasswordBoxPlaceholderForeground" ResourceKey="SimpleTextDefaultTertiaryBrush" />

			<StaticResource x:Key="FilledPasswordBoxForegroundPointerOver" ResourceKey="SimpleTextDefaultDefaultBrush" />
			<StaticResource x:Key="FilledPasswordBoxBackgroundPointerOver" ResourceKey="SimpleBackgroundDefaultDefaultBrush" />
			<StaticResource x:Key="FilledPasswordBoxBorderBrushPointerOver" ResourceKey="SimpleBorderDefaultDefaultBrush" />

			<StaticResource x:Key="FilledPasswordBoxForegroundFocused" ResourceKey="SimpleTextDefaultDefaultBrush" />
			<StaticResource x:Key="FilledPasswordBoxBackgroundFocused" ResourceKey="SimpleBackgroundDefaultDefaultBrush" />
			<StaticResource x:Key="FilledPasswordBoxBorderBrushFocused" ResourceKey="SimpleBorderBrandSecondaryBrush" />

			<StaticResource x:Key="FilledPasswordBoxForegroundDisabled" ResourceKey="SimpleTextDisabledDefaultBrush" />
			<StaticResource x:Key="FilledPasswordBoxBackgroundDisabled" ResourceKey="SimpleBackgroundDisabledDefaultBrush" />
			<StaticResource x:Key="FilledPasswordBoxBorderBrushDisabled" ResourceKey="SimpleBorderDisabledDefaultBrush" />
			<StaticResource x:Key="FilledPasswordBoxPlaceholderForegroundDisabled" ResourceKey="SimpleTextDisabledDefaultBrush" />

			<StaticResource x:Key="FilledPasswordBoxRevealForeground" ResourceKey="SimpleIconDefaultDefaultBrush" />
			<StaticResource x:Key="FilledPasswordBoxRevealForegroundPointerOver" ResourceKey="SimpleIconDefaultDefaultBrush" />
			<StaticResource x:Key="FilledPasswordBoxRevealForegroundPressed" ResourceKey="SimpleIconDefaultDefaultBrush" />

			<StaticResource x:Key="FilledPasswordBoxHeaderForeground" ResourceKey="SimpleTextDefaultDefaultBrush" />
			<StaticResource x:Key="FilledPasswordBoxHeaderForegroundDisabled" ResourceKey="SimpleTextDisabledDefaultBrush" />

			<!-- Backwards-compat aliases (SimplePasswordBox* → FilledPasswordBox*) -->
			<StaticResource x:Key="SimplePasswordBoxCornerRadius" ResourceKey="FilledPasswordBoxCornerRadius" />
			<StaticResource x:Key="SimplePasswordBoxBorderThickness" ResourceKey="FilledPasswordBoxBorderThickness" />
			<StaticResource x:Key="SimplePasswordBoxFocusedBorderThickness" ResourceKey="FilledPasswordBoxFocusedBorderThickness" />
			<StaticResource x:Key="SimplePasswordBoxPadding" ResourceKey="FilledPasswordBoxPadding" />
			<StaticResource x:Key="SimplePasswordBoxMinHeight" ResourceKey="FilledPasswordBoxMinHeight" />
			<StaticResource x:Key="SimplePasswordBoxHeaderMargin" ResourceKey="FilledPasswordBoxHeaderMargin" />
			<StaticResource x:Key="SimplePasswordBoxForeground" ResourceKey="FilledPasswordBoxForeground" />
			<StaticResource x:Key="SimplePasswordBoxBackground" ResourceKey="FilledPasswordBoxBackground" />
			<StaticResource x:Key="SimplePasswordBoxBorderBrush" ResourceKey="FilledPasswordBoxBorderBrush" />
			<StaticResource x:Key="SimplePasswordBoxPlaceholderForeground" ResourceKey="FilledPasswordBoxPlaceholderForeground" />
			<StaticResource x:Key="SimplePasswordBoxForegroundPointerOver" ResourceKey="FilledPasswordBoxForegroundPointerOver" />
			<StaticResource x:Key="SimplePasswordBoxBackgroundPointerOver" ResourceKey="FilledPasswordBoxBackgroundPointerOver" />
			<StaticResource x:Key="SimplePasswordBoxBorderBrushPointerOver" ResourceKey="FilledPasswordBoxBorderBrushPointerOver" />
			<StaticResource x:Key="SimplePasswordBoxForegroundFocused" ResourceKey="FilledPasswordBoxForegroundFocused" />
			<StaticResource x:Key="SimplePasswordBoxBackgroundFocused" ResourceKey="FilledPasswordBoxBackgroundFocused" />
			<StaticResource x:Key="SimplePasswordBoxBorderBrushFocused" ResourceKey="FilledPasswordBoxBorderBrushFocused" />
			<StaticResource x:Key="SimplePasswordBoxForegroundDisabled" ResourceKey="FilledPasswordBoxForegroundDisabled" />
			<StaticResource x:Key="SimplePasswordBoxBackgroundDisabled" ResourceKey="FilledPasswordBoxBackgroundDisabled" />
			<StaticResource x:Key="SimplePasswordBoxBorderBrushDisabled" ResourceKey="FilledPasswordBoxBorderBrushDisabled" />
			<StaticResource x:Key="SimplePasswordBoxPlaceholderForegroundDisabled" ResourceKey="FilledPasswordBoxPlaceholderForegroundDisabled" />
			<StaticResource x:Key="SimplePasswordBoxRevealForeground" ResourceKey="FilledPasswordBoxRevealForeground" />
			<StaticResource x:Key="SimplePasswordBoxRevealForegroundPointerOver" ResourceKey="FilledPasswordBoxRevealForegroundPointerOver" />
			<StaticResource x:Key="SimplePasswordBoxRevealForegroundPressed" ResourceKey="FilledPasswordBoxRevealForegroundPressed" />
			<StaticResource x:Key="SimplePasswordBoxHeaderForeground" ResourceKey="FilledPasswordBoxHeaderForeground" />
			<StaticResource x:Key="SimplePasswordBoxHeaderForegroundDisabled" ResourceKey="FilledPasswordBoxHeaderForegroundDisabled" />

			<!-- ── OutlinedPasswordBox — semantic keys (outlined variant: transparent bg) ── -->
			<StaticResource x:Key="OutlinedPasswordBoxCornerRadius" ResourceKey="FilledPasswordBoxCornerRadius" />
			<StaticResource x:Key="OutlinedPasswordBoxBorderThickness" ResourceKey="FilledPasswordBoxBorderThickness" />
			<StaticResource x:Key="OutlinedPasswordBoxFocusedBorderThickness" ResourceKey="FilledPasswordBoxFocusedBorderThickness" />
			<StaticResource x:Key="OutlinedPasswordBoxPadding" ResourceKey="FilledPasswordBoxPadding" />
			<StaticResource x:Key="OutlinedPasswordBoxMinHeight" ResourceKey="FilledPasswordBoxMinHeight" />
			<StaticResource x:Key="OutlinedPasswordBoxHeaderMargin" ResourceKey="FilledPasswordBoxHeaderMargin" />
			<StaticResource x:Key="OutlinedPasswordBoxForeground" ResourceKey="FilledPasswordBoxForeground" />
			<SolidColorBrush x:Key="OutlinedPasswordBoxBackground" Color="Transparent" />
			<StaticResource x:Key="OutlinedPasswordBoxBorderBrush" ResourceKey="FilledPasswordBoxBorderBrush" />
			<StaticResource x:Key="OutlinedPasswordBoxPlaceholderForeground" ResourceKey="FilledPasswordBoxPlaceholderForeground" />
			<StaticResource x:Key="OutlinedPasswordBoxForegroundPointerOver" ResourceKey="FilledPasswordBoxForegroundPointerOver" />
			<SolidColorBrush x:Key="OutlinedPasswordBoxBackgroundPointerOver" Color="Transparent" />
			<StaticResource x:Key="OutlinedPasswordBoxBorderBrushPointerOver" ResourceKey="FilledPasswordBoxBorderBrushPointerOver" />
			<StaticResource x:Key="OutlinedPasswordBoxForegroundFocused" ResourceKey="FilledPasswordBoxForegroundFocused" />
			<SolidColorBrush x:Key="OutlinedPasswordBoxBackgroundFocused" Color="Transparent" />
			<StaticResource x:Key="OutlinedPasswordBoxBorderBrushFocused" ResourceKey="FilledPasswordBoxBorderBrushFocused" />
			<StaticResource x:Key="OutlinedPasswordBoxForegroundDisabled" ResourceKey="FilledPasswordBoxForegroundDisabled" />
			<SolidColorBrush x:Key="OutlinedPasswordBoxBackgroundDisabled" Color="Transparent" />
			<StaticResource x:Key="OutlinedPasswordBoxBorderBrushDisabled" ResourceKey="FilledPasswordBoxBorderBrushDisabled" />
			<StaticResource x:Key="OutlinedPasswordBoxPlaceholderForegroundDisabled" ResourceKey="FilledPasswordBoxPlaceholderForegroundDisabled" />
			<StaticResource x:Key="OutlinedPasswordBoxRevealForeground" ResourceKey="FilledPasswordBoxRevealForeground" />
			<StaticResource x:Key="OutlinedPasswordBoxRevealForegroundPointerOver" ResourceKey="FilledPasswordBoxRevealForegroundPointerOver" />
			<StaticResource x:Key="OutlinedPasswordBoxRevealForegroundPressed" ResourceKey="FilledPasswordBoxRevealForegroundPressed" />
			<StaticResource x:Key="OutlinedPasswordBoxHeaderForeground" ResourceKey="FilledPasswordBoxHeaderForeground" />
			<StaticResource x:Key="OutlinedPasswordBoxHeaderForegroundDisabled" ResourceKey="FilledPasswordBoxHeaderForegroundDisabled" />
		</ResourceDictionary>

	</ResourceDictionary.ThemeDictionaries>

	<!-- ═══════════════════════════════════════════════════════════════════════ -->
	<!-- Default PasswordBox (SDS outlined input)                              -->
	<!-- ═══════════════════════════════════════════════════════════════════════ -->
	<Style x:Key="SimplePasswordBoxStyle"
		   TargetType="PasswordBox">
		<Setter Property="Foreground" Value="{ThemeResource SimplePasswordBoxForeground}" />
		<Setter Property="Background" Value="{ThemeResource SimplePasswordBoxBackground}" />
		<Setter Property="BorderBrush" Value="{ThemeResource SimplePasswordBoxBorderBrush}" />
		<Setter Property="BorderThickness" Value="{ThemeResource SimplePasswordBoxBorderThickness}" />
		<Setter Property="CornerRadius" Value="{ThemeResource SimplePasswordBoxCornerRadius}" />
		<Setter Property="Padding" Value="{ThemeResource SimplePasswordBoxPadding}" />
		<Setter Property="MinHeight" Value="{ThemeResource SimplePasswordBoxMinHeight}" />
		<Setter Property="FontFamily" Value="{ThemeResource SimpleFontFamily}" />
		<Setter Property="FontSize" Value="{ThemeResource SimpleTypographyScale03}" />
		<Setter Property="FontWeight" Value="Normal" />
		<Setter Property="HorizontalAlignment" Value="Stretch" />
		<Setter Property="VerticalAlignment" Value="Center" />
		<Setter Property="HorizontalContentAlignment" Value="Left" />
		<Setter Property="VerticalContentAlignment" Value="Center" />
		<Setter Property="UseSystemFocusVisuals" Value="{StaticResource UseSystemFocusVisuals}" />
		<Setter Property="FocusVisualMargin" Value="-3" />
		<Setter Property="Template">
			<Setter.Value>
				<ControlTemplate TargetType="PasswordBox">
					<Grid>
						<Grid.RowDefinitions>
							<RowDefinition Height="Auto" />
							<RowDefinition Height="*" />
						</Grid.RowDefinitions>

						<VisualStateManager.VisualStateGroups>
							<VisualStateGroup x:Name="CommonStates">
								<VisualState x:Name="Normal" />

								<VisualState x:Name="PointerOver">
									<VisualState.Setters>
										<Setter Target="BackgroundElement.Background" Value="{ThemeResource SimplePasswordBoxBackgroundPointerOver}" />
										<Setter Target="BorderElement.BorderBrush" Value="{ThemeResource SimplePasswordBoxBorderBrushPointerOver}" />
										<Setter Target="ContentElement.Foreground" Value="{ThemeResource SimplePasswordBoxForegroundPointerOver}" />
									</VisualState.Setters>
								</VisualState>

								<VisualState x:Name="Focused">
									<VisualState.Setters>
										<Setter Target="BackgroundElement.Background" Value="{ThemeResource SimplePasswordBoxBackgroundFocused}" />
										<Setter Target="BorderElement.BorderBrush" Value="{ThemeResource SimplePasswordBoxBorderBrushFocused}" />
										<Setter Target="BorderElement.BorderThickness" Value="{ThemeResource SimplePasswordBoxFocusedBorderThickness}" />
										<Setter Target="ContentElement.Foreground" Value="{ThemeResource SimplePasswordBoxForegroundFocused}" />
									</VisualState.Setters>
								</VisualState>

								<VisualState x:Name="Disabled">
									<VisualState.Setters>
										<Setter Target="BackgroundElement.Background" Value="{ThemeResource SimplePasswordBoxBackgroundDisabled}" />
										<Setter Target="BorderElement.BorderBrush" Value="{ThemeResource SimplePasswordBoxBorderBrushDisabled}" />
										<Setter Target="ContentElement.Foreground" Value="{ThemeResource SimplePasswordBoxForegroundDisabled}" />
										<Setter Target="PlaceholderElement.Foreground" Value="{ThemeResource SimplePasswordBoxPlaceholderForegroundDisabled}" />
										<Setter Target="HeaderContentPresenter.Foreground" Value="{ThemeResource SimplePasswordBoxHeaderForegroundDisabled}" />
									</VisualState.Setters>
								</VisualState>
							</VisualStateGroup>

							<VisualStateGroup x:Name="ButtonStates">
								<VisualState x:Name="ButtonVisible">
									<VisualState.Setters>
										<Setter Target="RevealButton.Visibility" Value="Visible" />
									</VisualState.Setters>
								</VisualState>
								<VisualState x:Name="ButtonCollapsed" />
							</VisualStateGroup>
						</VisualStateManager.VisualStateGroups>

						<!-- Header -->
						<ContentPresenter x:Name="HeaderContentPresenter"
										  Grid.Row="0"
										  Content="{TemplateBinding Header}"
										  ContentTemplate="{TemplateBinding HeaderTemplate}"
										  FontFamily="{ThemeResource SimpleFontFamily}"
										  FontSize="{ThemeResource SimpleTypographyScale02}"
										  FontWeight="SemiBold"
										  Foreground="{ThemeResource SimplePasswordBoxHeaderForeground}"
										  Margin="{ThemeResource SimplePasswordBoxHeaderMargin}"
										  TextWrapping="Wrap"
										  Visibility="Collapsed"
										  x:DeferLoadStrategy="Lazy" />

						<!-- Input field -->
						<Grid Grid.Row="1"
							  MinHeight="{TemplateBinding MinHeight}">

							<!-- Background fill -->
							<Border x:Name="BackgroundElement"
									Background="{TemplateBinding Background}"
									CornerRadius="{TemplateBinding CornerRadius}" />

							<!-- Content -->
							<Grid VerticalAlignment="Center">
								<Grid.ColumnDefinitions>
									<ColumnDefinition Width="*" />
									<ColumnDefinition Width="Auto" />
								</Grid.ColumnDefinitions>

								<Grid Grid.Column="0">
									<ContentControl x:Name="PlaceholderElement"
													Content="{TemplateBinding PlaceholderText}"
													Foreground="{ThemeResource SimplePasswordBoxPlaceholderForeground}"
													FontFamily="{TemplateBinding FontFamily}"
													FontSize="{TemplateBinding FontSize}"
													Padding="{TemplateBinding Padding}"
													Visibility="{Binding Password, RelativeSource={RelativeSource TemplatedParent}, Converter={StaticResource EmptyToVisibleConverter}}"
													IsHitTestVisible="False"
													IsTabStop="False" />

									<ScrollViewer x:Name="ContentElement"
												  HorizontalScrollMode="Auto"
												  HorizontalScrollBarVisibility="Hidden"
												  VerticalScrollMode="Disabled"
												  VerticalScrollBarVisibility="Hidden"
												  Padding="{TemplateBinding Padding}"
												  VerticalAlignment="Center"
												  IsHorizontalRailEnabled="False"
												  IsVerticalRailEnabled="False"
												  IsTabStop="False"
												  ZoomMode="Disabled"
												  AutomationProperties.AccessibilityView="Raw" />
								</Grid>

								<!-- Reveal button (Padding H: sds-size-space-200) -->
								<Button x:Name="RevealButton"
										Grid.Column="1"
										Visibility="Collapsed"
										Background="Transparent"
										BorderThickness="0"
										Padding="8,0"
										MinWidth="{ThemeResource SimpleIconMedium}"
										MinHeight="0"
										VerticalAlignment="Stretch"
										FontFamily="{ThemeResource SymbolThemeFontFamily}"
										FontSize="{ThemeResource SimpleTypographyScale03}"
										Foreground="{ThemeResource SimplePasswordBoxRevealForeground}"
										Content="&#xE052;"
										IsTabStop="False"
										AutomationProperties.AccessibilityView="Raw" />
							</Grid>

							<!-- Border overlay — thickness changes don't push inner content -->
							<Border x:Name="BorderElement"
									BorderBrush="{TemplateBinding BorderBrush}"
									BorderThickness="{TemplateBinding BorderThickness}"
									CornerRadius="{TemplateBinding CornerRadius}" />
						</Grid>
					</Grid>
				</ControlTemplate>
			</Setter.Value>
		</Setter>
	</Style>

	<!-- ═══════════════════════════════════════════════════════════════════════ -->
	<!-- Outlined PasswordBox (transparent background, visible border)          -->
	<!-- ═══════════════════════════════════════════════════════════════════════ -->
	<Style x:Key="SimpleOutlinedPasswordBoxStyle"
		   TargetType="PasswordBox"
		   BasedOn="{StaticResource SimplePasswordBoxStyle}">
		<Setter Property="Background" Value="{ThemeResource OutlinedPasswordBoxBackground}" />
	</Style>

</ResourceDictionary>
