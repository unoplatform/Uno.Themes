	</Style>

	<!-- ═══════════════════════════════════════════════════════════════════════ -->
	<!-- Backward-compat alias (old name) -->
	<!-- ═══════════════════════════════════════════════════════════════════════ -->
	<Style x:Key="SimplePasswordBoxStyle"
		   TargetType="PasswordBox"
		   BasedOn="{StaticResource SimpleFilledPasswordBoxStyle}" />

</ResourceDictionary>
