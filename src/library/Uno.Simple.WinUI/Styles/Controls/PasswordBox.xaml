<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
					xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

	<!--
		Simple Design System — PasswordBox Styles
		Maps SDS Input component tokens to WinUI PasswordBox.
		Same visual treatment as TextBox (SDS Input outlined style).
	-->

	<!-- ═══════════════════════════════════════════════════════════════════════ -->
	<!-- Lightweight styling ThemeResource aliases                              -->
	<!-- ═══════════════════════════════════════════════════════════════════════ -->
	<ResourceDictionary.ThemeDictionaries>

		<!-- ─── Light Theme ─── -->
		<ResourceDictionary x:Key="Light">
			<!-- Sizing -->
			<StaticResource x:Key="SimplePasswordBoxCornerRadius" ResourceKey="SimpleRadius200CornerRadius" /> <!-- sds-size-radius-200 -->
			<StaticResource x:Key="SimplePasswordBoxBorderThickness" ResourceKey="SimpleStrokeBorderThickness" /> <!-- sds-size-stroke-border -->
			<StaticResource x:Key="SimplePasswordBoxFocusedBorderThickness" ResourceKey="SimpleStrokeFocusRingThickness" /> <!-- sds-size-stroke-focus-ring -->
			<!-- H: sds-size-space-400, V: sds-size-space-100+sds-size-space-150 -->
			<Thickness x:Key="SimplePasswordBoxPadding">16,10,16,10</Thickness>
			<StaticResource x:Key="SimplePasswordBoxMinHeight" ResourceKey="SimpleIconLarge" /> <!-- sds-size-icon-large -->
			<!-- B: sds-size-space-100 -->
			<Thickness x:Key="SimplePasswordBoxHeaderMargin">0,0,0,4</Thickness>

			<!-- Normal state -->
			<StaticResource x:Key="SimplePasswordBoxForeground" ResourceKey="SimpleTextDefaultDefaultBrush" />
			<StaticResource x:Key="SimplePasswordBoxBackground" ResourceKey="SimpleBackgroundDefaultDefaultBrush" />
			<StaticResource x:Key="SimplePasswordBoxBorderBrush" ResourceKey="SimpleBorderDefaultDefaultBrush" />
			<StaticResource x:Key="SimplePasswordBoxPlaceholderForeground" ResourceKey="SimpleTextDefaultTertiaryBrush" />

			<!-- PointerOver state -->
			<StaticResource x:Key="SimplePasswordBoxForegroundPointerOver" ResourceKey="SimpleTextDefaultDefaultBrush" />
			<StaticResource x:Key="SimplePasswordBoxBackgroundPointerOver" ResourceKey="SimpleBackgroundDefaultDefaultBrush" />
			<StaticResource x:Key="SimplePasswordBoxBorderBrushPointerOver" ResourceKey="SimpleBorderDefaultDefaultBrush" />

			<!-- Focused state -->
			<StaticResource x:Key="SimplePasswordBoxForegroundFocused" ResourceKey="SimpleTextDefaultDefaultBrush" />
			<StaticResource x:Key="SimplePasswordBoxBackgroundFocused" ResourceKey="SimpleBackgroundDefaultDefaultBrush" />
			<StaticResource x:Key="SimplePasswordBoxBorderBrushFocused" ResourceKey="SimpleBorderBrandSecondaryBrush" />

			<!-- Disabled state -->
			<StaticResource x:Key="SimplePasswordBoxForegroundDisabled" ResourceKey="SimpleTextDisabledDefaultBrush" />
			<StaticResource x:Key="SimplePasswordBoxBackgroundDisabled" ResourceKey="SimpleBackgroundDisabledDefaultBrush" />
			<StaticResource x:Key="SimplePasswordBoxBorderBrushDisabled" ResourceKey="SimpleBorderDisabledDefaultBrush" />
			<StaticResource x:Key="SimplePasswordBoxPlaceholderForegroundDisabled" ResourceKey="SimpleTextDisabledDefaultBrush" />

			<!-- Reveal button -->
			<StaticResource x:Key="SimplePasswordBoxRevealForeground" ResourceKey="SimpleIconDefaultDefaultBrush" />
			<StaticResource x:Key="SimplePasswordBoxRevealForegroundPointerOver" ResourceKey="SimpleIconDefaultDefaultBrush" />
			<StaticResource x:Key="SimplePasswordBoxRevealForegroundPressed" ResourceKey="SimpleIconDefaultDefaultBrush" />

			<!-- Header / label -->
			<StaticResource x:Key="SimplePasswordBoxHeaderForeground" ResourceKey="SimpleTextDefaultDefaultBrush" />
			<StaticResource x:Key="SimplePasswordBoxHeaderForegroundDisabled" ResourceKey="SimpleTextDisabledDefaultBrush" />
		</ResourceDictionary>

		<!-- ─── Dark Theme (Default) ─── -->
		<ResourceDictionary x:Key="Default">
			<!-- Sizing -->
			<StaticResource x:Key="SimplePasswordBoxCornerRadius" ResourceKey="SimpleRadius200CornerRadius" /> <!-- sds-size-radius-200 -->
			<StaticResource x:Key="SimplePasswordBoxBorderThickness" ResourceKey="SimpleStrokeBorderThickness" /> <!-- sds-size-stroke-border -->
			<StaticResource x:Key="SimplePasswordBoxFocusedBorderThickness" ResourceKey="SimpleStrokeFocusRingThickness" /> <!-- sds-size-stroke-focus-ring -->
			<!-- H: sds-size-space-400, V: sds-size-space-100+sds-size-space-150 -->
			<Thickness x:Key="SimplePasswordBoxPadding">16,10,16,10</Thickness>
			<StaticResource x:Key="SimplePasswordBoxMinHeight" ResourceKey="SimpleIconLarge" /> <!-- sds-size-icon-large -->
			<!-- B: sds-size-space-100 -->
			<Thickness x:Key="SimplePasswordBoxHeaderMargin">0,0,0,4</Thickness>

			<StaticResource x:Key="SimplePasswordBoxForeground" ResourceKey="SimpleTextDefaultDefaultBrush" />
			<StaticResource x:Key="SimplePasswordBoxBackground" ResourceKey="SimpleBackgroundDefaultDefaultBrush" />
			<StaticResource x:Key="SimplePasswordBoxBorderBrush" ResourceKey="SimpleBorderDefaultDefaultBrush" />
			<StaticResource x:Key="SimplePasswordBoxPlaceholderForeground" ResourceKey="SimpleTextDefaultTertiaryBrush" />

			<StaticResource x:Key="SimplePasswordBoxForegroundPointerOver" ResourceKey="SimpleTextDefaultDefaultBrush" />
			<StaticResource x:Key="SimplePasswordBoxBackgroundPointerOver" ResourceKey="SimpleBackgroundDefaultDefaultBrush" />
			<StaticResource x:Key="SimplePasswordBoxBorderBrushPointerOver" ResourceKey="SimpleBorderDefaultDefaultBrush" />

			<StaticResource x:Key="SimplePasswordBoxForegroundFocused" ResourceKey="SimpleTextDefaultDefaultBrush" />
			<StaticResource x:Key="SimplePasswordBoxBackgroundFocused" ResourceKey="SimpleBackgroundDefaultDefaultBrush" />
			<StaticResource x:Key="SimplePasswordBoxBorderBrushFocused" ResourceKey="SimpleBorderBrandSecondaryBrush" />

			<StaticResource x:Key="SimplePasswordBoxForegroundDisabled" ResourceKey="SimpleTextDisabledDefaultBrush" />
			<StaticResource x:Key="SimplePasswordBoxBackgroundDisabled" ResourceKey="SimpleBackgroundDisabledDefaultBrush" />
			<StaticResource x:Key="SimplePasswordBoxBorderBrushDisabled" ResourceKey="SimpleBorderDisabledDefaultBrush" />
			<StaticResource x:Key="SimplePasswordBoxPlaceholderForegroundDisabled" ResourceKey="SimpleTextDisabledDefaultBrush" />

			<StaticResource x:Key="SimplePasswordBoxRevealForeground" ResourceKey="SimpleIconDefaultDefaultBrush" />
			<StaticResource x:Key="SimplePasswordBoxRevealForegroundPointerOver" ResourceKey="SimpleIconDefaultDefaultBrush" />
			<StaticResource x:Key="SimplePasswordBoxRevealForegroundPressed" ResourceKey="SimpleIconDefaultDefaultBrush" />

			<StaticResource x:Key="SimplePasswordBoxHeaderForeground" ResourceKey="SimpleTextDefaultDefaultBrush" />
			<StaticResource x:Key="SimplePasswordBoxHeaderForegroundDisabled" ResourceKey="SimpleTextDisabledDefaultBrush" />
		</ResourceDictionary>

	</ResourceDictionary.ThemeDictionaries>

	<!-- ═══════════════════════════════════════════════════════════════════════ -->
	<!-- Default PasswordBox (SDS outlined input)                              -->
	<!-- ═══════════════════════════════════════════════════════════════════════ -->
	<Style x:Key="SimplePasswordBoxStyle"
		   TargetType="PasswordBox">
		<Setter Property="Foreground" Value="{ThemeResource SimplePasswordBoxForeground}" />
		<Setter Property="Background" Value="{ThemeResource SimplePasswordBoxBackground}" />
		<Setter Property="BorderBrush" Value="{ThemeResource SimplePasswordBoxBorderBrush}" />
		<Setter Property="BorderThickness" Value="{ThemeResource SimplePasswordBoxBorderThickness}" />
		<Setter Property="CornerRadius" Value="{ThemeResource SimplePasswordBoxCornerRadius}" />
		<Setter Property="Padding" Value="{ThemeResource SimplePasswordBoxPadding}" />
		<Setter Property="MinHeight" Value="{ThemeResource SimplePasswordBoxMinHeight}" />
		<Setter Property="FontFamily" Value="{ThemeResource SimpleFontFamily}" />
		<Setter Property="FontSize" Value="{ThemeResource SimpleTypographyScale03}" />
		<Setter Property="FontWeight" Value="Normal" />
		<Setter Property="HorizontalAlignment" Value="Stretch" />
		<Setter Property="VerticalAlignment" Value="Center" />
		<Setter Property="HorizontalContentAlignment" Value="Left" />
		<Setter Property="VerticalContentAlignment" Value="Center" />
		<Setter Property="UseSystemFocusVisuals" Value="{StaticResource UseSystemFocusVisuals}" />
		<Setter Property="FocusVisualMargin" Value="-3" />
		<Setter Property="Template">
			<Setter.Value>
				<ControlTemplate TargetType="PasswordBox">
					<Grid>
						<Grid.RowDefinitions>
							<RowDefinition Height="Auto" />
							<RowDefinition Height="*" />
						</Grid.RowDefinitions>

						<VisualStateManager.VisualStateGroups>
							<VisualStateGroup x:Name="CommonStates">
								<VisualState x:Name="Normal" />

								<VisualState x:Name="PointerOver">
									<VisualState.Setters>
										<Setter Target="BorderElement.Background" Value="{ThemeResource SimplePasswordBoxBackgroundPointerOver}" />
										<Setter Target="BorderElement.BorderBrush" Value="{ThemeResource SimplePasswordBoxBorderBrushPointerOver}" />
										<Setter Target="ContentElement.Foreground" Value="{ThemeResource SimplePasswordBoxForegroundPointerOver}" />
									</VisualState.Setters>
								</VisualState>

								<VisualState x:Name="Focused">
									<VisualState.Setters>
										<Setter Target="BorderElement.Background" Value="{ThemeResource SimplePasswordBoxBackgroundFocused}" />
										<Setter Target="BorderElement.BorderBrush" Value="{ThemeResource SimplePasswordBoxBorderBrushFocused}" />
										<Setter Target="BorderElement.BorderThickness" Value="{ThemeResource SimplePasswordBoxFocusedBorderThickness}" />
										<Setter Target="ContentElement.Foreground" Value="{ThemeResource SimplePasswordBoxForegroundFocused}" />
										<Setter Target="PlaceholderTextContentPresenter.Visibility" Value="Collapsed" />
									</VisualState.Setters>
								</VisualState>

								<VisualState x:Name="Disabled">
									<VisualState.Setters>
										<Setter Target="BorderElement.Background" Value="{ThemeResource SimplePasswordBoxBackgroundDisabled}" />
										<Setter Target="BorderElement.BorderBrush" Value="{ThemeResource SimplePasswordBoxBorderBrushDisabled}" />
										<Setter Target="ContentElement.Foreground" Value="{ThemeResource SimplePasswordBoxForegroundDisabled}" />
										<Setter Target="PlaceholderTextContentPresenter.Foreground" Value="{ThemeResource SimplePasswordBoxPlaceholderForegroundDisabled}" />
										<Setter Target="HeaderContentPresenter.Foreground" Value="{ThemeResource SimplePasswordBoxHeaderForegroundDisabled}" />
									</VisualState.Setters>
								</VisualState>
							</VisualStateGroup>

							<VisualStateGroup x:Name="ButtonStates">
								<VisualState x:Name="ButtonVisible">
									<VisualState.Setters>
										<Setter Target="RevealButton.Visibility" Value="Visible" />
									</VisualState.Setters>
								</VisualState>
								<VisualState x:Name="ButtonCollapsed" />
							</VisualStateGroup>
						</VisualStateManager.VisualStateGroups>

						<!-- Header -->
						<ContentPresenter x:Name="HeaderContentPresenter"
										  Grid.Row="0"
										  Content="{TemplateBinding Header}"
										  ContentTemplate="{TemplateBinding HeaderTemplate}"
										  FontFamily="{ThemeResource SimpleFontFamily}"
										  FontSize="{ThemeResource SimpleTypographyScale02}"
										  FontWeight="SemiBold"
										  Foreground="{ThemeResource SimplePasswordBoxHeaderForeground}"
										  Margin="{ThemeResource SimplePasswordBoxHeaderMargin}"
										  TextWrapping="Wrap"
										  Visibility="Collapsed"
										  x:DeferLoadStrategy="Lazy" />

						<!-- Input field -->
						<Border x:Name="BorderElement"
								Grid.Row="1"
								Background="{TemplateBinding Background}"
								BorderBrush="{TemplateBinding BorderBrush}"
								BorderThickness="{TemplateBinding BorderThickness}"
								CornerRadius="{TemplateBinding CornerRadius}"
								MinHeight="{TemplateBinding MinHeight}">

							<Grid VerticalAlignment="Center">
								<Grid.ColumnDefinitions>
									<ColumnDefinition Width="*" />
									<ColumnDefinition Width="Auto" />
								</Grid.ColumnDefinitions>

								<Grid Grid.Column="0">
									<ContentControl x:Name="PlaceholderTextContentPresenter"
													Content="{TemplateBinding PlaceholderText}"
													Foreground="{ThemeResource SimplePasswordBoxPlaceholderForeground}"
													FontFamily="{TemplateBinding FontFamily}"
													FontSize="{TemplateBinding FontSize}"
													Padding="{TemplateBinding Padding}"
													IsHitTestVisible="False"
													IsTabStop="False" />

									<ScrollViewer x:Name="ContentElement"
												  HorizontalScrollMode="Auto"
												  HorizontalScrollBarVisibility="Hidden"
												  VerticalScrollMode="Disabled"
												  VerticalScrollBarVisibility="Hidden"
												  Padding="{TemplateBinding Padding}"
												  VerticalAlignment="Center"
												  IsHorizontalRailEnabled="False"
												  IsVerticalRailEnabled="False"
												  IsTabStop="False"
												  ZoomMode="Disabled"
												  AutomationProperties.AccessibilityView="Raw" />
								</Grid>

								<!-- Reveal button (Padding H: sds-size-space-200) -->
								<Button x:Name="RevealButton"
										Grid.Column="1"
										Visibility="Collapsed"
										Background="Transparent"
										BorderThickness="0"
										Padding="8,0"
										MinWidth="{StaticResource SimpleIconMedium}"
										MinHeight="0"
										VerticalAlignment="Stretch"
										FontFamily="{ThemeResource SymbolThemeFontFamily}"
										FontSize="{ThemeResource SimpleTypographyScale03}"
										Foreground="{ThemeResource SimplePasswordBoxRevealForeground}"
										Content="&#xE052;"
										IsTabStop="False"
										AutomationProperties.AccessibilityView="Raw" />
							</Grid>
						</Border>
					</Grid>
				</ControlTemplate>
			</Setter.Value>
		</Setter>
	</Style>

</ResourceDictionary>
