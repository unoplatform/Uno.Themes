<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
					xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
					xmlns:local="using:Microsoft.UI.Xaml.Controls">

	<!--
		Simple Design System — Expander Style
		Mapped from SDS Accordion / AccordionItem component.

		SDS Accordion-item behavior:
		  Collapsed bg = background-default-secondary (#F5F5F5 light / #2C2C2C dark)
		  Collapsed hover bg = background-default-secondary-hover (#E6E6E6 light / #1E1E1E dark)
		  Expanded bg  = background-default-default (#FFFFFF light / #1E1E1E dark)
		  Expanded hover bg = background-default-default-hover (#F5F5F5 light / #383838 dark)
		  Border = border-default-default, 1px inset box-shadow → BorderThickness=1
		  Corner radius = sds-size-radius-200 → 8px
		  Header padding = sds-size-space-400 → 16px
		  Content padding = 16px horizontal (matching header)
		  Title font = body-strong → 16px SemiBold
		  Chevron icon = icon-default-default, 20px, rotated 180° when expanded
		  Text = text-default-default
		  Disabled = background-disabled-default, text-disabled-default

		Lightweight styling: every visual-state brush is exposed via ThemeResource.
		States: Normal/PointerOver/Pressed/Disabled × Collapsed/Expanded (= ToggleButton Unchecked/Checked)
	-->

	<!-- ═══════════════════════════════════════════════════════════════════════ -->
	<!-- Lightweight styling ThemeResource aliases                              -->
	<!-- ═══════════════════════════════════════════════════════════════════════ -->
	<ResourceDictionary.ThemeDictionaries>

		<!-- ─── Light Theme ─── -->
		<ResourceDictionary x:Key="Light">

			<!-- Header — Collapsed (Normal) -->
			<StaticResource x:Key="SimpleExpanderHeaderBackground"                  ResourceKey="SurfaceVariantBrush" />
			<StaticResource x:Key="SimpleExpanderHeaderBackgroundPointerOver"        ResourceKey="PrimaryContainerBrush" />
			<StaticResource x:Key="SimpleExpanderHeaderBackgroundPressed"            ResourceKey="TertiaryContainerBrush" />
			<StaticResource x:Key="SimpleExpanderHeaderBackgroundDisabled"           ResourceKey="OnSurfaceDisabledBrush" />
			<StaticResource x:Key="SimpleExpanderHeaderForeground"                   ResourceKey="OnSurfaceBrush" />
			<StaticResource x:Key="SimpleExpanderHeaderForegroundPointerOver"        ResourceKey="OnSurfaceBrush" />
			<StaticResource x:Key="SimpleExpanderHeaderForegroundPressed"            ResourceKey="OnSurfaceBrush" />
			<StaticResource x:Key="SimpleExpanderHeaderForegroundDisabled"           ResourceKey="OnSurfaceDisabledBrush" />
			<StaticResource x:Key="SimpleExpanderHeaderBorderBrush"                  ResourceKey="OutlineBrush" />
			<StaticResource x:Key="SimpleExpanderHeaderBorderBrushPointerOver"       ResourceKey="OutlineBrush" />
			<StaticResource x:Key="SimpleExpanderHeaderBorderBrushPressed"           ResourceKey="OutlineBrush" />
			<StaticResource x:Key="SimpleExpanderHeaderBorderBrushDisabled"          ResourceKey="OutlineDisabledBrush" />

			<!-- Header — Expanded (Checked) -->
			<StaticResource x:Key="SimpleExpanderHeaderExpandedBackground"                ResourceKey="SurfaceBrush" />
			<StaticResource x:Key="SimpleExpanderHeaderExpandedBackgroundPointerOver"     ResourceKey="SurfaceVariantBrush" />
			<StaticResource x:Key="SimpleExpanderHeaderExpandedBackgroundPressed"         ResourceKey="PrimaryContainerBrush" />
			<StaticResource x:Key="SimpleExpanderHeaderExpandedBackgroundDisabled"        ResourceKey="OnSurfaceDisabledBrush" />
			<StaticResource x:Key="SimpleExpanderHeaderExpandedForeground"                ResourceKey="OnSurfaceBrush" />
			<StaticResource x:Key="SimpleExpanderHeaderExpandedForegroundPointerOver"     ResourceKey="OnSurfaceBrush" />
			<StaticResource x:Key="SimpleExpanderHeaderExpandedForegroundPressed"         ResourceKey="OnSurfaceBrush" />
			<StaticResource x:Key="SimpleExpanderHeaderExpandedForegroundDisabled"        ResourceKey="OnSurfaceDisabledBrush" />
			<StaticResource x:Key="SimpleExpanderHeaderExpandedBorderBrush"               ResourceKey="OutlineBrush" />
			<StaticResource x:Key="SimpleExpanderHeaderExpandedBorderBrushPointerOver"    ResourceKey="OutlineBrush" />
			<StaticResource x:Key="SimpleExpanderHeaderExpandedBorderBrushPressed"        ResourceKey="OutlineBrush" />
			<StaticResource x:Key="SimpleExpanderHeaderExpandedBorderBrushDisabled"       ResourceKey="OutlineDisabledBrush" />

			<!-- Chevron -->
			<StaticResource x:Key="SimpleExpanderChevronForeground"              ResourceKey="OnSurfaceBrush" />
			<StaticResource x:Key="SimpleExpanderChevronForegroundPointerOver"   ResourceKey="OnSurfaceBrush" />
			<StaticResource x:Key="SimpleExpanderChevronForegroundPressed"       ResourceKey="OnSurfaceBrush" />
			<StaticResource x:Key="SimpleExpanderChevronForegroundDisabled"      ResourceKey="OnSurfaceDisabledBrush" />

			<!-- Content -->
			<StaticResource x:Key="SimpleExpanderContentBackground"              ResourceKey="SurfaceBrush" />
			<StaticResource x:Key="SimpleExpanderContentBorderBrush"             ResourceKey="OutlineBrush" />
			<StaticResource x:Key="SimpleExpanderContentForeground"              ResourceKey="OnSurfaceBrush" />

		</ResourceDictionary>

		<!-- ─── Dark Theme (Default) ─── -->
		<ResourceDictionary x:Key="Default">

			<!-- Header — Collapsed (Normal) -->
			<StaticResource x:Key="SimpleExpanderHeaderBackground"                  ResourceKey="SurfaceVariantBrush" />
			<StaticResource x:Key="SimpleExpanderHeaderBackgroundPointerOver"        ResourceKey="PrimaryContainerBrush" />
			<StaticResource x:Key="SimpleExpanderHeaderBackgroundPressed"            ResourceKey="TertiaryContainerBrush" />
			<StaticResource x:Key="SimpleExpanderHeaderBackgroundDisabled"           ResourceKey="OnSurfaceDisabledBrush" />
			<StaticResource x:Key="SimpleExpanderHeaderForeground"                   ResourceKey="OnSurfaceBrush" />
			<StaticResource x:Key="SimpleExpanderHeaderForegroundPointerOver"        ResourceKey="OnSurfaceBrush" />
			<StaticResource x:Key="SimpleExpanderHeaderForegroundPressed"            ResourceKey="OnSurfaceBrush" />
			<StaticResource x:Key="SimpleExpanderHeaderForegroundDisabled"           ResourceKey="OnSurfaceDisabledBrush" />
			<StaticResource x:Key="SimpleExpanderHeaderBorderBrush"                  ResourceKey="OutlineBrush" />
			<StaticResource x:Key="SimpleExpanderHeaderBorderBrushPointerOver"       ResourceKey="OutlineBrush" />
			<StaticResource x:Key="SimpleExpanderHeaderBorderBrushPressed"           ResourceKey="OutlineBrush" />
			<StaticResource x:Key="SimpleExpanderHeaderBorderBrushDisabled"          ResourceKey="OutlineDisabledBrush" />

			<!-- Header — Expanded (Checked) -->
			<StaticResource x:Key="SimpleExpanderHeaderExpandedBackground"                ResourceKey="SurfaceBrush" />
			<StaticResource x:Key="SimpleExpanderHeaderExpandedBackgroundPointerOver"     ResourceKey="SurfaceVariantBrush" />
			<StaticResource x:Key="SimpleExpanderHeaderExpandedBackgroundPressed"         ResourceKey="PrimaryContainerBrush" />
			<StaticResource x:Key="SimpleExpanderHeaderExpandedBackgroundDisabled"        ResourceKey="OnSurfaceDisabledBrush" />
			<StaticResource x:Key="SimpleExpanderHeaderExpandedForeground"                ResourceKey="OnSurfaceBrush" />
			<StaticResource x:Key="SimpleExpanderHeaderExpandedForegroundPointerOver"     ResourceKey="OnSurfaceBrush" />
			<StaticResource x:Key="SimpleExpanderHeaderExpandedForegroundPressed"         ResourceKey="OnSurfaceBrush" />
			<StaticResource x:Key="SimpleExpanderHeaderExpandedForegroundDisabled"        ResourceKey="OnSurfaceDisabledBrush" />
			<StaticResource x:Key="SimpleExpanderHeaderExpandedBorderBrush"               ResourceKey="OutlineBrush" />
			<StaticResource x:Key="SimpleExpanderHeaderExpandedBorderBrushPointerOver"    ResourceKey="OutlineBrush" />
			<StaticResource x:Key="SimpleExpanderHeaderExpandedBorderBrushPressed"        ResourceKey="OutlineBrush" />
			<StaticResource x:Key="SimpleExpanderHeaderExpandedBorderBrushDisabled"       ResourceKey="OutlineDisabledBrush" />

			<!-- Chevron -->
			<StaticResource x:Key="SimpleExpanderChevronForeground"              ResourceKey="OnSurfaceBrush" />
			<StaticResource x:Key="SimpleExpanderChevronForegroundPointerOver"   ResourceKey="OnSurfaceBrush" />
			<StaticResource x:Key="SimpleExpanderChevronForegroundPressed"       ResourceKey="OnSurfaceBrush" />
			<StaticResource x:Key="SimpleExpanderChevronForegroundDisabled"      ResourceKey="OnSurfaceDisabledBrush" />

			<!-- Content -->
			<StaticResource x:Key="SimpleExpanderContentBackground"              ResourceKey="SurfaceBrush" />
			<StaticResource x:Key="SimpleExpanderContentBorderBrush"             ResourceKey="OutlineBrush" />
			<StaticResource x:Key="SimpleExpanderContentForeground"              ResourceKey="OnSurfaceBrush" />

		</ResourceDictionary>

	</ResourceDictionary.ThemeDictionaries>

	<!-- ═══════════════════════════════════════════════════════════════════════ -->
	<!-- Sizing / layout constants                                              -->
	<!-- ═══════════════════════════════════════════════════════════════════════ -->
	<!-- sds-size-space-1200 -->
	<StaticResource x:Key="SimpleExpanderMinHeight" ResourceKey="SimpleSpace1200" />
	<!-- sds-size-radius-200 -->
	<StaticResource x:Key="SimpleExpanderCornerRadius" ResourceKey="SimpleRadius200CornerRadius" />
	<!-- sds-size-space-400,0,0,0 -->
	<Thickness x:Key="SimpleExpanderHeaderPadding">16,0,0,0</Thickness>
	<!-- sds-size-space-400 -->
	<StaticResource x:Key="SimpleExpanderContentPadding" ResourceKey="SimpleSpace400Thickness" />
	<!-- sds-size-stroke-border -->
	<StaticResource x:Key="SimpleExpanderHeaderBorderThickness" ResourceKey="SimpleStrokeBorderThickness" />
	<!-- sds-size-stroke-border,0,sds-size-stroke-border,sds-size-stroke-border -->
	<Thickness x:Key="SimpleExpanderContentBorderThickness">1,0,1,1</Thickness>
	<!-- sds-size-stroke-border,sds-size-stroke-border,sds-size-stroke-border,0 -->
	<Thickness x:Key="SimpleExpanderContentUpBorderThickness">1,1,1,0</Thickness>
	<!-- sds-size-space-400+sds-size-space-100,0,sds-size-space-200,0 -->
	<Thickness x:Key="SimpleExpanderChevronMargin">20,0,8,0</Thickness>
	<!-- sds-size-icon-medium -->
	<StaticResource x:Key="SimpleExpanderChevronButtonSize" ResourceKey="SimpleIconMedium" />
	<x:Double x:Key="SimpleExpanderChevronGlyphSize">12</x:Double>
	<x:String x:Key="SimpleExpanderChevronDownGlyph">&#xE70D;</x:String>

	<!-- ═══════════════════════════════════════════════════════════════════════ -->
	<!-- Header ToggleButton style (ExpandDown direction)                       -->
	<!-- ═══════════════════════════════════════════════════════════════════════ -->
	<Style x:Key="SimpleExpanderHeaderDownStyle"
		   TargetType="ToggleButton">
		<Setter Property="Padding" Value="{StaticResource SimpleExpanderHeaderPadding}" />
		<Setter Property="HorizontalContentAlignment" Value="Left" />
		<Setter Property="BackgroundSizing" Value="InnerBorderEdge" />
		<Setter Property="Template">
			<Setter.Value>
				<ControlTemplate TargetType="ToggleButton">
					<Grid x:Name="ToggleButtonGrid"
						  CornerRadius="{TemplateBinding CornerRadius}"
						  BackgroundSizing="{TemplateBinding BackgroundSizing}"
						  Background="{TemplateBinding Background}"
						  MinHeight="{TemplateBinding MinHeight}"
						  MinWidth="{TemplateBinding MinWidth}"
						  MaxWidth="{TemplateBinding MaxWidth}"
						  Width="{TemplateBinding Width}"
						  HorizontalAlignment="{TemplateBinding HorizontalAlignment}"
						  BorderBrush="{ThemeResource SimpleExpanderHeaderBorderBrush}"
						  BorderThickness="{TemplateBinding BorderThickness}"
						  Padding="{TemplateBinding Padding}">

						<Grid.ColumnDefinitions>
							<ColumnDefinition Width="*" />
							<ColumnDefinition Width="Auto" />
						</Grid.ColumnDefinitions>

						<VisualStateManager.VisualStateGroups>
							<VisualStateGroup x:Name="CommonStates">

								<!-- ─── Collapsed states ─── -->
								<VisualState x:Name="Normal">
									<Storyboard>
										<ObjectAnimationUsingKeyFrames Storyboard.TargetName="ToggleButtonGrid" Storyboard.TargetProperty="Background">
											<DiscreteObjectKeyFrame KeyTime="0" Value="{ThemeResource SimpleExpanderHeaderBackground}" />
										</ObjectAnimationUsingKeyFrames>
										<ObjectAnimationUsingKeyFrames Storyboard.TargetName="ToggleButtonGrid" Storyboard.TargetProperty="BorderBrush">
											<DiscreteObjectKeyFrame KeyTime="0" Value="{ThemeResource SimpleExpanderHeaderBorderBrush}" />
										</ObjectAnimationUsingKeyFrames>
										<ObjectAnimationUsingKeyFrames Storyboard.TargetName="ContentPresenter" Storyboard.TargetProperty="Foreground">
											<DiscreteObjectKeyFrame KeyTime="0" Value="{ThemeResource SimpleExpanderHeaderForeground}" />
										</ObjectAnimationUsingKeyFrames>
										<ObjectAnimationUsingKeyFrames Storyboard.TargetName="ExpandCollapseChevron" Storyboard.TargetProperty="Foreground">
											<DiscreteObjectKeyFrame KeyTime="0" Value="{ThemeResource SimpleExpanderChevronForeground}" />
										</ObjectAnimationUsingKeyFrames>
									</Storyboard>
								</VisualState>

								<VisualState x:Name="PointerOver">
									<Storyboard>
										<ObjectAnimationUsingKeyFrames Storyboard.TargetName="ToggleButtonGrid" Storyboard.TargetProperty="Background">
											<DiscreteObjectKeyFrame KeyTime="0" Value="{ThemeResource SimpleExpanderHeaderBackgroundPointerOver}" />
										</ObjectAnimationUsingKeyFrames>
										<ObjectAnimationUsingKeyFrames Storyboard.TargetName="ToggleButtonGrid" Storyboard.TargetProperty="BorderBrush">
											<DiscreteObjectKeyFrame KeyTime="0" Value="{ThemeResource SimpleExpanderHeaderBorderBrushPointerOver}" />
										</ObjectAnimationUsingKeyFrames>
										<ObjectAnimationUsingKeyFrames Storyboard.TargetName="ContentPresenter" Storyboard.TargetProperty="Foreground">
											<DiscreteObjectKeyFrame KeyTime="0" Value="{ThemeResource SimpleExpanderHeaderForegroundPointerOver}" />
										</ObjectAnimationUsingKeyFrames>
										<ObjectAnimationUsingKeyFrames Storyboard.TargetName="ExpandCollapseChevron" Storyboard.TargetProperty="Foreground">
											<DiscreteObjectKeyFrame KeyTime="0" Value="{ThemeResource SimpleExpanderChevronForegroundPointerOver}" />
										</ObjectAnimationUsingKeyFrames>
									</Storyboard>
								</VisualState>

								<VisualState x:Name="Pressed">
									<Storyboard>
										<ObjectAnimationUsingKeyFrames Storyboard.TargetName="ToggleButtonGrid" Storyboard.TargetProperty="Background">
											<DiscreteObjectKeyFrame KeyTime="0" Value="{ThemeResource SimpleExpanderHeaderBackgroundPressed}" />
										</ObjectAnimationUsingKeyFrames>
										<ObjectAnimationUsingKeyFrames Storyboard.TargetName="ToggleButtonGrid" Storyboard.TargetProperty="BorderBrush">
											<DiscreteObjectKeyFrame KeyTime="0" Value="{ThemeResource SimpleExpanderHeaderBorderBrushPressed}" />
										</ObjectAnimationUsingKeyFrames>
										<ObjectAnimationUsingKeyFrames Storyboard.TargetName="ContentPresenter" Storyboard.TargetProperty="Foreground">
											<DiscreteObjectKeyFrame KeyTime="0" Value="{ThemeResource SimpleExpanderHeaderForegroundPressed}" />
										</ObjectAnimationUsingKeyFrames>
										<ObjectAnimationUsingKeyFrames Storyboard.TargetName="ExpandCollapseChevron" Storyboard.TargetProperty="Foreground">
											<DiscreteObjectKeyFrame KeyTime="0" Value="{ThemeResource SimpleExpanderChevronForegroundPressed}" />
										</ObjectAnimationUsingKeyFrames>
									</Storyboard>
								</VisualState>

								<VisualState x:Name="Disabled">
									<Storyboard>
										<ObjectAnimationUsingKeyFrames Storyboard.TargetName="ToggleButtonGrid" Storyboard.TargetProperty="Background">
											<DiscreteObjectKeyFrame KeyTime="0" Value="{ThemeResource SimpleExpanderHeaderBackgroundDisabled}" />
										</ObjectAnimationUsingKeyFrames>
										<ObjectAnimationUsingKeyFrames Storyboard.TargetName="ToggleButtonGrid" Storyboard.TargetProperty="BorderBrush">
											<DiscreteObjectKeyFrame KeyTime="0" Value="{ThemeResource SimpleExpanderHeaderBorderBrushDisabled}" />
										</ObjectAnimationUsingKeyFrames>
										<ObjectAnimationUsingKeyFrames Storyboard.TargetName="ContentPresenter" Storyboard.TargetProperty="Foreground">
											<DiscreteObjectKeyFrame KeyTime="0" Value="{ThemeResource SimpleExpanderHeaderForegroundDisabled}" />
										</ObjectAnimationUsingKeyFrames>
										<ObjectAnimationUsingKeyFrames Storyboard.TargetName="ExpandCollapseChevron" Storyboard.TargetProperty="Foreground">
											<DiscreteObjectKeyFrame KeyTime="0" Value="{ThemeResource SimpleExpanderChevronForegroundDisabled}" />
										</ObjectAnimationUsingKeyFrames>
									</Storyboard>
								</VisualState>

								<!-- ─── Expanded (Checked) states ─── -->
								<VisualState x:Name="Checked">
									<Storyboard>
										<DoubleAnimation Storyboard.TargetName="ExpandCollapseChevronRotateTransform"
														 Storyboard.TargetProperty="Angle"
														 To="180.0"
														 Duration="0:0:0" />
										<ObjectAnimationUsingKeyFrames Storyboard.TargetName="ToggleButtonGrid" Storyboard.TargetProperty="Background">
											<DiscreteObjectKeyFrame KeyTime="0" Value="{ThemeResource SimpleExpanderHeaderExpandedBackground}" />
										</ObjectAnimationUsingKeyFrames>
										<ObjectAnimationUsingKeyFrames Storyboard.TargetName="ToggleButtonGrid" Storyboard.TargetProperty="BorderBrush">
											<DiscreteObjectKeyFrame KeyTime="0" Value="{ThemeResource SimpleExpanderHeaderExpandedBorderBrush}" />
										</ObjectAnimationUsingKeyFrames>
										<ObjectAnimationUsingKeyFrames Storyboard.TargetName="ContentPresenter" Storyboard.TargetProperty="Foreground">
											<DiscreteObjectKeyFrame KeyTime="0" Value="{ThemeResource SimpleExpanderHeaderExpandedForeground}" />
										</ObjectAnimationUsingKeyFrames>
										<ObjectAnimationUsingKeyFrames Storyboard.TargetName="ExpandCollapseChevron" Storyboard.TargetProperty="Foreground">
											<DiscreteObjectKeyFrame KeyTime="0" Value="{ThemeResource SimpleExpanderChevronForeground}" />
										</ObjectAnimationUsingKeyFrames>
									</Storyboard>
								</VisualState>

								<VisualState x:Name="CheckedPointerOver">
									<Storyboard>
										<DoubleAnimation Storyboard.TargetName="ExpandCollapseChevronRotateTransform"
														 Storyboard.TargetProperty="Angle"
														 To="180.0"
														 Duration="0:0:0" />
										<ObjectAnimationUsingKeyFrames Storyboard.TargetName="ToggleButtonGrid" Storyboard.TargetProperty="Background">
											<DiscreteObjectKeyFrame KeyTime="0" Value="{ThemeResource SimpleExpanderHeaderExpandedBackgroundPointerOver}" />
										</ObjectAnimationUsingKeyFrames>
										<ObjectAnimationUsingKeyFrames Storyboard.TargetName="ToggleButtonGrid" Storyboard.TargetProperty="BorderBrush">
											<DiscreteObjectKeyFrame KeyTime="0" Value="{ThemeResource SimpleExpanderHeaderExpandedBorderBrushPointerOver}" />
										</ObjectAnimationUsingKeyFrames>
										<ObjectAnimationUsingKeyFrames Storyboard.TargetName="ContentPresenter" Storyboard.TargetProperty="Foreground">
											<DiscreteObjectKeyFrame KeyTime="0" Value="{ThemeResource SimpleExpanderHeaderExpandedForegroundPointerOver}" />
										</ObjectAnimationUsingKeyFrames>
										<ObjectAnimationUsingKeyFrames Storyboard.TargetName="ExpandCollapseChevron" Storyboard.TargetProperty="Foreground">
											<DiscreteObjectKeyFrame KeyTime="0" Value="{ThemeResource SimpleExpanderChevronForegroundPointerOver}" />
										</ObjectAnimationUsingKeyFrames>
									</Storyboard>
								</VisualState>

								<VisualState x:Name="CheckedPressed">
									<Storyboard>
										<DoubleAnimation Storyboard.TargetName="ExpandCollapseChevronRotateTransform"
														 Storyboard.TargetProperty="Angle"
														 To="180.0"
														 Duration="0:0:0" />
										<ObjectAnimationUsingKeyFrames Storyboard.TargetName="ToggleButtonGrid" Storyboard.TargetProperty="Background">
											<DiscreteObjectKeyFrame KeyTime="0" Value="{ThemeResource SimpleExpanderHeaderExpandedBackgroundPressed}" />
										</ObjectAnimationUsingKeyFrames>
										<ObjectAnimationUsingKeyFrames Storyboard.TargetName="ToggleButtonGrid" Storyboard.TargetProperty="BorderBrush">
											<DiscreteObjectKeyFrame KeyTime="0" Value="{ThemeResource SimpleExpanderHeaderExpandedBorderBrushPressed}" />
										</ObjectAnimationUsingKeyFrames>
										<ObjectAnimationUsingKeyFrames Storyboard.TargetName="ContentPresenter" Storyboard.TargetProperty="Foreground">
											<DiscreteObjectKeyFrame KeyTime="0" Value="{ThemeResource SimpleExpanderHeaderExpandedForegroundPressed}" />
										</ObjectAnimationUsingKeyFrames>
										<ObjectAnimationUsingKeyFrames Storyboard.TargetName="ExpandCollapseChevron" Storyboard.TargetProperty="Foreground">
											<DiscreteObjectKeyFrame KeyTime="0" Value="{ThemeResource SimpleExpanderChevronForegroundPressed}" />
										</ObjectAnimationUsingKeyFrames>
									</Storyboard>
								</VisualState>

								<VisualState x:Name="CheckedDisabled">
									<Storyboard>
										<DoubleAnimation Storyboard.TargetName="ExpandCollapseChevronRotateTransform"
														 Storyboard.TargetProperty="Angle"
														 To="180.0"
														 Duration="0:0:0" />
										<ObjectAnimationUsingKeyFrames Storyboard.TargetName="ToggleButtonGrid" Storyboard.TargetProperty="Background">
											<DiscreteObjectKeyFrame KeyTime="0" Value="{ThemeResource SimpleExpanderHeaderExpandedBackgroundDisabled}" />
										</ObjectAnimationUsingKeyFrames>
										<ObjectAnimationUsingKeyFrames Storyboard.TargetName="ToggleButtonGrid" Storyboard.TargetProperty="BorderBrush">
											<DiscreteObjectKeyFrame KeyTime="0" Value="{ThemeResource SimpleExpanderHeaderExpandedBorderBrushDisabled}" />
										</ObjectAnimationUsingKeyFrames>
										<ObjectAnimationUsingKeyFrames Storyboard.TargetName="ContentPresenter" Storyboard.TargetProperty="Foreground">
											<DiscreteObjectKeyFrame KeyTime="0" Value="{ThemeResource SimpleExpanderHeaderExpandedForegroundDisabled}" />
										</ObjectAnimationUsingKeyFrames>
										<ObjectAnimationUsingKeyFrames Storyboard.TargetName="ExpandCollapseChevron" Storyboard.TargetProperty="Foreground">
											<DiscreteObjectKeyFrame KeyTime="0" Value="{ThemeResource SimpleExpanderChevronForegroundDisabled}" />
										</ObjectAnimationUsingKeyFrames>
									</Storyboard>
								</VisualState>

								<!-- Indeterminate states (unused, required by ToggleButton contract) -->
								<VisualState x:Name="Indeterminate" />
								<VisualState x:Name="IndeterminatePointerOver" />
								<VisualState x:Name="IndeterminatePressed" />
								<VisualState x:Name="IndeterminateDisabled" />
							</VisualStateGroup>
						</VisualStateManager.VisualStateGroups>

						<!-- Header content -->
						<ContentPresenter x:Name="ContentPresenter"
										  Content="{TemplateBinding Content}"
										  ContentTemplate="{TemplateBinding ContentTemplate}"
										  ContentTransitions="{TemplateBinding ContentTransitions}"
										  HorizontalContentAlignment="{TemplateBinding HorizontalContentAlignment}"
										  VerticalContentAlignment="{TemplateBinding VerticalContentAlignment}"
										  Foreground="{TemplateBinding Foreground}" />

						<!-- Chevron button (SDS: 20px down-arrow icon) -->
						<Border x:Name="ExpandCollapseChevronBorder"
								Grid.Column="1"
								Width="{StaticResource SimpleExpanderChevronButtonSize}"
								Height="{StaticResource SimpleExpanderChevronButtonSize}"
								Margin="{StaticResource SimpleExpanderChevronMargin}"
								CornerRadius="{StaticResource SimpleExpanderCornerRadius}"
								Background="Transparent"
								BorderBrush="Transparent"
								BorderThickness="0">
							<FontIcon x:Name="ExpandCollapseChevron"
									  Glyph="{StaticResource SimpleExpanderChevronDownGlyph}"
									  FontFamily="{StaticResource SymbolThemeFontFamily}"
									  FontSize="{StaticResource SimpleExpanderChevronGlyphSize}"
									  Foreground="{ThemeResource SimpleExpanderChevronForeground}"
									  HorizontalAlignment="Center"
									  VerticalAlignment="Center"
									  IsTextScaleFactorEnabled="False"
									  RenderTransformOrigin="0.5,0.5"
									  AutomationProperties.AccessibilityView="Raw">
								<FontIcon.RenderTransform>
									<RotateTransform x:Name="ExpandCollapseChevronRotateTransform" Angle="0" />
								</FontIcon.RenderTransform>
							</FontIcon>
						</Border>
					</Grid>
				</ControlTemplate>
			</Setter.Value>
		</Setter>
	</Style>

	<!-- ═══════════════════════════════════════════════════════════════════════ -->
	<!-- Header ToggleButton style (ExpandUp direction)                        -->
	<!-- ═══════════════════════════════════════════════════════════════════════ -->
	<Style x:Key="SimpleExpanderHeaderUpStyle"
		   TargetType="ToggleButton"
		   BasedOn="{StaticResource SimpleExpanderHeaderDownStyle}">
		<Setter Property="Template">
			<Setter.Value>
				<ControlTemplate TargetType="ToggleButton">
					<Grid x:Name="ToggleButtonGrid"
						  CornerRadius="{TemplateBinding CornerRadius}"
						  BackgroundSizing="{TemplateBinding BackgroundSizing}"
						  Background="{TemplateBinding Background}"
						  MinHeight="{TemplateBinding MinHeight}"
						  MinWidth="{TemplateBinding MinWidth}"
						  MaxWidth="{TemplateBinding MaxWidth}"
						  Width="{TemplateBinding Width}"
						  HorizontalAlignment="{TemplateBinding HorizontalAlignment}"
						  BorderBrush="{ThemeResource SimpleExpanderHeaderBorderBrush}"
						  BorderThickness="{TemplateBinding BorderThickness}"
						  Padding="{TemplateBinding Padding}">

						<Grid.ColumnDefinitions>
							<ColumnDefinition Width="*" />
							<ColumnDefinition Width="Auto" />
						</Grid.ColumnDefinitions>

						<VisualStateManager.VisualStateGroups>
							<VisualStateGroup x:Name="CommonStates">

								<!-- ─── Collapsed states ─── -->
								<VisualState x:Name="Normal">
									<Storyboard>
										<ObjectAnimationUsingKeyFrames Storyboard.TargetName="ToggleButtonGrid" Storyboard.TargetProperty="Background">
											<DiscreteObjectKeyFrame KeyTime="0" Value="{ThemeResource SimpleExpanderHeaderBackground}" />
										</ObjectAnimationUsingKeyFrames>
										<ObjectAnimationUsingKeyFrames Storyboard.TargetName="ToggleButtonGrid" Storyboard.TargetProperty="BorderBrush">
											<DiscreteObjectKeyFrame KeyTime="0" Value="{ThemeResource SimpleExpanderHeaderBorderBrush}" />
										</ObjectAnimationUsingKeyFrames>
										<ObjectAnimationUsingKeyFrames Storyboard.TargetName="ContentPresenter" Storyboard.TargetProperty="Foreground">
											<DiscreteObjectKeyFrame KeyTime="0" Value="{ThemeResource SimpleExpanderHeaderForeground}" />
										</ObjectAnimationUsingKeyFrames>
										<ObjectAnimationUsingKeyFrames Storyboard.TargetName="ExpandCollapseChevron" Storyboard.TargetProperty="Foreground">
											<DiscreteObjectKeyFrame KeyTime="0" Value="{ThemeResource SimpleExpanderChevronForeground}" />
										</ObjectAnimationUsingKeyFrames>
									</Storyboard>
								</VisualState>

								<VisualState x:Name="PointerOver">
									<Storyboard>
										<ObjectAnimationUsingKeyFrames Storyboard.TargetName="ToggleButtonGrid" Storyboard.TargetProperty="Background">
											<DiscreteObjectKeyFrame KeyTime="0" Value="{ThemeResource SimpleExpanderHeaderBackgroundPointerOver}" />
										</ObjectAnimationUsingKeyFrames>
										<ObjectAnimationUsingKeyFrames Storyboard.TargetName="ToggleButtonGrid" Storyboard.TargetProperty="BorderBrush">
											<DiscreteObjectKeyFrame KeyTime="0" Value="{ThemeResource SimpleExpanderHeaderBorderBrushPointerOver}" />
										</ObjectAnimationUsingKeyFrames>
										<ObjectAnimationUsingKeyFrames Storyboard.TargetName="ContentPresenter" Storyboard.TargetProperty="Foreground">
											<DiscreteObjectKeyFrame KeyTime="0" Value="{ThemeResource SimpleExpanderHeaderForegroundPointerOver}" />
										</ObjectAnimationUsingKeyFrames>
										<ObjectAnimationUsingKeyFrames Storyboard.TargetName="ExpandCollapseChevron" Storyboard.TargetProperty="Foreground">
											<DiscreteObjectKeyFrame KeyTime="0" Value="{ThemeResource SimpleExpanderChevronForegroundPointerOver}" />
										</ObjectAnimationUsingKeyFrames>
									</Storyboard>
								</VisualState>

								<VisualState x:Name="Pressed">
									<Storyboard>
										<ObjectAnimationUsingKeyFrames Storyboard.TargetName="ToggleButtonGrid" Storyboard.TargetProperty="Background">
											<DiscreteObjectKeyFrame KeyTime="0" Value="{ThemeResource SimpleExpanderHeaderBackgroundPressed}" />
										</ObjectAnimationUsingKeyFrames>
										<ObjectAnimationUsingKeyFrames Storyboard.TargetName="ToggleButtonGrid" Storyboard.TargetProperty="BorderBrush">
											<DiscreteObjectKeyFrame KeyTime="0" Value="{ThemeResource SimpleExpanderHeaderBorderBrushPressed}" />
										</ObjectAnimationUsingKeyFrames>
										<ObjectAnimationUsingKeyFrames Storyboard.TargetName="ContentPresenter" Storyboard.TargetProperty="Foreground">
											<DiscreteObjectKeyFrame KeyTime="0" Value="{ThemeResource SimpleExpanderHeaderForegroundPressed}" />
										</ObjectAnimationUsingKeyFrames>
										<ObjectAnimationUsingKeyFrames Storyboard.TargetName="ExpandCollapseChevron" Storyboard.TargetProperty="Foreground">
											<DiscreteObjectKeyFrame KeyTime="0" Value="{ThemeResource SimpleExpanderChevronForegroundPressed}" />
										</ObjectAnimationUsingKeyFrames>
									</Storyboard>
								</VisualState>

								<VisualState x:Name="Disabled">
									<Storyboard>
										<ObjectAnimationUsingKeyFrames Storyboard.TargetName="ToggleButtonGrid" Storyboard.TargetProperty="Background">
											<DiscreteObjectKeyFrame KeyTime="0" Value="{ThemeResource SimpleExpanderHeaderBackgroundDisabled}" />
										</ObjectAnimationUsingKeyFrames>
										<ObjectAnimationUsingKeyFrames Storyboard.TargetName="ToggleButtonGrid" Storyboard.TargetProperty="BorderBrush">
											<DiscreteObjectKeyFrame KeyTime="0" Value="{ThemeResource SimpleExpanderHeaderBorderBrushDisabled}" />
										</ObjectAnimationUsingKeyFrames>
										<ObjectAnimationUsingKeyFrames Storyboard.TargetName="ContentPresenter" Storyboard.TargetProperty="Foreground">
											<DiscreteObjectKeyFrame KeyTime="0" Value="{ThemeResource SimpleExpanderHeaderForegroundDisabled}" />
										</ObjectAnimationUsingKeyFrames>
										<ObjectAnimationUsingKeyFrames Storyboard.TargetName="ExpandCollapseChevron" Storyboard.TargetProperty="Foreground">
											<DiscreteObjectKeyFrame KeyTime="0" Value="{ThemeResource SimpleExpanderChevronForegroundDisabled}" />
										</ObjectAnimationUsingKeyFrames>
									</Storyboard>
								</VisualState>

								<!-- ─── Expanded (Checked) states ─── -->
								<VisualState x:Name="Checked">
									<Storyboard>
										<DoubleAnimation Storyboard.TargetName="ExpandCollapseChevronRotateTransform"
														 Storyboard.TargetProperty="Angle"
														 To="180.0"
														 Duration="0:0:0" />
										<ObjectAnimationUsingKeyFrames Storyboard.TargetName="ToggleButtonGrid" Storyboard.TargetProperty="Background">
											<DiscreteObjectKeyFrame KeyTime="0" Value="{ThemeResource SimpleExpanderHeaderExpandedBackground}" />
										</ObjectAnimationUsingKeyFrames>
										<ObjectAnimationUsingKeyFrames Storyboard.TargetName="ToggleButtonGrid" Storyboard.TargetProperty="BorderBrush">
											<DiscreteObjectKeyFrame KeyTime="0" Value="{ThemeResource SimpleExpanderHeaderExpandedBorderBrush}" />
										</ObjectAnimationUsingKeyFrames>
										<ObjectAnimationUsingKeyFrames Storyboard.TargetName="ContentPresenter" Storyboard.TargetProperty="Foreground">
											<DiscreteObjectKeyFrame KeyTime="0" Value="{ThemeResource SimpleExpanderHeaderExpandedForeground}" />
										</ObjectAnimationUsingKeyFrames>
										<ObjectAnimationUsingKeyFrames Storyboard.TargetName="ExpandCollapseChevron" Storyboard.TargetProperty="Foreground">
											<DiscreteObjectKeyFrame KeyTime="0" Value="{ThemeResource SimpleExpanderChevronForeground}" />
										</ObjectAnimationUsingKeyFrames>
									</Storyboard>
								</VisualState>

								<VisualState x:Name="CheckedPointerOver">
									<Storyboard>
										<DoubleAnimation Storyboard.TargetName="ExpandCollapseChevronRotateTransform"
														 Storyboard.TargetProperty="Angle"
														 To="180.0"
														 Duration="0:0:0" />
										<ObjectAnimationUsingKeyFrames Storyboard.TargetName="ToggleButtonGrid" Storyboard.TargetProperty="Background">
											<DiscreteObjectKeyFrame KeyTime="0" Value="{ThemeResource SimpleExpanderHeaderExpandedBackgroundPointerOver}" />
										</ObjectAnimationUsingKeyFrames>
										<ObjectAnimationUsingKeyFrames Storyboard.TargetName="ToggleButtonGrid" Storyboard.TargetProperty="BorderBrush">
											<DiscreteObjectKeyFrame KeyTime="0" Value="{ThemeResource SimpleExpanderHeaderExpandedBorderBrushPointerOver}" />
										</ObjectAnimationUsingKeyFrames>
										<ObjectAnimationUsingKeyFrames Storyboard.TargetName="ContentPresenter" Storyboard.TargetProperty="Foreground">
											<DiscreteObjectKeyFrame KeyTime="0" Value="{ThemeResource SimpleExpanderHeaderExpandedForegroundPointerOver}" />
										</ObjectAnimationUsingKeyFrames>
										<ObjectAnimationUsingKeyFrames Storyboard.TargetName="ExpandCollapseChevron" Storyboard.TargetProperty="Foreground">
											<DiscreteObjectKeyFrame KeyTime="0" Value="{ThemeResource SimpleExpanderChevronForegroundPointerOver}" />
										</ObjectAnimationUsingKeyFrames>
									</Storyboard>
								</VisualState>

								<VisualState x:Name="CheckedPressed">
									<Storyboard>
										<DoubleAnimation Storyboard.TargetName="ExpandCollapseChevronRotateTransform"
														 Storyboard.TargetProperty="Angle"
														 To="180.0"
														 Duration="0:0:0" />
										<ObjectAnimationUsingKeyFrames Storyboard.TargetName="ToggleButtonGrid" Storyboard.TargetProperty="Background">
											<DiscreteObjectKeyFrame KeyTime="0" Value="{ThemeResource SimpleExpanderHeaderExpandedBackgroundPressed}" />
										</ObjectAnimationUsingKeyFrames>
										<ObjectAnimationUsingKeyFrames Storyboard.TargetName="ToggleButtonGrid" Storyboard.TargetProperty="BorderBrush">
											<DiscreteObjectKeyFrame KeyTime="0" Value="{ThemeResource SimpleExpanderHeaderExpandedBorderBrushPressed}" />
										</ObjectAnimationUsingKeyFrames>
										<ObjectAnimationUsingKeyFrames Storyboard.TargetName="ContentPresenter" Storyboard.TargetProperty="Foreground">
											<DiscreteObjectKeyFrame KeyTime="0" Value="{ThemeResource SimpleExpanderHeaderExpandedForegroundPressed}" />
										</ObjectAnimationUsingKeyFrames>
										<ObjectAnimationUsingKeyFrames Storyboard.TargetName="ExpandCollapseChevron" Storyboard.TargetProperty="Foreground">
											<DiscreteObjectKeyFrame KeyTime="0" Value="{ThemeResource SimpleExpanderChevronForegroundPressed}" />
										</ObjectAnimationUsingKeyFrames>
									</Storyboard>
								</VisualState>

								<VisualState x:Name="CheckedDisabled">
									<Storyboard>
										<DoubleAnimation Storyboard.TargetName="ExpandCollapseChevronRotateTransform"
														 Storyboard.TargetProperty="Angle"
														 To="180.0"
														 Duration="0:0:0" />
										<ObjectAnimationUsingKeyFrames Storyboard.TargetName="ToggleButtonGrid" Storyboard.TargetProperty="Background">
											<DiscreteObjectKeyFrame KeyTime="0" Value="{ThemeResource SimpleExpanderHeaderExpandedBackgroundDisabled}" />
										</ObjectAnimationUsingKeyFrames>
										<ObjectAnimationUsingKeyFrames Storyboard.TargetName="ToggleButtonGrid" Storyboard.TargetProperty="BorderBrush">
											<DiscreteObjectKeyFrame KeyTime="0" Value="{ThemeResource SimpleExpanderHeaderExpandedBorderBrushDisabled}" />
										</ObjectAnimationUsingKeyFrames>
										<ObjectAnimationUsingKeyFrames Storyboard.TargetName="ContentPresenter" Storyboard.TargetProperty="Foreground">
											<DiscreteObjectKeyFrame KeyTime="0" Value="{ThemeResource SimpleExpanderHeaderExpandedForegroundDisabled}" />
										</ObjectAnimationUsingKeyFrames>
										<ObjectAnimationUsingKeyFrames Storyboard.TargetName="ExpandCollapseChevron" Storyboard.TargetProperty="Foreground">
											<DiscreteObjectKeyFrame KeyTime="0" Value="{ThemeResource SimpleExpanderChevronForegroundDisabled}" />
										</ObjectAnimationUsingKeyFrames>
									</Storyboard>
								</VisualState>

								<VisualState x:Name="Indeterminate" />
								<VisualState x:Name="IndeterminatePointerOver" />
								<VisualState x:Name="IndeterminatePressed" />
								<VisualState x:Name="IndeterminateDisabled" />
							</VisualStateGroup>
						</VisualStateManager.VisualStateGroups>

						<!-- Header content -->
						<ContentPresenter x:Name="ContentPresenter"
										  Content="{TemplateBinding Content}"
										  ContentTemplate="{TemplateBinding ContentTemplate}"
										  ContentTransitions="{TemplateBinding ContentTransitions}"
										  HorizontalContentAlignment="{TemplateBinding HorizontalContentAlignment}"
										  VerticalContentAlignment="{TemplateBinding VerticalContentAlignment}"
										  Foreground="{TemplateBinding Foreground}" />

						<!-- Chevron (SDS: up-arrow for ExpandUp — initial angle 180, rotates to 0 when expanded) -->
						<Border x:Name="ExpandCollapseChevronBorder"
								Grid.Column="1"
								Width="{StaticResource SimpleExpanderChevronButtonSize}"
								Height="{StaticResource SimpleExpanderChevronButtonSize}"
								Margin="{StaticResource SimpleExpanderChevronMargin}"
								CornerRadius="{StaticResource SimpleExpanderCornerRadius}"
								Background="Transparent"
								BorderBrush="Transparent"
								BorderThickness="0">
							<FontIcon x:Name="ExpandCollapseChevron"
									  Glyph="{StaticResource SimpleExpanderChevronDownGlyph}"
									  FontFamily="{StaticResource SymbolThemeFontFamily}"
									  FontSize="{StaticResource SimpleExpanderChevronGlyphSize}"
									  Foreground="{ThemeResource SimpleExpanderChevronForeground}"
									  HorizontalAlignment="Center"
									  VerticalAlignment="Center"
									  IsTextScaleFactorEnabled="False"
									  RenderTransformOrigin="0.5,0.5"
									  AutomationProperties.AccessibilityView="Raw">
								<FontIcon.RenderTransform>
									<RotateTransform x:Name="ExpandCollapseChevronRotateTransform" Angle="0" />
								</FontIcon.RenderTransform>
							</FontIcon>
						</Border>
					</Grid>
				</ControlTemplate>
			</Setter.Value>
		</Setter>
	</Style>

	<!-- ═══════════════════════════════════════════════════════════════════════ -->
	<!-- Expander Style                                                         -->
	<!-- ═══════════════════════════════════════════════════════════════════════ -->
	<Style x:Key="SimpleExpanderStyle"
		   TargetType="Expander">

		<Setter Property="IsTabStop" Value="False" />
		<Setter Property="Background" Value="{ThemeResource SimpleExpanderContentBackground}" />
		<Setter Property="BackgroundSizing" Value="InnerBorderEdge" />
		<Setter Property="MinWidth" Value="{ThemeResource FlyoutThemeMinWidth}" />
		<Setter Property="MinHeight" Value="{StaticResource SimpleExpanderMinHeight}" />
		<Setter Property="BorderThickness" Value="{StaticResource SimpleExpanderContentBorderThickness}" />
		<Setter Property="BorderBrush" Value="{ThemeResource SimpleExpanderContentBorderBrush}" />
		<Setter Property="Padding" Value="{StaticResource SimpleExpanderContentPadding}" />
		<Setter Property="HorizontalAlignment" Value="Stretch" />
		<Setter Property="VerticalAlignment" Value="Center" />
		<Setter Property="CornerRadius" Value="{StaticResource SimpleExpanderCornerRadius}" />
		<Setter Property="Foreground" Value="{ThemeResource SimpleExpanderContentForeground}" />
		<Setter Property="FontFamily" Value="{ThemeResource SimpleFontFamily}" />
		<Setter Property="FontSize" Value="{ThemeResource SimpleTypographyScale03}" />

		<Setter Property="Template">
			<Setter.Value>
				<ControlTemplate TargetType="Expander">
					<Grid MinWidth="{TemplateBinding MinWidth}"
						  MaxWidth="{TemplateBinding MaxWidth}">

						<Grid.RowDefinitions>
							<RowDefinition x:Name="Row0" Height="Auto" />
							<RowDefinition x:Name="Row1" Height="*" />
						</Grid.RowDefinitions>

						<VisualStateManager.VisualStateGroups>
							<VisualStateGroup x:Name="ExpandStates">

								<VisualState x:Name="ExpandUp">
									<VisualState.Setters>
										<Setter Target="ExpanderHeader.CornerRadius"
												Value="{Binding CornerRadius, RelativeSource={RelativeSource TemplatedParent}, Converter={StaticResource BottomCornerRadiusFilterConverter}}" />
									</VisualState.Setters>
									<VisualState.Storyboard>
										<Storyboard>
											<ObjectAnimationUsingKeyFrames Storyboard.TargetName="ExpanderContent" Storyboard.TargetProperty="Visibility">
												<DiscreteObjectKeyFrame KeyTime="0" Value="Visible" />
											</ObjectAnimationUsingKeyFrames>
											<DoubleAnimationUsingKeyFrames Storyboard.TargetName="ExpanderContent"
																	   Storyboard.TargetProperty="(UIElement.RenderTransform).(CompositeTransform.TranslateY)">
												<DiscreteDoubleKeyFrame KeyTime="0" Value="{Binding RelativeSource={RelativeSource TemplatedParent}, Path=TemplateSettings.ContentHeight}" />
												<SplineDoubleKeyFrame KeyTime="0:0:0.333" Value="0" KeySpline="0.0, 0.0, 0.0, 1.0" />
											</DoubleAnimationUsingKeyFrames>
										</Storyboard>
									</VisualState.Storyboard>
								</VisualState>

								<VisualState x:Name="CollapseDown">
									<VisualState.Storyboard>
										<Storyboard>
											<ObjectAnimationUsingKeyFrames Storyboard.TargetName="ExpanderContent" Storyboard.TargetProperty="Visibility">
												<DiscreteObjectKeyFrame KeyTime="0:0:0.2" Value="Collapsed" />
											</ObjectAnimationUsingKeyFrames>
											<DoubleAnimationUsingKeyFrames Storyboard.TargetName="ExpanderContent"
																	   Storyboard.TargetProperty="(UIElement.RenderTransform).(CompositeTransform.TranslateY)">
												<DiscreteDoubleKeyFrame KeyTime="0" Value="0" />
												<SplineDoubleKeyFrame KeyTime="0:0:0.167" Value="{Binding RelativeSource={RelativeSource TemplatedParent}, Path=TemplateSettings.ContentHeight}" KeySpline="1.0, 1.0, 0.0, 1.0" />
											</DoubleAnimationUsingKeyFrames>
										</Storyboard>
									</VisualState.Storyboard>
								</VisualState>

								<VisualState x:Name="ExpandDown">
									<VisualState.Setters>
										<Setter Target="ExpanderHeader.CornerRadius"
												Value="{Binding CornerRadius, RelativeSource={RelativeSource TemplatedParent}, Converter={StaticResource TopCornerRadiusFilterConverter}}" />
									</VisualState.Setters>
									<VisualState.Storyboard>
										<Storyboard>
											<ObjectAnimationUsingKeyFrames Storyboard.TargetName="ExpanderContent" Storyboard.TargetProperty="Visibility">
												<DiscreteObjectKeyFrame KeyTime="0" Value="Visible" />
											</ObjectAnimationUsingKeyFrames>
											<DoubleAnimationUsingKeyFrames Storyboard.TargetName="ExpanderContent"
																	   Storyboard.TargetProperty="(UIElement.RenderTransform).(CompositeTransform.TranslateY)">
												<DiscreteDoubleKeyFrame KeyTime="0" Value="{Binding RelativeSource={RelativeSource TemplatedParent}, Path=TemplateSettings.NegativeContentHeight}" />
												<SplineDoubleKeyFrame KeyTime="0:0:0.333" Value="0" KeySpline="0.0, 0.0, 0.0, 1.0" />
											</DoubleAnimationUsingKeyFrames>
										</Storyboard>
									</VisualState.Storyboard>
								</VisualState>

								<VisualState x:Name="CollapseUp">
									<VisualState.Storyboard>
										<Storyboard>
											<ObjectAnimationUsingKeyFrames Storyboard.TargetName="ExpanderContent" Storyboard.TargetProperty="Visibility">
												<DiscreteObjectKeyFrame KeyTime="0:0:0.167" Value="Collapsed" />
											</ObjectAnimationUsingKeyFrames>
											<DoubleAnimationUsingKeyFrames Storyboard.TargetName="ExpanderContent"
																	   Storyboard.TargetProperty="(UIElement.RenderTransform).(CompositeTransform.TranslateY)">
												<DiscreteDoubleKeyFrame KeyTime="0" Value="0" />
												<SplineDoubleKeyFrame KeyTime="0:0:0.167" Value="{Binding RelativeSource={RelativeSource TemplatedParent}, Path=TemplateSettings.NegativeContentHeight}" KeySpline="1.0, 1.0, 0.0, 1.0" />
											</DoubleAnimationUsingKeyFrames>
										</Storyboard>
									</VisualState.Storyboard>
								</VisualState>

							</VisualStateGroup>

							<VisualStateGroup x:Name="ExpandDirectionStates">
								<VisualState x:Name="Down" />
								<VisualState x:Name="Up">
									<VisualState.Setters>
										<Setter Target="ExpanderHeader.Style" Value="{StaticResource SimpleExpanderHeaderUpStyle}" />
										<Setter Target="ExpanderContent.BorderThickness" Value="{StaticResource SimpleExpanderContentUpBorderThickness}" />
										<Setter Target="ExpanderContent.CornerRadius"
												Value="{Binding CornerRadius, RelativeSource={RelativeSource TemplatedParent}, Converter={StaticResource TopCornerRadiusFilterConverter}}" />
										<Setter Target="ExpanderHeader.(Grid.Row)" Value="1" />
										<Setter Target="ExpanderContentClip.(Grid.Row)" Value="0" />
										<Setter Target="Row0.Height" Value="*" />
										<Setter Target="Row1.Height" Value="Auto" />
									</VisualState.Setters>
								</VisualState>
							</VisualStateGroup>
						</VisualStateManager.VisualStateGroups>

						<!-- Header (ToggleButton) -->
						<ToggleButton x:Name="ExpanderHeader"
									  Grid.Row="0"
									  Style="{StaticResource SimpleExpanderHeaderDownStyle}"
									  Content="{TemplateBinding Header}"
									  ContentTemplate="{TemplateBinding HeaderTemplate}"
									  ContentTemplateSelector="{TemplateBinding HeaderTemplateSelector}"
									  Background="{ThemeResource SimpleExpanderHeaderBackground}"
									  BorderBrush="{ThemeResource SimpleExpanderHeaderBorderBrush}"
									  BorderThickness="{StaticResource SimpleExpanderHeaderBorderThickness}"
									  CornerRadius="{TemplateBinding CornerRadius}"
									  MinHeight="{StaticResource SimpleExpanderMinHeight}"
									  MinWidth="{TemplateBinding MinWidth}"
									  MaxWidth="{TemplateBinding MaxWidth}"
									  Padding="{StaticResource SimpleExpanderHeaderPadding}"
									  FontFamily="{ThemeResource SimpleFontFamily}"
									  FontSize="{ThemeResource SimpleTypographyScale03}"
									  FontWeight="{ThemeResource SimpleSemiBoldFontWeight}"
									  Foreground="{ThemeResource SimpleExpanderHeaderForeground}"
									  HorizontalAlignment="Stretch"
									  HorizontalContentAlignment="{StaticResource ExpanderHeaderHorizontalContentAlignment}"
									  VerticalContentAlignment="{StaticResource ExpanderHeaderVerticalContentAlignment}"
									  IsEnabled="{TemplateBinding IsEnabled}"
									  IsChecked="{Binding Path=IsExpanded, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
									  BackgroundSizing="InnerBorderEdge"
									  AutomationProperties.AutomationId="ExpanderToggleButton"
									  IsTabStop="True" />

						<!-- The clip is a composition clip applied in code -->
						<Border x:Name="ExpanderContentClip"
								Grid.Row="1">
							<Border x:Name="ExpanderContent"
									Background="{TemplateBinding Background}"
									BackgroundSizing="{TemplateBinding BackgroundSizing}"
									BorderBrush="{TemplateBinding BorderBrush}"
									BorderThickness="{StaticResource SimpleExpanderContentBorderThickness}"
									CornerRadius="{Binding CornerRadius, RelativeSource={RelativeSource TemplatedParent}, Converter={StaticResource BottomCornerRadiusFilterConverter}}"
									MinHeight="{TemplateBinding MinHeight}"
									HorizontalAlignment="Stretch"
									VerticalAlignment="Stretch"
									Padding="{TemplateBinding Padding}"
									Visibility="Collapsed">
								<ContentPresenter Content="{TemplateBinding Content}"
												  ContentTemplate="{TemplateBinding ContentTemplate}"
												  ContentTemplateSelector="{TemplateBinding ContentTemplateSelector}"
												  Foreground="{TemplateBinding Foreground}"
												  HorizontalContentAlignment="{TemplateBinding HorizontalContentAlignment}"
												  VerticalContentAlignment="{TemplateBinding VerticalContentAlignment}" />
								<Border.RenderTransform>
									<CompositeTransform />
								</Border.RenderTransform>
							</Border>
						</Border>

					</Grid>
				</ControlTemplate>
			</Setter.Value>
		</Setter>
	</Style>

	<!-- Default alias (for implicit style usage) -->
	<Style x:Key="SimpleDefaultExpanderStyle"
		   BasedOn="{StaticResource SimpleExpanderStyle}"
		   TargetType="Expander" />

</ResourceDictionary>
