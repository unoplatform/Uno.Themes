																	Value="{ThemeResource OnSurfaceDisabledBrush}" />
										</ObjectAnimationUsingKeyFrames>
										<ObjectAnimationUsingKeyFrames Storyboard.TargetName="ToggleButtonGrid"
																	   Storyboard.TargetProperty="BorderBrush">
