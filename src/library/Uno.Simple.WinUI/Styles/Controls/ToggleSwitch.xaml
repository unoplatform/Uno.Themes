<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
					xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

	<!--
		Simple Design System — ToggleSwitch Style
		Lightweight styling: every visual-state brush is exposed via ThemeResource.

		States: CommonStates (Normal/PointerOver/Pressed/Disabled) ×
		        ToggleStates (Off/On/Dragging)
		SDS source: Switch/switch.css
	-->

	<!-- ═══════════════════════════════════════════════════════════════════════ -->
	<!-- Lightweight styling ThemeResource aliases                              -->
	<!-- ═══════════════════════════════════════════════════════════════════════ -->
	<ResourceDictionary.ThemeDictionaries>

		<!-- ─── Light Theme ─── -->
		<ResourceDictionary x:Key="Light">

			<!-- Off state track -->
			<StaticResource x:Key="SimpleToggleSwitchTrackOffBackground"       ResourceKey="SimpleBackgroundDefaultSecondaryBrush" />
			<StaticResource x:Key="SimpleToggleSwitchTrackOffBorderBrush"      ResourceKey="SimpleBorderDefaultDefaultBrush" />
			<!-- On state track -->
			<StaticResource x:Key="SimpleToggleSwitchTrackOnBackground"        ResourceKey="SimpleBackgroundBrandDefaultBrush" />
			<!-- Thumb fills -->
			<StaticResource x:Key="SimpleToggleSwitchThumbOffFill"             ResourceKey="SimpleIconDefaultSecondaryBrush" />
			<StaticResource x:Key="SimpleToggleSwitchThumbOnFill"              ResourceKey="SimpleIconBrandOnBrandBrush" />
			<!-- Pressed -->
			<StaticResource x:Key="SimpleToggleSwitchTrackOffBackgroundPressed" ResourceKey="SimpleBackgroundDefaultSecondaryPressedBrush" />
			<StaticResource x:Key="SimpleToggleSwitchTrackOnBackgroundPressed"  ResourceKey="SimpleBackgroundBrandPressedBrush" />
			<!-- Disabled -->
			<StaticResource x:Key="SimpleToggleSwitchTrackDisabledBackground"  ResourceKey="SimpleBackgroundDisabledDefaultBrush" />
			<StaticResource x:Key="SimpleToggleSwitchTrackDisabledBorderBrush" ResourceKey="SimpleBorderDisabledDefaultBrush" />
			<StaticResource x:Key="SimpleToggleSwitchThumbDisabledFill"        ResourceKey="SimpleIconDisabledDefaultBrush" />
			<!-- Label -->
			<StaticResource x:Key="SimpleToggleSwitchForeground"               ResourceKey="SimpleTextDefaultDefaultBrush" />
			<StaticResource x:Key="SimpleToggleSwitchForegroundDisabled"       ResourceKey="SimpleTextDisabledDefaultBrush" />
		</ResourceDictionary>

		<!-- ─── Dark Theme (Default) ─── -->
		<ResourceDictionary x:Key="Default">

			<!-- Off state track -->
			<StaticResource x:Key="SimpleToggleSwitchTrackOffBackground"       ResourceKey="SimpleBackgroundDefaultSecondaryBrush" />
			<StaticResource x:Key="SimpleToggleSwitchTrackOffBorderBrush"      ResourceKey="SimpleBorderDefaultDefaultBrush" />
			<!-- On state track -->
			<StaticResource x:Key="SimpleToggleSwitchTrackOnBackground"        ResourceKey="SimpleBackgroundBrandDefaultBrush" />
			<!-- Thumb fills -->
			<StaticResource x:Key="SimpleToggleSwitchThumbOffFill"             ResourceKey="SimpleIconDefaultSecondaryBrush" />
			<StaticResource x:Key="SimpleToggleSwitchThumbOnFill"              ResourceKey="SimpleIconBrandOnBrandBrush" />
			<!-- Pressed -->
			<StaticResource x:Key="SimpleToggleSwitchTrackOffBackgroundPressed" ResourceKey="SimpleBackgroundDefaultSecondaryPressedBrush" />
			<StaticResource x:Key="SimpleToggleSwitchTrackOnBackgroundPressed"  ResourceKey="SimpleBackgroundBrandPressedBrush" />
			<!-- Disabled -->
			<StaticResource x:Key="SimpleToggleSwitchTrackDisabledBackground"  ResourceKey="SimpleBackgroundDisabledDefaultBrush" />
			<StaticResource x:Key="SimpleToggleSwitchTrackDisabledBorderBrush" ResourceKey="SimpleBorderDisabledDefaultBrush" />
			<StaticResource x:Key="SimpleToggleSwitchThumbDisabledFill"        ResourceKey="SimpleIconDisabledDefaultBrush" />
			<!-- Label -->
			<StaticResource x:Key="SimpleToggleSwitchForeground"               ResourceKey="SimpleTextDefaultDefaultBrush" />
			<StaticResource x:Key="SimpleToggleSwitchForegroundDisabled"       ResourceKey="SimpleTextDisabledDefaultBrush" />
		</ResourceDictionary>

	</ResourceDictionary.ThemeDictionaries>

	<!-- ═══════════════════════════════════════════════════════════════════════ -->
	<!-- Layout / sizing resources (theme-agnostic)                            -->
	<!-- ═══════════════════════════════════════════════════════════════════════ -->
	<StaticResource x:Key="SimpleToggleSwitchTrackWidth" ResourceKey="SimpleIconLarge" /> <!-- sds-size-icon-large -->
	<StaticResource x:Key="SimpleToggleSwitchTrackHeight" ResourceKey="SimpleIconSmall" /> <!-- sds-size-icon-small -->
	<x:Double x:Key="SimpleToggleSwitchTrackRadius">12</x:Double> <!-- no exact SDS token (12) -->
	<StaticResource x:Key="SimpleToggleSwitchStrokeThickness" ResourceKey="SimpleStrokeBorder" /> <!-- sds-size-stroke-border -->
	<StaticResource x:Key="SimpleToggleSwitchThumbSize" ResourceKey="SimpleSpace400" /> <!-- sds-size-space-400 -->
	<Thickness x:Key="SimpleToggleSwitchThumbOffMargin">4,0,0,0</Thickness> <!-- sds-size-space-100,0,0,0 -->
	<Thickness x:Key="SimpleToggleSwitchThumbOnMargin">20,0,0,0</Thickness> <!-- no exact SDS token for 20 -->
	<Thickness x:Key="SimpleToggleSwitchHeaderMargin">0,0,0,4</Thickness> <!-- 0,0,0,sds-size-space-100 -->

	<!-- ═══════════════════════════════════════════════════════════════════════ -->
	<!-- SimpleToggleSwitchStyle                                                -->
	<!-- ═══════════════════════════════════════════════════════════════════════ -->
	<Style x:Key="SimpleToggleSwitchStyle"
		   TargetType="ToggleSwitch">
		<Setter Property="FontFamily" Value="{ThemeResource SimpleFontFamily}" />
		<Setter Property="FontSize" Value="{ThemeResource SimpleBodySmallFontSize}" />
		<Setter Property="Foreground" Value="{ThemeResource SimpleToggleSwitchForeground}" />
		<Setter Property="HorizontalAlignment" Value="Left" />
		<Setter Property="VerticalAlignment" Value="Center" />
		<Setter Property="HorizontalContentAlignment" Value="Left" />
		<Setter Property="MinWidth" Value="{StaticResource SimpleIconLarge}" />
		<Setter Property="UseSystemFocusVisuals" Value="{StaticResource UseSystemFocusVisuals}" />
		<Setter Property="FocusVisualMargin" Value="-3" />
		<Setter Property="Template">
			<Setter.Value>
				<ControlTemplate TargetType="ToggleSwitch">
					<Grid>
						<VisualStateManager.VisualStateGroups>

							<!-- ToggleStates MUST be declared first so CommonStates (declared second)
							     can override colors in the Disabled state. -->
							<VisualStateGroup x:Name="ToggleStates">
								<VisualState x:Name="Dragging" />

								<VisualState x:Name="Off">
									<VisualState.Setters>
										<Setter Target="OuterBorder.Opacity" Value="1" />
										<Setter Target="SwitchKnobBounds.Opacity" Value="0" />
										<Setter Target="KnobOff.Opacity" Value="1" />
										<Setter Target="KnobOn.Opacity" Value="0" />
									</VisualState.Setters>
								</VisualState>

								<VisualState x:Name="On">
									<VisualState.Setters>
										<Setter Target="OuterBorder.Opacity" Value="0" />
										<Setter Target="SwitchKnobBounds.Opacity" Value="1" />
										<Setter Target="KnobOff.Opacity" Value="0" />
										<Setter Target="KnobOn.Opacity" Value="1" />
									</VisualState.Setters>
								</VisualState>
							</VisualStateGroup>

							<!-- CommonStates declared AFTER ToggleStates.
							     Disabled setters override ToggleStates colors. -->
							<VisualStateGroup x:Name="CommonStates">
								<VisualState x:Name="Normal" />
								<VisualState x:Name="PointerOver" />

								<VisualState x:Name="Pressed">
									<VisualState.Setters>
										<Setter Target="OuterBorder.Fill" Value="{ThemeResource SimpleToggleSwitchTrackOffBackgroundPressed}" />
										<Setter Target="SwitchKnobBounds.Fill" Value="{ThemeResource SimpleToggleSwitchTrackOnBackgroundPressed}" />
									</VisualState.Setters>
								</VisualState>

								<VisualState x:Name="Disabled">
									<VisualState.Setters>
										<Setter Target="OuterBorder.Fill" Value="{ThemeResource SimpleToggleSwitchTrackDisabledBackground}" />
										<Setter Target="OuterBorder.Stroke" Value="{ThemeResource SimpleToggleSwitchTrackDisabledBorderBrush}" />
										<Setter Target="SwitchKnobBounds.Fill" Value="{ThemeResource SimpleToggleSwitchTrackDisabledBackground}" />
										<Setter Target="KnobOff.Fill" Value="{ThemeResource SimpleToggleSwitchThumbDisabledFill}" />
										<Setter Target="KnobOn.Fill" Value="{ThemeResource SimpleToggleSwitchThumbDisabledFill}" />
										<Setter Target="ContentPresenter.Foreground" Value="{ThemeResource SimpleToggleSwitchForegroundDisabled}" />
										<Setter Target="HeaderContentPresenter.Foreground" Value="{ThemeResource SimpleToggleSwitchForegroundDisabled}" />
									</VisualState.Setters>
								</VisualState>
							</VisualStateGroup>

						</VisualStateManager.VisualStateGroups>

						<Grid.RowDefinitions>
							<RowDefinition Height="Auto" />
							<RowDefinition Height="Auto" />
						</Grid.RowDefinitions>

						<Grid.ColumnDefinitions>
							<ColumnDefinition Width="*" />
							<ColumnDefinition Width="Auto" />
						</Grid.ColumnDefinitions>

						<!-- Header -->
						<ContentPresenter x:Name="HeaderContentPresenter"
										  Grid.Row="0"
										  Grid.Column="0"
										  Content="{TemplateBinding Header}"
										  ContentTemplate="{TemplateBinding HeaderTemplate}"
										  Foreground="{ThemeResource SimpleToggleSwitchForeground}"
										  Margin="{StaticResource SimpleToggleSwitchHeaderMargin}"
										  VerticalAlignment="Top"
										  Visibility="Collapsed" />

						<!-- Track & Knob -->
						<Grid Grid.Row="1"
							  Grid.Column="0"
							  HorizontalAlignment="Left"
							  VerticalAlignment="Top"
							  Width="{StaticResource SimpleToggleSwitchTrackWidth}"
							  Height="{StaticResource SimpleToggleSwitchTrackHeight}">

							<!-- Off Track -->
							<Rectangle x:Name="OuterBorder"
									   Width="{StaticResource SimpleToggleSwitchTrackWidth}"
									   Height="{StaticResource SimpleToggleSwitchTrackHeight}"
									   RadiusX="{StaticResource SimpleToggleSwitchTrackRadius}"
									   RadiusY="{StaticResource SimpleToggleSwitchTrackRadius}"
									   Fill="{ThemeResource SimpleToggleSwitchTrackOffBackground}"
									   Stroke="{ThemeResource SimpleToggleSwitchTrackOffBorderBrush}"
									   StrokeThickness="{StaticResource SimpleToggleSwitchStrokeThickness}"
									   HorizontalAlignment="Center" />

							<!-- On Track -->
							<Rectangle x:Name="SwitchKnobBounds"
									   Width="{StaticResource SimpleToggleSwitchTrackWidth}"
									   Height="{StaticResource SimpleToggleSwitchTrackHeight}"
									   RadiusX="{StaticResource SimpleToggleSwitchTrackRadius}"
									   RadiusY="{StaticResource SimpleToggleSwitchTrackRadius}"
									   Fill="{ThemeResource SimpleToggleSwitchTrackOnBackground}"
									   HorizontalAlignment="Center"
									   Opacity="0" />

							<Grid x:Name="SwitchKnob"
								  HorizontalAlignment="Left"
								  Width="{StaticResource SimpleToggleSwitchTrackWidth}"
								  Height="{StaticResource SimpleToggleSwitchTrackHeight}">

								<!-- On Thumb (right position) -->
								<Grid x:Name="SwitchKnobOn"
									  HorizontalAlignment="Left">
									<Ellipse x:Name="KnobOn"
											 Width="{StaticResource SimpleToggleSwitchThumbSize}"
											 Height="{StaticResource SimpleToggleSwitchThumbSize}"
											 Fill="{ThemeResource SimpleToggleSwitchThumbOnFill}"
											 Margin="{StaticResource SimpleToggleSwitchThumbOnMargin}"
											 HorizontalAlignment="Left"
											 VerticalAlignment="Center"
											 Opacity="0" />
								</Grid>

								<!-- Off Thumb (left position) -->
								<Grid x:Name="SwitchKnobOff"
									  HorizontalAlignment="Left">
									<Ellipse x:Name="KnobOff"
											 Width="{StaticResource SimpleToggleSwitchThumbSize}"
											 Height="{StaticResource SimpleToggleSwitchThumbSize}"
											 Fill="{ThemeResource SimpleToggleSwitchThumbOffFill}"
											 Margin="{StaticResource SimpleToggleSwitchThumbOffMargin}"
											 HorizontalAlignment="Left"
											 VerticalAlignment="Center" />
								</Grid>
							</Grid>

							<!-- SwitchThumb for dragging -->
							<Thumb x:Name="SwitchThumb"
								   AutomationProperties.AccessibilityView="Raw">
								<Thumb.Template>
									<ControlTemplate TargetType="Thumb">
										<Rectangle Fill="Transparent" />
									</ControlTemplate>
								</Thumb.Template>
							</Thumb>
						</Grid>

						<!-- Content -->
						<ContentPresenter x:Name="ContentPresenter"
										  Grid.Row="1"
										  Grid.Column="0"
										  Grid.ColumnSpan="2"
										  Foreground="{TemplateBinding Foreground}"
										  HorizontalAlignment="Left"
										  VerticalAlignment="Center"
										  AutomationProperties.AccessibilityView="Raw" />
					</Grid>
				</ControlTemplate>
			</Setter.Value>
		</Setter>
	</Style>

</ResourceDictionary>
