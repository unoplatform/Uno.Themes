<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
					xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
					xmlns:muxc="using:Microsoft.UI.Xaml.Controls">

	<!--
		Simple Design System — ProgressBar Style
		Horizontal progress indicator using Simple's brand (accent) and track colors.
		Supports both determinate and indeterminate states via the built-in ProgressBar control.

		Resource layers:
		  ProgressBar*       = semantic keys (source of truth)
		  SimpleProgressBar* = Simple-prefixed aliases → ProgressBar*
	-->

	<ResourceDictionary.ThemeDictionaries>

		<!-- ─── Light Theme ─── -->
		<ResourceDictionary x:Key="Light">
			<StaticResource x:Key="ProgressBarForeground" ResourceKey="SimpleBackgroundBrandDefaultBrush" />
			<StaticResource x:Key="ProgressBarBackground" ResourceKey="SimpleBackgroundDefaultSecondaryBrush" />
			<StaticResource x:Key="ProgressBarForegroundDisabled" ResourceKey="SimpleBackgroundDisabledDefaultBrush" />
			<StaticResource x:Key="ProgressBarBackgroundDisabled" ResourceKey="SimpleBackgroundDisabledDefaultBrush" />

			<!-- Backwards-compat aliases -->
			<StaticResource x:Key="SimpleProgressBarForeground" ResourceKey="ProgressBarForeground" />
			<StaticResource x:Key="SimpleProgressBarBackground" ResourceKey="ProgressBarBackground" />
			<StaticResource x:Key="SimpleProgressBarForegroundDisabled" ResourceKey="ProgressBarForegroundDisabled" />
			<StaticResource x:Key="SimpleProgressBarBackgroundDisabled" ResourceKey="ProgressBarBackgroundDisabled" />
		</ResourceDictionary>

		<!-- ─── Dark Theme (Default) ─── -->
		<ResourceDictionary x:Key="Default">
			<StaticResource x:Key="ProgressBarForeground" ResourceKey="SimpleBackgroundBrandDefaultBrush" />
			<StaticResource x:Key="ProgressBarBackground" ResourceKey="SimpleBackgroundDefaultTertiaryBrush" />
			<StaticResource x:Key="ProgressBarForegroundDisabled" ResourceKey="SimpleBackgroundDisabledDefaultBrush" />
			<StaticResource x:Key="ProgressBarBackgroundDisabled" ResourceKey="SimpleBackgroundDisabledDefaultBrush" />

			<StaticResource x:Key="SimpleProgressBarForeground" ResourceKey="ProgressBarForeground" />
			<StaticResource x:Key="SimpleProgressBarBackground" ResourceKey="ProgressBarBackground" />
			<StaticResource x:Key="SimpleProgressBarForegroundDisabled" ResourceKey="ProgressBarForegroundDisabled" />
			<StaticResource x:Key="SimpleProgressBarBackgroundDisabled" ResourceKey="ProgressBarBackgroundDisabled" />
		</ResourceDictionary>

	</ResourceDictionary.ThemeDictionaries>

	<!-- ═══════════════════════════════════════════════════════════════════════ -->
	<!-- Sizing constants                                                       -->
	<!-- ═══════════════════════════════════════════════════════════════════════ -->
	<x:Double x:Key="SimpleProgressBarMinWidth">250</x:Double>
	<x:Double x:Key="SimpleProgressBarHeight">4</x:Double>

	<!-- ═══════════════════════════════════════════════════════════════════════ -->
	<!-- ProgressBar Style                                                      -->
	<!-- ═══════════════════════════════════════════════════════════════════════ -->
	<Style x:Key="SimpleProgressBarStyle"
		   TargetType="muxc:ProgressBar">
		<Setter Property="Foreground" Value="{ThemeResource SimpleProgressBarForeground}" />
		<Setter Property="Background" Value="{ThemeResource SimpleProgressBarBackground}" />
		<Setter Property="MinWidth" Value="{StaticResource SimpleProgressBarMinWidth}" />
		<Setter Property="Height" Value="{StaticResource SimpleProgressBarHeight}" />
		<Setter Property="CornerRadius" Value="2" />
	</Style>

	<!-- ═══════════════════════════════════════════════════════════════════════ -->
	<!-- Default alias                                                          -->
	<!-- ═══════════════════════════════════════════════════════════════════════ -->
	<Style x:Key="SimpleDefaultProgressBarStyle"
		   TargetType="muxc:ProgressBar"
		   BasedOn="{StaticResource SimpleProgressBarStyle}" />

</ResourceDictionary>
