<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
					xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
					xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
					xmlns:not_win="http://uno.ui/not_win"
					mc:Ignorable="not_win">

	<Style x:Key="SimpleCalendarViewStyle"
		   TargetType="CalendarView">

		<Setter Property="Foreground" Value="{ThemeResource OnSurfaceBrush}" />
		<Setter Property="Background" Value="{ThemeResource SurfaceBrush}" />
		<Setter Property="BorderBrush" Value="{ThemeResource OutlineBrush}" />
		<not_win:Setter Property="BorderThickness"
						Value="0" />
		<Setter Property="HorizontalAlignment" Value="Left" />
		<Setter Property="VerticalAlignment" Value="Center" />
		<Setter Property="HorizontalContentAlignment" Value="Stretch" />
		<Setter Property="VerticalContentAlignment" Value="Stretch" />
		<Setter Property="IsTabStop" Value="False" />
		<Setter Property="UseSystemFocusVisuals" Value="{StaticResource UseSystemFocusVisuals}" />

		<Setter Property="SelectedBorderBrush" Value="{ThemeResource PrimaryBrush}" />
		<Setter Property="SelectedForeground" Value="{ThemeResource OnPrimaryBrush}" />
		<Setter Property="SelectedHoverBorderBrush" Value="{ThemeResource PrimaryBrush}" />
		<Setter Property="SelectedPressedBorderBrush" Value="{ThemeResource PrimaryBrush}" />

		<Setter Property="TodayForeground" Value="{ThemeResource PrimaryBrush}" />

		<Setter Property="HoverBorderBrush" Value="{ThemeResource PrimaryHoverBrush}" />
		<Setter Property="PressedBorderBrush" Value="{ThemeResource PrimaryBrush}" />
		<Setter Property="FocusBorderBrush" Value="{ThemeResource PrimaryBrush}" />

		<Setter Property="CalendarItemForeground" Value="{ThemeResource OnSurfaceBrush}" />
		<Setter Property="CalendarItemBackground" Value="Transparent" />
		<Setter Property="CalendarItemBorderBrush" Value="Transparent" />
		<Setter Property="OutOfScopeForeground" Value="{ThemeResource OnSurfaceLowBrush}" />
		<Setter Property="OutOfScopeBackground" Value="Transparent" />
		<Setter Property="BlackoutForeground" Value="{ThemeResource OnSurfaceLowBrush}" />

		<!-- Typography -->
		<Setter Property="DayItemFontSize" Value="14" />
		<Setter Property="MonthYearItemFontSize" Value="14" />
		<Setter Property="FirstOfMonthLabelFontSize" Value="0" />

		<not_win:Setter Property="CornerRadius"
						Value="8" />
		<not_win:Setter Property="DayItemCornerRadius"
						Value="20" />
		<not_win:Setter Property="CalendarItemCornerRadius"
						Value="40" />
		<not_win:Setter Property="CalendarItemBorderThickness"
						Value="0" />
		<not_win:Setter Property="SelectedBackground"
						Value="{ThemeResource PrimaryBrush}" />
		<not_win:Setter Property="TodaySelectedBackground"
						Value="{ThemeResource PrimaryBrush}" />
		<not_win:Setter Property="TodayBackground"
						Value="Transparent" />
	</Style>

	<Style x:Key="SimpleDefaultCalendarViewStyle"
		   TargetType="CalendarView"
		   BasedOn="{StaticResource SimpleCalendarViewStyle}" />
</ResourceDictionary>
