<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
					xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

	<!--
		Shared Shape Tokens

		This file defines the canonical set of corner radius tokens used across all themes.
		Each theme may override these defaults in its own shape file.
		The values follow a 4-px grid scale.

		Key naming: Radius{scale} for raw doubles, Radius{scale}CornerRadius for typed companions.
	-->

	<ResourceDictionary.ThemeDictionaries>

		<!-- ═══════════════════════════════════════════════════════════════ -->
		<!-- DARK THEME (Default)                                          -->
		<!-- ═══════════════════════════════════════════════════════════════ -->
		<ResourceDictionary x:Key="Default">

			<!-- Corner radius scale (px) -->
			<x:Double x:Key="Radius0">0</x:Double>
			<x:Double x:Key="Radius050">2</x:Double>
			<x:Double x:Key="Radius100">4</x:Double>
			<x:Double x:Key="Radius200">8</x:Double>
			<x:Double x:Key="Radius400">16</x:Double>
			<x:Double x:Key="RadiusFull">9999</x:Double>

			<!-- Typed CornerRadius companions -->
			<CornerRadius x:Key="Radius0CornerRadius">0</CornerRadius>
			<CornerRadius x:Key="Radius050CornerRadius">2</CornerRadius>
			<CornerRadius x:Key="Radius100CornerRadius">4</CornerRadius>
			<CornerRadius x:Key="Radius200CornerRadius">8</CornerRadius>
			<CornerRadius x:Key="Radius400CornerRadius">16</CornerRadius>
			<CornerRadius x:Key="RadiusFullCornerRadius">9999</CornerRadius>

		</ResourceDictionary>

		<!-- ═══════════════════════════════════════════════════════════════ -->
		<!-- LIGHT THEME                                                   -->
		<!-- ═══════════════════════════════════════════════════════════════ -->
		<ResourceDictionary x:Key="Light">

			<!-- Corner radius scale (px) -->
			<x:Double x:Key="Radius0">0</x:Double>
			<x:Double x:Key="Radius050">2</x:Double>
			<x:Double x:Key="Radius100">4</x:Double>
			<x:Double x:Key="Radius200">8</x:Double>
			<x:Double x:Key="Radius400">16</x:Double>
			<x:Double x:Key="RadiusFull">9999</x:Double>

			<!-- Typed CornerRadius companions -->
			<CornerRadius x:Key="Radius0CornerRadius">0</CornerRadius>
			<CornerRadius x:Key="Radius050CornerRadius">2</CornerRadius>
			<CornerRadius x:Key="Radius100CornerRadius">4</CornerRadius>
			<CornerRadius x:Key="Radius200CornerRadius">8</CornerRadius>
			<CornerRadius x:Key="Radius400CornerRadius">16</CornerRadius>
			<CornerRadius x:Key="RadiusFullCornerRadius">9999</CornerRadius>

		</ResourceDictionary>

	</ResourceDictionary.ThemeDictionaries>

</ResourceDictionary>
