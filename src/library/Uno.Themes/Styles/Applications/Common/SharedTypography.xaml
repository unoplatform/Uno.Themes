<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
					xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

	<!--
		Shared Typography Tokens

		This file defines the canonical set of semantic typography tokens.
		The key names follow the Material Design 3 type scale and are used
		by control templates across all themes.

		Each theme (Material, Simple, Cupertino) overrides these defaults
		in its own Typography/Fonts file. The values here serve only as a
		baseline fallback and match the Material M3 specification.
	-->

