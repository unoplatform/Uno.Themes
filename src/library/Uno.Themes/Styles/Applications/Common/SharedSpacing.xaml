<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
					xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

	<!--
		Shared Spacing Tokens

		This file defines the canonical set of spacing tokens used across all themes.
		Each theme may override these defaults in its own spacing file.
		The values here serve as a baseline and follow a 4-px grid scale.

		Key naming: Space{scale} where scale indicates the density step.
		Typed Thickness companions use the suffix "Thickness".
	-->

	<ResourceDictionary.ThemeDictionaries>

		<!-- ═══════════════════════════════════════════════════════════════ -->
		<!-- DARK THEME (Default)                                          -->
		<!-- ═══════════════════════════════════════════════════════════════ -->
		<ResourceDictionary x:Key="Default">

			<!-- Spacing scale (px) -->
			<x:Double x:Key="Space0">0</x:Double>
			<x:Double x:Key="Space050">2</x:Double>
			<x:Double x:Key="Space100">4</x:Double>
			<x:Double x:Key="Space150">6</x:Double>
			<x:Double x:Key="Space200">8</x:Double>
			<x:Double x:Key="Space300">12</x:Double>
			<x:Double x:Key="Space400">16</x:Double>
			<x:Double x:Key="Space600">24</x:Double>
			<x:Double x:Key="Space800">32</x:Double>
			<x:Double x:Key="Space1200">48</x:Double>
			<x:Double x:Key="Space1600">64</x:Double>
			<x:Double x:Key="Space2400">96</x:Double>
			<x:Double x:Key="Space4000">160</x:Double>

			<!-- Typed Thickness companions (uniform) -->
			<Thickness x:Key="Space0Thickness">0</Thickness>
			<Thickness x:Key="Space050Thickness">2</Thickness>
			<Thickness x:Key="Space100Thickness">4</Thickness>
			<Thickness x:Key="Space150Thickness">6</Thickness>
			<Thickness x:Key="Space200Thickness">8</Thickness>
			<Thickness x:Key="Space300Thickness">12</Thickness>
			<Thickness x:Key="Space400Thickness">16</Thickness>
			<Thickness x:Key="Space600Thickness">24</Thickness>
			<Thickness x:Key="Space800Thickness">32</Thickness>
			<Thickness x:Key="Space1200Thickness">48</Thickness>
			<Thickness x:Key="Space1600Thickness">64</Thickness>
			<Thickness x:Key="Space2400Thickness">96</Thickness>
			<Thickness x:Key="Space4000Thickness">160</Thickness>

		</ResourceDictionary>

		<!-- ═══════════════════════════════════════════════════════════════ -->
		<!-- LIGHT THEME                                                   -->
		<!-- ═══════════════════════════════════════════════════════════════ -->
		<ResourceDictionary x:Key="Light">

			<!-- Spacing scale (px) -->
			<x:Double x:Key="Space0">0</x:Double>
			<x:Double x:Key="Space050">2</x:Double>
			<x:Double x:Key="Space100">4</x:Double>
			<x:Double x:Key="Space150">6</x:Double>
			<x:Double x:Key="Space200">8</x:Double>
			<x:Double x:Key="Space300">12</x:Double>
			<x:Double x:Key="Space400">16</x:Double>
			<x:Double x:Key="Space600">24</x:Double>
			<x:Double x:Key="Space800">32</x:Double>
			<x:Double x:Key="Space1200">48</x:Double>
			<x:Double x:Key="Space1600">64</x:Double>
			<x:Double x:Key="Space2400">96</x:Double>
			<x:Double x:Key="Space4000">160</x:Double>

			<!-- Typed Thickness companions (uniform) -->
			<Thickness x:Key="Space0Thickness">0</Thickness>
			<Thickness x:Key="Space050Thickness">2</Thickness>
			<Thickness x:Key="Space100Thickness">4</Thickness>
			<Thickness x:Key="Space150Thickness">6</Thickness>
			<Thickness x:Key="Space200Thickness">8</Thickness>
			<Thickness x:Key="Space300Thickness">12</Thickness>
			<Thickness x:Key="Space400Thickness">16</Thickness>
			<Thickness x:Key="Space600Thickness">24</Thickness>
			<Thickness x:Key="Space800Thickness">32</Thickness>
			<Thickness x:Key="Space1200Thickness">48</Thickness>
			<Thickness x:Key="Space1600Thickness">64</Thickness>
			<Thickness x:Key="Space2400Thickness">96</Thickness>
			<Thickness x:Key="Space4000Thickness">160</Thickness>

		</ResourceDictionary>

	</ResourceDictionary.ThemeDictionaries>

</ResourceDictionary>
