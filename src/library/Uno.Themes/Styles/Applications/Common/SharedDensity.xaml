<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
					xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

	<!--
		Shared Density Tokens

		This file defines the canonical set of density-related tokens used across all themes:
		control heights, touch targets, and icon sizes.
		Each theme may override these defaults in its own density file.
	-->

	<ResourceDictionary.ThemeDictionaries>

		<!-- ═══════════════════════════════════════════════════════════════ -->
		<!-- DARK THEME (Default)                                          -->
		<!-- ═══════════════════════════════════════════════════════════════ -->
		<ResourceDictionary x:Key="Default">

			<!-- Control heights -->
			<x:Double x:Key="ControlHeightSmall">32</x:Double>
			<x:Double x:Key="ControlHeightMedium">40</x:Double>
			<x:Double x:Key="ControlHeightLarge">48</x:Double>

			<!-- Touch target -->
			<x:Double x:Key="TouchTargetMinSize">48</x:Double>

			<!-- Icon sizes -->
			<x:Double x:Key="IconSizeSmall">16</x:Double>
			<x:Double x:Key="IconSizeMedium">24</x:Double>
			<x:Double x:Key="IconSizeLarge">32</x:Double>

		</ResourceDictionary>

		<!-- ═══════════════════════════════════════════════════════════════ -->
		<!-- LIGHT THEME                                                   -->
		<!-- ═══════════════════════════════════════════════════════════════ -->
		<ResourceDictionary x:Key="Light">

			<!-- Control heights -->
			<x:Double x:Key="ControlHeightSmall">32</x:Double>
			<x:Double x:Key="ControlHeightMedium">40</x:Double>
			<x:Double x:Key="ControlHeightLarge">48</x:Double>

			<!-- Touch target -->
			<x:Double x:Key="TouchTargetMinSize">48</x:Double>

			<!-- Icon sizes -->
			<x:Double x:Key="IconSizeSmall">16</x:Double>
			<x:Double x:Key="IconSizeMedium">24</x:Double>
			<x:Double x:Key="IconSizeLarge">32</x:Double>

		</ResourceDictionary>

	</ResourceDictionary.ThemeDictionaries>

</ResourceDictionary>
