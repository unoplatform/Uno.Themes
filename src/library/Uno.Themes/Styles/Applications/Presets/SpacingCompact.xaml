<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
					xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

	<!--
		Spacing Preset: Compact

		All spacing values are scaled to ~75% of the default (Cozy) values.
		Merge this dictionary via SpacingOverrideSource or SpacingOverrideDictionary
		on BaseTheme to apply compact spacing app-wide.
	-->

	<ResourceDictionary.ThemeDictionaries>

		<ResourceDictionary x:Key="Default">
			<x:Double x:Key="Space0">0</x:Double>
			<x:Double x:Key="Space050">1</x:Double>
			<x:Double x:Key="Space100">3</x:Double>
			<x:Double x:Key="Space150">4</x:Double>
			<x:Double x:Key="Space200">6</x:Double>
			<x:Double x:Key="Space300">9</x:Double>
			<x:Double x:Key="Space400">12</x:Double>
			<x:Double x:Key="Space600">18</x:Double>
			<x:Double x:Key="Space800">24</x:Double>
			<x:Double x:Key="Space1200">36</x:Double>
			<x:Double x:Key="Space1600">48</x:Double>
			<x:Double x:Key="Space2400">72</x:Double>
			<x:Double x:Key="Space4000">120</x:Double>

			<Thickness x:Key="Space0Thickness">0</Thickness>
			<Thickness x:Key="Space050Thickness">1</Thickness>
			<Thickness x:Key="Space100Thickness">3</Thickness>
			<Thickness x:Key="Space150Thickness">4</Thickness>
			<Thickness x:Key="Space200Thickness">6</Thickness>
			<Thickness x:Key="Space300Thickness">9</Thickness>
			<Thickness x:Key="Space400Thickness">12</Thickness>
			<Thickness x:Key="Space600Thickness">18</Thickness>
			<Thickness x:Key="Space800Thickness">24</Thickness>
			<Thickness x:Key="Space1200Thickness">36</Thickness>
			<Thickness x:Key="Space1600Thickness">48</Thickness>
			<Thickness x:Key="Space2400Thickness">72</Thickness>
			<Thickness x:Key="Space4000Thickness">120</Thickness>
		</ResourceDictionary>

		<ResourceDictionary x:Key="Light">
			<x:Double x:Key="Space0">0</x:Double>
			<x:Double x:Key="Space050">1</x:Double>
			<x:Double x:Key="Space100">3</x:Double>
			<x:Double x:Key="Space150">4</x:Double>
			<x:Double x:Key="Space200">6</x:Double>
			<x:Double x:Key="Space300">9</x:Double>
			<x:Double x:Key="Space400">12</x:Double>
			<x:Double x:Key="Space600">18</x:Double>
			<x:Double x:Key="Space800">24</x:Double>
			<x:Double x:Key="Space1200">36</x:Double>
			<x:Double x:Key="Space1600">48</x:Double>
			<x:Double x:Key="Space2400">72</x:Double>
			<x:Double x:Key="Space4000">120</x:Double>

			<Thickness x:Key="Space0Thickness">0</Thickness>
			<Thickness x:Key="Space050Thickness">1</Thickness>
			<Thickness x:Key="Space100Thickness">3</Thickness>
			<Thickness x:Key="Space150Thickness">4</Thickness>
			<Thickness x:Key="Space200Thickness">6</Thickness>
			<Thickness x:Key="Space300Thickness">9</Thickness>
			<Thickness x:Key="Space400Thickness">12</Thickness>
			<Thickness x:Key="Space600Thickness">18</Thickness>
			<Thickness x:Key="Space800Thickness">24</Thickness>
			<Thickness x:Key="Space1200Thickness">36</Thickness>
			<Thickness x:Key="Space1600Thickness">48</Thickness>
			<Thickness x:Key="Space2400Thickness">72</Thickness>
			<Thickness x:Key="Space4000Thickness">120</Thickness>
		</ResourceDictionary>

	</ResourceDictionary.ThemeDictionaries>

</ResourceDictionary>
