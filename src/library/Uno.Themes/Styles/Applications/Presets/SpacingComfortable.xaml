<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
					xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

	<!--
		Spacing Preset: Comfortable

		All spacing values are scaled to ~125% of the default (Cozy) values.
		Merge this dictionary via SpacingOverrideSource or SpacingOverrideDictionary
		on BaseTheme to apply comfortable spacing app-wide.
	-->

	<ResourceDictionary.ThemeDictionaries>

		<ResourceDictionary x:Key="Default">
			<x:Double x:Key="Space0">0</x:Double>
			<x:Double x:Key="Space050">3</x:Double>
			<x:Double x:Key="Space100">5</x:Double>
			<x:Double x:Key="Space150">8</x:Double>
			<x:Double x:Key="Space200">10</x:Double>
			<x:Double x:Key="Space300">15</x:Double>
			<x:Double x:Key="Space400">20</x:Double>
			<x:Double x:Key="Space600">30</x:Double>
			<x:Double x:Key="Space800">40</x:Double>
			<x:Double x:Key="Space1200">60</x:Double>
			<x:Double x:Key="Space1600">80</x:Double>
			<x:Double x:Key="Space2400">120</x:Double>
			<x:Double x:Key="Space4000">200</x:Double>

			<Thickness x:Key="Space0Thickness">0</Thickness>
			<Thickness x:Key="Space050Thickness">3</Thickness>
			<Thickness x:Key="Space100Thickness">5</Thickness>
			<Thickness x:Key="Space150Thickness">8</Thickness>
			<Thickness x:Key="Space200Thickness">10</Thickness>
			<Thickness x:Key="Space300Thickness">15</Thickness>
			<Thickness x:Key="Space400Thickness">20</Thickness>
			<Thickness x:Key="Space600Thickness">30</Thickness>
			<Thickness x:Key="Space800Thickness">40</Thickness>
			<Thickness x:Key="Space1200Thickness">60</Thickness>
			<Thickness x:Key="Space1600Thickness">80</Thickness>
			<Thickness x:Key="Space2400Thickness">120</Thickness>
			<Thickness x:Key="Space4000Thickness">200</Thickness>
		</ResourceDictionary>

		<ResourceDictionary x:Key="Light">
			<x:Double x:Key="Space0">0</x:Double>
			<x:Double x:Key="Space050">3</x:Double>
			<x:Double x:Key="Space100">5</x:Double>
			<x:Double x:Key="Space150">8</x:Double>
			<x:Double x:Key="Space200">10</x:Double>
			<x:Double x:Key="Space300">15</x:Double>
			<x:Double x:Key="Space400">20</x:Double>
			<x:Double x:Key="Space600">30</x:Double>
			<x:Double x:Key="Space800">40</x:Double>
			<x:Double x:Key="Space1200">60</x:Double>
			<x:Double x:Key="Space1600">80</x:Double>
			<x:Double x:Key="Space2400">120</x:Double>
			<x:Double x:Key="Space4000">200</x:Double>

			<Thickness x:Key="Space0Thickness">0</Thickness>
			<Thickness x:Key="Space050Thickness">3</Thickness>
			<Thickness x:Key="Space100Thickness">5</Thickness>
			<Thickness x:Key="Space150Thickness">8</Thickness>
			<Thickness x:Key="Space200Thickness">10</Thickness>
			<Thickness x:Key="Space300Thickness">15</Thickness>
			<Thickness x:Key="Space400Thickness">20</Thickness>
			<Thickness x:Key="Space600Thickness">30</Thickness>
			<Thickness x:Key="Space800Thickness">40</Thickness>
			<Thickness x:Key="Space1200Thickness">60</Thickness>
			<Thickness x:Key="Space1600Thickness">80</Thickness>
			<Thickness x:Key="Space2400Thickness">120</Thickness>
			<Thickness x:Key="Space4000Thickness">200</Thickness>
		</ResourceDictionary>

	</ResourceDictionary.ThemeDictionaries>

</ResourceDictionary>
