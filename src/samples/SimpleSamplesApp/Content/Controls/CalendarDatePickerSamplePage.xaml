<Page x:Class="Uno.Themes.Simple.Samples.Content.Controls.CalendarDatePickerSamplePage"
	  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
	  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	  xmlns:smtx="using:ShowMeTheXAML"
	  Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

	<ScrollViewer>
		<StackPanel Padding="24"
					Spacing="8"
					MaxWidth="800">
			<TextBlock Text="CalendarDatePicker"
					   Style="{StaticResource SamplePageHeaderTextBlockStyle}" />

			<!-- Basic -->
			<TextBlock Text="Basic CalendarDatePicker"
					   Style="{StaticResource SampleSectionHeaderTextBlockStyle}" />
			<smtx:XamlDisplay UniqueKey="Simple_CalendarDatePicker_Basic">
				<CalendarDatePicker />
			</smtx:XamlDisplay>

			<!-- With Header -->
			<TextBlock Text="With Header"
					   Style="{StaticResource SampleSectionHeaderTextBlockStyle}" />
			<smtx:XamlDisplay UniqueKey="Simple_CalendarDatePicker_WithHeader">
				<CalendarDatePicker Header="Appointment Date"
									PlaceholderText="Pick a date" />
			</smtx:XamlDisplay>

			<!-- Disabled -->
			<TextBlock Text="Disabled"
					   Style="{StaticResource SampleSectionHeaderTextBlockStyle}" />
			<smtx:XamlDisplay UniqueKey="Simple_CalendarDatePicker_Disabled">
				<CalendarDatePicker Header="Disabled"
									IsEnabled="False" />
			</smtx:XamlDisplay>
		</StackPanel>
	</ScrollViewer>
</Page>
