<Page x:Class="Uno.Themes.Simple.Samples.Content.Controls.TextBlockSamplePage"
	  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
	  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	  xmlns:smtx="using:ShowMeTheXAML"
	  Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

	<ScrollViewer>
		<StackPanel Padding="24"
					Spacing="8"
					MaxWidth="800">
			<TextBlock Text="TextBlock / Typography"
					   Style="{StaticResource SamplePageHeaderTextBlockStyle}" />

			<!-- Title Hero -->
			<TextBlock Text="Title Hero — 72px Bold"
					   Style="{StaticResource SampleSectionHeaderTextBlockStyle}" />
			<smtx:XamlDisplay UniqueKey="Simple_TextBlock_TitleHero">
				<TextBlock Text="Title Hero"
						   Style="{StaticResource SimpleTitleHeroTextBlockStyle}" />
			</smtx:XamlDisplay>

			<!-- Title Page -->
			<TextBlock Text="Title Page — 48px Bold"
					   Style="{StaticResource SampleSectionHeaderTextBlockStyle}" />
			<smtx:XamlDisplay UniqueKey="Simple_TextBlock_TitlePage">
				<TextBlock Text="Title Page"
						   Style="{StaticResource SimpleTitlePageTextBlockStyle}" />
			</smtx:XamlDisplay>

			<!-- Subtitle -->
			<TextBlock Text="Subtitle — 32px Normal"
					   Style="{StaticResource SampleSectionHeaderTextBlockStyle}" />
			<smtx:XamlDisplay UniqueKey="Simple_TextBlock_Subtitle">
				<TextBlock Text="Subtitle"
						   Style="{StaticResource SimpleSubtitleTextBlockStyle}" />
			</smtx:XamlDisplay>

			<!-- Heading -->
			<TextBlock Text="Heading — 24px SemiBold"
					   Style="{StaticResource SampleSectionHeaderTextBlockStyle}" />
			<smtx:XamlDisplay UniqueKey="Simple_TextBlock_Heading">
				<TextBlock Text="Heading"
						   Style="{StaticResource SimpleHeadingTextBlockStyle}" />
			</smtx:XamlDisplay>

			<!-- Subheading -->
			<TextBlock Text="Subheading — 20px Normal"
					   Style="{StaticResource SampleSectionHeaderTextBlockStyle}" />
			<smtx:XamlDisplay UniqueKey="Simple_TextBlock_Subheading">
				<TextBlock Text="Subheading"
						   Style="{StaticResource SimpleSubheadingTextBlockStyle}" />
			</smtx:XamlDisplay>

			<!-- Body Base -->
			<TextBlock Text="Body Base — 16px Normal"
					   Style="{StaticResource SampleSectionHeaderTextBlockStyle}" />
			<smtx:XamlDisplay UniqueKey="Simple_TextBlock_BodyBase">
				<TextBlock Text="Body Base — The quick brown fox jumps over the lazy dog."
						   Style="{StaticResource SimpleBodyBaseTextBlockStyle}" />
			</smtx:XamlDisplay>

			<!-- Body Strong -->
			<TextBlock Text="Body Strong — 16px SemiBold"
					   Style="{StaticResource SampleSectionHeaderTextBlockStyle}" />
			<smtx:XamlDisplay UniqueKey="Simple_TextBlock_BodyStrong">
				<TextBlock Text="Body Strong — The quick brown fox jumps over the lazy dog."
						   Style="{StaticResource SimpleBodyStrongTextBlockStyle}" />
			</smtx:XamlDisplay>

			<!-- Body Emphasis -->
			<TextBlock Text="Body Emphasis — 16px Italic"
					   Style="{StaticResource SampleSectionHeaderTextBlockStyle}" />
			<smtx:XamlDisplay UniqueKey="Simple_TextBlock_BodyEmphasis">
				<TextBlock Text="Body Emphasis — The quick brown fox jumps over the lazy dog."
						   Style="{StaticResource SimpleBodyEmphasisTextBlockStyle}" />
			</smtx:XamlDisplay>

			<!-- Body Small -->
			<TextBlock Text="Body Small — 14px Normal"
					   Style="{StaticResource SampleSectionHeaderTextBlockStyle}" />
			<smtx:XamlDisplay UniqueKey="Simple_TextBlock_BodySmall">
				<TextBlock Text="Body Small — The quick brown fox jumps over the lazy dog."
						   Style="{StaticResource SimpleBodySmallTextBlockStyle}" />
			</smtx:XamlDisplay>

			<!-- Body Small Strong -->
			<TextBlock Text="Body Small Strong — 14px SemiBold"
					   Style="{StaticResource SampleSectionHeaderTextBlockStyle}" />
			<smtx:XamlDisplay UniqueKey="Simple_TextBlock_BodySmallStrong">
				<TextBlock Text="Body Small Strong — The quick brown fox jumps over the lazy dog."
						   Style="{StaticResource SimpleBodySmallStrongTextBlockStyle}" />
			</smtx:XamlDisplay>

			<!-- Body Code -->
			<TextBlock Text="Body Code — 16px Mono"
					   Style="{StaticResource SampleSectionHeaderTextBlockStyle}" />
			<smtx:XamlDisplay UniqueKey="Simple_TextBlock_BodyCode">
				<TextBlock Text="Body Code — console.log('Hello, world!');"
						   Style="{StaticResource SimpleBodyCodeTextBlockStyle}" />
			</smtx:XamlDisplay>

			<!-- Caption -->
			<TextBlock Text="Caption — 12px Normal"
					   Style="{StaticResource SampleSectionHeaderTextBlockStyle}" />
			<smtx:XamlDisplay UniqueKey="Simple_TextBlock_Caption">
				<TextBlock Text="Caption — The quick brown fox jumps over the lazy dog."
						   Style="{StaticResource SimpleCaptionTextBlockStyle}" />
			</smtx:XamlDisplay>

		</StackPanel>
	</ScrollViewer>
</Page>
