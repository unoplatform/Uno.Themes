<Page x:Class="Uno.Themes.Simple.Samples.Content.Controls.SliderSamplePage"
	  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
	  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	  xmlns:smtx="using:ShowMeTheXAML"
	  Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

	<ScrollViewer>
		<StackPanel Padding="24"
					Spacing="8"
					MaxWidth="800">
			<TextBlock Text="Slider"
					   Style="{StaticResource SamplePageHeaderTextBlockStyle}" />

			<!-- Basic Slider -->
			<TextBlock Text="Basic Slider"
					   Style="{StaticResource SampleSectionHeaderTextBlockStyle}" />
			<smtx:XamlDisplay UniqueKey="Simple_Slider_Basic">
				<Slider Value="50"
						Minimum="0"
						Maximum="100" />
			</smtx:XamlDisplay>

			<!-- Slider with Header -->
			<TextBlock Text="Slider with Header"
					   Style="{StaticResource SampleSectionHeaderTextBlockStyle}" />
			<smtx:XamlDisplay UniqueKey="Simple_Slider_WithHeader">
				<Slider Header="Volume"
						Value="75"
						Minimum="0"
						Maximum="100" />
			</smtx:XamlDisplay>

			<!-- Slider with Steps -->
			<TextBlock Text="Slider with Steps"
					   Style="{StaticResource SampleSectionHeaderTextBlockStyle}" />
			<smtx:XamlDisplay UniqueKey="Simple_Slider_Stepped">
				<Slider Header="Quality"
						Value="3"
						Minimum="0"
						Maximum="5"
						StepFrequency="1"
						TickFrequency="1"
						TickPlacement="Outside" />
			</smtx:XamlDisplay>

			<!-- Range Values -->
			<TextBlock Text="Range Values"
					   Style="{StaticResource SampleSectionHeaderTextBlockStyle}" />
			<smtx:XamlDisplay UniqueKey="Simple_Slider_Range">
				<Slider Header="Temperature (°C)"
						Value="22"
						Minimum="-10"
						Maximum="40" />
			</smtx:XamlDisplay>

			<!-- Disabled -->
			<TextBlock Text="Disabled"
					   Style="{StaticResource SampleSectionHeaderTextBlockStyle}" />
			<smtx:XamlDisplay UniqueKey="Simple_Slider_Disabled">
				<Slider Header="Disabled Slider"
						Value="30"
						Minimum="0"
						Maximum="100"
						IsEnabled="False" />
			</smtx:XamlDisplay>
		</StackPanel>
	</ScrollViewer>
</Page>
