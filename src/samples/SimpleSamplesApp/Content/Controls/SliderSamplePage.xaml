<Page x:Class="Uno.Themes.Simple.Samples.Content.Controls.SliderSamplePage"
	  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
	  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	  xmlns:smtx="using:ShowMeTheXAML"
	  Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

	<ScrollViewer>
		<StackPanel Padding="24"
					Spacing="8"
					MaxWidth="800">
			<TextBlock Text="Slider"
					   Style="{StaticResource SamplePageHeaderTextBlockStyle}" />

			<!-- Default Slider -->
			<TextBlock Text="Default Slider"
					   Style="{StaticResource SampleSectionHeaderTextBlockStyle}" />
			<smtx:XamlDisplay UniqueKey="Simple_Slider_Default">
				<Slider Style="{StaticResource SimpleSliderStyle}"
						Value="50"
						Width="300" />
			</smtx:XamlDisplay>

			<!-- With Header -->
			<TextBlock Text="With Header"
					   Style="{StaticResource SampleSectionHeaderTextBlockStyle}" />
			<smtx:XamlDisplay UniqueKey="Simple_Slider_WithHeader">
				<Slider Style="{StaticResource SimpleSliderStyle}"
						Header="Volume"
						Value="75"
						Width="300" />
			</smtx:XamlDisplay>

			<!-- Min and Max Values -->
			<TextBlock Text="Custom Range (0–1000)"
					   Style="{StaticResource SampleSectionHeaderTextBlockStyle}" />
			<smtx:XamlDisplay UniqueKey="Simple_Slider_CustomRange">
				<Slider Style="{StaticResource SimpleSliderStyle}"
						Minimum="0"
						Maximum="1000"
						Value="250"
						StepFrequency="50"
						Width="300" />
			</smtx:XamlDisplay>

			<!-- Min Value (at start) -->
			<TextBlock Text="At Minimum"
					   Style="{StaticResource SampleSectionHeaderTextBlockStyle}" />
			<smtx:XamlDisplay UniqueKey="Simple_Slider_Minimum">
				<Slider Style="{StaticResource SimpleSliderStyle}"
						Value="0"
						Width="300" />
			</smtx:XamlDisplay>

			<!-- Max Value (at end) -->
			<TextBlock Text="At Maximum"
					   Style="{StaticResource SampleSectionHeaderTextBlockStyle}" />
			<smtx:XamlDisplay UniqueKey="Simple_Slider_Maximum">
				<Slider Style="{StaticResource SimpleSliderStyle}"
						Value="100"
						Width="300" />
			</smtx:XamlDisplay>

			<!-- Disabled -->
			<TextBlock Text="Disabled"
					   Style="{StaticResource SampleSectionHeaderTextBlockStyle}" />
			<smtx:XamlDisplay UniqueKey="Simple_Slider_Disabled">
				<Slider Style="{StaticResource SimpleSliderStyle}"
						Value="40"
						IsEnabled="False"
						Width="300" />
			</smtx:XamlDisplay>

		</StackPanel>
	</ScrollViewer>
</Page>
