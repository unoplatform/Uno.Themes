<Page x:Class="Uno.Themes.Simple.Samples.Content.Controls.CalendarViewSamplePage"
	  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
	  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	  xmlns:smtx="using:ShowMeTheXAML"
	  Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

	<ScrollViewer>
		<StackPanel Padding="24"
					Spacing="8"
					MaxWidth="800">
			<TextBlock Text="CalendarView"
					   Style="{StaticResource SamplePageHeaderTextBlockStyle}" />

			<!-- Basic CalendarView -->
			<TextBlock Text="Basic CalendarView"
					   Style="{StaticResource SampleSectionHeaderTextBlockStyle}" />
			<smtx:XamlDisplay UniqueKey="Simple_CalendarView_Basic">
				<CalendarView />
			</smtx:XamlDisplay>

			<!-- Multiple Selection -->
			<TextBlock Text="Multiple Selection"
					   Style="{StaticResource SampleSectionHeaderTextBlockStyle}" />
			<smtx:XamlDisplay UniqueKey="Simple_CalendarView_MultipleSelection">
				<CalendarView SelectionMode="Multiple" />
			</smtx:XamlDisplay>

			<!-- Month/Year only -->
			<TextBlock Text="Month Display"
					   Style="{StaticResource SampleSectionHeaderTextBlockStyle}" />
			<smtx:XamlDisplay UniqueKey="Simple_CalendarView_MonthDisplay">
				<CalendarView DisplayMode="Month" />
			</smtx:XamlDisplay>
		</StackPanel>
	</ScrollViewer>
</Page>
