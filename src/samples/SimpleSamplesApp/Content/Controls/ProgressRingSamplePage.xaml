<Page x:Class="Uno.Themes.Simple.Samples.Content.Controls.ProgressRingSamplePage"
	  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
	  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	  xmlns:smtx="using:ShowMeTheXAML"
	  xmlns:muxc="using:Microsoft.UI.Xaml.Controls"
	  Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

	<ScrollViewer>
		<StackPanel Padding="24"
					Spacing="8"
					MaxWidth="800">
			<TextBlock Text="ProgressRing"
					   Style="{StaticResource SamplePageHeaderTextBlockStyle}" />

			<!-- Active -->
			<TextBlock Text="Active (Indeterminate)"
					   Style="{StaticResource SampleSectionHeaderTextBlockStyle}" />
			<smtx:XamlDisplay UniqueKey="Simple_ProgressRing_Active">
				<muxc:ProgressRing IsActive="True"
								   Width="48"
								   Height="48" />
			</smtx:XamlDisplay>

			<!-- Determinate -->
			<TextBlock Text="Determinate"
					   Style="{StaticResource SampleSectionHeaderTextBlockStyle}" />
			<smtx:XamlDisplay UniqueKey="Simple_ProgressRing_Determinate">
				<muxc:ProgressRing IsIndeterminate="False"
								   Value="65"
								   Width="48"
								   Height="48" />
			</smtx:XamlDisplay>

			<!-- Sizes -->
			<TextBlock Text="Sizes"
					   Style="{StaticResource SampleSectionHeaderTextBlockStyle}" />
			<smtx:XamlDisplay UniqueKey="Simple_ProgressRing_Sizes">
				<StackPanel Orientation="Horizontal"
							Spacing="16"
							VerticalAlignment="Center">
					<muxc:ProgressRing IsActive="True"
									   Width="24"
									   Height="24" />
					<muxc:ProgressRing IsActive="True"
									   Width="48"
									   Height="48" />
					<muxc:ProgressRing IsActive="True"
									   Width="72"
									   Height="72" />
				</StackPanel>
			</smtx:XamlDisplay>

			<!-- Disabled -->
			<TextBlock Text="Disabled"
					   Style="{StaticResource SampleSectionHeaderTextBlockStyle}" />
			<smtx:XamlDisplay UniqueKey="Simple_ProgressRing_Disabled">
				<muxc:ProgressRing IsActive="True"
								   Width="48"
								   Height="48"
								   IsEnabled="False" />
			</smtx:XamlDisplay>
		</StackPanel>
	</ScrollViewer>
</Page>
