<Page x:Class="Uno.Themes.Simple.Samples.Content.Controls.HyperlinkButtonSamplePage"
	  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
	  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	  xmlns:smtx="using:ShowMeTheXAML"
	  Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

	<ScrollViewer>
		<StackPanel Padding="24"
					Spacing="8"
					MaxWidth="800">
			<TextBlock Text="HyperlinkButton"
					   Style="{StaticResource SamplePageHeaderTextBlockStyle}" />

			<!-- Basic -->
			<TextBlock Text="Basic HyperlinkButton"
					   Style="{StaticResource SampleSectionHeaderTextBlockStyle}" />
			<smtx:XamlDisplay UniqueKey="Simple_HyperlinkButton_Basic">
				<HyperlinkButton Content="Click me" />
			</smtx:XamlDisplay>

			<!-- With NavigateUri -->
			<TextBlock Text="With NavigateUri"
					   Style="{StaticResource SampleSectionHeaderTextBlockStyle}" />
			<smtx:XamlDisplay UniqueKey="Simple_HyperlinkButton_NavigateUri">
				<HyperlinkButton Content="Visit Uno Platform"
								 NavigateUri="https://platform.uno" />
			</smtx:XamlDisplay>

			<!-- Disabled -->
			<TextBlock Text="Disabled"
					   Style="{StaticResource SampleSectionHeaderTextBlockStyle}" />
			<smtx:XamlDisplay UniqueKey="Simple_HyperlinkButton_Disabled">
				<HyperlinkButton Content="Disabled Link"
								 IsEnabled="False" />
			</smtx:XamlDisplay>

			<!-- Custom Content -->
			<TextBlock Text="Custom Content"
					   Style="{StaticResource SampleSectionHeaderTextBlockStyle}" />
			<smtx:XamlDisplay UniqueKey="Simple_HyperlinkButton_CustomContent">
				<HyperlinkButton NavigateUri="https://platform.uno">
					<StackPanel Orientation="Horizontal"
								Spacing="8">
						<SymbolIcon Symbol="Globe" />
						<TextBlock Text="Uno Platform Website"
								   VerticalAlignment="Center" />
					</StackPanel>
				</HyperlinkButton>
			</smtx:XamlDisplay>
		</StackPanel>
	</ScrollViewer>
</Page>
