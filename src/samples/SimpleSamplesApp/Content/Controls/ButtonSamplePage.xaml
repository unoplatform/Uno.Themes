<Page x:Class="Uno.Themes.Simple.Samples.Content.Controls.ButtonSamplePage"
	  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
	  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	  xmlns:smtx="using:ShowMeTheXAML"
	  Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

	<ScrollViewer>
		<StackPanel Padding="24"
					Spacing="8"
					MaxWidth="800">
			<TextBlock Text="Button"
					   Style="{StaticResource SamplePageHeaderTextBlockStyle}" />

			<!-- Primary Button -->
			<TextBlock Text="Primary Button"
					   Style="{StaticResource SampleSectionHeaderTextBlockStyle}" />
			<smtx:XamlDisplay UniqueKey="Simple_Button_Primary">
				<StackPanel Orientation="Horizontal"
							Spacing="12">
					<Button Content="Primary"
							Style="{StaticResource SimplePrimaryButtonStyle}" />
					<Button Content="Disabled"
							Style="{StaticResource SimplePrimaryButtonStyle}"
							IsEnabled="False" />
				</StackPanel>
			</smtx:XamlDisplay>

			<!-- Neutral Button -->
			<TextBlock Text="Neutral Button"
					   Style="{StaticResource SampleSectionHeaderTextBlockStyle}" />
			<smtx:XamlDisplay UniqueKey="Simple_Button_Neutral">
				<StackPanel Orientation="Horizontal"
							Spacing="12">
					<Button Content="Neutral"
							Style="{StaticResource SimpleNeutralButtonStyle}" />
					<Button Content="Disabled"
							Style="{StaticResource SimpleNeutralButtonStyle}"
							IsEnabled="False" />
				</StackPanel>
			</smtx:XamlDisplay>

			<!-- Subtle Button -->
			<TextBlock Text="Subtle Button"
					   Style="{StaticResource SampleSectionHeaderTextBlockStyle}" />
			<smtx:XamlDisplay UniqueKey="Simple_Button_Subtle">
				<StackPanel Orientation="Horizontal"
							Spacing="12">
					<Button Content="Subtle"
							Style="{StaticResource SimpleSubtleButtonStyle}" />
					<Button Content="Disabled"
							Style="{StaticResource SimpleSubtleButtonStyle}"
							IsEnabled="False" />
				</StackPanel>
			</smtx:XamlDisplay>

			<!-- Danger Primary Button -->
			<TextBlock Text="Danger Primary Button"
					   Style="{StaticResource SampleSectionHeaderTextBlockStyle}" />
			<smtx:XamlDisplay UniqueKey="Simple_Button_DangerPrimary">
				<StackPanel Orientation="Horizontal"
							Spacing="12">
					<Button Content="Danger Primary"
							Style="{StaticResource SimpleDangerPrimaryButtonStyle}" />
					<Button Content="Disabled"
							Style="{StaticResource SimpleDangerPrimaryButtonStyle}"
							IsEnabled="False" />
				</StackPanel>
			</smtx:XamlDisplay>

			<!-- Danger Subtle Button -->
			<TextBlock Text="Danger Subtle Button"
					   Style="{StaticResource SampleSectionHeaderTextBlockStyle}" />
			<smtx:XamlDisplay UniqueKey="Simple_Button_DangerSubtle">
				<StackPanel Orientation="Horizontal"
							Spacing="12">
					<Button Content="Danger Subtle"
							Style="{StaticResource SimpleDangerSubtleButtonStyle}" />
					<Button Content="Disabled"
							Style="{StaticResource SimpleDangerSubtleButtonStyle}"
							IsEnabled="False" />
				</StackPanel>
			</smtx:XamlDisplay>

			<!-- Small Size Variants -->
			<TextBlock Text="Small Size Variants"
					   Style="{StaticResource SampleSectionHeaderTextBlockStyle}" />
			<smtx:XamlDisplay UniqueKey="Simple_Button_SmallVariants">
				<StackPanel Spacing="12">
					<StackPanel Orientation="Horizontal"
								Spacing="12">
						<Button Content="Small Primary"
								Style="{StaticResource SimpleSmallPrimaryButtonStyle}" />
						<Button Content="Small Neutral"
								Style="{StaticResource SimpleSmallNeutralButtonStyle}" />
						<Button Content="Small Subtle"
								Style="{StaticResource SimpleSmallSubtleButtonStyle}" />
					</StackPanel>
					<StackPanel Orientation="Horizontal"
								Spacing="12">
						<Button Content="Small Danger Primary"
								Style="{StaticResource SimpleSmallDangerPrimaryButtonStyle}" />
						<Button Content="Small Danger Subtle"
								Style="{StaticResource SimpleSmallDangerSubtleButtonStyle}" />
					</StackPanel>
				</StackPanel>
			</smtx:XamlDisplay>

			<!-- Small Size Variants — Disabled -->
			<TextBlock Text="Small Size Variants — Disabled"
					   Style="{StaticResource SampleSectionHeaderTextBlockStyle}" />
			<smtx:XamlDisplay UniqueKey="Simple_Button_SmallVariants_Disabled">
				<StackPanel Spacing="12">
					<StackPanel Orientation="Horizontal"
								Spacing="12">
						<Button Content="Small Primary"
								Style="{StaticResource SimpleSmallPrimaryButtonStyle}"
								IsEnabled="False" />
						<Button Content="Small Neutral"
								Style="{StaticResource SimpleSmallNeutralButtonStyle}"
								IsEnabled="False" />
						<Button Content="Small Subtle"
								Style="{StaticResource SimpleSmallSubtleButtonStyle}"
								IsEnabled="False" />
					</StackPanel>
					<StackPanel Orientation="Horizontal"
								Spacing="12">
						<Button Content="Small Danger Primary"
								Style="{StaticResource SimpleSmallDangerPrimaryButtonStyle}"
								IsEnabled="False" />
						<Button Content="Small Danger Subtle"
								Style="{StaticResource SimpleSmallDangerSubtleButtonStyle}"
								IsEnabled="False" />
					</StackPanel>
				</StackPanel>
			</smtx:XamlDisplay>

		</StackPanel>
	</ScrollViewer>
</Page>
