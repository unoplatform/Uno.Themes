<Page x:Class="Uno.Themes.Simple.Samples.Content.Controls.ToggleButtonSamplePage"
	  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
	  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	  xmlns:smtx="using:ShowMeTheXAML"
	  Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

	<ScrollViewer>
		<StackPanel Padding="24"
					Spacing="8"
					MaxWidth="800">
			<TextBlock Text="ToggleButton"
					   Style="{StaticResource SamplePageHeaderTextBlockStyle}" />

			<!-- Basic ToggleButton -->
			<TextBlock Text="Basic ToggleButton"
					   Style="{StaticResource SampleSectionHeaderTextBlockStyle}" />
			<smtx:XamlDisplay UniqueKey="Simple_ToggleButton_Unchecked">
				<ToggleButton Content="Unchecked" />
			</smtx:XamlDisplay>
			<smtx:XamlDisplay UniqueKey="Simple_ToggleButton_Checked">
				<ToggleButton Content="Checked"
							  IsChecked="True" />
			</smtx:XamlDisplay>

			<!-- With Icons -->
			<TextBlock Text="With Icon Content"
					   Style="{StaticResource SampleSectionHeaderTextBlockStyle}" />
			<smtx:XamlDisplay UniqueKey="Simple_ToggleButton_WithIcon">
				<StackPanel Orientation="Horizontal"
							Spacing="12">
					<ToggleButton>
						<SymbolIcon Symbol="Bold" />
					</ToggleButton>
					<ToggleButton IsChecked="True">
						<SymbolIcon Symbol="Italic" />
					</ToggleButton>
					<ToggleButton>
						<SymbolIcon Symbol="Underline" />
					</ToggleButton>
				</StackPanel>
			</smtx:XamlDisplay>

			<!-- Three-State -->
			<TextBlock Text="Three-State"
					   Style="{StaticResource SampleSectionHeaderTextBlockStyle}" />
			<smtx:XamlDisplay UniqueKey="Simple_ToggleButton_ThreeState">
				<ToggleButton Content="Three-State"
							  IsThreeState="True" />
			</smtx:XamlDisplay>

			<!-- Disabled -->
			<TextBlock Text="Disabled"
					   Style="{StaticResource SampleSectionHeaderTextBlockStyle}" />
			<smtx:XamlDisplay UniqueKey="Simple_ToggleButton_DisabledUnchecked">
				<ToggleButton Content="Disabled Unchecked"
							  IsEnabled="False" />
			</smtx:XamlDisplay>
			<smtx:XamlDisplay UniqueKey="Simple_ToggleButton_DisabledChecked">
				<ToggleButton Content="Disabled Checked"
							  IsChecked="True"
							  IsEnabled="False" />
			</smtx:XamlDisplay>
		</StackPanel>
	</ScrollViewer>
</Page>
