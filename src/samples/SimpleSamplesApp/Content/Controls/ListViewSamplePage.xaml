<Page x:Class="Uno.Themes.Simple.Samples.Content.Controls.ListViewSamplePage"
	  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
	  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	  xmlns:smtx="using:ShowMeTheXAML"
	  Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

	<ScrollViewer>
		<StackPanel Padding="24"
					Spacing="8"
					MaxWidth="800">
			<TextBlock Text="ListView"
					   Style="{StaticResource SamplePageHeaderTextBlockStyle}" />

			<!-- Basic ListView -->
			<TextBlock Text="Basic ListView"
					   Style="{StaticResource SampleSectionHeaderTextBlockStyle}" />
			<smtx:XamlDisplay UniqueKey="Simple_ListView_Basic">
				<ListView MaxHeight="300">
					<ListViewItem Content="First Item" />
					<ListViewItem Content="Second Item" />
					<ListViewItem Content="Third Item" />
					<ListViewItem Content="Fourth Item" />
					<ListViewItem Content="Fifth Item" />
				</ListView>
			</smtx:XamlDisplay>

			<!-- Single Selection -->
			<TextBlock Text="Single Selection"
					   Style="{StaticResource SampleSectionHeaderTextBlockStyle}" />
			<smtx:XamlDisplay UniqueKey="Simple_ListView_SingleSelection">
				<ListView SelectionMode="Single"
						  MaxHeight="300">
					<ListViewItem Content="Option A" />
					<ListViewItem Content="Option B"
								  IsSelected="True" />
					<ListViewItem Content="Option C" />
					<ListViewItem Content="Option D" />
				</ListView>
			</smtx:XamlDisplay>

			<!-- Multiple Selection -->
			<TextBlock Text="Multiple Selection"
					   Style="{StaticResource SampleSectionHeaderTextBlockStyle}" />
			<smtx:XamlDisplay UniqueKey="Simple_ListView_MultiSelection">
				<ListView SelectionMode="Multiple"
						  MaxHeight="300">
					<ListViewItem Content="Apple" />
					<ListViewItem Content="Banana" />
					<ListViewItem Content="Cherry" />
					<ListViewItem Content="Date" />
					<ListViewItem Content="Elderberry" />
				</ListView>
			</smtx:XamlDisplay>

			<!-- With Disabled Item -->
			<TextBlock Text="Disabled Items"
					   Style="{StaticResource SampleSectionHeaderTextBlockStyle}" />
			<smtx:XamlDisplay UniqueKey="Simple_ListView_DisabledItems">
				<ListView MaxHeight="300">
					<ListViewItem Content="Enabled" />
					<ListViewItem Content="Disabled"
								  IsEnabled="False" />
					<ListViewItem Content="Enabled" />
				</ListView>
			</smtx:XamlDisplay>
		</StackPanel>
	</ScrollViewer>
</Page>
