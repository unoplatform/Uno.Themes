<Page x:Class="Uno.Themes.Simple.Samples.Content.Controls.PasswordBoxSamplePage"
	  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
	  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	  xmlns:smtx="using:ShowMeTheXAML"
	  Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

	<ScrollViewer>
		<StackPanel Padding="24"
					Spacing="8"
					MaxWidth="800">
			<TextBlock Text="PasswordBox"
					   Style="{StaticResource SamplePageHeaderTextBlockStyle}" />

			<!-- Default PasswordBox -->
			<TextBlock Text="Default PasswordBox"
					   Style="{StaticResource SampleSectionHeaderTextBlockStyle}" />
			<smtx:XamlDisplay UniqueKey="Simple_PasswordBox_Default">
				<PasswordBox Style="{StaticResource SimplePasswordBoxStyle}"
							 PlaceholderText="Enter password"
							 Width="300" />
			</smtx:XamlDisplay>

			<!-- With Header -->
			<TextBlock Text="With Header"
					   Style="{StaticResource SampleSectionHeaderTextBlockStyle}" />
			<smtx:XamlDisplay UniqueKey="Simple_PasswordBox_WithHeader">
				<PasswordBox Style="{StaticResource SimplePasswordBoxStyle}"
							 Header="Password"
							 PlaceholderText="Enter password"
							 Width="300" />
			</smtx:XamlDisplay>

			<!-- With Password -->
			<TextBlock Text="With Password"
					   Style="{StaticResource SampleSectionHeaderTextBlockStyle}" />
			<smtx:XamlDisplay UniqueKey="Simple_PasswordBox_WithPassword">
				<PasswordBox Style="{StaticResource SimplePasswordBoxStyle}"
							 Password="secret123"
							 Width="300" />
			</smtx:XamlDisplay>

			<!-- With Reveal Button -->
			<TextBlock Text="With Reveal Button"
					   Style="{StaticResource SampleSectionHeaderTextBlockStyle}" />
			<smtx:XamlDisplay UniqueKey="Simple_PasswordBox_RevealButton">
				<PasswordBox Style="{StaticResource SimplePasswordBoxStyle}"
							 PasswordRevealMode="Peek"
							 PlaceholderText="Peek to reveal"
							 Width="300" />
			</smtx:XamlDisplay>

			<!-- Disabled -->
			<TextBlock Text="Disabled"
					   Style="{StaticResource SampleSectionHeaderTextBlockStyle}" />
			<smtx:XamlDisplay UniqueKey="Simple_PasswordBox_Disabled">
				<PasswordBox Style="{StaticResource SimplePasswordBoxStyle}"
							 PlaceholderText="Disabled"
							 IsEnabled="False"
							 Width="300" />
			</smtx:XamlDisplay>

		</StackPanel>
	</ScrollViewer>
</Page>
