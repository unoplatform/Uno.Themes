<Page x:Class="Uno.Themes.Simple.Samples.Content.Controls.PasswordBoxSamplePage"
	  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
	  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	  xmlns:smtx="using:ShowMeTheXAML"
	  Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

	<ScrollViewer>
		<StackPanel Padding="24"
					Spacing="8"
					MaxWidth="800">
			<TextBlock Text="PasswordBox"
					   Style="{StaticResource SamplePageHeaderTextBlockStyle}" />

			<!-- Basic PasswordBox -->
			<TextBlock Text="Basic PasswordBox"
					   Style="{StaticResource SampleSectionHeaderTextBlockStyle}" />
			<smtx:XamlDisplay UniqueKey="Simple_PasswordBox_Basic">
				<PasswordBox PlaceholderText="Enter password" />
			</smtx:XamlDisplay>

			<!-- With Header -->
			<TextBlock Text="With Header"
					   Style="{StaticResource SampleSectionHeaderTextBlockStyle}" />
			<smtx:XamlDisplay UniqueKey="Simple_PasswordBox_WithHeader">
				<PasswordBox Header="Password"
							 PlaceholderText="Enter your password" />
			</smtx:XamlDisplay>

			<!-- With Reveal Button -->
			<TextBlock Text="With Reveal Button"
					   Style="{StaticResource SampleSectionHeaderTextBlockStyle}" />
			<smtx:XamlDisplay UniqueKey="Simple_PasswordBox_Reveal">
				<PasswordBox Header="Password"
							 PlaceholderText="Enter password"
							 PasswordRevealMode="Peek" />
			</smtx:XamlDisplay>

			<!-- Max Length -->
			<TextBlock Text="Max Length"
					   Style="{StaticResource SampleSectionHeaderTextBlockStyle}" />
			<smtx:XamlDisplay UniqueKey="Simple_PasswordBox_MaxLength">
				<PasswordBox Header="PIN"
							 PlaceholderText="4-digit PIN"
							 MaxLength="4" />
			</smtx:XamlDisplay>

			<!-- Disabled -->
			<TextBlock Text="Disabled"
					   Style="{StaticResource SampleSectionHeaderTextBlockStyle}" />
			<smtx:XamlDisplay UniqueKey="Simple_PasswordBox_Disabled">
				<PasswordBox Header="Disabled"
							 PlaceholderText="Cannot type here"
							 IsEnabled="False" />
			</smtx:XamlDisplay>
		</StackPanel>
	</ScrollViewer>
</Page>
