<Page x:Class="Uno.Themes.Samples.Content.Controls.CalendarDatePickerSamplePage"
	  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
	  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	  xmlns:sample="using:Uno.Themes.Samples"
	  xmlns:smtx="using:ShowMeTheXAML"
	  Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

	<sample:SamplePageLayout>
		<sample:SamplePageLayout.SimpleTemplate>
			<DataTemplate>
				<StackPanel Spacing="8">
					<smtx:XamlDisplay UniqueKey="Simple_CalendarDatePicker_Basic">
						<CalendarDatePicker />
					</smtx:XamlDisplay>

					<smtx:XamlDisplay UniqueKey="Simple_CalendarDatePicker_WithHeader">
						<CalendarDatePicker Header="Appointment Date"
											PlaceholderText="Pick a date" />
					</smtx:XamlDisplay>

					<smtx:XamlDisplay UniqueKey="Simple_CalendarDatePicker_Disabled">
						<CalendarDatePicker Header="Disabled"
											IsEnabled="False" />
					</smtx:XamlDisplay>
				</StackPanel>
			</DataTemplate>
		</sample:SamplePageLayout.SimpleTemplate>
	</sample:SamplePageLayout>
</Page>
