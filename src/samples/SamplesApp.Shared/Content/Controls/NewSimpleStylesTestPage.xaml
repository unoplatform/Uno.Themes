<Page x:Class="Uno.Themes.Samples.Content.Controls.NewSimpleStylesTestPage"
	  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
	  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	  xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
	  xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
	  xmlns:muxc="using:Microsoft.UI.Xaml.Controls"
	  xmlns:sample="using:Uno.Themes.Samples"
	  xmlns:smtx="using:ShowMeTheXAML"
	  mc:Ignorable="d">

	<Grid Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">
		<sample:SamplePageLayout>
			<sample:SamplePageLayout.SimpleTemplate>
				<DataTemplate>
					<StackPanel Spacing="8">

						<!-- ═══════════════════════════════════════════ -->
						<!-- #1643 HyperlinkButton -->
						<!-- ═══════════════════════════════════════════ -->
						<TextBlock Text="HyperlinkButton (#1643)"
								   Style="{StaticResource TitleSmall}"
								   Margin="0,16,0,4" />

						<smtx:XamlDisplay UniqueKey="Simple_NewStyles_HyperlinkPrimary"
										  Style="{StaticResource XamlDisplayBelowStyle}">
							<HyperlinkButton Content="Primary HyperlinkButton"
											 Style="{StaticResource SimpleHyperlinkButtonStyle}" />
						</smtx:XamlDisplay>

						<smtx:XamlDisplay UniqueKey="Simple_NewStyles_HyperlinkSecondary"
										  Style="{StaticResource XamlDisplayBelowStyle}">
							<HyperlinkButton Content="Secondary HyperlinkButton"
											 Style="{StaticResource SimpleSecondaryHyperlinkButtonStyle}" />
						</smtx:XamlDisplay>

						<smtx:XamlDisplay UniqueKey="Simple_NewStyles_HyperlinkDisabled"
										  Style="{StaticResource XamlDisplayBelowStyle}">
							<HyperlinkButton Content="Disabled HyperlinkButton"
											 IsEnabled="False" />
						</smtx:XamlDisplay>

						<!-- ═══════════════════════════════════════════ -->
						<!-- #1640 IconToggleButton -->
						<!-- ═══════════════════════════════════════════ -->
						<TextBlock Text="IconToggleButton (#1640)"
								   Style="{StaticResource TitleSmall}"
								   Margin="0,24,0,4" />

						<smtx:XamlDisplay UniqueKey="Simple_NewStyles_IconToggle_Off"
										  Style="{StaticResource XamlDisplayBelowStyle}">
							<ToggleButton Style="{StaticResource SimpleIconToggleButtonStyle}"
										  Content="&#xE734;" />
						</smtx:XamlDisplay>

						<smtx:XamlDisplay UniqueKey="Simple_NewStyles_IconToggle_On"
										  Style="{StaticResource XamlDisplayBelowStyle}">
							<ToggleButton Style="{StaticResource SimpleIconToggleButtonStyle}"
										  Content="&#xE735;"
										  IsChecked="True" />
						</smtx:XamlDisplay>

						<smtx:XamlDisplay UniqueKey="Simple_NewStyles_IconToggle_Disabled"
										  Style="{StaticResource XamlDisplayBelowStyle}">
							<ToggleButton Style="{StaticResource SimpleIconToggleButtonStyle}"
										  Content="&#xE734;"
										  IsEnabled="False" />
						</smtx:XamlDisplay>

						<!-- ═══════════════════════════════════════════ -->
						<!-- #1641 OutlinedTextBox -->
						<!-- ═══════════════════════════════════════════ -->
						<TextBlock Text="OutlinedTextBox (#1641)"
								   Style="{StaticResource TitleSmall}"
								   Margin="0,24,0,4" />

						<smtx:XamlDisplay UniqueKey="Simple_NewStyles_OutlinedTextBox"
										  Style="{StaticResource XamlDisplayBelowStyle}">
							<TextBox Style="{StaticResource SimpleOutlinedTextBoxStyle}"
									 PlaceholderText="Outlined TextBox" />
						</smtx:XamlDisplay>

						<smtx:XamlDisplay UniqueKey="Simple_NewStyles_OutlinedTextBox_WithText"
										  Style="{StaticResource XamlDisplayBelowStyle}">
							<TextBox Style="{StaticResource SimpleOutlinedTextBoxStyle}"
									 Header="Label"
									 Text="With header and text" />
						</smtx:XamlDisplay>

						<!-- ═══════════════════════════════════════════ -->
						<!-- #1642 OutlinedPasswordBox -->
						<!-- ═══════════════════════════════════════════ -->
						<TextBlock Text="OutlinedPasswordBox (#1642)"
								   Style="{StaticResource TitleSmall}"
								   Margin="0,24,0,4" />

						<smtx:XamlDisplay UniqueKey="Simple_NewStyles_OutlinedPasswordBox"
										  Style="{StaticResource XamlDisplayBelowStyle}">
							<PasswordBox Style="{StaticResource SimpleOutlinedPasswordBoxStyle}"
										 PlaceholderText="Outlined PasswordBox" />
						</smtx:XamlDisplay>

						<smtx:XamlDisplay UniqueKey="Simple_NewStyles_OutlinedPasswordBox_Header"
										  Style="{StaticResource XamlDisplayBelowStyle}">
							<PasswordBox Style="{StaticResource SimpleOutlinedPasswordBoxStyle}"
										 Header="Password"
										 PlaceholderText="Enter password" />
						</smtx:XamlDisplay>

						<!-- ═══════════════════════════════════════════ -->
						<!-- #1644 RadioMenuFlyoutItem -->
						<!-- ═══════════════════════════════════════════ -->
						<TextBlock Text="RadioMenuFlyoutItem (#1644)"
								   Style="{StaticResource TitleSmall}"
								   Margin="0,24,0,4" />

						<smtx:XamlDisplay UniqueKey="Simple_NewStyles_RadioMenuFlyout"
										  Style="{StaticResource XamlDisplayBelowStyle}">
							<Button Content="Show Radio MenuFlyout">
								<Button.Flyout>
									<MenuFlyout>
										<muxc:RadioMenuFlyoutItem Text="Option A" GroupName="TestGroup" />
										<muxc:RadioMenuFlyoutItem Text="Option B" GroupName="TestGroup" IsChecked="True" />
										<muxc:RadioMenuFlyoutItem Text="Option C" GroupName="TestGroup" />
									</MenuFlyout>
								</Button.Flyout>
							</Button>
						</smtx:XamlDisplay>

						<!-- ═══════════════════════════════════════════ -->
						<!-- #1645 FlyoutPresenter -->
						<!-- ═══════════════════════════════════════════ -->
						<TextBlock Text="FlyoutPresenter (#1645)"
								   Style="{StaticResource TitleSmall}"
								   Margin="0,24,0,4" />

						<smtx:XamlDisplay UniqueKey="Simple_NewStyles_FlyoutPresenter"
										  Style="{StaticResource XamlDisplayBelowStyle}">
							<Button Content="Show Flyout">
								<Button.Flyout>
									<Flyout>
										<StackPanel Spacing="8" MinWidth="200">
											<TextBlock Text="Flyout Content"
													   Style="{StaticResource TitleSmall}" />
											<TextBlock Text="This uses the SimpleFlyoutPresenterStyle."
													   TextWrapping="Wrap" />
										</StackPanel>
									</Flyout>
								</Button.Flyout>
							</Button>
						</smtx:XamlDisplay>

						<!-- ═══════════════════════════════════════════ -->
						<!-- #1647 ProgressBar -->
						<!-- ═══════════════════════════════════════════ -->
						<TextBlock Text="ProgressBar (#1647)"
								   Style="{StaticResource TitleSmall}"
								   Margin="0,24,0,4" />

						<smtx:XamlDisplay UniqueKey="Simple_NewStyles_ProgressBar_Determinate"
										  Style="{StaticResource XamlDisplayBelowStyle}">
							<muxc:ProgressBar Value="60"
											  Minimum="0"
											  Maximum="100"
											  Width="300"
											  HorizontalAlignment="Left" />
						</smtx:XamlDisplay>

						<smtx:XamlDisplay UniqueKey="Simple_NewStyles_ProgressBar_Indeterminate"
										  Style="{StaticResource XamlDisplayBelowStyle}">
							<muxc:ProgressBar IsIndeterminate="True"
											  Width="300"
											  HorizontalAlignment="Left" />
						</smtx:XamlDisplay>

						<!-- ═══════════════════════════════════════════ -->
						<!-- #1648 ProgressRing -->
						<!-- ═══════════════════════════════════════════ -->
						<TextBlock Text="ProgressRing (#1648)"
								   Style="{StaticResource TitleSmall}"
								   Margin="0,24,0,4" />

						<StackPanel Orientation="Horizontal" Spacing="24">
							<smtx:XamlDisplay UniqueKey="Simple_NewStyles_ProgressRing_Determinate"
											  Style="{StaticResource XamlDisplayBelowStyle}">
								<muxc:ProgressRing Value="75"
												   IsActive="True"
												   Width="48"
												   Height="48" />
							</smtx:XamlDisplay>

							<smtx:XamlDisplay UniqueKey="Simple_NewStyles_ProgressRing_Indeterminate"
											  Style="{StaticResource XamlDisplayBelowStyle}">
								<muxc:ProgressRing IsIndeterminate="True"
												   IsActive="True"
												   Width="48"
												   Height="48" />
							</smtx:XamlDisplay>
						</StackPanel>

						<!-- ═══════════════════════════════════════════ -->
						<!-- #1649 PipsPager -->
						<!-- ═══════════════════════════════════════════ -->
						<TextBlock Text="PipsPager (#1649)"
								   Style="{StaticResource TitleSmall}"
								   Margin="0,24,0,4" />

						<smtx:XamlDisplay UniqueKey="Simple_NewStyles_PipsPager"
										  Style="{StaticResource XamlDisplayBelowStyle}">
							<muxc:PipsPager NumberOfPages="5"
											SelectedPageIndex="2"
											HorizontalAlignment="Left" />
						</smtx:XamlDisplay>

						<smtx:XamlDisplay UniqueKey="Simple_NewStyles_PipsPager_Many"
										  Style="{StaticResource XamlDisplayBelowStyle}">
							<muxc:PipsPager NumberOfPages="10"
											MaxVisiblePips="5"
											SelectedPageIndex="4"
											HorizontalAlignment="Left" />
						</smtx:XamlDisplay>

						<!-- ═══════════════════════════════════════════ -->
						<!-- #1650 RatingControl -->
						<!-- ═══════════════════════════════════════════ -->
						<TextBlock Text="RatingControl (#1650)"
								   Style="{StaticResource TitleSmall}"
								   Margin="0,24,0,4" />

						<smtx:XamlDisplay UniqueKey="Simple_NewStyles_RatingControl"
										  Style="{StaticResource XamlDisplayBelowStyle}">
							<RatingControl Value="3" />
						</smtx:XamlDisplay>

						<smtx:XamlDisplay UniqueKey="Simple_NewStyles_RatingControl_ReadOnly"
										  Style="{StaticResource XamlDisplayBelowStyle}">
							<RatingControl Value="4"
										   IsReadOnly="True" />
						</smtx:XamlDisplay>

						<!-- ═══════════════════════════════════════════ -->
						<!-- #1646 NavigationView -->
						<!-- ═══════════════════════════════════════════ -->
						<TextBlock Text="NavigationView (#1646)"
								   Style="{StaticResource TitleSmall}"
								   Margin="0,24,0,4" />

						<smtx:XamlDisplay UniqueKey="Simple_NewStyles_NavigationView"
										  Style="{StaticResource XamlDisplayBelowStyle}">
							<muxc:NavigationView PaneDisplayMode="Left"
												 IsBackButtonVisible="Collapsed"
												 IsSettingsVisible="False"
												 Height="250">
								<muxc:NavigationView.MenuItems>
									<muxc:NavigationViewItem Content="Home" Icon="Home" />
									<muxc:NavigationViewItem Content="Browse" Icon="Library" />
									<muxc:NavigationViewItem Content="Settings" Icon="Setting" />
								</muxc:NavigationView.MenuItems>
								<TextBlock Text="NavigationView content area"
										   Margin="16"
										   VerticalAlignment="Center" />
							</muxc:NavigationView>
						</smtx:XamlDisplay>

						<!-- ═══════════════════════════════════════════ -->
						<!-- #1639 FAB Aliases -->
						<!-- ═══════════════════════════════════════════ -->
						<TextBlock Text="FAB Aliases (#1639)"
								   Style="{StaticResource TitleSmall}"
								   Margin="0,24,0,4" />

						<StackPanel Orientation="Horizontal" Spacing="12">
							<smtx:XamlDisplay UniqueKey="Simple_NewStyles_FAB_Primary"
											  Style="{StaticResource XamlDisplayBelowStyle}">
								<Button Style="{StaticResource FabStyle}"
										Content="&#xE710;" />
							</smtx:XamlDisplay>

							<smtx:XamlDisplay UniqueKey="Simple_NewStyles_FAB_Secondary"
											  Style="{StaticResource XamlDisplayBelowStyle}">
								<Button Style="{StaticResource SecondaryFabStyle}"
										Content="&#xE710;" />
							</smtx:XamlDisplay>

							<smtx:XamlDisplay UniqueKey="Simple_NewStyles_FAB_Tertiary"
											  Style="{StaticResource XamlDisplayBelowStyle}">
								<Button Style="{StaticResource TertiaryFabStyle}"
										Content="&#xE710;" />
							</smtx:XamlDisplay>

							<smtx:XamlDisplay UniqueKey="Simple_NewStyles_FAB_Surface"
											  Style="{StaticResource XamlDisplayBelowStyle}">
								<Button Style="{StaticResource SurfaceFabStyle}"
										Content="&#xE710;" />
							</smtx:XamlDisplay>
						</StackPanel>

					</StackPanel>
				</DataTemplate>
			</sample:SamplePageLayout.SimpleTemplate>
		</sample:SamplePageLayout>
	</Grid>
</Page>
