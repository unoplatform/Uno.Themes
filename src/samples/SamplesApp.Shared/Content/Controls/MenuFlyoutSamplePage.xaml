<Page x:Class="Uno.Themes.Samples.Content.Controls.MenuFlyoutSamplePage"
	  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
	  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	  xmlns:sample="using:Uno.Themes.Samples"
	  xmlns:smtx="using:ShowMeTheXAML"
	  Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

	<sample:SamplePageLayout>
		<sample:SamplePageLayout.SimpleTemplate>
			<DataTemplate>
				<StackPanel Spacing="8">
					<!-- Basic MenuFlyout -->
					<smtx:XamlDisplay UniqueKey="Simple_MenuFlyout_Basic">
						<Button Content="Open Menu">
							<Button.Flyout>
								<MenuFlyout>
									<MenuFlyoutItem Text="Cut" />
									<MenuFlyoutItem Text="Copy" />
									<MenuFlyoutItem Text="Paste" />
								</MenuFlyout>
							</Button.Flyout>
						</Button>
					</smtx:XamlDisplay>

					<!-- With Icons -->
					<smtx:XamlDisplay UniqueKey="Simple_MenuFlyout_WithIcons">
						<Button Content="Edit Menu">
							<Button.Flyout>
								<MenuFlyout>
									<MenuFlyoutItem Text="Cut">
										<MenuFlyoutItem.Icon>
											<SymbolIcon Symbol="Cut" />
										</MenuFlyoutItem.Icon>
									</MenuFlyoutItem>
									<MenuFlyoutItem Text="Copy">
										<MenuFlyoutItem.Icon>
											<SymbolIcon Symbol="Copy" />
										</MenuFlyoutItem.Icon>
									</MenuFlyoutItem>
									<MenuFlyoutItem Text="Paste">
										<MenuFlyoutItem.Icon>
											<SymbolIcon Symbol="Paste" />
										</MenuFlyoutItem.Icon>
									</MenuFlyoutItem>
								</MenuFlyout>
							</Button.Flyout>
						</Button>
					</smtx:XamlDisplay>

					<!-- With Separator -->
					<smtx:XamlDisplay UniqueKey="Simple_MenuFlyout_Separator">
						<Button Content="File Menu">
							<Button.Flyout>
								<MenuFlyout>
									<MenuFlyoutItem Text="New" />
									<MenuFlyoutItem Text="Open" />
									<MenuFlyoutItem Text="Save" />
									<MenuFlyoutSeparator />
									<MenuFlyoutItem Text="Exit" />
								</MenuFlyout>
							</Button.Flyout>
						</Button>
					</smtx:XamlDisplay>

					<!-- Toggle MenuFlyoutItem -->
					<smtx:XamlDisplay UniqueKey="Simple_MenuFlyout_Toggle">
						<Button Content="View Options">
							<Button.Flyout>
								<MenuFlyout>
									<ToggleMenuFlyoutItem Text="Show Toolbar"
														   IsChecked="True" />
									<ToggleMenuFlyoutItem Text="Show Status Bar"
														   IsChecked="True" />
									<ToggleMenuFlyoutItem Text="Show Ruler" />
								</MenuFlyout>
							</Button.Flyout>
						</Button>
					</smtx:XamlDisplay>

					<!-- SubItem (Nested Menu) -->
					<smtx:XamlDisplay UniqueKey="Simple_MenuFlyout_SubItem">
						<Button Content="Format Menu">
							<Button.Flyout>
								<MenuFlyout>
									<MenuFlyoutItem Text="Bold" />
									<MenuFlyoutItem Text="Italic" />
									<MenuFlyoutSubItem Text="Text Color">
										<MenuFlyoutItem Text="Red" />
										<MenuFlyoutItem Text="Green" />
										<MenuFlyoutItem Text="Blue" />
									</MenuFlyoutSubItem>
									<MenuFlyoutSubItem Text="Font Size">
										<MenuFlyoutItem Text="Small" />
										<MenuFlyoutItem Text="Medium" />
										<MenuFlyoutItem Text="Large" />
									</MenuFlyoutSubItem>
								</MenuFlyout>
							</Button.Flyout>
						</Button>
					</smtx:XamlDisplay>

					<!-- Disabled Items -->
					<smtx:XamlDisplay UniqueKey="Simple_MenuFlyout_Disabled">
						<Button Content="Edit Menu (Mixed)">
							<Button.Flyout>
								<MenuFlyout>
									<MenuFlyoutItem Text="Undo"
													 IsEnabled="False" />
									<MenuFlyoutItem Text="Redo"
													 IsEnabled="False" />
									<MenuFlyoutSeparator />
									<MenuFlyoutItem Text="Cut" />
									<MenuFlyoutItem Text="Copy" />
									<MenuFlyoutItem Text="Paste" />
								</MenuFlyout>
							</Button.Flyout>
						</Button>
					</smtx:XamlDisplay>

					<!-- Radio MenuFlyoutItem -->
					<smtx:XamlDisplay UniqueKey="Simple_MenuFlyout_RadioItems">
						<Button Content="Sort Options">
							<Button.Flyout>
								<MenuFlyout>
									<RadioMenuFlyoutItem Text="Sort by Name" GroupName="SortGroup" IsChecked="True" />
									<RadioMenuFlyoutItem Text="Sort by Date" GroupName="SortGroup" />
									<RadioMenuFlyoutItem Text="Sort by Size" GroupName="SortGroup" />
								</MenuFlyout>
							</Button.Flyout>
						</Button>
					</smtx:XamlDisplay>
				</StackPanel>
			</DataTemplate>
		</sample:SamplePageLayout.SimpleTemplate>
	</sample:SamplePageLayout>
</Page>
