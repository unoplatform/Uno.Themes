<Page x:Class="Uno.Themes.Samples.Content.Styles.SemanticStylingSamplePage"
	  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
	  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	  xmlns:sample="using:Uno.Themes.Samples"
	  xmlns:smtx="using:ShowMeTheXAML"
	  Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

	<sample:SamplePageLayout>
		<sample:SamplePageLayout.SimpleTemplate>
			<DataTemplate>
				<StackPanel Spacing="16" Margin="16,0">

					<!-- ═══════════════════════════════════════════════════════════ -->
					<!-- SECTION 1: Semantic Button Styles                          -->
					<!-- These are design-system-agnostic style keys that resolve   -->
					<!-- to the correct Simple theme variant.                       -->
					<!-- ═══════════════════════════════════════════════════════════ -->
					<TextBlock Text="Semantic Button Styles"
							   Style="{StaticResource TitleLarge}"
							   Margin="0,16,0,4" />
					<TextBlock Text="Design-system-agnostic keys that resolve to Simple theme styles. The same keys work under Material and Simple themes."
							   Style="{StaticResource BodyMedium}"
							   Opacity="0.7"
							   Margin="0,0,0,8"
							   TextWrapping="Wrap" />

					<!-- FilledButtonStyle → SimplePrimaryButtonStyle -->
					<smtx:XamlDisplay UniqueKey="Simple_Semantic_FilledButton"
									  Style="{StaticResource XamlDisplayBelowStyle}">
						<StackPanel Orientation="Horizontal" Spacing="12">
							<Button Content="FilledButtonStyle"
									Style="{StaticResource FilledButtonStyle}" />
							<Button Content="Disabled"
									Style="{StaticResource FilledButtonStyle}"
									IsEnabled="False" />
						</StackPanel>
					</smtx:XamlDisplay>

					<!-- FilledTonalButtonStyle → SimpleNeutralButtonStyle -->
					<smtx:XamlDisplay UniqueKey="Simple_Semantic_FilledTonalButton"
									  Style="{StaticResource XamlDisplayBelowStyle}">
						<StackPanel Orientation="Horizontal" Spacing="12">
							<Button Content="FilledTonalButtonStyle"
									Style="{StaticResource FilledTonalButtonStyle}" />
							<Button Content="Disabled"
									Style="{StaticResource FilledTonalButtonStyle}"
									IsEnabled="False" />
						</StackPanel>
					</smtx:XamlDisplay>

					<!-- OutlinedButtonStyle → SimpleNeutralButtonStyle -->
					<smtx:XamlDisplay UniqueKey="Simple_Semantic_OutlinedButton"
									  Style="{StaticResource XamlDisplayBelowStyle}">
						<StackPanel Orientation="Horizontal" Spacing="12">
							<Button Content="OutlinedButtonStyle"
									Style="{StaticResource OutlinedButtonStyle}" />
							<Button Content="Disabled"
									Style="{StaticResource OutlinedButtonStyle}"
									IsEnabled="False" />
						</StackPanel>
					</smtx:XamlDisplay>

					<!-- TextButtonStyle → SimpleSubtleButtonStyle -->
					<smtx:XamlDisplay UniqueKey="Simple_Semantic_TextButton"
									  Style="{StaticResource XamlDisplayBelowStyle}">
						<StackPanel Orientation="Horizontal" Spacing="12">
							<Button Content="TextButtonStyle"
									Style="{StaticResource TextButtonStyle}" />
							<Button Content="Disabled"
									Style="{StaticResource TextButtonStyle}"
									IsEnabled="False" />
						</StackPanel>
					</smtx:XamlDisplay>

					<!-- IconButtonStyle → SimpleIconButtonPrimaryStyle -->
					<smtx:XamlDisplay UniqueKey="Simple_Semantic_IconButton"
									  Style="{StaticResource XamlDisplayBelowStyle}">
						<StackPanel Orientation="Horizontal" Spacing="12">
							<Button Style="{StaticResource IconButtonStyle}">
								<SymbolIcon Symbol="Favorite" />
							</Button>
							<Button Style="{StaticResource IconButtonStyle}" IsEnabled="False">
								<SymbolIcon Symbol="Favorite" />
							</Button>
						</StackPanel>
					</smtx:XamlDisplay>

					<!-- ═══════════════════════════════════════════════════════════ -->
					<!-- SECTION 2: Lightweight Styling — Semantic Key Override     -->
					<!-- Override the semantic (unprefixed) resource key.           -->
					<!-- ═══════════════════════════════════════════════════════════ -->
					<TextBlock Text="Lightweight Styling: Semantic Key Override"
							   Style="{StaticResource TitleLarge}"
							   Margin="0,32,0,4" />
					<TextBlock Text="Overriding the semantic key (e.g. FilledButtonBackground) propagates through the alias chain to affect the control."
							   Style="{StaticResource BodyMedium}"
							   Opacity="0.7"
							   Margin="0,0,0,8"
							   TextWrapping="Wrap" />

					<!-- Override FilledButtonBackground via semantic key -->
					<smtx:XamlDisplay UniqueKey="Simple_Semantic_Override_FilledButtonBackground"
									  Style="{StaticResource XamlDisplayBelowStyle}">
						<StackPanel Orientation="Horizontal" Spacing="12">
							<StackPanel.Resources>
								<SolidColorBrush x:Key="FilledButtonBackground" Color="DarkOrchid" />
								<SolidColorBrush x:Key="FilledButtonBackgroundPointerOver" Color="MediumOrchid" />
								<SolidColorBrush x:Key="FilledButtonBackgroundPressed" Color="Purple" />
							</StackPanel.Resources>
							<Button Content="Semantic: FilledButtonBackground"
									Style="{StaticResource FilledButtonStyle}" />
						</StackPanel>
					</smtx:XamlDisplay>

					<!-- Override FilledTonalButtonBackground via semantic key -->
					<smtx:XamlDisplay UniqueKey="Simple_Semantic_Override_FilledTonalButtonBackground"
									  Style="{StaticResource XamlDisplayBelowStyle}">
						<StackPanel Orientation="Horizontal" Spacing="12">
							<StackPanel.Resources>
								<SolidColorBrush x:Key="FilledTonalButtonBackground" Color="DarkSlateBlue" />
								<SolidColorBrush x:Key="FilledTonalButtonBackgroundPointerOver" Color="SlateBlue" />
								<SolidColorBrush x:Key="FilledTonalButtonBackgroundPressed" Color="MidnightBlue" />
							</StackPanel.Resources>
							<Button Content="Semantic: FilledTonalButtonBackground"
									Style="{StaticResource FilledTonalButtonStyle}" />
						</StackPanel>
					</smtx:XamlDisplay>

					<!-- Override TextButtonForeground via semantic key -->
					<smtx:XamlDisplay UniqueKey="Simple_Semantic_Override_TextButtonForeground"
									  Style="{StaticResource XamlDisplayBelowStyle}">
						<StackPanel Orientation="Horizontal" Spacing="12">
							<StackPanel.Resources>
								<SolidColorBrush x:Key="TextButtonForeground" Color="Crimson" />
								<SolidColorBrush x:Key="TextButtonForegroundPointerOver" Color="OrangeRed" />
								<SolidColorBrush x:Key="TextButtonForegroundPressed" Color="DarkRed" />
							</StackPanel.Resources>
							<Button Content="Semantic: TextButtonForeground"
									Style="{StaticResource TextButtonStyle}" />
						</StackPanel>
					</smtx:XamlDisplay>

					<!-- ═══════════════════════════════════════════════════════════ -->
					<!-- SECTION 3: Lightweight Styling — Simple Key Override       -->
					<!-- Override the Simple-prefixed resource key directly.        -->
					<!-- ═══════════════════════════════════════════════════════════ -->
					<TextBlock Text="Lightweight Styling: Simple Key Override"
							   Style="{StaticResource TitleLarge}"
							   Margin="0,32,0,4" />
					<TextBlock Text="Overriding the Simple-prefixed key (e.g. SimplePrimaryButtonBackground) directly affects the control because the template references it."
							   Style="{StaticResource BodyMedium}"
							   Opacity="0.7"
							   Margin="0,0,0,8"
							   TextWrapping="Wrap" />

					<!-- Override SimplePrimaryButtonBackground -->
					<smtx:XamlDisplay UniqueKey="Simple_Override_SimplePrimaryButtonBackground"
									  Style="{StaticResource XamlDisplayBelowStyle}">
						<StackPanel Orientation="Horizontal" Spacing="12">
							<StackPanel.Resources>
								<SolidColorBrush x:Key="SimplePrimaryButtonBackground" Color="DarkGreen" />
								<SolidColorBrush x:Key="SimplePrimaryButtonBackgroundPointerOver" Color="ForestGreen" />
								<SolidColorBrush x:Key="SimplePrimaryButtonBackgroundPressed" Color="Green" />
							</StackPanel.Resources>
							<Button Content="Simple: SimplePrimaryButtonBackground"
									Style="{StaticResource SimplePrimaryButtonStyle}" />
						</StackPanel>
					</smtx:XamlDisplay>

					<!-- Override SimpleNeutralButtonBackground -->
					<smtx:XamlDisplay UniqueKey="Simple_Override_SimpleNeutralButtonBackground"
									  Style="{StaticResource XamlDisplayBelowStyle}">
						<StackPanel Orientation="Horizontal" Spacing="12">
							<StackPanel.Resources>
								<SolidColorBrush x:Key="SimpleNeutralButtonBackground" Color="DarkOrange" />
								<SolidColorBrush x:Key="SimpleNeutralButtonBackgroundPointerOver" Color="Orange" />
								<SolidColorBrush x:Key="SimpleNeutralButtonBackgroundPressed" Color="OrangeRed" />
							</StackPanel.Resources>
							<Button Content="Simple: SimpleNeutralButtonBackground"
									Style="{StaticResource SimpleNeutralButtonStyle}" />
						</StackPanel>
					</smtx:XamlDisplay>

					<!-- Override SimpleSubtleButtonForeground -->
					<smtx:XamlDisplay UniqueKey="Simple_Override_SimpleSubtleButtonForeground"
									  Style="{StaticResource XamlDisplayBelowStyle}">
						<StackPanel Orientation="Horizontal" Spacing="12">
							<StackPanel.Resources>
								<SolidColorBrush x:Key="SimpleSubtleButtonForeground" Color="Teal" />
								<SolidColorBrush x:Key="SimpleSubtleButtonForegroundPointerOver" Color="DarkCyan" />
								<SolidColorBrush x:Key="SimpleSubtleButtonForegroundPressed" Color="DarkSlateGray" />
							</StackPanel.Resources>
							<Button Content="Simple: SimpleSubtleButtonForeground"
									Style="{StaticResource SimpleSubtleButtonStyle}" />
						</StackPanel>
					</smtx:XamlDisplay>

					<!-- ═══════════════════════════════════════════════════════════ -->
					<!-- SECTION 4: Side-by-Side Comparison                         -->
					<!-- Same control, both override approaches next to default.    -->
					<!-- ═══════════════════════════════════════════════════════════ -->
					<TextBlock Text="Side-by-Side: Default vs Semantic vs Simple Override"
							   Style="{StaticResource TitleLarge}"
							   Margin="0,32,0,4" />
					<TextBlock Text="All three buttons use the same style. The left is unmodified, the center overrides the semantic key, and the right overrides the Simple-prefixed key."
							   Style="{StaticResource BodyMedium}"
							   Opacity="0.7"
							   Margin="0,0,0,8"
							   TextWrapping="Wrap" />

					<smtx:XamlDisplay UniqueKey="Simple_Semantic_SideBySide_Background"
									  Style="{StaticResource XamlDisplayBelowStyle}">
						<StackPanel Orientation="Horizontal" Spacing="12">
							<!-- Default -->
							<Button Content="Default"
									Style="{StaticResource FilledButtonStyle}" />

							<!-- Semantic key override -->
							<Grid>
								<Grid.Resources>
									<SolidColorBrush x:Key="FilledButtonBackground" Color="DarkOrchid" />
									<SolidColorBrush x:Key="FilledButtonForeground" Color="White" />
								</Grid.Resources>
								<Button Content="Semantic Override"
										Style="{StaticResource FilledButtonStyle}" />
							</Grid>

							<!-- Simple-prefixed key override -->
							<Grid>
								<Grid.Resources>
									<SolidColorBrush x:Key="SimplePrimaryButtonBackground" Color="DarkGreen" />
									<SolidColorBrush x:Key="SimplePrimaryButtonForeground" Color="White" />
								</Grid.Resources>
								<Button Content="Simple Override"
										Style="{StaticResource FilledButtonStyle}" />
							</Grid>
						</StackPanel>
					</smtx:XamlDisplay>

					<smtx:XamlDisplay UniqueKey="Simple_Semantic_SideBySide_Foreground"
									  Style="{StaticResource XamlDisplayBelowStyle}">
						<StackPanel Orientation="Horizontal" Spacing="12">
							<!-- Default -->
							<Button Content="Default"
									Style="{StaticResource TextButtonStyle}" />

							<!-- Semantic key override -->
							<Grid>
								<Grid.Resources>
									<SolidColorBrush x:Key="TextButtonForeground" Color="Crimson" />
								</Grid.Resources>
								<Button Content="Semantic Override"
										Style="{StaticResource TextButtonStyle}" />
							</Grid>

							<!-- Simple-prefixed key override -->
							<Grid>
								<Grid.Resources>
									<SolidColorBrush x:Key="SimpleSubtleButtonForeground" Color="Teal" />
								</Grid.Resources>
								<Button Content="Simple Override"
										Style="{StaticResource TextButtonStyle}" />
							</Grid>
						</StackPanel>
					</smtx:XamlDisplay>

					<!-- Bottom padding -->
					<Border Height="32" />
				</StackPanel>
			</DataTemplate>
		</sample:SamplePageLayout.SimpleTemplate>
	</sample:SamplePageLayout>
</Page>
