<Page x:Class="Uno.Themes.Samples.Content.Styles.SeedColorSamplePage"
	  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
	  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	  xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
	  xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
	  mc:Ignorable="d"
	  Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

	<ScrollViewer>
		<StackPanel Spacing="8" Margin="24,0" MaxWidth="1200">

			<!-- Header -->
			<TextBlock Text="Seed Color Palette Generator"
					   Style="{StaticResource HeadlineSmall}"
					   Margin="0,16,0,4" />
			<TextBlock Text="Pick a color to generate a full Material Design 3 palette using the HCT (Hue-Chroma-Tone) color space."
					   Style="{StaticResource BodyMedium}"
					   Opacity="0.7"
					   TextWrapping="Wrap" />

			<!-- Color Picker + Seed Info -->
			<StackPanel Orientation="Horizontal" Spacing="24" Margin="0,8,0,0">
				<ColorPicker x:Name="SeedColorPicker"
							 Color="#6750A4"
							 ColorSpectrumShape="Ring"
							 IsAlphaEnabled="False"
							 IsAlphaTextInputVisible="False"
							 IsHexInputVisible="False"
							 IsColorSliderVisible="True"
							 IsColorChannelTextInputVisible="False"
							 IsColorPreviewVisible="False"
							 IsMoreButtonVisible="False"
							 ColorChanged="SeedColorPicker_ColorChanged" />

				<!-- Seed Info -->
				<StackPanel VerticalAlignment="Center" Spacing="8" Width="120">
					<Border x:Name="SeedSwatch"
							Width="64" Height="64"
							CornerRadius="12"
							HorizontalAlignment="Left" />
					<TextBlock x:Name="SeedHex"
							   Style="{StaticResource LabelLarge}" />
					<TextBlock x:Name="SeedHctText"
							   Style="{StaticResource BodySmall}"
							   Opacity="0.6" />
				</StackPanel>
			</StackPanel>

			<!-- Tonal Palettes Section -->
			<TextBlock Text="Tonal Palettes"
					   Style="{StaticResource TitleMedium}"
					   Margin="0,0,0,4" />
			<TextBlock Text="Each row shows tones 0-100 for a derived palette. Primary uses the seed hue with boosted chroma; Secondary desaturates it; Tertiary shifts hue by 60 degrees."
					   Style="{StaticResource BodySmall}"
					   Opacity="0.6"
					   TextWrapping="Wrap"
					   Margin="0,0,0,8" />

			<!-- Tone scale header -->
			<Grid>
				<Grid.ColumnDefinitions>
					<ColumnDefinition Width="100" />
					<ColumnDefinition Width="*" />
					<ColumnDefinition Width="*" />
					<ColumnDefinition Width="*" />
					<ColumnDefinition Width="*" />
					<ColumnDefinition Width="*" />
					<ColumnDefinition Width="*" />
					<ColumnDefinition Width="*" />
					<ColumnDefinition Width="*" />
					<ColumnDefinition Width="*" />
					<ColumnDefinition Width="*" />
					<ColumnDefinition Width="*" />
					<ColumnDefinition Width="*" />
					<ColumnDefinition Width="*" />
				</Grid.ColumnDefinitions>
				<TextBlock Grid.Column="0" Text="Palette" Style="{StaticResource LabelSmall}" Opacity="0.5" />
				<TextBlock Grid.Column="1" Text="0" Style="{StaticResource LabelSmall}" HorizontalAlignment="Center" Opacity="0.5" />
				<TextBlock Grid.Column="2" Text="10" Style="{StaticResource LabelSmall}" HorizontalAlignment="Center" Opacity="0.5" />
				<TextBlock Grid.Column="3" Text="20" Style="{StaticResource LabelSmall}" HorizontalAlignment="Center" Opacity="0.5" />
				<TextBlock Grid.Column="4" Text="30" Style="{StaticResource LabelSmall}" HorizontalAlignment="Center" Opacity="0.5" />
				<TextBlock Grid.Column="5" Text="40" Style="{StaticResource LabelSmall}" HorizontalAlignment="Center" Opacity="0.5" />
				<TextBlock Grid.Column="6" Text="50" Style="{StaticResource LabelSmall}" HorizontalAlignment="Center" Opacity="0.5" />
				<TextBlock Grid.Column="7" Text="60" Style="{StaticResource LabelSmall}" HorizontalAlignment="Center" Opacity="0.5" />
				<TextBlock Grid.Column="8" Text="70" Style="{StaticResource LabelSmall}" HorizontalAlignment="Center" Opacity="0.5" />
				<TextBlock Grid.Column="9" Text="80" Style="{StaticResource LabelSmall}" HorizontalAlignment="Center" Opacity="0.5" />
				<TextBlock Grid.Column="10" Text="90" Style="{StaticResource LabelSmall}" HorizontalAlignment="Center" Opacity="0.5" />
				<TextBlock Grid.Column="11" Text="95" Style="{StaticResource LabelSmall}" HorizontalAlignment="Center" Opacity="0.5" />
				<TextBlock Grid.Column="12" Text="99" Style="{StaticResource LabelSmall}" HorizontalAlignment="Center" Opacity="0.5" />
				<TextBlock Grid.Column="13" Text="100" Style="{StaticResource LabelSmall}" HorizontalAlignment="Center" Opacity="0.5" />
			</Grid>

			<!-- Primary Tonal Palette -->
			<Grid Height="44">
				<Grid.ColumnDefinitions>
					<ColumnDefinition Width="100" />
					<ColumnDefinition Width="*" /><ColumnDefinition Width="*" /><ColumnDefinition Width="*" />
					<ColumnDefinition Width="*" /><ColumnDefinition Width="*" /><ColumnDefinition Width="*" />
					<ColumnDefinition Width="*" /><ColumnDefinition Width="*" /><ColumnDefinition Width="*" />
					<ColumnDefinition Width="*" /><ColumnDefinition Width="*" /><ColumnDefinition Width="*" />
					<ColumnDefinition Width="*" />
				</Grid.ColumnDefinitions>
				<TextBlock Grid.Column="0" Text="Primary" Style="{StaticResource LabelMedium}" VerticalAlignment="Center" />
				<Border x:Name="PrimaryP0" Grid.Column="1" CornerRadius="4,0,0,4"><TextBlock/></Border>
				<Border x:Name="PrimaryP10" Grid.Column="2"><TextBlock/></Border>
				<Border x:Name="PrimaryP20" Grid.Column="3"><TextBlock/></Border>
				<Border x:Name="PrimaryP30" Grid.Column="4"><TextBlock/></Border>
				<Border x:Name="PrimaryP40" Grid.Column="5"><TextBlock/></Border>
				<Border x:Name="PrimaryP50" Grid.Column="6"><TextBlock/></Border>
				<Border x:Name="PrimaryP60" Grid.Column="7"><TextBlock/></Border>
				<Border x:Name="PrimaryP70" Grid.Column="8"><TextBlock/></Border>
				<Border x:Name="PrimaryP80" Grid.Column="9"><TextBlock/></Border>
				<Border x:Name="PrimaryP90" Grid.Column="10"><TextBlock/></Border>
				<Border x:Name="PrimaryP95" Grid.Column="11"><TextBlock/></Border>
				<Border x:Name="PrimaryP99" Grid.Column="12"><TextBlock/></Border>
				<Border x:Name="PrimaryP100" Grid.Column="13" CornerRadius="0,4,4,0"><TextBlock/></Border>
			</Grid>

			<!-- Secondary Tonal Palette -->
			<Grid Height="44">
				<Grid.ColumnDefinitions>
					<ColumnDefinition Width="100" />
					<ColumnDefinition Width="*" /><ColumnDefinition Width="*" /><ColumnDefinition Width="*" />
					<ColumnDefinition Width="*" /><ColumnDefinition Width="*" /><ColumnDefinition Width="*" />
					<ColumnDefinition Width="*" /><ColumnDefinition Width="*" /><ColumnDefinition Width="*" />
					<ColumnDefinition Width="*" /><ColumnDefinition Width="*" /><ColumnDefinition Width="*" />
					<ColumnDefinition Width="*" />
				</Grid.ColumnDefinitions>
				<TextBlock Grid.Column="0" Text="Secondary" Style="{StaticResource LabelMedium}" VerticalAlignment="Center" />
				<Border x:Name="SecondaryP0" Grid.Column="1" CornerRadius="4,0,0,4"><TextBlock/></Border>
				<Border x:Name="SecondaryP10" Grid.Column="2"><TextBlock/></Border>
				<Border x:Name="SecondaryP20" Grid.Column="3"><TextBlock/></Border>
				<Border x:Name="SecondaryP30" Grid.Column="4"><TextBlock/></Border>
				<Border x:Name="SecondaryP40" Grid.Column="5"><TextBlock/></Border>
				<Border x:Name="SecondaryP50" Grid.Column="6"><TextBlock/></Border>
				<Border x:Name="SecondaryP60" Grid.Column="7"><TextBlock/></Border>
				<Border x:Name="SecondaryP70" Grid.Column="8"><TextBlock/></Border>
				<Border x:Name="SecondaryP80" Grid.Column="9"><TextBlock/></Border>
				<Border x:Name="SecondaryP90" Grid.Column="10"><TextBlock/></Border>
				<Border x:Name="SecondaryP95" Grid.Column="11"><TextBlock/></Border>
				<Border x:Name="SecondaryP99" Grid.Column="12"><TextBlock/></Border>
				<Border x:Name="SecondaryP100" Grid.Column="13" CornerRadius="0,4,4,0"><TextBlock/></Border>
			</Grid>

			<!-- Tertiary Tonal Palette -->
			<Grid Height="44">
				<Grid.ColumnDefinitions>
					<ColumnDefinition Width="100" />
					<ColumnDefinition Width="*" /><ColumnDefinition Width="*" /><ColumnDefinition Width="*" />
					<ColumnDefinition Width="*" /><ColumnDefinition Width="*" /><ColumnDefinition Width="*" />
					<ColumnDefinition Width="*" /><ColumnDefinition Width="*" /><ColumnDefinition Width="*" />
					<ColumnDefinition Width="*" /><ColumnDefinition Width="*" /><ColumnDefinition Width="*" />
					<ColumnDefinition Width="*" />
				</Grid.ColumnDefinitions>
				<TextBlock Grid.Column="0" Text="Tertiary" Style="{StaticResource LabelMedium}" VerticalAlignment="Center" />
				<Border x:Name="TertiaryP0" Grid.Column="1" CornerRadius="4,0,0,4"><TextBlock/></Border>
				<Border x:Name="TertiaryP10" Grid.Column="2"><TextBlock/></Border>
				<Border x:Name="TertiaryP20" Grid.Column="3"><TextBlock/></Border>
				<Border x:Name="TertiaryP30" Grid.Column="4"><TextBlock/></Border>
				<Border x:Name="TertiaryP40" Grid.Column="5"><TextBlock/></Border>
				<Border x:Name="TertiaryP50" Grid.Column="6"><TextBlock/></Border>
				<Border x:Name="TertiaryP60" Grid.Column="7"><TextBlock/></Border>
				<Border x:Name="TertiaryP70" Grid.Column="8"><TextBlock/></Border>
				<Border x:Name="TertiaryP80" Grid.Column="9"><TextBlock/></Border>
				<Border x:Name="TertiaryP90" Grid.Column="10"><TextBlock/></Border>
				<Border x:Name="TertiaryP95" Grid.Column="11"><TextBlock/></Border>
				<Border x:Name="TertiaryP99" Grid.Column="12"><TextBlock/></Border>
				<Border x:Name="TertiaryP100" Grid.Column="13" CornerRadius="0,4,4,0"><TextBlock/></Border>
			</Grid>

			<!-- Neutral Tonal Palette -->
			<Grid Height="44">
				<Grid.ColumnDefinitions>
					<ColumnDefinition Width="100" />
					<ColumnDefinition Width="*" /><ColumnDefinition Width="*" /><ColumnDefinition Width="*" />
					<ColumnDefinition Width="*" /><ColumnDefinition Width="*" /><ColumnDefinition Width="*" />
					<ColumnDefinition Width="*" /><ColumnDefinition Width="*" /><ColumnDefinition Width="*" />
					<ColumnDefinition Width="*" /><ColumnDefinition Width="*" /><ColumnDefinition Width="*" />
					<ColumnDefinition Width="*" />
				</Grid.ColumnDefinitions>
				<TextBlock Grid.Column="0" Text="Neutral" Style="{StaticResource LabelMedium}" VerticalAlignment="Center" />
				<Border x:Name="NeutralP0" Grid.Column="1" CornerRadius="4,0,0,4"><TextBlock/></Border>
				<Border x:Name="NeutralP10" Grid.Column="2"><TextBlock/></Border>
				<Border x:Name="NeutralP20" Grid.Column="3"><TextBlock/></Border>
				<Border x:Name="NeutralP30" Grid.Column="4"><TextBlock/></Border>
				<Border x:Name="NeutralP40" Grid.Column="5"><TextBlock/></Border>
				<Border x:Name="NeutralP50" Grid.Column="6"><TextBlock/></Border>
				<Border x:Name="NeutralP60" Grid.Column="7"><TextBlock/></Border>
				<Border x:Name="NeutralP70" Grid.Column="8"><TextBlock/></Border>
				<Border x:Name="NeutralP80" Grid.Column="9"><TextBlock/></Border>
				<Border x:Name="NeutralP90" Grid.Column="10"><TextBlock/></Border>
				<Border x:Name="NeutralP95" Grid.Column="11"><TextBlock/></Border>
				<Border x:Name="NeutralP99" Grid.Column="12"><TextBlock/></Border>
				<Border x:Name="NeutralP100" Grid.Column="13" CornerRadius="0,4,4,0"><TextBlock/></Border>
			</Grid>

			<!-- Neutral Variant Tonal Palette -->
			<Grid Height="44">
				<Grid.ColumnDefinitions>
					<ColumnDefinition Width="100" />
					<ColumnDefinition Width="*" /><ColumnDefinition Width="*" /><ColumnDefinition Width="*" />
					<ColumnDefinition Width="*" /><ColumnDefinition Width="*" /><ColumnDefinition Width="*" />
					<ColumnDefinition Width="*" /><ColumnDefinition Width="*" /><ColumnDefinition Width="*" />
					<ColumnDefinition Width="*" /><ColumnDefinition Width="*" /><ColumnDefinition Width="*" />
					<ColumnDefinition Width="*" />
				</Grid.ColumnDefinitions>
				<TextBlock Grid.Column="0" Text="Neutral Var." Style="{StaticResource LabelMedium}" VerticalAlignment="Center" />
				<Border x:Name="NeutralVarP0" Grid.Column="1" CornerRadius="4,0,0,4"><TextBlock/></Border>
				<Border x:Name="NeutralVarP10" Grid.Column="2"><TextBlock/></Border>
				<Border x:Name="NeutralVarP20" Grid.Column="3"><TextBlock/></Border>
				<Border x:Name="NeutralVarP30" Grid.Column="4"><TextBlock/></Border>
				<Border x:Name="NeutralVarP40" Grid.Column="5"><TextBlock/></Border>
				<Border x:Name="NeutralVarP50" Grid.Column="6"><TextBlock/></Border>
				<Border x:Name="NeutralVarP60" Grid.Column="7"><TextBlock/></Border>
				<Border x:Name="NeutralVarP70" Grid.Column="8"><TextBlock/></Border>
				<Border x:Name="NeutralVarP80" Grid.Column="9"><TextBlock/></Border>
				<Border x:Name="NeutralVarP90" Grid.Column="10"><TextBlock/></Border>
				<Border x:Name="NeutralVarP95" Grid.Column="11"><TextBlock/></Border>
				<Border x:Name="NeutralVarP99" Grid.Column="12"><TextBlock/></Border>
				<Border x:Name="NeutralVarP100" Grid.Column="13" CornerRadius="0,4,4,0"><TextBlock/></Border>
			</Grid>

			<!-- Error Tonal Palette -->
			<Grid Height="44">
				<Grid.ColumnDefinitions>
					<ColumnDefinition Width="100" />
					<ColumnDefinition Width="*" /><ColumnDefinition Width="*" /><ColumnDefinition Width="*" />
					<ColumnDefinition Width="*" /><ColumnDefinition Width="*" /><ColumnDefinition Width="*" />
					<ColumnDefinition Width="*" /><ColumnDefinition Width="*" /><ColumnDefinition Width="*" />
					<ColumnDefinition Width="*" /><ColumnDefinition Width="*" /><ColumnDefinition Width="*" />
					<ColumnDefinition Width="*" />
				</Grid.ColumnDefinitions>
				<TextBlock Grid.Column="0" Text="Error" Style="{StaticResource LabelMedium}" VerticalAlignment="Center" />
				<Border x:Name="ErrorP0" Grid.Column="1" CornerRadius="4,0,0,4"><TextBlock/></Border>
				<Border x:Name="ErrorP10" Grid.Column="2"><TextBlock/></Border>
				<Border x:Name="ErrorP20" Grid.Column="3"><TextBlock/></Border>
				<Border x:Name="ErrorP30" Grid.Column="4"><TextBlock/></Border>
				<Border x:Name="ErrorP40" Grid.Column="5"><TextBlock/></Border>
				<Border x:Name="ErrorP50" Grid.Column="6"><TextBlock/></Border>
				<Border x:Name="ErrorP60" Grid.Column="7"><TextBlock/></Border>
				<Border x:Name="ErrorP70" Grid.Column="8"><TextBlock/></Border>
				<Border x:Name="ErrorP80" Grid.Column="9"><TextBlock/></Border>
				<Border x:Name="ErrorP90" Grid.Column="10"><TextBlock/></Border>
				<Border x:Name="ErrorP95" Grid.Column="11"><TextBlock/></Border>
				<Border x:Name="ErrorP99" Grid.Column="12"><TextBlock/></Border>
				<Border x:Name="ErrorP100" Grid.Column="13" CornerRadius="0,4,4,0"><TextBlock/></Border>
			</Grid>

			<!-- Semantic Color Roles Section -->
			<TextBlock Text="Semantic Color Roles"
					   Style="{StaticResource TitleMedium}"
					   Margin="0,24,0,4" />
			<TextBlock Text="These are the named color roles derived from the tonal palettes. Light and Dark schemes use different tone levels to ensure proper contrast."
					   Style="{StaticResource BodySmall}"
					   Opacity="0.6"
					   TextWrapping="Wrap"
					   Margin="0,0,0,8" />

			<!-- Light Scheme -->
			<TextBlock Text="Light Scheme" Style="{StaticResource LabelLarge}" Margin="0,8,0,4" />
			<Grid ColumnSpacing="2" RowSpacing="2">
				<Grid.ColumnDefinitions>
					<ColumnDefinition Width="*" /><ColumnDefinition Width="*" />
					<ColumnDefinition Width="*" /><ColumnDefinition Width="*" />
				</Grid.ColumnDefinitions>
				<Grid.RowDefinitions>
					<RowDefinition Height="56" /><RowDefinition Height="32" />
					<RowDefinition Height="56" /><RowDefinition Height="32" />
					<RowDefinition Height="56" /><RowDefinition Height="32" />
					<RowDefinition Height="56" /><RowDefinition Height="32" />
				</Grid.RowDefinitions>

				<Border x:Name="LightPrimary" Grid.Row="0" Grid.Column="0" CornerRadius="8,0,0,0" Padding="8"><TextBlock Text="Primary" VerticalAlignment="Center"/></Border>
				<Border x:Name="LightOnPrimary" Grid.Row="1" Grid.Column="0" Padding="8"><TextBlock Text="On Primary" VerticalAlignment="Center" FontSize="11"/></Border>
				<Border x:Name="LightSecondary" Grid.Row="0" Grid.Column="1" Padding="8"><TextBlock Text="Secondary" VerticalAlignment="Center"/></Border>
				<Border x:Name="LightOnSecondary" Grid.Row="1" Grid.Column="1" Padding="8"><TextBlock Text="On Secondary" VerticalAlignment="Center" FontSize="11"/></Border>
				<Border x:Name="LightTertiary" Grid.Row="0" Grid.Column="2" Padding="8"><TextBlock Text="Tertiary" VerticalAlignment="Center"/></Border>
				<Border x:Name="LightOnTertiary" Grid.Row="1" Grid.Column="2" Padding="8"><TextBlock Text="On Tertiary" VerticalAlignment="Center" FontSize="11"/></Border>
				<Border x:Name="LightError" Grid.Row="0" Grid.Column="3" CornerRadius="0,8,0,0" Padding="8"><TextBlock Text="Error" VerticalAlignment="Center"/></Border>
				<Border x:Name="LightOnError" Grid.Row="1" Grid.Column="3" Padding="8"><TextBlock Text="On Error" VerticalAlignment="Center" FontSize="11"/></Border>

				<Border x:Name="LightPrimaryContainer" Grid.Row="2" Grid.Column="0" Padding="8"><TextBlock Text="Primary Container" VerticalAlignment="Center"/></Border>
				<Border x:Name="LightOnPrimaryContainer" Grid.Row="3" Grid.Column="0" Padding="8"><TextBlock Text="On Primary Container" VerticalAlignment="Center" FontSize="11"/></Border>
				<Border x:Name="LightSecondaryContainer" Grid.Row="2" Grid.Column="1" Padding="8"><TextBlock Text="Secondary Container" VerticalAlignment="Center"/></Border>
				<Border x:Name="LightOnSecondaryContainer" Grid.Row="3" Grid.Column="1" Padding="8"><TextBlock Text="On Secondary Container" VerticalAlignment="Center" FontSize="11"/></Border>
				<Border x:Name="LightTertiaryContainer" Grid.Row="2" Grid.Column="2" Padding="8"><TextBlock Text="Tertiary Container" VerticalAlignment="Center"/></Border>
				<Border x:Name="LightOnTertiaryContainer" Grid.Row="3" Grid.Column="2" Padding="8"><TextBlock Text="On Tertiary Container" VerticalAlignment="Center" FontSize="11"/></Border>
				<Border x:Name="LightErrorContainer" Grid.Row="2" Grid.Column="3" Padding="8"><TextBlock Text="Error Container" VerticalAlignment="Center"/></Border>
				<Border x:Name="LightOnErrorContainer" Grid.Row="3" Grid.Column="3" Padding="8"><TextBlock Text="On Error Container" VerticalAlignment="Center" FontSize="11"/></Border>

				<Border x:Name="LightBackground" Grid.Row="4" Grid.Column="0" Grid.ColumnSpan="2" Padding="8"><TextBlock Text="Background" VerticalAlignment="Center"/></Border>
				<Border x:Name="LightSurface" Grid.Row="4" Grid.Column="2" Grid.ColumnSpan="2" Padding="8"><TextBlock Text="Surface" VerticalAlignment="Center"/></Border>
				<Border x:Name="LightOnBackground" Grid.Row="5" Grid.Column="0" Grid.ColumnSpan="2" Padding="8"><TextBlock Text="On Background" VerticalAlignment="Center" FontSize="11"/></Border>
				<Border x:Name="LightOnSurface" Grid.Row="5" Grid.Column="2" Grid.ColumnSpan="2" Padding="8"><TextBlock Text="On Surface" VerticalAlignment="Center" FontSize="11"/></Border>

				<Border x:Name="LightOutline" Grid.Row="6" Grid.Column="0" Grid.ColumnSpan="2" CornerRadius="0,0,0,8" Padding="8"><TextBlock Text="Outline" VerticalAlignment="Center"/></Border>
				<Border x:Name="LightOutlineVariant" Grid.Row="6" Grid.Column="2" Grid.ColumnSpan="2" CornerRadius="0,0,8,0" Padding="8"><TextBlock Text="Outline Variant" VerticalAlignment="Center"/></Border>
			</Grid>

			<!-- Dark Scheme -->
			<TextBlock Text="Dark Scheme" Style="{StaticResource LabelLarge}" Margin="0,16,0,4" />
			<Grid ColumnSpacing="2" RowSpacing="2">
				<Grid.ColumnDefinitions>
					<ColumnDefinition Width="*" /><ColumnDefinition Width="*" />
					<ColumnDefinition Width="*" /><ColumnDefinition Width="*" />
				</Grid.ColumnDefinitions>
				<Grid.RowDefinitions>
					<RowDefinition Height="56" /><RowDefinition Height="32" />
					<RowDefinition Height="56" /><RowDefinition Height="32" />
					<RowDefinition Height="56" /><RowDefinition Height="32" />
					<RowDefinition Height="56" /><RowDefinition Height="32" />
				</Grid.RowDefinitions>

				<Border x:Name="DarkPrimary" Grid.Row="0" Grid.Column="0" CornerRadius="8,0,0,0" Padding="8"><TextBlock Text="Primary" VerticalAlignment="Center"/></Border>
				<Border x:Name="DarkOnPrimary" Grid.Row="1" Grid.Column="0" Padding="8"><TextBlock Text="On Primary" VerticalAlignment="Center" FontSize="11"/></Border>
				<Border x:Name="DarkSecondary" Grid.Row="0" Grid.Column="1" Padding="8"><TextBlock Text="Secondary" VerticalAlignment="Center"/></Border>
				<Border x:Name="DarkOnSecondary" Grid.Row="1" Grid.Column="1" Padding="8"><TextBlock Text="On Secondary" VerticalAlignment="Center" FontSize="11"/></Border>
				<Border x:Name="DarkTertiary" Grid.Row="0" Grid.Column="2" Padding="8"><TextBlock Text="Tertiary" VerticalAlignment="Center"/></Border>
				<Border x:Name="DarkOnTertiary" Grid.Row="1" Grid.Column="2" Padding="8"><TextBlock Text="On Tertiary" VerticalAlignment="Center" FontSize="11"/></Border>
				<Border x:Name="DarkError" Grid.Row="0" Grid.Column="3" CornerRadius="0,8,0,0" Padding="8"><TextBlock Text="Error" VerticalAlignment="Center"/></Border>
				<Border x:Name="DarkOnError" Grid.Row="1" Grid.Column="3" Padding="8"><TextBlock Text="On Error" VerticalAlignment="Center" FontSize="11"/></Border>

				<Border x:Name="DarkPrimaryContainer" Grid.Row="2" Grid.Column="0" Padding="8"><TextBlock Text="Primary Container" VerticalAlignment="Center"/></Border>
				<Border x:Name="DarkOnPrimaryContainer" Grid.Row="3" Grid.Column="0" Padding="8"><TextBlock Text="On Primary Container" VerticalAlignment="Center" FontSize="11"/></Border>
				<Border x:Name="DarkSecondaryContainer" Grid.Row="2" Grid.Column="1" Padding="8"><TextBlock Text="Secondary Container" VerticalAlignment="Center"/></Border>
				<Border x:Name="DarkOnSecondaryContainer" Grid.Row="3" Grid.Column="1" Padding="8"><TextBlock Text="On Secondary Container" VerticalAlignment="Center" FontSize="11"/></Border>
				<Border x:Name="DarkTertiaryContainer" Grid.Row="2" Grid.Column="2" Padding="8"><TextBlock Text="Tertiary Container" VerticalAlignment="Center"/></Border>
				<Border x:Name="DarkOnTertiaryContainer" Grid.Row="3" Grid.Column="2" Padding="8"><TextBlock Text="On Tertiary Container" VerticalAlignment="Center" FontSize="11"/></Border>
				<Border x:Name="DarkErrorContainer" Grid.Row="2" Grid.Column="3" Padding="8"><TextBlock Text="Error Container" VerticalAlignment="Center"/></Border>
				<Border x:Name="DarkOnErrorContainer" Grid.Row="3" Grid.Column="3" Padding="8"><TextBlock Text="On Error Container" VerticalAlignment="Center" FontSize="11"/></Border>

				<Border x:Name="DarkBackground" Grid.Row="4" Grid.Column="0" Grid.ColumnSpan="2" Padding="8"><TextBlock Text="Background" VerticalAlignment="Center"/></Border>
				<Border x:Name="DarkSurface" Grid.Row="4" Grid.Column="2" Grid.ColumnSpan="2" Padding="8"><TextBlock Text="Surface" VerticalAlignment="Center"/></Border>
				<Border x:Name="DarkOnBackground" Grid.Row="5" Grid.Column="0" Grid.ColumnSpan="2" Padding="8"><TextBlock Text="On Background" VerticalAlignment="Center" FontSize="11"/></Border>
				<Border x:Name="DarkOnSurface" Grid.Row="5" Grid.Column="2" Grid.ColumnSpan="2" Padding="8"><TextBlock Text="On Surface" VerticalAlignment="Center" FontSize="11"/></Border>

				<Border x:Name="DarkOutline" Grid.Row="6" Grid.Column="0" Grid.ColumnSpan="2" CornerRadius="0,0,0,8" Padding="8"><TextBlock Text="Outline" VerticalAlignment="Center"/></Border>
				<Border x:Name="DarkOutlineVariant" Grid.Row="6" Grid.Column="2" Grid.ColumnSpan="2" CornerRadius="0,0,8,0" Padding="8"><TextBlock Text="Outline Variant" VerticalAlignment="Center"/></Border>
			</Grid>

			<!-- Usage Snippet -->
			<TextBlock Text="Usage"
					   Style="{StaticResource TitleMedium}"
					   Margin="0,24,0,4" />
			<Border Background="{ThemeResource SurfaceVariantBrush}"
					CornerRadius="8"
					Padding="16">
				<TextBlock x:Name="XamlSnippet"
						   FontFamily="Consolas, Courier New, monospace"
						   Style="{StaticResource BodyMedium}"
						   IsTextSelectionEnabled="True" />
			</Border>

			<Border Height="32" />
		</StackPanel>
	</ScrollViewer>
</Page>
